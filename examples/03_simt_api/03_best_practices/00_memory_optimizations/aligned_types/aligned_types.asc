/* !
 * \file aligned_types.asc
 * \brief 展示结构体类型对齐对 Global Memory 访存的影响
 */

#include <cstdint>
#include <cstddef>
#include <cstdio>
#include "acl/acl.h"

constexpr uint32_t THREAD_COUNT = 2048;                  // threads per block
constexpr size_t MEM_BYTES = 512ULL * 1024ULL * 1024ULL; // 总数据量 512 MiB

// ---- 4 byte group ----
struct alignas(4) Align4 {
    unsigned char r, g, b, a;
}; // sizeof=4,  alignof=4
struct Misalign4 {
    unsigned char r, g, b, a;
}; // sizeof=4,  alignof=1

// ---- 4 byte group, 2 × u16 (填补 alignof=2 的访存档位) ----
struct alignas(4) Align2U16 {
    uint16_t a, b;
}; // sizeof=4,  alignof=4
struct Misalign2U16 {
    uint16_t a, b;
}; // sizeof=4,  alignof=2

// ---- 8 byte group (Misalign8 因整体合并加载，访存序列与 Align8 相同) ----
struct alignas(8) Align8 {
    unsigned int l, a;
}; // sizeof=8,  alignof=8
struct Misalign8 {
    unsigned int l, a;
}; // sizeof=8,  alignof=4

// ---- 16 byte group ----
struct alignas(16) Align16 {
    unsigned int r, g, b, a;
}; // sizeof=16, alignof=16
struct Misalign16 {
    unsigned int r, g, b, a;
}; // sizeof=16, alignof=4

// ---- 32 byte group ----
struct alignas(32) Align32 {
    unsigned int v[8];
}; // sizeof=32, alignof=32
struct Misalign32 {
    unsigned int v[8];
}; // sizeof=32, alignof=4

// ---- mixed-field group: 2 × u8 + u16 (sizeof=4, 字段顺序保证零 padding) ----
struct alignas(4) AlignU8U16 {
    uint8_t a, b;
    uint16_t c;
}; // sizeof=4,  alignof=4
struct MisalignU8U16 {
    uint8_t a, b;
    uint16_t c;
}; // sizeof=4,  alignof=2

// ---- mixed-field group: u8 + u16 (sizeof=4, 含 1B 中间 padding，对照零 padding 版的 *U8U16) ----
struct alignas(4) AlignU8PadU16 {
    uint8_t a;
    uint16_t b;
}; // sizeof=4,  alignof=4 (中间 1B padding @ offset 1)
struct MisalignU8PadU16 {
    uint8_t a;
    uint16_t b;
}; // sizeof=4,  alignof=2 (中间 1B padding @ offset 1)

/**
 * @brief 逐元素数据搬运核函数，将 d_idata 整体复制到 d_odata。
 * @param d_odata      输出数组地址（Device Global Memory）
 * @param d_idata      输入数组地址（Device Global Memory）
 * @param num_elements 元素总数
 */
template <class TData>
__global__ __launch_bounds__(THREAD_COUNT) void aligned_type_kernel(
    TData* d_odata, TData* d_idata, uint32_t num_elements)
{
    const uint32_t tid = blockIdx.x * blockDim.x + threadIdx.x;
    const uint32_t num_threads = blockDim.x * gridDim.x;
    for (uint32_t pos = tid; pos < num_elements; pos += num_threads) {
        d_odata[pos] = d_idata[pos];
    }
}

template <class TData>
bool verify_packed(const uint8_t* h_odata, const uint8_t* h_idata, uint32_t num_elements, uint32_t packed_size)
{
    for (uint32_t pos = 0; pos < num_elements; pos++) {
        const uint8_t* src = h_idata + pos * sizeof(TData);
        const uint8_t* dst = h_odata + pos * sizeof(TData);
        for (uint32_t i = 0; i < packed_size; i++) {
            if (src[i] != dst[i]) {
                return false;
            }
        }
    }
    return true;
}

template <class TData>
bool run_test(
    const char* name, uint32_t packed_size, uint8_t* d_idata, uint8_t* d_odata, uint8_t* h_idata, uint8_t* h_odata,
    aclrtStream stream)
{
    uint32_t num_elements = static_cast<uint32_t>(MEM_BYTES / sizeof(TData));
    aclrtMemset(d_odata, MEM_BYTES, 0, MEM_BYTES);

    aligned_type_kernel<TData><<<1, THREAD_COUNT, 0, stream>>>(
        reinterpret_cast<TData*>(d_odata), reinterpret_cast<TData*>(d_idata), num_elements);
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(h_odata, MEM_BYTES, d_odata, MEM_BYTES, ACL_MEMCPY_DEVICE_TO_HOST);
    bool passed = verify_packed<TData>(h_odata, h_idata, num_elements, packed_size);

    if (!passed) {
        printf(
            "[%-12s] sizeof=%2uB alignof=%2uB elems=%9u  [TEST FAIL]\n", name, static_cast<uint32_t>(sizeof(TData)),
            static_cast<uint32_t>(alignof(TData)), num_elements);
    }
    return passed;
}

int32_t main(int32_t argc, char* argv[])
{
    (void)argc;
    (void)argv;

    int32_t device_id = 0;
    aclrtStream stream = nullptr;

    aclInit(nullptr);
    aclrtSetDevice(device_id);
    aclrtCreateStream(&stream);

    uint8_t* h_idata = nullptr;
    uint8_t* h_odata = nullptr;
    void* d_idata = nullptr;
    void* d_odata = nullptr;

    aclrtMallocHost(reinterpret_cast<void**>(&h_idata), MEM_BYTES);
    aclrtMallocHost(reinterpret_cast<void**>(&h_odata), MEM_BYTES);
    aclrtMalloc(&d_idata, MEM_BYTES, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc(&d_odata, MEM_BYTES, ACL_MEM_MALLOC_HUGE_FIRST);

    for (size_t i = 0; i < MEM_BYTES; i++) {
        h_idata[i] = static_cast<uint8_t>((i & 0xFF) + 1);
    }
    aclrtMemcpy(d_idata, MEM_BYTES, h_idata, MEM_BYTES, ACL_MEMCPY_HOST_TO_DEVICE);

    uint32_t failures = 0;
    failures += !run_test<Align4>(
        "Align4", 4, static_cast<uint8_t*>(d_idata), static_cast<uint8_t*>(d_odata), h_idata, h_odata, stream);
    failures += !run_test<Misalign4>(
        "Misalign4", 4, static_cast<uint8_t*>(d_idata), static_cast<uint8_t*>(d_odata), h_idata, h_odata, stream);
    failures += !run_test<Align2U16>(
        "Align2U16", 4, static_cast<uint8_t*>(d_idata), static_cast<uint8_t*>(d_odata), h_idata, h_odata, stream);
    failures += !run_test<Misalign2U16>(
        "Misalign2U16", 4, static_cast<uint8_t*>(d_idata), static_cast<uint8_t*>(d_odata), h_idata, h_odata, stream);
    failures += !run_test<Align8>(
        "Align8", 8, static_cast<uint8_t*>(d_idata), static_cast<uint8_t*>(d_odata), h_idata, h_odata, stream);
    failures += !run_test<Misalign8>(
        "Misalign8", 8, static_cast<uint8_t*>(d_idata), static_cast<uint8_t*>(d_odata), h_idata, h_odata, stream);
    failures += !run_test<Align16>(
        "Align16", 16, static_cast<uint8_t*>(d_idata), static_cast<uint8_t*>(d_odata), h_idata, h_odata, stream);
    failures += !run_test<Misalign16>(
        "Misalign16", 16, static_cast<uint8_t*>(d_idata), static_cast<uint8_t*>(d_odata), h_idata, h_odata, stream);
    failures += !run_test<Align32>(
        "Align32", 32, static_cast<uint8_t*>(d_idata), static_cast<uint8_t*>(d_odata), h_idata, h_odata, stream);
    failures += !run_test<Misalign32>(
        "Misalign32", 32, static_cast<uint8_t*>(d_idata), static_cast<uint8_t*>(d_odata), h_idata, h_odata, stream);
    failures += !run_test<AlignU8U16>(
        "AlignU8U16", 4, static_cast<uint8_t*>(d_idata), static_cast<uint8_t*>(d_odata), h_idata, h_odata, stream);
    failures += !run_test<MisalignU8U16>(
        "MisalignU8U16", 4, static_cast<uint8_t*>(d_idata), static_cast<uint8_t*>(d_odata), h_idata, h_odata, stream);
    failures += !run_test<AlignU8PadU16>(
        "AlignU8PadU16", 4, static_cast<uint8_t*>(d_idata), static_cast<uint8_t*>(d_odata), h_idata, h_odata, stream);
    failures += !run_test<MisalignU8PadU16>(
        "MisalignU8PadU16", 4, static_cast<uint8_t*>(d_idata), static_cast<uint8_t*>(d_odata), h_idata, h_odata,
        stream);

    if (failures != 0) {
        printf("\n[Failed] Case accuracy is verification failed!\n");
    } else {
        printf("\n[Success] Case accuracy is verification passed.\n");
    }

    aclrtFree(d_idata);
    aclrtFree(d_odata);
    aclrtFreeHost(h_idata);
    aclrtFreeHost(h_odata);

    const char* err = aclGetRecentErrMsg();
    if (err != nullptr) {
        fprintf(stderr, "%s\n", err);
    }

    aclrtDestroyStream(stream);
    aclrtResetDevice(device_id);
    aclFinalize();

    return failures == 0 ? 0 : 1;
}
