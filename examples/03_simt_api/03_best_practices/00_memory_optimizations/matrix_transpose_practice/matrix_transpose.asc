#include <cmath>
#include <cstdint>
#include <cstdio>
#include <cstdlib>
#include <vector>
#include "acl/acl.h"
#include "simt_api/asc_simt.h"

#ifndef SCENARIO_NUM
#define SCENARIO_NUM 3
#endif

#if SCENARIO_NUM < 0 || SCENARIO_NUM > 3
#error "SCENARIO_NUM must be one of 0, 1, 2, 3."
#endif

namespace {
constexpr int TILE_DIM = 32;

uint32_t verify_result(const std::vector<float> &output, const std::vector<float> &golden, float abs_tolerance = 1e-3f)
{
    if (output.size() != golden.size()) {
        printf("[Failed] Case accuracy is verification failed!\n");
        return 1;
    }
    for (size_t i = 0; i < output.size(); ++i) {
        if (std::fabs(output[i] - golden[i]) > abs_tolerance) {
            printf("[Failed] Case accuracy is verification failed!\n");
            return 1;
        }
    }
    printf("[Success] Case accuracy is verification passed.\n");
    return 0;
}

std::vector<float> compute_golden(const std::vector<float> &input,
                                  const std::vector<uint32_t> &input_shape,
                                  int32_t kernel_kind)
{
    if (input_shape.size() != 2) {
        fprintf(stderr, "Input shape must be 2-D.\n");
        return {};
    }

    const uint32_t height = input_shape[0];
    const uint32_t width = input_shape[1];
    if (input.size() != static_cast<size_t>(height) * width) {
        fprintf(stderr, "Input data size does not match input shape.\n");
        return {};
    }

    if (kernel_kind == 0) {
        return input;
    }

    // Host reference transpose:
    // output(col, row) = input(row, col)
    std::vector<float> output(input.size());
    for (uint32_t row = 0; row < height; ++row) {
        for (uint32_t col = 0; col < width; ++col) {
            output[static_cast<size_t>(col) * height + row] = input[static_cast<size_t>(row) * width + col];
        }
    }
    return output;
}
} // namespace

__global__ void copy_kernel(float *output, const float *input, int width, int height)
{
    // One thread handles one element in the current 32x32 tile.
    int x_index = blockIdx.x * TILE_DIM + threadIdx.x;
    int y_index = blockIdx.y * TILE_DIM + threadIdx.y;
    int index = x_index + width * y_index;

    output[index] = input[index];
}

__global__ void transpose_naive_kernel(float *output, const float *input, int width, int height)
{
    // Original coordinates in input.
    int x_index = blockIdx.x * TILE_DIM + threadIdx.x;
    int y_index = blockIdx.y * TILE_DIM + threadIdx.y;

    int index_in = x_index + width * y_index;
    // Transposed coordinates in output.
    int index_out = y_index + height * x_index;

    output[index_out] = input[index_in];
}

__global__ void transpose_coalesced_kernel(float *output, const float *input, int width, int height)
{
    // UB tile used to reorganize global accesses.
    __ubuf__ float tile[TILE_DIM][TILE_DIM];

    // Read one input element from the current tile.
    int x_index = blockIdx.x * TILE_DIM + threadIdx.x;
    int y_index = blockIdx.y * TILE_DIM + threadIdx.y;
    int index_in = x_index + y_index * width;

    // GM -> UB with original layout.
    tile[threadIdx.y][threadIdx.x] = input[index_in];
    asc_syncthreads();

    // Swap block coordinates to point at the transposed output tile.
    x_index = blockIdx.y * TILE_DIM + threadIdx.x;
    y_index = blockIdx.x * TILE_DIM + threadIdx.y;
    int index_out = x_index + y_index * height;

    // Read transposed coordinates from UB and write back to GM.
    output[index_out] = tile[threadIdx.x][threadIdx.y];
}

__global__ void transpose_avoid_bank_conflicts_kernel(float *output, const float *input, int width, int height)
{
    // +1 padding changes the UB row stride to mitigate bank conflicts.
    __ubuf__ float tile[TILE_DIM][TILE_DIM + 1];

    int x_index = blockIdx.x * TILE_DIM + threadIdx.x;
    int y_index = blockIdx.y * TILE_DIM + threadIdx.y;
    int index_in = x_index + y_index * width;

    // GM -> UB with original layout.
    tile[threadIdx.y][threadIdx.x] = input[index_in];
    asc_syncthreads();

    // Swap block coordinates to point at the transposed output tile.
    x_index = blockIdx.y * TILE_DIM + threadIdx.x;
    y_index = blockIdx.x * TILE_DIM + threadIdx.y;
    int index_out = x_index + y_index * height;

    // Read transposed coordinates from the padded UB tile.
    output[index_out] = tile[threadIdx.x][threadIdx.y];
}

enum KernelKind {
    K_COPY = 0,
    K_TRANSPOSE_NAIVE = 1,
    K_TRANSPOSE_COALESCED = 2,
    K_TRANSPOSE_AVOID_BANK_CONFLICTS = 3,
};

const char *get_kernel_name(int kernel_kind)
{
    switch (kernel_kind) {
        case K_COPY:
            return "copy";
        case K_TRANSPOSE_NAIVE:
            return "transpose_naive";
        case K_TRANSPOSE_COALESCED:
            return "transpose_coalesced";
        case K_TRANSPOSE_AVOID_BANK_CONFLICTS:
            return "transpose_avoid_bank_conflicts";
        default:
            return "unknown";
    }
}

std::vector<float> transpose(const std::vector<float> &input_host,
                             const std::vector<uint32_t> &input_shape,
                             int32_t kernel_kind)
{
    const size_t tensor_elem_count = input_host.size();
    const size_t tensor_byte_size = tensor_elem_count * sizeof(float);
    std::vector<float> output_host(tensor_elem_count, 0.0f);

    if (input_shape.size() != 2) {
        fprintf(stderr, "Input shape must be 2-D.\n");
        return {};
    }

    const int32_t matrix_height = static_cast<int32_t>(input_shape[0]);
    const int32_t matrix_width = static_cast<int32_t>(input_shape[1]);
    if (input_host.size() != static_cast<size_t>(matrix_height) * matrix_width) {
        fprintf(stderr, "Input data size does not match input shape.\n");
        return {};
    }

    // Runtime setup.
    aclInit(nullptr);
    aclrtSetDevice(0);

    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    float *input_device = nullptr;
    float *output_device = nullptr;
    // Allocate one input matrix and one output matrix in device memory.
    aclrtMalloc(reinterpret_cast<void **>(&input_device), tensor_byte_size, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc(reinterpret_cast<void **>(&output_device), tensor_byte_size, ACL_MEM_MALLOC_HUGE_FIRST);

    // Copy the input matrix to device.
    aclrtMemcpy(input_device, tensor_byte_size, input_host.data(), tensor_byte_size, ACL_MEMCPY_HOST_TO_DEVICE);

    // One block handles one 32x32 tile with 32x32 threads.
    dim3 blocks_per_grid(static_cast<uint32_t>(matrix_width / TILE_DIM), static_cast<uint32_t>(matrix_height / TILE_DIM), 1);
    dim3 threads_per_block(static_cast<uint32_t>(TILE_DIM), static_cast<uint32_t>(TILE_DIM), 1);

    if (kernel_kind == K_COPY) {
        copy_kernel<<<blocks_per_grid, threads_per_block, 0, stream>>>(output_device, input_device, matrix_width, matrix_height);
    } else if (kernel_kind == K_TRANSPOSE_NAIVE) {
        transpose_naive_kernel<<<blocks_per_grid, threads_per_block, 0, stream>>>(output_device, input_device, matrix_width, matrix_height);
    } else if (kernel_kind == K_TRANSPOSE_COALESCED) {
        transpose_coalesced_kernel<<<blocks_per_grid, threads_per_block, 0, stream>>>(output_device, input_device, matrix_width, matrix_height);
    } else if (kernel_kind == K_TRANSPOSE_AVOID_BANK_CONFLICTS) {
        transpose_avoid_bank_conflicts_kernel<<<blocks_per_grid, threads_per_block, 0, stream>>>(output_device, input_device, matrix_width, matrix_height);
    }

    aclrtSynchronizeStream(stream);
    aclrtMemcpy(output_host.data(), tensor_byte_size, output_device, tensor_byte_size, ACL_MEMCPY_DEVICE_TO_HOST);

    const char *err = aclGetRecentErrMsg();
    if (err != nullptr) {
        fprintf(stderr, "%s\n", err);
    }
    aclrtFree(input_device);
    aclrtFree(output_device);
    aclrtDestroyStream(stream);
    aclrtResetDevice(0);
    aclFinalize();
    return output_host;
}

int main(int argc, char **argv)
{
    const uint32_t kernel_kind = static_cast<uint32_t>(SCENARIO_NUM);
    printf("Usage: %s (compile-time SCENARIO_NUM=%u)\n", argv[0], kernel_kind);
    printf("Running case %u: %s...\n", kernel_kind, get_kernel_name(static_cast<int32_t>(kernel_kind)));

    const std::vector<uint32_t> input_shape = {1024, 1024};
    const uint32_t matrix_height = input_shape[0];
    const uint32_t matrix_width = input_shape[1];

    if (matrix_width != matrix_height) {
        std::fprintf(stderr, "Only square matrices are supported in this sample.\n");
        return EXIT_FAILURE;
    }

    if (matrix_width % TILE_DIM != 0 || matrix_height % TILE_DIM != 0) {
        std::fprintf(stderr, "Matrix shape must be multiple of TILE_DIM=%d.\n", TILE_DIM);
        return EXIT_FAILURE;
    }

    const size_t tensor_elem_count = static_cast<size_t>(matrix_width) * matrix_height;
    std::vector<float> input(tensor_elem_count);

    // Initialize deterministic input data.
    for (size_t i = 0; i < tensor_elem_count; ++i) {
        input[i] = static_cast<float>(i * 1.25f);
    }

    auto golden = compute_golden(input, input_shape, static_cast<int32_t>(kernel_kind));
    auto output = transpose(input, input_shape, static_cast<int32_t>(kernel_kind));

    return verify_result(output, golden);
}
