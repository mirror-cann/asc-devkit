/* !
 * \file data_cache_hint.asc
 * \brief Demo for data cache hint optimization using asc_ldcg and asc_stcg
 */

#include <cstdint>
#include <cstddef>
#include <cmath>
#include <random>
#include <iostream>
#include <vector>
#include "acl/acl.h"
#include "asc_simt.h"

#ifndef SCENARIO_NUM
#define SCENARIO_NUM 1
#endif

#if SCENARIO_NUM < 1 || SCENARIO_NUM > 2
#error "SCENARIO_NUM must be one of 1, 2"
#endif

namespace {
constexpr float PI = ASCRT_PI_F;
constexpr uint32_t INPUT_SIZE = 256 * 1024 / sizeof(float);
constexpr uint32_t TABLE_SIZE = 32 * 1024 / sizeof(float);
constexpr uint32_t THREAD_COUNT = 1024;
constexpr uint32_t UB_SIZE = 216 * 1024;
}

enum KernelKind {
    USE_BASELINE = 1,
    USE_OPTIMIZED = 2
};

extern __ubuf__ char dynamicBuf[];

__global__ void sin_table_lookup_baseline(float* input, float* sin_table, float* output, uint32_t input_length,
                                            uint32_t table_length)
{
    for (int idx = threadIdx.x; idx < input_length; idx += blockDim.x) {
        float x = input[idx];
        float sign = 1.0f;
        if (x < 0.0f) {
            sign = -1.0f;
            x = -x;
        }
        float two_pi = 2.0f * PI;
        x = fmodf(x, two_pi);
        if (x >= PI) {
            x = two_pi - x;
            sign = -sign;
        }

        float index_float = x * static_cast<float>(table_length) / PI;
        uint32_t n = static_cast<uint32_t>(floorf(index_float));
        float frac = index_float - static_cast<float>(n);

        float low_val = sin_table[n];
        float high_val = 0.0f;
        if (n + 1 >= table_length) {
            high_val = sin_table[0];
        } else {
            high_val = sin_table[n + 1];
        }
        output[idx] = sign * (low_val + frac * (high_val - low_val));
    }
}

__global__ void sin_table_lookup_optimized(float* input, float* sin_table, float* output, uint32_t input_length,
                                            uint32_t table_length)
{
    for (int idx = threadIdx.x; idx < input_length; idx += blockDim.x) {
        float x = asc_ldcg(&input[idx]);
        float sign = 1.0f;
        if (x < 0.0f) {
            sign = -1.0f;
            x = -x;
        }
        float two_pi = 2.0f * PI;
        x = fmodf(x, two_pi);
        if (x >= PI) {
            x = two_pi - x;
            sign = -sign;
        }

        float index_float = x * static_cast<float>(table_length) / PI;
        uint32_t n = static_cast<uint32_t>(floorf(index_float));
        float frac = index_float - static_cast<float>(n);

        float low_val = asc_ldca(&sin_table[n]);
        float high_val = 0.0f;
        if (n + 1 >= table_length) {
            high_val = asc_ldca(&sin_table[0]);
        } else {
            high_val = asc_ldca(&sin_table[n + 1]);
        }
        float y = sign * (low_val + frac * (high_val - low_val));
        asc_stcg(&output[idx], y);
    }
}

void generate_input_and_golden_data(std::vector<float>& input, std::vector<float>& golden, uint32_t input_length)
{
    for (int32_t index = 0; index < input_length; index ++) {
        input[index] = 2 * PI * index / TABLE_SIZE;
        golden[index] = sinf(input[index]);
    }
}

void generate_sin_table(std::vector<float>& sin_table, uint32_t table_length)
{
    for (uint32_t i = 0; i < table_length; i++) {
        float angle = static_cast<float>(i) / table_length * PI;
        sin_table[i] = sin(angle);
    }
}

std::vector<float> launch_kernel(std::vector<float>& input, std::vector<float>& sin_table,
                                 uint32_t input_length, uint32_t table_length, uint32_t kernel_type)
{
    size_t input_bytes = input_length * sizeof(float);
    size_t table_bytes = table_length * sizeof(float);
    size_t output_bytes = input_length * sizeof(float);

    uint32_t blocks_per_grid = 1;

    int32_t device_id = 0;
    aclrtStream stream = nullptr;
    void* input_host = reinterpret_cast<void*>(input.data());
    void* input_device = nullptr;
    void* table_host = reinterpret_cast<void*>(sin_table.data());
    void* table_device = nullptr;
    void* output_host = nullptr;
    void* output_device = nullptr;

    aclInit(nullptr);
    aclrtSetDevice(device_id);
    aclrtCreateStream(&stream);
    aclrtMallocHost(&output_host, output_bytes);
    aclrtMalloc(&input_device, input_bytes, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc(&table_device, table_bytes, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc(&output_device, output_bytes, ACL_MEM_MALLOC_HUGE_FIRST);

    aclrtMemcpy(input_device, input_bytes, input_host, input_bytes, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(table_device, table_bytes, table_host, table_bytes, ACL_MEMCPY_HOST_TO_DEVICE);

    if (kernel_type == USE_BASELINE) {
        sin_table_lookup_baseline<<<blocks_per_grid, THREAD_COUNT, UB_SIZE, stream>>>(
            static_cast<float*>(input_device), static_cast<float*>(table_device),
            static_cast<float*>(output_device), input_length, table_length);
    } else {
        sin_table_lookup_optimized<<<blocks_per_grid, THREAD_COUNT, UB_SIZE, stream>>>(
            static_cast<float*>(input_device), static_cast<float*>(table_device),
            static_cast<float*>(output_device), input_length, table_length);
    }

    aclrtSynchronizeStream(stream);

    aclrtMemcpy(output_host, output_bytes, output_device, output_bytes, ACL_MEMCPY_DEVICE_TO_HOST);
    std::vector<float> output(static_cast<float*>(output_host), static_cast<float*>(output_host) + input_length);

    aclrtFree(input_device);
    aclrtFree(table_device);
    aclrtFree(output_device);
    aclrtFreeHost(output_host);

    const char* err = aclGetRecentErrMsg();
    if (err != nullptr) {
        fprintf(stderr, "%s\n", err);
    }

    aclrtDestroyStream(stream);
    aclrtResetDevice(device_id);
    aclFinalize();

    return output;
}

uint32_t verify_result(const std::vector<float> &output, const std::vector<float> &golden, float abs_tolerance = 1e-3f)
{
    if (output.size() != golden.size()) {
        printf("[Failed] Case accuracy is verification failed!\n");
        return 1;
    }
    for (size_t i = 0; i < output.size(); ++i) {
        if (std::fabs(output[i] - golden[i]) > abs_tolerance) {
            printf("[Failed] Case accuracy is verification failed!\n");
            return 1;
        }
    }
    printf("[Success] Case accuracy is verification passed.\n");
    return 0;
}


const char *get_kernel_name(int kernel_kind)
{
    switch (kernel_kind) {
        case USE_BASELINE:
            return "baseline";
        case USE_OPTIMIZED:
            return "optimized";
        default:
            return "unknown";
    }
}

int32_t main(int32_t argc, char* argv[])
{
    const uint32_t kernel_kind = static_cast<uint32_t>(SCENARIO_NUM);
    printf("Usage: %s (compile-time SCENARIO_NUM=%u)\n", argv[0], kernel_kind);
    printf("Running case %u: %s...\n", kernel_kind, get_kernel_name(static_cast<int32_t>(kernel_kind)));

    std::vector<float> input(INPUT_SIZE);
    std::vector<float> sin_table(TABLE_SIZE);
    std::vector<float> golden(INPUT_SIZE);

    generate_input_and_golden_data(input, golden, INPUT_SIZE);
    generate_sin_table(sin_table, TABLE_SIZE);

    printf("=== Running Kernel ===\n");
    std::vector<float> output = launch_kernel(input, sin_table, INPUT_SIZE, TABLE_SIZE, SCENARIO_NUM);

    return verify_result(output, golden);
}
