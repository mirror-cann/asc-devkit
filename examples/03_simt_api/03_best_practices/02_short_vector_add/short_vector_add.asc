/* !
 * \file short_vector_add.asc
 * \brief
 */

#include "acl/acl.h"
#include "simt_api/asc_fp16.h"
#include "data_utils.h"


constexpr uint32_t TOTAL_LENGTH = 64 * 256 * 1024;
constexpr uint32_t THREAD_NUM_PER_BLOCK = 1024;
constexpr uint32_t BLOCK_NUM = 64;

template<typename T>
__global__ void add(T* x, T* y, T* z, uint64_t size)
{
    // gridDim.x * blockDim.x 线程总数 (N * X * 1024)
    int32_t stride = gridDim.x * blockDim.x;

    // 每个线程从自己的全局idx开始，每次递增总线程数，直到处理完所有元素
    for (int32_t idx = blockIdx.x * blockDim.x + threadIdx.x; idx < size; idx += stride) {
        z[idx] = x[idx] + y[idx];
    }
}

template<typename T, typename U>
__global__ void add2(T* x, T* y, T* z, uint64_t size)
{
    // 转为向量类型
    const U* x2 = reinterpret_cast<const U*>(x);
    const U* y2 = reinterpret_cast<const U*>(y);
    U* z2 = reinterpret_cast<U*>(z);
    // 此处用除法一次性算出for循环的边界值
    uint64_t vector_size = size / 2;
    int32_t stride = gridDim.x * blockDim.x;

    // 向量化循环处理偶数对（步长同样是总线程数）
    for (int32_t idx = blockIdx.x * blockDim.x + threadIdx.x; idx < vector_size; idx += stride) {
        z2[idx] = x2[idx] + y2[idx];
    }

    // 最后一个奇数元素处理（如果size是奇数，由全局第0号线程在最后处理）
    if (blockIdx.x == 0 && threadIdx.x == 0 && (size % 2 != 0)) {
        uint64_t last_idx = size - 1;
        z[last_idx] = x[last_idx] + y[last_idx];
    }
}

int32_t main(int32_t argc, char* argv[])
{
    constexpr uint32_t scenario_num = static_cast<uint32_t>(SCENARIO_NUM);
    aclInit(nullptr);
    aclrtSetDevice(0);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    size_t tensor_byte_size = TOTAL_LENGTH * sizeof(half);
    uint8_t *x_host, *y_host, *z_host;
    half *x_device, *y_device, *z_device;
    aclrtMallocHost((void**)(&x_host), tensor_byte_size);
    aclrtMallocHost((void**)(&y_host), tensor_byte_size);
    aclrtMallocHost((void**)(&z_host), tensor_byte_size);
    aclrtMalloc((void**)&x_device, tensor_byte_size, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&y_device, tensor_byte_size, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&z_device, tensor_byte_size, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/input_x.bin", tensor_byte_size, x_host, tensor_byte_size);
    ReadFile("./input/input_y.bin", tensor_byte_size, y_host, tensor_byte_size);
    aclrtMemcpy(x_device, tensor_byte_size, x_host, tensor_byte_size, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(y_device, tensor_byte_size, y_host, tensor_byte_size, ACL_MEMCPY_HOST_TO_DEVICE);
    if(scenario_num ==  1){
        add<half><<<BLOCK_NUM, THREAD_NUM_PER_BLOCK, 0, stream>>>(x_device, y_device, z_device, TOTAL_LENGTH);
    } else if (scenario_num == 2) {
        add2<half, half2><<<BLOCK_NUM, THREAD_NUM_PER_BLOCK, 0, stream>>>(x_device, y_device, z_device, TOTAL_LENGTH);
    }
    aclrtSynchronizeStream(stream);
    aclrtMemcpy(z_host, tensor_byte_size, z_device, tensor_byte_size, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", z_host, tensor_byte_size);

    aclrtFree(x_device);
    aclrtFree(y_device);
    aclrtFree(z_device);
    aclrtFreeHost(x_host);
    aclrtFreeHost(y_host);
    aclrtFreeHost(z_host);

    aclrtDestroyStream(stream);
    aclrtResetDevice(0);
    aclFinalize();
    return 0;
}