/* !
 * \file grid_config.asc
 * \brief SIMT gather sample demonstrating grid/block configuration and per-thread loop optimization
 */

#include <iostream>
#include <iterator>
#include <vector>
#include <cstdlib>
#include <ctime>
#include "acl/acl.h"
#include "simt_api/asc_simt.h"

#ifndef SCENARIO_NUM
#define SCENARIO_NUM 1
#endif

#if SCENARIO_NUM < 1 || SCENARIO_NUM > 13
#error "SCENARIO_NUM must be one of 1..13."
#endif

namespace {
constexpr uint32_t MAX_THREAD_NUM = 2048;
constexpr uint32_t INDEX_WIDTH = 2048;
constexpr uint32_t INDEX_ROWS = 1024;
// 大shape：[1024,2048] = 2097152个元素(Case 1)
constexpr uint32_t LARGE_SHAPE_TOTAL_LENGTH = INDEX_ROWS * INDEX_WIDTH;

// 小shape：[8,2048] = 16384个元素(Case 2)
constexpr uint32_t SMALL_SHAPE_TOTAL_LENGTH = 16384;
constexpr uint32_t AIV_CORE_NUM = 64;

enum class KernelType {
    EMPTY,          // 空核函数，仅测调度基线
    GATHER_NAIVE,   // 每线程处理1个元素，无stride循环(最朴素写法)
    GATHER_STRIDED, // 每个block跨步处理一段元素(优化写法)
};

struct ScenarioConfig {
    uint32_t blocks_per_grid;
    uint32_t total_length;
    KernelType kernel;
    const char* name;
};

// 运行期查询物理 Vector Core(AIV)数量；查询失败时回退到经验值 AIV_CORE_NUM
uint32_t query_aiv_core_num(int32_t device_id)
{
    int64_t core_num = 0;
    aclError ret = aclrtGetDeviceInfo(static_cast<uint32_t>(device_id), ACL_DEV_ATTR_VECTOR_CORE_NUM, &core_num);
    return (ret == ACL_SUCCESS && core_num > 0) ? static_cast<uint32_t>(core_num) : AIV_CORE_NUM;
}

// 解析每block线程数：按每核实际元素数自适应，封顶到硬件上限MAX_THREAD_NUM
// (每核元素数<2048时降低线程数，消除空转线程)
uint32_t resolve_thread_num(uint32_t blocks_per_grid, uint32_t total_length)
{
    uint32_t per_core = (total_length + blocks_per_grid - 1) / blocks_per_grid; // 向上取整
    return per_core < MAX_THREAD_NUM ? per_core : MAX_THREAD_NUM;
}

ScenarioConfig get_scenario_config(uint32_t scenario)
{
    switch (scenario) {
        // 大shape [1024,2048] = 2097152
        case 1:
            return {1, LARGE_SHAPE_TOTAL_LENGTH, KernelType::EMPTY, "large shape, 1 core, empty kernel"};
        case 2:
            return {32, LARGE_SHAPE_TOTAL_LENGTH, KernelType::EMPTY, "large shape, 32 cores, empty kernel"};
        case 3:
            return {0, LARGE_SHAPE_TOTAL_LENGTH, KernelType::EMPTY, "large shape, full physical cores, empty kernel"};
        case 4:
            return {128, LARGE_SHAPE_TOTAL_LENGTH, KernelType::EMPTY, "large shape, 128 cores, empty kernel"};
        case 5:
            return {1024, LARGE_SHAPE_TOTAL_LENGTH, KernelType::EMPTY, "large shape, 1024 cores, empty kernel"};
        case 6:
            return {1024, LARGE_SHAPE_TOTAL_LENGTH, KernelType::GATHER_NAIVE, "large shape, 1024 cores, gather naive"};
        case 7:
            return {
                0, LARGE_SHAPE_TOTAL_LENGTH, KernelType::GATHER_STRIDED,
                "large shape, full physical cores, gather strided"};
        case 8:
            return {32, LARGE_SHAPE_TOTAL_LENGTH, KernelType::GATHER_STRIDED, "large shape, 32 cores, gather strided"};
        // 小shape [8,2048] = 16384，扫描核数4/8/16/32/64；每block线程数自适应(每核元素数<2048时降到实际值)
        case 9:
            return {
                4, SMALL_SHAPE_TOTAL_LENGTH, KernelType::GATHER_STRIDED, "small shape(16384), 4 cores, gather strided"};
        case 10:
            return {
                8, SMALL_SHAPE_TOTAL_LENGTH, KernelType::GATHER_STRIDED, "small shape(16384), 8 cores, gather strided"};
        case 11:
            return {
                16, SMALL_SHAPE_TOTAL_LENGTH, KernelType::GATHER_STRIDED,
                "small shape(16384), 16 cores, gather strided"};
        case 12:
            return {
                32, SMALL_SHAPE_TOTAL_LENGTH, KernelType::GATHER_STRIDED,
                "small shape(16384), 32 cores, gather strided"};
        case 13:
            return {
                0, SMALL_SHAPE_TOTAL_LENGTH, KernelType::GATHER_STRIDED,
                "small shape(16384), full physical cores, gather strided"};
        default:
            return {32, LARGE_SHAPE_TOTAL_LENGTH, KernelType::EMPTY, "unknown"};
    }
}
} // namespace

__global__ __launch_bounds__(MAX_THREAD_NUM) void empty_kernel(
    float* input, uint32_t* index, float* output, uint32_t input_total_length, uint32_t index_total_length)
{}

// 最朴素写法：每个线程只处理1个元素，无for循环
// 要求 gridDim.x * blockDim.x == index_total_length
// block对应[1024,2048]张量的一行，thread对应一列，线程号即元素号，一一对应
__global__ __launch_bounds__(MAX_THREAD_NUM) void gather_naive_kernel(
    float* input, uint32_t* index, float* output, uint32_t input_total_length, uint32_t index_total_length)
{
    uint32_t global_idx = blockIdx.x * blockDim.x + threadIdx.x;

    uint32_t gather_idx = index[global_idx];
    if (gather_idx >= input_total_length) {
        gather_idx = 0;
    }
    output[global_idx] = input[gather_idx];
}

// 优化写法：全局 grid-stride loop，所有线程在整个数组上以"总线程数"为步长跨步遍历
__global__ __launch_bounds__(MAX_THREAD_NUM) void gather_strided_kernel(
    float* input, uint32_t* index, float* output, uint32_t input_total_length, uint32_t index_total_length)
{
    uint32_t global_idx = blockIdx.x * blockDim.x + threadIdx.x;
    uint32_t stride = gridDim.x * blockDim.x;

    for (uint32_t i = global_idx; i < index_total_length; i += stride) {
        uint32_t gather_idx = index[i];
        if (gather_idx >= input_total_length) {
            gather_idx = 0;
        }
        output[i] = input[gather_idx];
    }
}

std::vector<float> run_kernel(
    std::vector<float>& input, std::vector<uint32_t>& index, uint32_t blocks_per_grid, KernelType kernel)
{
    uint32_t input_total_length = input.size();
    size_t input_total_byte_size = input_total_length * sizeof(float);

    uint32_t index_total_length = index.size();
    size_t index_total_byte_size = index_total_length * sizeof(uint32_t);

    uint32_t output_total_length = index.size();
    size_t output_total_byte_size = output_total_length * sizeof(float);

    int32_t device_id = 0;
    aclrtStream stream = nullptr;

    uint8_t* input_host = reinterpret_cast<uint8_t*>(input.data());
    uint8_t* index_host = reinterpret_cast<uint8_t*>(index.data());
    uint8_t* output_host = nullptr;
    float* input_device = nullptr;
    uint32_t* index_device = nullptr;
    float* output_device = nullptr;

    aclInit(nullptr);
    aclrtSetDevice(device_id);
    aclrtCreateStream(&stream);

    // blocks_per_grid == 0 表示"用满全部物理核"：运行期查询真实核数后替换
    if (blocks_per_grid == 0) {
        blocks_per_grid = query_aiv_core_num(device_id);
    }

    aclrtMallocHost((void**)(&output_host), output_total_byte_size);
    aclrtMalloc((void**)&input_device, input_total_byte_size, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&index_device, index_total_byte_size, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&output_device, output_total_byte_size, ACL_MEM_MALLOC_HUGE_FIRST);

    aclrtMemcpy(input_device, input_total_byte_size, input_host, input_total_byte_size, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(index_device, index_total_byte_size, index_host, index_total_byte_size, ACL_MEMCPY_HOST_TO_DEVICE);

    if (kernel == KernelType::GATHER_NAIVE) {
        gather_naive_kernel<<<blocks_per_grid, INDEX_WIDTH, 0, stream>>>(
            input_device, index_device, output_device, input_total_length, index_total_length);
    } else if (kernel == KernelType::GATHER_STRIDED) {
        uint32_t threads_per_block = resolve_thread_num(blocks_per_grid, index_total_length);
        gather_strided_kernel<<<blocks_per_grid, threads_per_block, 0, stream>>>(
            input_device, index_device, output_device, input_total_length, index_total_length);
    } else {
        aclrtMemcpy(
            output_device, output_total_byte_size, input_device, output_total_byte_size, ACL_MEMCPY_DEVICE_TO_DEVICE);
        empty_kernel<<<blocks_per_grid, MAX_THREAD_NUM, 0, stream>>>(
            input_device, index_device, output_device, input_total_length, index_total_length);
    }

    aclrtSynchronizeStream(stream);

    aclrtMemcpy(output_host, output_total_byte_size, output_device, output_total_byte_size, ACL_MEMCPY_DEVICE_TO_HOST);
    std::vector<float> output((float*)output_host, (float*)(output_host + output_total_byte_size));

    aclrtFree(input_device);
    aclrtFree(index_device);
    aclrtFree(output_device);
    aclrtFreeHost(output_host);

    const char* err = aclGetRecentErrMsg();
    if (err != nullptr) {
        fprintf(stderr, "%s\n", err);
    }

    aclrtDestroyStream(stream);
    aclrtResetDevice(device_id);
    aclFinalize();
    return output;
}

uint32_t verify_result(std::vector<float>& output, std::vector<float>& golden)
{
    auto print_tensor = [](std::vector<float>& tensor, const char* name) {
        constexpr size_t max_print_size = 20;
        std::cout << name << ": ";
        std::copy(
            tensor.begin(), tensor.begin() + std::min(tensor.size(), max_print_size),
            std::ostream_iterator<float>(std::cout, " "));
        if (tensor.size() > max_print_size) {
            std::cout << "...";
        }
        std::cout << std::endl;
    };
    print_tensor(output, "Output");
    print_tensor(golden, "Golden");

    if (std::equal(golden.begin(), golden.end(), output.begin())) {
        std::cout << "[Success] Case accuracy is verification passed." << std::endl;
        return 0;
    } else {
        std::cout << "[Failed] Case accuracy is verification failed!" << std::endl;
        return 1;
    }
}

int32_t main(int32_t argc, char* argv[])
{
    srand(static_cast<uint32_t>(time(nullptr)));

    const uint32_t scenario = static_cast<uint32_t>(SCENARIO_NUM);
    ScenarioConfig config = get_scenario_config(scenario);

    printf("Scenario %u: %s\n", scenario, config.name);

    constexpr uint32_t input_total_length = 2100000;
    std::vector<float> input(input_total_length);
    for (uint32_t i = 0; i < input_total_length; i++) {
        input[i] = i * 1.2f;
    }

    // 元素总数随场景而定：Case 0/1为大shape(2097152)，Case 2为小shape(16384)
    const uint32_t total_length = config.total_length;
    std::vector<uint32_t> index(total_length);
    for (uint32_t i = 0; i < total_length; i++) {
        index[i] = rand() % input_total_length;
    }

    std::vector<float> golden(total_length);
    if (config.kernel == KernelType::EMPTY) {
        for (uint32_t i = 0; i < total_length; i++) {
            golden[i] = input[i];
        }
    } else {
        for (uint32_t i = 0; i < total_length; i++) {
            golden[i] = input[index[i]];
        }
    }

    std::vector<float> output = run_kernel(input, index, config.blocks_per_grid, config.kernel);
    if (output.empty()) {
        return 1;
    }
    return verify_result(output, golden);
}
