/* !
 * \file sincos_compute.asc
 * \brief SIMT sincos computation sample for thread configuration tuning.
 */

#include <algorithm>
#include <iostream>
#include <iterator>
#include <set>
#include <vector>
#include <cmath>
#include "acl/acl.h"
#include <asc_simt.h>

constexpr int32_t PER_THREAD_LOOP = 16;
constexpr int32_t BLOCKS_PER_GRID = 48;
constexpr int32_t THREADS_PER_BLOCK = 512;

__global__ void sincos_thread_1024(float* input, float* output_sin, 
                                    float* output_cos, uint64_t total_length)
{
    int32_t blk_start_idx = blockIdx.x * THREADS_PER_BLOCK * PER_THREAD_LOOP;

    for (int i = 0; i < PER_THREAD_LOOP; i++) {
        int idx = blk_start_idx + i * THREADS_PER_BLOCK + threadIdx.x;
        sincosf(input[idx], output_sin + idx, output_cos + idx);
    }
}

__global__ __launch_bounds__(512) void sincos_thread_512(float* input, 
                                    float* output_sin, float* output_cos,
                                    uint64_t total_length)
{
    int32_t blk_start_idx = blockIdx.x * THREADS_PER_BLOCK * PER_THREAD_LOOP;

    for (int i = 0; i < PER_THREAD_LOOP; i++) {
        int idx = blk_start_idx + i * THREADS_PER_BLOCK + threadIdx.x;
        sincosf(input[idx], output_sin + idx, output_cos + idx);
    }
}

void sincos_func(std::vector<float>& input, std::vector<float>& output_sin, std::vector<float>& output_cos, const std::string& case_name)
{
    if (input.empty()) {
        std::cout << "[ERROR] Empty input tensors." << std::endl;
        return;
    }

    uint32_t total_length = input.size();
    size_t total_byte_size = total_length * sizeof(float);

    int32_t device_id = 0;
    aclrtStream stream = nullptr;

    uint8_t* input_host = reinterpret_cast<uint8_t *>(input.data());
    float* input_device = nullptr;
    float* output_sin_device = nullptr;
    float* output_cos_device = nullptr;
    // Init
    aclInit(nullptr);
    aclrtSetDevice(device_id);
    aclrtCreateStream(&stream);

    // Allocate host and device memory, and copy input data from host to device
    aclrtMalloc((void **)&input_device, total_byte_size, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void **)&output_sin_device, total_byte_size, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void **)&output_cos_device, total_byte_size, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMemcpy(input_device, total_byte_size, input_host, total_byte_size, ACL_MEMCPY_HOST_TO_DEVICE);

    // Configure kernel launch parameters
    uint32_t dyn_ubuf_size = 0;  // No dynamic memory required in this sample

    // Call kernel function with <<<...>>>
    if (case_name == "1024") {
        // launch_bound was set to 1024 by default
        sincos_thread_1024<<<BLOCKS_PER_GRID, THREADS_PER_BLOCK, dyn_ubuf_size, stream>>>(
            input_device, output_sin_device, output_cos_device, total_length);
    } else {
        // launch_bound was set to 512
        sincos_thread_512<<<BLOCKS_PER_GRID, THREADS_PER_BLOCK, dyn_ubuf_size, stream>>>(
            input_device, output_sin_device, output_cos_device, total_length);
    }


    // Wait for the sincos_thread_1024 kernel to complete
    aclrtSynchronizeStream(stream);

    // Copy the result from device memory to host memory
    aclrtMemcpy(output_sin.data(), total_byte_size, output_sin_device, total_byte_size, ACL_MEMCPY_DEVICE_TO_HOST);
    aclrtMemcpy(output_cos.data(), total_byte_size, output_cos_device, total_byte_size, ACL_MEMCPY_DEVICE_TO_HOST);

    // free memory
    aclrtFree(input_device);
    aclrtFree(output_sin_device);
    aclrtFree(output_cos_device);

    const char* err = aclGetRecentErrMsg();
    if (err != nullptr) {
        fprintf(stderr, "%s\n", err);
    }

    // DeInit
    aclrtDestroyStream(stream);
    aclrtResetDevice(device_id);
    aclFinalize();
}

uint32_t verify_result(std::vector<float>& output, std::vector<float>& golden)
{
    auto print_tensor = [](std::vector<float>& tensor, const char* name) {
        constexpr size_t max_print_size = 20;
        std::cout << name << ": ";
        std::copy(tensor.begin(), tensor.begin() + std::min(tensor.size(), max_print_size),
            std::ostream_iterator<float>(std::cout, " "));
        if (tensor.size() > max_print_size) {
            std::cout << "...";
        }
        std::cout << std::endl;
    };
    print_tensor(output, "Output");
    print_tensor(golden, "Golden");
    constexpr float EPS = 0.0001;
    if (std::equal(output.begin(), output.end(), golden.begin(), [](float x, float y) {
            return fabs(x - y) < EPS;
        })) {
        std::cout << "[Success] Case accuracy is verification passed." << std::endl;
        return 0;
    }
    std::cout << "[Failed] Case accuracy is verification failed!" << std::endl;
    return 1;
}

int32_t main(int32_t argc, char* argv[])
{
    if (argc != 2) {
        std::cout << "[Failed] Invalid input, only \"sincos_compute 1024\" or \"sincos_compute 512\" is supported." << std::endl;
        return 1;
    }

    std::string case_name(argv[1]);
    std::set<std::string> supported_cases{"1024", "512"};
    if (!supported_cases.count(case_name)) {
        std::cout << "[Failed] Invalid case name, only \"sincos_compute 1024\" or \"sincos_compute 512\" is supported." << std::endl;
        return 1;
    }

    constexpr uint32_t total_length = BLOCKS_PER_GRID * THREADS_PER_BLOCK * PER_THREAD_LOOP;

    std::vector<float> input(total_length);
    for (uint32_t i = 0; i < total_length; i++) {
        input[i] = i * 1.2f;
    }

    std::vector<float> golden_sin(total_length);
    std::vector<float> golden_cos(total_length);
    std::vector<float> output_sin(total_length);
    std::vector<float> output_cos(total_length);
    for (uint32_t i = 0; i < total_length; i++) {
        golden_sin[i] = sin(input[i]);
        golden_cos[i] = cos(input[i]);
    }

    sincos_func(input, output_sin, output_cos, case_name);
    if (output_sin.empty() || output_cos.empty()) {
        return 1;
    }
    return verify_result(output_sin, golden_sin) && verify_result(output_cos, golden_cos);
}
