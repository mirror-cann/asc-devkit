/* !
 * \file stack_overflow.asc
 * \brief Demonstrates stack overflow scenario and optimization in SIMT kernels.
 */

#include <cstdint>
#include <cstdio>
#include <vector>
#include <cmath>
#include <iostream>
#include "acl/acl.h"
#include "simt_api/asc_simt.h"

#ifndef SCENARIO_NUM
#define SCENARIO_NUM 1
#endif

#if SCENARIO_NUM < 1 || SCENARIO_NUM > 4
#error "SCENARIO_NUM must be one of 1, 2, 3, 4"
#endif

namespace {
constexpr uint32_t BUFFER_SIZE = 320;
constexpr uint32_t total_length = 2048;
constexpr uint32_t THREAD_COUNT = 1024;
constexpr uint32_t UB_SIZE = 0;
} // namespace

enum KernelKind {
    USE_LARGE_ARRAY_BASELINE = 1,
    USE_LARGE_ARRAY_OPTIMIZED = 2,
    USE_RECURSION_BASELINE = 3,
    USE_RECURSION_OPTIMIZED = 4,
};

// ============================================================
// kernel 内定义大局部数组，栈开销较大
// ============================================================
// 每个线程在栈上分配 320 * 4 = 1280B 的局部数组。
__global__ void simt_stack_overflow(int32_t* input, float* output, uint32_t total_length)
{
    uint32_t idx = blockIdx.x * blockDim.x + threadIdx.x;
    if (idx >= total_length) {
        return;
    }
    float local_buffer[BUFFER_SIZE];

    for (uint32_t i = 0; i < BUFFER_SIZE; i++) {
        local_buffer[i] = i + 1;
    }

    float sum = 1.0f;
    for (uint32_t i = 0; i < input[idx]; i++) {
        sum *= local_buffer[i];
    }
    output[idx] = sum;
}

// ============================================================
// 递归调用叠加栈帧，栈开销较大
// ============================================================
__aicore__ float recursive_stack_stage(int32_t value)
{
    if (value < 1) {
        return 1.0f;
    }
    return recursive_stack_stage(value - 1) * value;
}

__global__ void simt_recursive_stack_overflow(int32_t* input, float* output, uint32_t total_length)
{
    uint32_t idx = blockIdx.x * blockDim.x + threadIdx.x;
    if (idx >= total_length) {
        return;
    }
    output[idx] = recursive_stack_stage(input[idx]);
}

__aicore__ float recursive_stack_stage_optimized(int32_t value)
{
    float result = 1.0f;
    for (int32_t i = 2; i <= value; ++i) {
        result *= i;
    }
    return result;
}

__global__ void simt_recursive_stack_overflow_optimized(int32_t* input, float* output, uint32_t total_length)
{
    uint32_t idx = blockIdx.x * blockDim.x + threadIdx.x;
    if (idx >= total_length) {
        return;
    }
    output[idx] = recursive_stack_stage_optimized(input[idx]);
}

std::vector<float> launch_kernel(std::vector<int32_t>& input, uint32_t total_length, uint32_t kernel_type)
{
    size_t input_bytes = total_length * sizeof(int32_t);
    size_t output_bytes = total_length * sizeof(float);

    int32_t device_id = 0;
    aclrtStream stream = nullptr;
    void* input_host = reinterpret_cast<void*>(input.data());
    void* input_device = nullptr;
    void* output_host = nullptr;
    void* output_device = nullptr;

    uint32_t blocks_per_grid = total_length / THREAD_COUNT;
    uint32_t threads_per_block = THREAD_COUNT;
    uint32_t dyn_ubuf_size = UB_SIZE;

    if (kernel_type == USE_LARGE_ARRAY_OPTIMIZED) {
        aclInit("acl.json");
    } else {
        aclInit(nullptr);
    }

    aclrtSetDevice(device_id);
    aclrtCreateStream(&stream);
    aclrtMallocHost(&output_host, output_bytes);
    aclrtMalloc(&input_device, input_bytes, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc(&output_device, output_bytes, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMemcpy(input_device, input_bytes, input_host, input_bytes, ACL_MEMCPY_HOST_TO_DEVICE);

    printf("========================================\n");
    printf("[Host] Running kernel (SCENARIO_NUM=%u)...\n", kernel_type);
    printf("========================================\n");
    if (kernel_type == USE_RECURSION_BASELINE) {
        simt_recursive_stack_overflow<<<blocks_per_grid, threads_per_block, dyn_ubuf_size, stream>>>(
            static_cast<int32_t*>(input_device), static_cast<float*>(output_device), total_length);
    } else if (kernel_type == USE_RECURSION_OPTIMIZED) {
        simt_recursive_stack_overflow_optimized<<<blocks_per_grid, threads_per_block, dyn_ubuf_size, stream>>>(
            static_cast<int32_t*>(input_device), static_cast<float*>(output_device), total_length);
    } else {
        simt_stack_overflow<<<blocks_per_grid, threads_per_block, dyn_ubuf_size, stream>>>(
            static_cast<int32_t*>(input_device), static_cast<float*>(output_device), total_length);
    }

    aclrtSynchronizeStream(stream);

    aclrtMemcpy(output_host, output_bytes, output_device, output_bytes, ACL_MEMCPY_DEVICE_TO_HOST);
    std::vector<float> output(static_cast<float*>(output_host), static_cast<float*>(output_host) + total_length);

    aclrtFree(input_device);
    aclrtFree(output_device);
    aclrtFreeHost(output_host);
    const char* err = aclGetRecentErrMsg();
    if (err != nullptr) {
        fprintf(stderr, "[Host] kernel error: %s\n", err);
    } else {
        printf("[Host] kernel completed.\n");
    }
    aclrtDestroyStream(stream);
    aclrtResetDevice(device_id);
    aclFinalize();
    return output;
}

float factorial(unsigned int n)
{
    float result = 1;
    for (unsigned int i = 2; i <= n; ++i) {
        result *= i;
    }
    return result;
}

void generate_input_and_golden_data(std::vector<int32_t>& input, std::vector<float>& golden, uint32_t input_length)
{
    for (int32_t index = 0; index < input_length; index++) {
        input[index] = index % 100;
        golden[index] = factorial(input[index]);
    }
}

uint32_t verify_result(const std::vector<float>& output, const std::vector<float>& golden, float abs_tolerance = 1e-3f)
{
    if (output.size() != golden.size()) {
        printf("[Failed] Case accuracy verification failed!\n");
        return 1;
    }
    for (size_t i = 0; i < output.size(); ++i) {
        if (std::fabs(output[i] - golden[i]) > abs_tolerance) {
            printf("[Failed] Case accuracy verification failed!\n");
            return 1;
        }
    }
    printf("test pass!\n");
    return 0;
}

const char* get_kernel_name(int kernel_kind)
{
    switch (kernel_kind) {
        case USE_LARGE_ARRAY_BASELINE:
            return "large local array baseline (aclInit(nullptr), stack overflow)";
        case USE_LARGE_ARRAY_OPTIMIZED:
            return "large local array optimized (aclInit(acl.json), stack configured)";
        case USE_RECURSION_BASELINE:
            return "recursive call baseline (aclInit(nullptr), stack overflow)";
        case USE_RECURSION_OPTIMIZED:
            return "recursive call optimized (aclInit(nullptr), stack optimized)";
        default:
            return "unknown";
    }
}

int32_t main(int32_t argc, char* argv[])
{
    const uint32_t kernel_kind = static_cast<uint32_t>(SCENARIO_NUM);
    printf("Usage: %s (compile-time SCENARIO_NUM=%u)\n", argv[0], kernel_kind);
    printf("Running case %u: %s...\n", kernel_kind, get_kernel_name(static_cast<int32_t>(kernel_kind)));

    std::vector<int32_t> input(total_length);
    std::vector<float> golden(total_length);
    generate_input_and_golden_data(input, golden, total_length);

    std::vector<float> output = launch_kernel(input, total_length, kernel_kind);
    return verify_result(output, golden);
}
