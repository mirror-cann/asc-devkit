#include <cassert>
#include <cstdio>
#include <cstdlib>

#include "acl/acl.h"
#include "simt_api/asc_simt.h"

constexpr unsigned int HISTOGRAM_BIN_COUNT = 256U;
constexpr unsigned int WARP_SHIFT = 5U;
constexpr unsigned int WARP_SIZE = 1U << WARP_SHIFT;
constexpr unsigned int WARP_COUNT = 32U;
constexpr unsigned int THREADS_PER_BLOCK = WARP_COUNT * WARP_SIZE;
constexpr unsigned int HISTOGRAM_TEMP_MEMORY = WARP_COUNT * HISTOGRAM_BIN_COUNT;
constexpr unsigned int REDUCE_BLOCK_SIZE = 128U;
constexpr unsigned int PARTIAL_HISTOGRAM_COUNT = 72U;
constexpr unsigned int FIXED_INPUT_BYTE_COUNT = 72U * 1024U * 4U;
constexpr unsigned int FIXED_SEED = 2009U;

struct HostBuffers {
    unsigned char* input_bytes = nullptr;
    unsigned int* expected_histogram = nullptr;
    unsigned int* actual_histogram = nullptr;
};

struct DeviceBuffers {
    unsigned int* input_words = nullptr;
    unsigned int* final_histogram = nullptr;
    unsigned int* partial_histogram = nullptr;
    aclrtStream stream = nullptr;
};

void check_acl(aclError result, const char* const func, const char* const file, int const line)
{
    if (result != ACL_SUCCESS) {
        std::fprintf(
            stderr, "ACL error at %s:%d code=%d(%s) \"%s\"\n", file, line, static_cast<int>(result),
            aclGetRecentErrMsg(), func);
        std::exit(EXIT_FAILURE);
    }
}

void check_acl_launch(const char* kernel_name, const char* const file, int const line)
{
    const aclError result = aclrtGetLastError(ACL_RT_THREAD_LEVEL);
    if (result != ACL_SUCCESS) {
        std::fprintf(
            stderr, "ACL error at %s:%d kernel=\"%s\" code=%d(%s)\n", file, line, kernel_name, static_cast<int>(result),
            aclGetRecentErrMsg());
        std::exit(EXIT_FAILURE);
    }
}

#define CHECK_ACL(val) check_acl((val), #val, __FILE__, __LINE__)
#define CHECK_ACL_LAUNCH(kernel_name) check_acl_launch((kernel_name), __FILE__, __LINE__)

void compute_histogram_cpu(unsigned int* histogram_out, const void* byte_data, unsigned int byte_count)
{
    for (unsigned int bin_index = 0; bin_index < HISTOGRAM_BIN_COUNT; ++bin_index) {
        histogram_out[bin_index] = 0;
    }

    assert(sizeof(unsigned int) == 4 && (byte_count % sizeof(unsigned int)) == 0);

    const unsigned int* packed_words = (const unsigned int*)(byte_data);
    const unsigned int word_count = byte_count / sizeof(unsigned int);

    for (unsigned int tid = 0; tid < word_count; ++tid) {
        const unsigned int packed_word = packed_words[tid];
        histogram_out[(packed_word >> 0) & 0xFFU]++;
        histogram_out[(packed_word >> 8) & 0xFFU]++;
        histogram_out[(packed_word >> 16) & 0xFFU]++;
        histogram_out[(packed_word >> 24) & 0xFFU]++;
    }
}

void seed_input_bytes(unsigned char* bytes, unsigned int byte_count, unsigned int seed)
{
    std::srand((int)seed);
    for (unsigned int byte_index = 0; byte_index < byte_count; ++byte_index) {
        bytes[byte_index] = (unsigned char)(std::rand() % HISTOGRAM_BIN_COUNT);
    }
}

bool histograms_match(const unsigned int* lhs, const unsigned int* rhs, unsigned int* mismatch_bin)
{
    for (unsigned int bin_index = 0; bin_index < HISTOGRAM_BIN_COUNT; ++bin_index) {
        if (lhs[bin_index] != rhs[bin_index]) {
            if (mismatch_bin != nullptr) {
                *mismatch_bin = bin_index;
            }
            return false;
        }
    }
    return true;
}

__global__ void accumulate_block_local_histogram(
    unsigned int* partial_histogram, const unsigned int* input_words, unsigned int word_count)
{
    __ubuf__ unsigned int s_mem_histogram[HISTOGRAM_TEMP_MEMORY];
    __ubuf__ unsigned int* warp_histogram;
    warp_histogram = s_mem_histogram + (threadIdx.x >> WARP_SHIFT) * HISTOGRAM_BIN_COUNT;

#pragma unroll
    for (unsigned int chunk_index = 0; chunk_index < (HISTOGRAM_TEMP_MEMORY / THREADS_PER_BLOCK); ++chunk_index) {
        s_mem_histogram[threadIdx.x + chunk_index * THREADS_PER_BLOCK] = 0;
    }
    asc_syncthreads();
    for (unsigned int tid = blockIdx.x * blockDim.x + threadIdx.x; tid < word_count; tid += blockDim.x * gridDim.x) {
        const uint packed_word = input_words[tid];
        // 提取 packed_word 的 第0个字节 (最低8位, bits 0-7)，作为直方图下标，并对直方图对应位置原子累加1
        asc_atomic_add(warp_histogram + ((packed_word >> 0) & 0xFFU), 1U);
        // 提取 packed_word 的 第1个字节 (bits 8-15)，作为直方图下标，并对直方图对应位置原子累加1
        asc_atomic_add(warp_histogram + ((packed_word >> 8) & 0xFFU), 1U);
        // 提取 packed_word 的 第2个字节 (bits 16-23)，作为直方图下标，并对直方图对应位置原子累加1
        asc_atomic_add(warp_histogram + ((packed_word >> 16) & 0xFFU), 1U);
        // 提取 packed_word 的 第3个字节 (最高8位, bits 24-31)，作为直方图下标，并对直方图对应位置原子累加1
        asc_atomic_add(warp_histogram + ((packed_word >> 24) & 0xFFU), 1U);
    }
    asc_syncthreads();
    for (unsigned int bin_index = threadIdx.x; bin_index < HISTOGRAM_BIN_COUNT; bin_index += THREADS_PER_BLOCK) {
        unsigned int bin_sum = 0;
        for (uint warp_index = 0; warp_index < WARP_COUNT; ++warp_index) {
            bin_sum += s_mem_histogram[bin_index + warp_index * HISTOGRAM_BIN_COUNT];
        }
        partial_histogram[blockIdx.x * HISTOGRAM_BIN_COUNT + bin_index] = bin_sum;
    }
}

__global__ void merge_block_local_histogram(
    unsigned int* final_histogram, const unsigned int* partial_histogram, unsigned int partial_count)
{
    __ubuf__ unsigned int his_bins_reduction[REDUCE_BLOCK_SIZE];
    unsigned int bin_accumulator = 0;
    for (unsigned int partial_index = threadIdx.x; partial_index < partial_count; partial_index += REDUCE_BLOCK_SIZE) {
        bin_accumulator += partial_histogram[blockIdx.x + partial_index * HISTOGRAM_BIN_COUNT];
    }
    his_bins_reduction[threadIdx.x] = bin_accumulator;
    for (unsigned int stride = REDUCE_BLOCK_SIZE / 2; stride > 0; stride >>= 1) {
        asc_syncthreads();
        if (threadIdx.x < stride) {
            his_bins_reduction[threadIdx.x] += his_bins_reduction[threadIdx.x + stride];
        }
    }

    if (threadIdx.x == 0) {
        final_histogram[blockIdx.x] = his_bins_reduction[0];
    }
}

void release_host_buffers(HostBuffers* host)
{
    std::free(host->input_bytes);
    std::free(host->expected_histogram);
    std::free(host->actual_histogram);
    host->input_bytes = nullptr;
    host->expected_histogram = nullptr;
    host->actual_histogram = nullptr;
}

void release_device_buffers(DeviceBuffers* device)
{
    if (device->partial_histogram != nullptr) {
        aclrtFree(device->partial_histogram);
        device->partial_histogram = nullptr;
    }
    if (device->final_histogram != nullptr) {
        aclrtFree(device->final_histogram);
        device->final_histogram = nullptr;
    }
    if (device->input_words != nullptr) {
        aclrtFree(device->input_words);
        device->input_words = nullptr;
    }
    if (device->stream != nullptr) {
        aclrtDestroyStream(device->stream);
        device->stream = nullptr;
    }
}

bool allocate_host_buffers(HostBuffers* host)
{
    host->input_bytes = (unsigned char*)std::malloc(FIXED_INPUT_BYTE_COUNT);
    host->expected_histogram = (unsigned int*)std::malloc(HISTOGRAM_BIN_COUNT * sizeof(unsigned int));
    host->actual_histogram = (unsigned int*)std::malloc(HISTOGRAM_BIN_COUNT * sizeof(unsigned int));

    if (host->input_bytes != nullptr && host->expected_histogram != nullptr && host->actual_histogram != nullptr) {
        return true;
    }

    std::fprintf(stderr, "host memory allocation failed\n");
    release_host_buffers(host);
    return false;
}

void allocate_device_buffers(DeviceBuffers* device)
{
    CHECK_ACL(aclrtCreateStream(&device->stream));
    CHECK_ACL(aclrtMalloc((void**)(&device->input_words), FIXED_INPUT_BYTE_COUNT, ACL_MEM_MALLOC_HUGE_FIRST));
    CHECK_ACL(aclrtMalloc(
        (void**)(&device->final_histogram), HISTOGRAM_BIN_COUNT * sizeof(unsigned int), ACL_MEM_MALLOC_HUGE_FIRST));
    CHECK_ACL(aclrtMalloc(
        (void**)(&device->partial_histogram), PARTIAL_HISTOGRAM_COUNT * HISTOGRAM_BIN_COUNT * sizeof(unsigned int),
        ACL_MEM_MALLOC_HUGE_FIRST));
}

void compute_histogram_npu(const DeviceBuffers& device)
{
    const unsigned int word_count = FIXED_INPUT_BYTE_COUNT / sizeof(unsigned int);
    const unsigned int dynamic_ubuf_size = 0;

    accumulate_block_local_histogram<<<
        dim3(PARTIAL_HISTOGRAM_COUNT), dim3(THREADS_PER_BLOCK), dynamic_ubuf_size, device.stream>>>(
        device.partial_histogram, device.input_words, word_count);
    CHECK_ACL_LAUNCH("accumulate_block_local_histogram");

    merge_block_local_histogram<<<
        dim3(HISTOGRAM_BIN_COUNT), dim3(REDUCE_BLOCK_SIZE), dynamic_ubuf_size, device.stream>>>(
        device.final_histogram, device.partial_histogram, PARTIAL_HISTOGRAM_COUNT);
    CHECK_ACL_LAUNCH("merge_block_local_histogram");
    aclrtSynchronizeStream(device.stream);
}

int main()
{
    static_assert((FIXED_INPUT_BYTE_COUNT % 4) == 0, "FIXED_INPUT_BYTE_COUNT must be 4 bytes aligned");
    HostBuffers host;
    if (!allocate_host_buffers(&host)) {
        return EXIT_FAILURE;
    }
    seed_input_bytes(host.input_bytes, FIXED_INPUT_BYTE_COUNT, FIXED_SEED);
    compute_histogram_cpu(host.expected_histogram, host.input_bytes, FIXED_INPUT_BYTE_COUNT);
    aclInit(nullptr);
    aclrtSetDevice(0);
    DeviceBuffers device;
    allocate_device_buffers(&device);
    CHECK_ACL(aclrtMemcpy(
        device.input_words, FIXED_INPUT_BYTE_COUNT, host.input_bytes, FIXED_INPUT_BYTE_COUNT,
        ACL_MEMCPY_HOST_TO_DEVICE));

    std::printf("Running histogram256 on Ascend C SIMT for fixed %u bytes\n", FIXED_INPUT_BYTE_COUNT);
    compute_histogram_npu(device);
    CHECK_ACL(aclrtMemcpy(
        host.actual_histogram, HISTOGRAM_BIN_COUNT * sizeof(unsigned int), device.final_histogram,
        HISTOGRAM_BIN_COUNT * sizeof(unsigned int), ACL_MEMCPY_DEVICE_TO_HOST));

    unsigned int mismatch_bin = 0;
    const bool matched = histograms_match(host.actual_histogram, host.expected_histogram, &mismatch_bin);
    if (matched) {
        std::printf("Validation passed\n");
    } else {
        std::fprintf(
            stderr, "Validation failed at bin %u: device=%u cpu=%u\n", mismatch_bin,
            host.actual_histogram[mismatch_bin], host.expected_histogram[mismatch_bin]);
    }
    release_device_buffers(&device);
    aclrtResetDevice(0);
    aclFinalize();
    release_host_buffers(&host);
    return matched ? EXIT_SUCCESS : EXIT_FAILURE;
}
