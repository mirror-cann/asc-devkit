#include <cstdio>
#include <cstdlib>

#include "acl/acl.h"
#include "simt_api/asc_simt.h"

const char* SAMPLE_NAME = "Atomic Intrinsics Example";

void check_acl(aclError result, const char* const func, const char* const file, int const line)
{
    if (result != ACL_SUCCESS) {
        std::fprintf(
            stderr, "ACL error at %s:%d code=%d(%s) \"%s\"\n", file, line, static_cast<int>(result),
            aclGetRecentErrMsg(), func);
        std::exit(EXIT_FAILURE);
    }
}

#define CHECK_ACL(val) check_acl((val), #val, __FILE__, __LINE__)

bool cpu_golden(int* output_data, const int thread_num)
{
    int val = 0;
    for (int i = 0; i < thread_num; ++i) {
        val += 5;
    }
    if (val != output_data[0]) {
        printf("atomicAdd failed\n");
        return false;
    }

    val = 0;
    for (int i = 0; i < thread_num; ++i) {
        val -= 5;
    }
    if (val != output_data[1]) {
        printf("atomicSub failed\n");
        return false;
    }

    if (output_data[2] < 0 || output_data[2] >= thread_num) {
        printf("atomicExch failed\n");
        return false;
    }

    val = 0;
    for (int i = 0; i < thread_num; ++i) {
        val = (i > val) ? i : val;
    }
    if (val != output_data[3]) {
        printf("atomicMax failed\n");
        return false;
    }

    val = thread_num;
    for (int i = 0; i < thread_num; ++i) {
        val = (i < val) ? i : val;
    }
    if (val != output_data[4]) {
        printf("atomicMin failed\n");
        return false;
    }

    int limit = 11;
    val = 0;
    for (int i = 0; i < thread_num; ++i) {
        val = (val >= limit) ? 0 : val + 1;
    }
    if (val != output_data[5]) {
        printf("atomicInc failed\n");
        return false;
    }

    limit = 100;
    val = 0;
    for (int i = 0; i < thread_num; ++i) {
        val = ((val == 0) || (val > limit)) ? limit : val - 1;
    }
    if (val != output_data[6]) {
        printf("atomicDec failed\n");
        return false;
    }

    if (output_data[7] < 0 || output_data[7] >= thread_num) {
        printf("atomicCAS failed\n");
        return false;
    }

    val = 0xff;
    for (int i = 0; i < thread_num; ++i) {
        val &= (2 * i + 1);
    }
    if (val != output_data[8]) {
        printf("atomicAnd failed\n");
        return false;
    }

    unsigned int uval = 0u;
    for (int i = 0; i < thread_num; ++i) {
        uval |= 1u << (i & 31);
    }
    if (uval != (unsigned int)output_data[9]) {
        printf("atomicOr failed\n");
        return false;
    }

    val = 0xff;
    for (int i = 0; i < thread_num; ++i) {
        val ^= i;
    }
    if (val != output_data[10]) {
        printf("atomicXor failed\n");
        return false;
    }

    return true;
}

__global__ void atomic_intrinsics_kernel(int* output_data)
{
    const unsigned int tid = blockIdx.x * blockDim.x + threadIdx.x;

    // Atomic addition
    asc_atomic_add(&output_data[0], 5);

    // Atomic subtraction (final should be 0)
    asc_atomic_sub(&output_data[1], 5);

    // Atomic exchange
    asc_atomic_exch(&output_data[2], tid);

    // Atomic maximum
    asc_atomic_max(&output_data[3], tid);

    // Atomic minimum
    asc_atomic_min(&output_data[4], tid);

    // Atomic increment
    asc_atomic_inc((unsigned int*)&output_data[5], 11u);

    // Atomic decrement
    asc_atomic_dec((unsigned int*)&output_data[6], 100u);

    // Atomic compare-and-swap
    asc_atomic_cas(&output_data[7], tid - 1, tid);

    // Bitwise atomic instructions

    // Atomic AND
    asc_atomic_and(&output_data[8], 2 * tid + 1);

    // Atomic OR
    asc_atomic_or(&output_data[9], 1u << (tid & 31u));

    // Atomic XOR
    asc_atomic_xor(&output_data[10], tid);
}

int main()
{
    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);
    printf("%s starting...\n", SAMPLE_NAME);
    unsigned int threads_per_block = 256;
    unsigned int blocks_per_grid = 64;
    unsigned int num_data = 11;
    unsigned int mem_size = sizeof(int) * num_data;
    int* h_output_data = nullptr;
    CHECK_ACL(aclrtMallocHost((void**)&h_output_data, mem_size));
    for (unsigned int i = 0; i < num_data; i++) {
        h_output_data[i] = 0;
    }
    h_output_data[8] = 0xff;
    h_output_data[10] = 0xff;
    int* d_output_data = nullptr;
    CHECK_ACL(aclrtMalloc((void**)&d_output_data, mem_size, ACL_MEM_MALLOC_HUGE_FIRST));
    CHECK_ACL(aclrtMemcpy(d_output_data, mem_size, h_output_data, mem_size, ACL_MEMCPY_HOST_TO_DEVICE));

    atomic_intrinsics_kernel<<<blocks_per_grid, threads_per_block, 0, stream>>>(d_output_data);

    CHECK_ACL(aclrtSynchronizeStream(stream));
    CHECK_ACL(aclrtMemcpy(h_output_data, mem_size, d_output_data, mem_size, ACL_MEMCPY_DEVICE_TO_HOST));
    bool ok = cpu_golden(h_output_data, threads_per_block * blocks_per_grid);
    printf("%s completed, returned %s\n", SAMPLE_NAME, ok ? "OK" : "ERROR!");

    aclrtFree(d_output_data);
    aclrtFreeHost(h_output_data);
    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();
    return ok ? EXIT_SUCCESS : EXIT_FAILURE;
}
