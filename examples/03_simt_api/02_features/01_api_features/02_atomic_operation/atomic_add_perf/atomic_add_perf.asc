/* !
 * \file atomic_add_perf.asc
 * \brief SIMT asc_atomic_add performance workload sample.
 *
 * Twenty scenarios grouped into five cases. Each scenario runs exactly one
 * kernel; pick it with -DSCENARIO_NUM=<n>. Every thread contributes one +1
 * update, so the workload is fully described by (blocks, threads).
 *
 * The scenario -> config mapping lives in get_scenario_config(); every other
 * function reads the returned ScenarioConfig fields at runtime, so there is a
 * single point of scenario-specific branching instead of scattered #if chains.
 *
 *   Case 1  single GM address vs single UB address, one block, 1024 threads
 *           S1  GM  int32  direct atomic add   (no return value)
 *           S2  UB  int32  direct atomic add   (no return value)
 *   Case 2  same GM address hit by 8 blocks x 1024 threads
 *           S3  GM  int32  direct atomic add   (no return value)
 *           S4  UB  int32  block-local accumulation before GM writeback
 *   Case 3  return-value overhead, one block, 2048 threads on one address
 *           S5  GM  int32  with    return value
 *           S6  GM  int32  without return value
 *           S7  UB  int32  with    return value
 *           S8  UB  int32  without return value
 *   Case 4  same-address contention intensity, dense counters over a shared
 *           target pool, with return value, 48 blocks x 256 threads (12288).
 *           Only target_count varies; threads/blocks stay fixed so contention
 *           intensity is the sole variable. Contention = threads/target_count.
 *           S9   GM int32  target_count 12288 (1 thread/addr, no same-addr contention)
 *           S10  GM int32  target_count 1024  (12 threads/addr)
 *           S11  GM int32  target_count 32    (384 threads/addr)
 *           S12  GM int32  target_count 1     (12288 threads/addr, extreme)
 *           S13  GM int64  target_count 12288
 *           S14  GM int64  target_count 1024
 *           S15  GM int64  target_count 32
 *           S16  GM int64  target_count 1
 *   Case 5  int32 vs int64 choice depends on whether the return value is used,
 *           dense per-thread counters, 48 blocks x 256 threads, target_count 1024
 *           S17  GM int32  (no return value)
 *           S18  GM int64  (no return value)
 *           S19  GM int32  (with return value)
 *           S20  GM int64  (with return value)
 */

#include <cstdint>
#include <cstdio>
#include <cstdlib>

#include "acl/acl.h"
#include "simt_api/asc_simt.h"
#include "simt_api/device_atomic_functions.h"

#ifndef SCENARIO_NUM
#define SCENARIO_NUM 1
#endif

#if SCENARIO_NUM < 1 || SCENARIO_NUM > 20
#error "SCENARIO_NUM must be one of 1..20."
#endif

#ifndef SKIP_VALIDATION
#define SKIP_VALIDATION 0
#endif

namespace {

// Upper bound on threads per block across all scenarios; used as the single
// __launch_bounds__ value for every kernel (actual launches may use fewer).
constexpr uint32_t MAX_THREADS_PER_BLOCK = 2048;

// Case 4/5/6 map each thread to a target via (globalTid % target_count). With
// fewer targets than threads, several threads contend for the same address:
// contention intensity = total_threads / target_count. Each dense scenario
// carries its own target_count in ScenarioConfig; the largest value across all
// scenarios bounds the host-side validation buffers and device allocation.
// Case 4's no-contention point uses target_count = 12288 (= 48 x 256 threads),
// one target per thread.
constexpr uint64_t MAX_TARGET_COUNT = 12288;

// Each kernel variant. Single/UB accumulation kernels always operate on int32; dense
// kernels come in int32/int64 and with/without-return-value flavours.
enum class KernelType {
    GM_SINGLE_NO_RETURN,      // S1, S3, S6
    GM_SINGLE_RETURN,         // S5
    UB_LOCAL_NO_RETURN,       // S2, S8
    UB_LOCAL_RETURN,          // S7
    UB_BLOCK_ACCUM_NO_RETURN, // S4
    GM_DENSE_I32_NO_RETURN,   // S9
    GM_DENSE_I64_NO_RETURN,   // S10
    GM_DENSE_I32_RETURN,      // S11
    GM_DENSE_I64_RETURN,      // S12
};

struct ScenarioConfig {
    uint32_t blocks;
    uint32_t threads;
    uint64_t target_count; // dense pool size; 0 for single/UB accumulation scenarios
    KernelType kernel;
    const char* name;
};

// Single source of truth for scenario -> config. Every other function reads
// these fields at runtime instead of re-deriving them from SCENARIO_NUM.
ScenarioConfig get_scenario_config(uint32_t scenario)
{
    switch (scenario) {
        case 1:
            return {1, 1024, 0, KernelType::GM_SINGLE_NO_RETURN, "Case1 GM int32 single-address, no return value"};
        case 2:
            return {1, 1024, 0, KernelType::UB_LOCAL_NO_RETURN, "Case1 UB int32 single-address, no return value"};
        case 3:
            return {8, 1024, 0, KernelType::GM_SINGLE_NO_RETURN, "Case2 GM int32 single-address, no return value"};
        case 4:
            return {
                8, 1024, 0, KernelType::UB_BLOCK_ACCUM_NO_RETURN,
                "Case2 UB int32 block-local accumulation, no return value"};
        case 5:
            return {1, 2048, 0, KernelType::GM_SINGLE_RETURN, "Case3 GM int32 single-address, with return value"};
        case 6:
            return {1, 2048, 0, KernelType::GM_SINGLE_NO_RETURN, "Case3 GM int32 single-address, no return value"};
        case 7:
            return {1, 2048, 0, KernelType::UB_LOCAL_RETURN, "Case3 UB int32 single-address, with return value"};
        case 8:
            return {1, 2048, 0, KernelType::UB_LOCAL_NO_RETURN, "Case3 UB int32 single-address, no return value"};
        // Case 4: same-address contention intensity. Fixed 48 x 256 = 12288
        // threads, with return value; only target_count varies (weak -> strong
        // contention within each dtype group).
        case 9:
            return {
                48, 256, 12288, KernelType::GM_DENSE_I32_RETURN,
                "Case4 GM int32 dense, with return value, target_count=12288 (1 thread/addr)"};
        case 10:
            return {
                48, 256, 1024, KernelType::GM_DENSE_I32_RETURN,
                "Case4 GM int32 dense, with return value, target_count=1024 (12 threads/addr)"};
        case 11:
            return {
                48, 256, 32, KernelType::GM_DENSE_I32_RETURN,
                "Case4 GM int32 dense, with return value, target_count=32 (384 threads/addr)"};
        case 12:
            return {
                48, 256, 1, KernelType::GM_DENSE_I32_RETURN,
                "Case4 GM int32 dense, with return value, target_count=1 (12288 threads/addr)"};
        case 13:
            return {
                48, 256, 12288, KernelType::GM_DENSE_I64_RETURN,
                "Case4 GM int64 dense, with return value, target_count=12288 (1 thread/addr)"};
        case 14:
            return {
                48, 256, 1024, KernelType::GM_DENSE_I64_RETURN,
                "Case4 GM int64 dense, with return value, target_count=1024 (12 threads/addr)"};
        case 15:
            return {
                48, 256, 32, KernelType::GM_DENSE_I64_RETURN,
                "Case4 GM int64 dense, with return value, target_count=32 (384 threads/addr)"};
        case 16:
            return {
                48, 256, 1, KernelType::GM_DENSE_I64_RETURN,
                "Case4 GM int64 dense, with return value, target_count=1 (12288 threads/addr)"};
        case 17:
            return {48, 256, 1024, KernelType::GM_DENSE_I32_NO_RETURN, "Case5 GM int32 dense, no return value"};
        case 18:
            return {48, 256, 1024, KernelType::GM_DENSE_I64_NO_RETURN, "Case5 GM int64 dense, no return value"};
        case 19:
            return {48, 256, 1024, KernelType::GM_DENSE_I32_RETURN, "Case5 GM int32 dense, with return value"};
        case 20:
            return {48, 256, 1024, KernelType::GM_DENSE_I64_RETURN, "Case5 GM int64 dense, with return value"};
        default:
            return {1, 2048, 0, KernelType::GM_SINGLE_NO_RETURN, "unknown"};
    }
}

bool is_dense(KernelType k)
{
    return k == KernelType::GM_DENSE_I32_NO_RETURN || k == KernelType::GM_DENSE_I64_NO_RETURN ||
           k == KernelType::GM_DENSE_I32_RETURN || k == KernelType::GM_DENSE_I64_RETURN;
}

bool is_i64(KernelType k) { return k == KernelType::GM_DENSE_I64_NO_RETURN || k == KernelType::GM_DENSE_I64_RETURN; }

bool writes_gm_result(KernelType k) { return k != KernelType::UB_LOCAL_NO_RETURN && k != KernelType::UB_LOCAL_RETURN; }

} // namespace

void check_acl(aclError result, const char* const func, const char* const file, int const line)
{
    if (result != ACL_SUCCESS) {
        std::fprintf(
            stderr, "ACL error at %s:%d code=%d(%s) \"%s\"\n", file, line, (int)result, aclGetRecentErrMsg(), func);
        std::exit(EXIT_FAILURE);
    }
}

void check_acl_launch(const char* kernel_name, const char* const file, int const line)
{
    const aclError result = aclrtGetLastError(ACL_RT_THREAD_LEVEL);
    if (result != ACL_SUCCESS) {
        std::fprintf(
            stderr, "ACL error at %s:%d kernel=\"%s\" code=%d(%s)\n", file, line, kernel_name, (int)result,
            aclGetRecentErrMsg());
        std::exit(EXIT_FAILURE);
    }
}

#define CHECK_ACL(val) check_acl((val), #val, __FILE__, __LINE__)
#define CHECK_ACL_LAUNCH(kernel_name) check_acl_launch((kernel_name), __FILE__, __LINE__)

// ---------------------------------------------------------------------------
// Case 1 / 2 / 3 -- single GM address.
// Every thread does one asc_atomic_add on the SAME gm counter, so the counter
// is contended by all (blocks x threads) threads at once: maximum contention.
// ---------------------------------------------------------------------------
__global__ __launch_bounds__(MAX_THREADS_PER_BLOCK) void atomic_add_gm_single_return(int32_t* counter)
{
    volatile int32_t old_value_sink = asc_atomic_add(counter, 1);
    (void)old_value_sink;
}

__global__ __launch_bounds__(MAX_THREADS_PER_BLOCK) void atomic_add_gm_single_no_return(int32_t* counter)
{
    asc_atomic_add(counter, 1);
}

// ---------------------------------------------------------------------------
// Case 1 / 3 -- single UB address.
// These kernels only call asc_atomic_add on UB and do not write a result back
// to GM. They are pure interface-call workloads for memory-tier and return-
// value comparisons.
// ---------------------------------------------------------------------------
__global__ __launch_bounds__(MAX_THREADS_PER_BLOCK) void atomic_add_ub_local_return()
{
    __ubuf__ int32_t local[1];
    volatile int32_t old_value_sink = asc_atomic_add(&local[0], 1);
    (void)old_value_sink;
}

__global__ __launch_bounds__(MAX_THREADS_PER_BLOCK) void atomic_add_ub_local_no_return()
{
    __ubuf__ int32_t local[1];
    asc_atomic_add(&local[0], 1);
}

// ---------------------------------------------------------------------------
// Case 2 -- block-local UB accumulation before GM writeback.
// Each block accumulates into one private UB counter, then thread 0 adds the
// block subtotal into the single shared GM result. GM atomics drop from
// (blocks x threads) down to blocks.
// ---------------------------------------------------------------------------
__global__ __launch_bounds__(MAX_THREADS_PER_BLOCK) void atomic_add_ub_block_accum_no_return(int32_t* gm_result)
{
    __ubuf__ int32_t local[1];
    if (threadIdx.x == 0) {
        local[0] = 0;
    }
    asc_syncthreads();

    asc_atomic_add(&local[0], 1);
    asc_syncthreads();

    if (threadIdx.x == 0) {
        asc_atomic_add(gm_result, local[0]);
    }
}

// ---------------------------------------------------------------------------
// Case 4 / 5 / 6 -- dense counters over a shared target pool.
// Each thread maps to a target via (globalTid % target_count). With fewer
// targets than threads, several threads contend for the same address: real
// same-address contention. Targets stay packed tightly, so the cacheline-
// packing effect (32 int32 vs 16 int64 targets per 128B line) is present on
// top of the contention. Case 4 sweeps target_count to vary contention
// intensity; Case 5/6 fix target_count = 1024 and compare int32 vs int64.
// ---------------------------------------------------------------------------
__global__ __launch_bounds__(MAX_THREADS_PER_BLOCK) void atomic_add_gm_dense_i32_no_return(
    int32_t* counters, uint64_t target_count)
{
    asc_atomic_add(counters + ((blockIdx.x * blockDim.x + threadIdx.x) % target_count), 1);
}

__global__ __launch_bounds__(MAX_THREADS_PER_BLOCK) void atomic_add_gm_dense_i64_no_return(
    int64_t* counters, uint64_t target_count)
{
    asc_atomic_add(counters + ((blockIdx.x * blockDim.x + threadIdx.x) % target_count), 1LL);
}

__global__ __launch_bounds__(MAX_THREADS_PER_BLOCK) void atomic_add_gm_dense_i32_return(
    int32_t* counters, uint64_t target_count)
{
    volatile int32_t old_value_sink =
        asc_atomic_add(counters + ((blockIdx.x * blockDim.x + threadIdx.x) % target_count), 1);
    (void)old_value_sink;
}

__global__ __launch_bounds__(MAX_THREADS_PER_BLOCK) void atomic_add_gm_dense_i64_return(
    int64_t* counters, uint64_t target_count)
{
    volatile int64_t old_value_sink =
        asc_atomic_add(counters + ((blockIdx.x * blockDim.x + threadIdx.x) % target_count), 1LL);
    (void)old_value_sink;
}

// Dispatch the kernel selected by config. A single runtime switch replaces the
// old per-scenario #if/#elif chain.
void run_selected_kernel(aclrtStream stream, const ScenarioConfig& config, int32_t* gm_i32, int64_t* gm_i64)
{
    switch (config.kernel) {
        case KernelType::GM_SINGLE_NO_RETURN:
            atomic_add_gm_single_no_return<<<config.blocks, config.threads, 0, stream>>>(gm_i32);
            CHECK_ACL_LAUNCH("atomic_add_gm_single_no_return");
            break;
        case KernelType::GM_SINGLE_RETURN:
            atomic_add_gm_single_return<<<config.blocks, config.threads, 0, stream>>>(gm_i32);
            CHECK_ACL_LAUNCH("atomic_add_gm_single_return");
            break;
        case KernelType::UB_LOCAL_NO_RETURN:
            atomic_add_ub_local_no_return<<<config.blocks, config.threads, 0, stream>>>();
            CHECK_ACL_LAUNCH("atomic_add_ub_local_no_return");
            break;
        case KernelType::UB_LOCAL_RETURN:
            atomic_add_ub_local_return<<<config.blocks, config.threads, 0, stream>>>();
            CHECK_ACL_LAUNCH("atomic_add_ub_local_return");
            break;
        case KernelType::UB_BLOCK_ACCUM_NO_RETURN:
            atomic_add_ub_block_accum_no_return<<<config.blocks, config.threads, 0, stream>>>(gm_i32);
            CHECK_ACL_LAUNCH("atomic_add_ub_block_accum_no_return");
            break;
        case KernelType::GM_DENSE_I32_NO_RETURN:
            atomic_add_gm_dense_i32_no_return<<<config.blocks, config.threads, 0, stream>>>(
                gm_i32, config.target_count);
            CHECK_ACL_LAUNCH("atomic_add_gm_dense_i32_no_return");
            break;
        case KernelType::GM_DENSE_I64_NO_RETURN:
            atomic_add_gm_dense_i64_no_return<<<config.blocks, config.threads, 0, stream>>>(
                gm_i64, config.target_count);
            CHECK_ACL_LAUNCH("atomic_add_gm_dense_i64_no_return");
            break;
        case KernelType::GM_DENSE_I32_RETURN:
            atomic_add_gm_dense_i32_return<<<config.blocks, config.threads, 0, stream>>>(gm_i32, config.target_count);
            CHECK_ACL_LAUNCH("atomic_add_gm_dense_i32_return");
            break;
        case KernelType::GM_DENSE_I64_RETURN:
            atomic_add_gm_dense_i64_return<<<config.blocks, config.threads, 0, stream>>>(gm_i64, config.target_count);
            CHECK_ACL_LAUNCH("atomic_add_gm_dense_i64_return");
            break;
    }
    CHECK_ACL(aclrtSynchronizeStream(stream));
}

// File-scope buffers keep the dense target arrays off the stack. Only the dense
// scenarios use the full arrays; single/accumulation scenarios use element [0].
static int32_t g_raw_i32[MAX_TARGET_COUNT];
static int64_t g_raw_i64[MAX_TARGET_COUNT];

// Single-address / block-local accumulation: one counter holds every atomic add.
static bool check_single_total(uint64_t actual, uint64_t expected)
{
    if (actual != expected) {
        std::fprintf(stderr, "Validation failed: counter=%lu expected=%lu\n", actual, expected);
        return false;
    }
    return true;
}

// Dense: threads map to targets via (globalTid % target_count). Target i is hit
// by every thread whose global id is congruent to i modulo target_count, i.e.
// floor(T/N) threads, plus one more for the first (T % N) targets. The counts
// must match exactly and sum to the total atomic adds.
static bool check_dense_counts(
    const int64_t* counts, uint64_t target_count, uint64_t total_threads, uint64_t total_atomic_adds)
{
    const uint64_t base = total_threads / target_count;
    const uint64_t rem = total_threads % target_count;
    uint64_t total = 0;
    for (uint64_t i = 0; i < target_count; ++i) {
        const uint64_t expected = base + (i < rem ? 1 : 0);
        const uint64_t actual = (uint64_t)counts[i];
        if (actual != expected) {
            std::fprintf(stderr, "Validation failed: counter[%lu]=%lu expected=%lu\n", i, actual, expected);
            return false;
        }
        total += actual;
    }
    if (total != total_atomic_adds) {
        std::fprintf(stderr, "Validation failed: total=%lu expected=%lu\n", total, total_atomic_adds);
        return false;
    }
    return true;
}

bool validate_result(
    const ScenarioConfig& config, int32_t* gm_i32, int64_t* gm_i64, uint64_t total_threads, uint64_t total_atomic_adds)
{
    if (!is_dense(config.kernel)) {
        // Single-address / block-local accumulation: one int32 counter holds every atomic add.
        int32_t counter = 0;
        CHECK_ACL(aclrtMemcpy(&counter, sizeof(counter), gm_i32, sizeof(counter), ACL_MEMCPY_DEVICE_TO_HOST));
        return check_single_total((uint64_t)counter, total_atomic_adds);
    }
    if (!is_i64(config.kernel)) {
        // Dense int32: widen to int64 to reuse check_dense_counts.
        const uint64_t bytes = config.target_count * sizeof(int32_t);
        CHECK_ACL(aclrtMemcpy(g_raw_i32, bytes, gm_i32, bytes, ACL_MEMCPY_DEVICE_TO_HOST));
        for (uint64_t i = 0; i < config.target_count; ++i) {
            g_raw_i64[i] = (int64_t)g_raw_i32[i];
        }
        return check_dense_counts(g_raw_i64, config.target_count, total_threads, total_atomic_adds);
    }
    // Dense int64.
    const uint64_t bytes = config.target_count * sizeof(int64_t);
    CHECK_ACL(aclrtMemcpy(g_raw_i64, bytes, gm_i64, bytes, ACL_MEMCPY_DEVICE_TO_HOST));
    return check_dense_counts(g_raw_i64, config.target_count, total_threads, total_atomic_adds);
}

int main()
{
    const ScenarioConfig config = get_scenario_config(SCENARIO_NUM);
    // Every thread does exactly one atomic add, so the total equals the thread count.
    const uint64_t total_threads = (uint64_t)config.blocks * config.threads;
    const uint64_t total_atomic_adds = total_threads;

    // GM result counters accumulate total_atomic_adds and must fit int32.
    if (writes_gm_result(config.kernel) && !is_dense(config.kernel) && total_atomic_adds > (uint64_t)INT32_MAX) {
        std::fprintf(
            stderr, "single-address counter must not overflow int32 (total_atomic_adds=%lu)\n", total_atomic_adds);
        return EXIT_FAILURE;
    }

    std::printf("Scenario %u: %s\n", (uint32_t)SCENARIO_NUM, config.name);
    std::printf(
        "Workload: blocks=%u threads_per_block=%u total_atomic_adds=%lu\n", config.blocks, config.threads,
        total_atomic_adds);

    CHECK_ACL(aclInit(nullptr));
    CHECK_ACL(aclrtSetDevice(0));

    aclrtStream stream = nullptr;
    int32_t* gm_i32 = nullptr;
    int64_t* gm_i64 = nullptr;
    CHECK_ACL(aclrtCreateStream(&stream));

    if (!is_i64(config.kernel)) {
        // int32 path: single/accumulation use one counter, dense use target_count counters.
        const uint64_t count = is_dense(config.kernel) ? config.target_count : 1;
        const uint64_t i32_bytes = count * sizeof(int32_t);
        CHECK_ACL(aclrtMalloc((void**)(&gm_i32), i32_bytes, ACL_MEM_MALLOC_HUGE_FIRST));
        CHECK_ACL(aclrtMemset(gm_i32, i32_bytes, 0, i32_bytes));
    } else {
        const uint64_t i64_bytes = config.target_count * sizeof(int64_t);
        CHECK_ACL(aclrtMalloc((void**)(&gm_i64), i64_bytes, ACL_MEM_MALLOC_HUGE_FIRST));
        CHECK_ACL(aclrtMemset(gm_i64, i64_bytes, 0, i64_bytes));
    }

    run_selected_kernel(stream, config, gm_i32, gm_i64);

#if SKIP_VALIDATION
    const bool matched = true;
    std::printf("Validation skipped\n");
#else
    const bool matched =
        !writes_gm_result(config.kernel) || validate_result(config, gm_i32, gm_i64, total_threads, total_atomic_adds);
    if (!writes_gm_result(config.kernel)) {
        std::printf("Validation skipped: UB-only scenario has no GM result\n");
    } else {
        std::printf("%s\n", matched ? "Validation passed" : "Validation failed");
    }
#endif

    if (gm_i64 != nullptr) {
        aclrtFree(gm_i64);
    }
    if (gm_i32 != nullptr) {
        aclrtFree(gm_i32);
    }
    if (stream != nullptr) {
        aclrtDestroyStream(stream);
    }
    CHECK_ACL(aclrtResetDevice(0));
    CHECK_ACL(aclFinalize());
    return matched ? EXIT_SUCCESS : EXIT_FAILURE;
}
