/*!
 * \file sobel_warp_shfl.asc
 * \brief
 */

#include <algorithm>
#include <cmath>
#include <cstdint>
#include <cstdio>
#include <vector>
#include "acl/acl.h"
#include "simt_api/asc_simt.h"

namespace {
constexpr int IMAGE_WIDTH = 1023;
constexpr int IMAGE_HEIGHT = 1025;
constexpr uint16_t THRESHOLD = 200;
constexpr uint32_t WARP_SIZE = 32;
constexpr uint32_t THREAD_COUNT = 2048;
} // namespace

struct EdgePixel {
    uint16_t x, y, strength;
};

__global__ __launch_bounds__(THREAD_COUNT) void sobel_edge_detect(
    EdgePixel *edge_list,
    uint32_t *edge_count,
    const uint8_t *input,
    int width, int height)
{
    uint32_t idx = blockIdx.x * blockDim.x + threadIdx.x;
    int lane_id = laneid(); // 线程在warp内的lane编号（0~31）
    int warp_id = idx / warpSize; // 线程所在的warp编号
    int tiles_x = (width + warpSize - 1) / warpSize;    // 图像宽度方向按warp分块的块数（每块32列）
    int x = (warp_id % tiles_x) * warpSize + lane_id;   // 像素列号：当前warp在横向的起始位置 + warp内偏移，保证同warp同行
    int y = warp_id / tiles_x;                          // 像素行号：第几行warp

    bool in_image = (x < width && y < height);

    uint16_t strength = 0;
    if (y > 0 && y < height - 1) { // 排除首尾行
        // 第一步：每个线程读取自身对应列的上、中、下三行像素值
        int top = in_image ? input[(y - 1) * width + x] : 0;
        int mid = in_image ? input[y * width + x] : 0;
        int bot = in_image ? input[(y + 1) * width + x] : 0;

        // 第二步：通过warp shuffle获取左右邻居列的像素数据，避免额外的Global Memory访存
        int shfl_top_left = asc_shfl_up(top, 1, warpSize);     // 从lane_id-1获取其top值 → 作为自己的左邻top
        int shfl_top_right = asc_shfl_down(top, 1, warpSize);   // 从lane_id+1获取其top值 → 作为自己的右邻top
        int shfl_mid_left = asc_shfl_up(mid, 1, warpSize);
        int shfl_mid_right = asc_shfl_down(mid, 1, warpSize);
        int shfl_bot_left = asc_shfl_up(bot, 1, warpSize);
        int shfl_bot_right = asc_shfl_down(bot, 1, warpSize);

        if (in_image && x > 0 && x < width - 1) { // 排除首尾列
            // 第三步：warp边界处（lane_id=0/31）shuffle拿不到warp外像素数据，需直接访问Global Memory
            int top_left = (lane_id == 0) ? input[(y - 1) * width + (x - 1)] : shfl_top_left;
            int top_right = (lane_id == 31) ? input[(y - 1) * width + (x + 1)] : shfl_top_right;
            int mid_left = (lane_id == 0) ? input[y * width + (x - 1)] : shfl_mid_left;
            int mid_right = (lane_id == 31) ? input[y * width + (x + 1)] : shfl_mid_right;
            int bot_left = (lane_id == 0) ? input[(y + 1) * width + (x - 1)] : shfl_bot_left;
            int bot_right = (lane_id == 31) ? input[(y + 1) * width + (x + 1)] : shfl_bot_right;

            // 第四步：用完整的3×3邻域计算Sobel水平梯度Gx和垂直梯度Gy
            int gx = -top_left + top_right - 2 * mid_left + 2 * mid_right - bot_left + bot_right;
            int gy = -top_left - 2 * top - top_right + bot_left + 2 * bot + bot_right;
            strength = static_cast<uint16_t>(abs(gx) + abs(gy)); // 梯度强度 = |Gx| + |Gy|
        }
    }

    // edge_mask记录当前warp内的边缘像素筛选结果，第i位为1表示lane i对应像素满足阈值条件。
    uint32_t edge_mask = asc_ballot(strength >= THRESHOLD);

    // 当前warp没有边缘像素时直接返回，避免执行无效的原子加。
    if (edge_mask == 0) {
        return;
    }

    // lane_id 0通过一次原子加为整个warp申请输出位置。
    // 如果不使用ballot，每个边缘像素都需要单独执行原子加，最多会增加32倍原子操作。
    uint32_t warp_base = 0;
    if (lane_id == 0) {
        warp_base = asc_atomic_add(edge_count, static_cast<uint32_t>(__popc(edge_mask)));
    }
    // 将lane 0申请到的起始位置广播给warp内其他lane。
    warp_base = asc_shfl(warp_base, 0, warpSize);

    if (edge_mask & lanemask_eq()) {                        // lanemask_eq()只保留当前lane对应的bit，用于判断当前lane是否为边缘像素。
        // 当前边缘像素的局部偏移等于本warp内lane编号更小的边缘像素数量。
        uint32_t lower_mask = edge_mask & lanemask_lt();    // lanemask_lt()生成当前lane之前所有lane的掩码，与edge_mask相与后只保留前序边缘lane。
        int local_idx = __popc(lower_mask);                 // 统计前序边缘lane数量，作为当前边缘像素在本warp紧凑输出中的偏移。
        edge_list[warp_base + local_idx] = {
            static_cast<uint16_t>(x),
            static_cast<uint16_t>(y),
            strength
        };
    }
}

uint16_t sobel_pixel(const std::vector<uint8_t> &input, int width, int x, int y)
{
    int tl = input[(y - 1) * width + (x - 1)];
    int t = input[(y - 1) * width + x];
    int tr = input[(y - 1) * width + (x + 1)];
    int ml = input[y * width + (x - 1)];
    int mr = input[y * width + (x + 1)];
    int bl = input[(y + 1) * width + (x - 1)];
    int b = input[(y + 1) * width + x];
    int br = input[(y + 1) * width + (x + 1)];
    int gx = -tl + tr - 2 * ml + 2 * mr - bl + br;
    int gy = -tl - 2 * t - tr + bl + 2 * b + br;
    return static_cast<uint16_t>(std::abs(gx) + std::abs(gy));
}

std::vector<EdgePixel> sobel_ref(const std::vector<uint8_t> &input, int width, int height)
{
    std::vector<EdgePixel> out;
    for (int y = 1; y < height - 1; ++y) {
        for (int x = 1; x < width - 1; ++x) {
            uint16_t s = sobel_pixel(input, width, x, y);
            if (s >= THRESHOLD) {
                out.push_back({
                    static_cast<uint16_t>(x),
                    static_cast<uint16_t>(y),
                    s
                });
            }
        }
    }
    return out;
}

struct CompactResult {
    std::vector<EdgePixel> edge_list;
    uint32_t edge_count;
};

CompactResult launch_sobel(const std::vector<uint8_t> &input, int width, int height)
{
    uint64_t pixels = static_cast<uint64_t>(width) * height;
    uint32_t tiles_x = (static_cast<uint32_t>(width) + WARP_SIZE - 1) / WARP_SIZE;
    uint32_t total_threads = tiles_x * static_cast<uint32_t>(height) * WARP_SIZE;
    size_t input_byte_size = pixels * sizeof(uint8_t);
    size_t list_byte_size = pixels * sizeof(EdgePixel);
    size_t count_byte_size = sizeof(uint32_t);

    int32_t device_id = 0;
    aclrtStream stream = nullptr;

    uint8_t *input_device = nullptr;
    EdgePixel *list_device = nullptr;
    uint32_t *count_device = nullptr;
    EdgePixel *list_host = nullptr;
    uint32_t count_host = 0;

    aclInit(nullptr);
    aclrtSetDevice(device_id);
    aclrtCreateStream(&stream);

    aclrtMallocHost(reinterpret_cast<void **>(&list_host), list_byte_size);
    aclrtMalloc(reinterpret_cast<void **>(&input_device), input_byte_size, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc(reinterpret_cast<void **>(&list_device), list_byte_size, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc(reinterpret_cast<void **>(&count_device), count_byte_size, ACL_MEM_MALLOC_HUGE_FIRST);

    aclrtMemcpy(input_device, input_byte_size, input.data(), input_byte_size, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemset(count_device, count_byte_size, 0, count_byte_size);

    uint32_t threads_per_block = THREAD_COUNT;
    uint32_t blocks_per_grid = (total_threads + threads_per_block - 1) / threads_per_block;

    sobel_edge_detect<<<blocks_per_grid, threads_per_block, 0, stream>>>(
        list_device, count_device, input_device, width, height);
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(&count_host, count_byte_size, count_device, count_byte_size, ACL_MEMCPY_DEVICE_TO_HOST);
    if (count_host > 0) {
        aclrtMemcpy(list_host, static_cast<size_t>(count_host) * sizeof(EdgePixel),
                    list_device, static_cast<size_t>(count_host) * sizeof(EdgePixel), ACL_MEMCPY_DEVICE_TO_HOST);
    }

    std::vector<EdgePixel> result(list_host, list_host + count_host);

    aclrtFree(input_device);
    aclrtFree(list_device);
    aclrtFree(count_device);
    aclrtFreeHost(list_host);

    const char *err = aclGetRecentErrMsg();
    if (err != nullptr) {
        fprintf(stderr, "%s\n", err);
    }

    aclrtDestroyStream(stream);
    aclrtResetDevice(device_id);
    aclFinalize();

    return {result, count_host};
}

bool edge_pixel_less(const EdgePixel &lhs, const EdgePixel &rhs)
{
    if (lhs.y != rhs.y) {
        return lhs.y < rhs.y;
    }
    if (lhs.x != rhs.x) {
        return lhs.x < rhs.x;
    }
    return lhs.strength < rhs.strength;
}

bool edge_pixel_equal(const EdgePixel &lhs, const EdgePixel &rhs)
{
    return lhs.x == rhs.x && lhs.y == rhs.y && lhs.strength == rhs.strength;
}

uint32_t verify_result(const std::vector<EdgePixel> &edge_list, uint32_t edge_count,
    const std::vector<EdgePixel> &golden)
{
    if (edge_count != golden.size()) {
        printf("[Failed] Case accuracy is verification failed! edge count mismatch\n");
        return 1;
    }

    std::vector<EdgePixel> actual(edge_list.begin(), edge_list.begin() + edge_count);
    std::vector<EdgePixel> expected = golden;
    std::sort(actual.begin(), actual.end(), edge_pixel_less);
    std::sort(expected.begin(), expected.end(), edge_pixel_less);

    if (std::equal(actual.begin(), actual.end(), expected.begin(), edge_pixel_equal)) {
        printf("[Success] Case accuracy is verification passed.\n");
        return 0;
    }
    printf("[Failed] Case accuracy is verification failed!\n");
    return 1;
}

void fill_input(std::vector<uint8_t> &input, int width, int height)
{
    for (int y = 0; y < height; ++y) {
        for (int x = 0; x < width; ++x) {
            input[y * width + x] = static_cast<uint8_t>((x * 3 + y * 5 + (x ^ y) / 8) & 255);
        }
    }
}

void print_compact_result(const std::vector<EdgePixel> &edge_list, uint32_t edge_count,
    int width, int height, int print_n)
{
    uint64_t pixels = static_cast<uint64_t>(width) * height;
    printf("=== compact edge list ===\n");
    printf("total pixels: %llu  edge pixels: %u  ratio: %.1f%%\n",
        static_cast<unsigned long long>(pixels), edge_count, 100.0 * edge_count / pixels);
    printf("first %d entries:\n", print_n);
    printf("%-6s %-6s %-10s\n", "x", "y", "strength");
    uint32_t n = (edge_count < static_cast<uint32_t>(print_n)) ? edge_count : static_cast<uint32_t>(print_n);
    for (uint32_t i = 0; i < n; ++i) {
        printf("%-6u %-6u %-10u\n", edge_list[i].x, edge_list[i].y, edge_list[i].strength);
    }
}

int32_t main()
{
    int width = IMAGE_WIDTH;
    int height = IMAGE_HEIGHT;

    printf("Image: %dx%d  threshold: %u\n", width, height, THRESHOLD);

    uint64_t pixels = static_cast<uint64_t>(width) * height;
    std::vector<uint8_t> input(pixels);
    fill_input(input, width, height);

    std::vector<EdgePixel> golden = sobel_ref(input, width, height);
    CompactResult result = launch_sobel(input, width, height);

    print_compact_result(result.edge_list, result.edge_count, width, height, 10);

    return verify_result(result.edge_list, result.edge_count, golden);
}
