/* !
 * \file sync_barrier.asc
 * \brief SIMT single-block reduction sample using thread block synchronization.
 */

#include <iostream>
#include <vector>
#include "acl/acl.h"
#include "simt_api/asc_simt.h"

namespace {
constexpr uint32_t THREAD_COUNT = 1024;
}

__global__ __launch_bounds__(THREAD_COUNT) void kernel_sync_barrier(
    float* input, float* output, uint32_t input_total_length)
{
    extern __ubuf__ float smem[];
    uint32_t tid = threadIdx.x;
    uint32_t lane_id = laneid();
    uint32_t warp_id = tid / warpSize;

    float val = (tid < input_total_length) ? input[tid] : 0.0f;

    // warp内归约，asc_reduce_add返回当前warp所有线程val的总和
    val = asc_reduce_add(val);
    // 仅首线程写入共享内存
    if (lane_id == 0) {
        smem[warp_id] = val;
    }

    asc_syncthreads(); // 跨warp同步

    if (tid == 0) {
        for (int i = 1; i < blockDim.x / warpSize; i++) {
            val += smem[i];
        }
        *output = val;
    }
}

uint32_t verify_result(float output, float golden)
{
    std::cout << "Output: " << output << std::endl;
    std::cout << "Golden: " << golden << std::endl;

    float abs_err = std::abs(output - golden);
    float rel_err = abs_err / std::abs(golden);

    if (abs_err < 1e-4f && rel_err < 1e-4f) {
        std::cout << "[Success] Case accuracy verification passed." << std::endl;
        return 0;
    } else {
        std::cout << "[Failed] Case accuracy verification failed!" << std::endl;
        return 1;
    }
}

int32_t main(int32_t argc, char* argv[])
{
    constexpr uint32_t input_total_length = 1024;
    uint32_t blocks_per_grid = 1;
    size_t input_total_byte_size = input_total_length * sizeof(float);
    size_t output_total_byte_size = blocks_per_grid * sizeof(float);

    std::vector<float> input(input_total_length);
    for (uint32_t i = 0; i < input_total_length; i++) {
        input[i] = i % 10;
    }

    int32_t device_id = 0;
    aclrtStream stream = nullptr;

    uint8_t* input_host = reinterpret_cast<uint8_t*>(input.data());
    uint8_t* output_host = nullptr;
    float* input_device = nullptr;
    float* output_device = nullptr;

    aclInit(nullptr);
    aclrtSetDevice(device_id);
    aclrtCreateStream(&stream);

    aclrtMallocHost((void**)&output_host, output_total_byte_size);
    aclrtMalloc((void**)&input_device, input_total_byte_size, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&output_device, output_total_byte_size, ACL_MEM_MALLOC_HUGE_FIRST);

    aclrtMemcpy(input_device, input_total_byte_size, input_host, input_total_byte_size, ACL_MEMCPY_HOST_TO_DEVICE);

    uint32_t threads_per_block = THREAD_COUNT;
    uint32_t dyn_ubuf_size = threads_per_block * sizeof(float) / 32;
    kernel_sync_barrier<<<blocks_per_grid, threads_per_block, dyn_ubuf_size, stream>>>(
        input_device, output_device, input_total_length);
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(output_host, output_total_byte_size, output_device, output_total_byte_size, ACL_MEMCPY_DEVICE_TO_HOST);
    float output = *reinterpret_cast<float*>(output_host);

    aclrtFree(input_device);
    aclrtFree(output_device);

    const char* err = aclGetRecentErrMsg();
    if (err != nullptr) {
        fprintf(stderr, "%s\n", err);
    }

    aclrtDestroyStream(stream);
    aclrtResetDevice(device_id);
    aclFinalize();

    // Host侧校验
    constexpr uint32_t WARP_SIZE = 32;
    constexpr uint32_t warp_count = THREAD_COUNT / WARP_SIZE;
    std::vector<float> reduce_buf(input);

    for (uint32_t w = 0; w < warp_count; w++) {
        uint32_t base = w * WARP_SIZE;
        for (uint32_t s = 1; s < WARP_SIZE; s <<= 1) {
            for (uint32_t i = 0; i < WARP_SIZE; i += 2 * s) {
                reduce_buf[base + i] += reduce_buf[base + i + s];
            }
        }
    }

    float golden = reduce_buf[0];
    for (uint32_t i = 1; i < warp_count; i++) {
        golden += reduce_buf[i * WARP_SIZE];
    }

    return verify_result(output, golden);
}
