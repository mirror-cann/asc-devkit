/* !
 * \file memory_fence.asc
 * \brief SIMT multi-block reduction sample using thread fence synchronization.
 */

#include <iostream>
#include <vector>
#include "acl/acl.h"
#include "simt_api/asc_simt.h"

namespace {
constexpr uint32_t THREAD_COUNT = 1024;
}

__aicore__ inline void block_reduce(float* smem, uint32_t tid, float val)
{
    uint32_t lane_id = laneid();
    uint32_t warp_id = tid / warpSize;

    // warp内归约，asc_reduce_add返回当前warp所有线程val的总和
    val = asc_reduce_add(val);
    // 仅首线程写入共享内存
    if (lane_id == 0) {
        smem[warp_id] = val;
    }

    asc_syncthreads(); // 跨warp同步

    // block级顺序累加
    if (tid == 0) {
        for (uint32_t i = 1; i < blockDim.x / warpSize; i++) {
            val += smem[i];
        }
        smem[0] = val;
    }
}

__global__ void __launch_bounds__(THREAD_COUNT)
    kernel_memory_fence(float* input, float* block_sums, float* output, uint32_t* counter, uint32_t input_total_length)
{
    extern __ubuf__ float smem[];
    __ubuf__ uint32_t is_last;
    uint32_t tid = threadIdx.x;
    uint32_t idx = blockIdx.x * blockDim.x + threadIdx.x;

    float val = (idx < input_total_length) ? input[idx] : 0.0f;

    // 每个block内部归约，得到该block的和
    block_reduce(smem, tid, val);

    if (tid == 0) {
        block_sums[blockIdx.x] = smem[0];
    }

    // 确保当前block对block_sums的写入对其他block可见
    asc_threadfence();

    if (tid == 0) {
        uint32_t ticket = asc_atomic_add(counter, 1);
        is_last = (ticket == gridDim.x - 1);
    }

    // block内同步：将is_last标志从0号线程广播到该block的所有线程
    asc_syncthreads();

    // 最后一个block负责全局归约：将所有block的部分和汇总为最终结果
    if (is_last) {
        float my_sum = 0; // 当前线程负责累加的block部分和
        // 每个线程以blockDim.x为步长遍历block_sums数组，
        for (uint32_t i = tid; i < gridDim.x; i += blockDim.x) {
            my_sum += block_sums[i];
        }
        // 对my_sum做block内部归约，得到所有block部分和的总和
        block_reduce(smem, tid, my_sum);

        if (tid == 0) {
            output[0] = smem[0];
        }
    }
}

uint32_t verify_result(float output, float golden)
{
    std::cout << "Output: " << output << std::endl;
    std::cout << "Golden: " << golden << std::endl;

    float abs_err = std::abs(output - golden);
    float rel_err = abs_err / std::abs(golden);

    if (abs_err < 1e-4f && rel_err < 1e-4f) {
        std::cout << "[Success] Case accuracy is verification passed." << std::endl;
        return 0;
    } else {
        std::cout << "[Failed] Case accuracy is verification failed!" << std::endl;
        return 1;
    }
}

float host_block_reduce(std::vector<float>& data, uint32_t WARP_SIZE, uint32_t thread_count)
{
    uint32_t warp_count = thread_count / WARP_SIZE;

    // warp内直接求和
    std::vector<float> warp_sums(warp_count, 0.0f);
    for (uint32_t w = 0; w < warp_count; w++) {
        uint32_t base = w * WARP_SIZE;
        for (uint32_t lane = 0; lane < WARP_SIZE; lane++) {
            warp_sums[w] += data[base + lane];
        }
    }

    // 顺序累加
    float result = warp_sums[0];
    for (uint32_t i = 1; i < warp_count; i++) {
        result += warp_sums[i];
    }

    return result;
}

int32_t main(int32_t argc, char* argv[])
{
    constexpr uint32_t input_total_length = 1024 * 1024;

    uint32_t threads_per_block = THREAD_COUNT;
    uint32_t dyn_ubuf_size = threads_per_block / 32 * sizeof(float);
    uint32_t blocks_per_grid = (input_total_length + threads_per_block - 1) / threads_per_block;

    size_t input_total_byte_size = input_total_length * sizeof(float);
    size_t block_sums_total_byte_size = blocks_per_grid * sizeof(float);
    size_t output_total_byte_size = 1 * sizeof(float);

    std::vector<float> input(input_total_length);
    for (uint32_t i = 0; i < input_total_length; i++) {
        input[i] = i % 10;
    }

    int32_t device_id = 0;
    aclrtStream stream = nullptr;

    uint8_t* input_host = reinterpret_cast<uint8_t*>(input.data());
    uint8_t* output_host = nullptr;
    float* input_device = nullptr;
    float* block_sums_device = nullptr;
    float* output_device = nullptr;
    uint32_t* counter_device = nullptr; // 原子计数器，用于判断最后一个完成的block

    aclInit(nullptr);
    aclrtSetDevice(device_id);
    aclrtCreateStream(&stream);

    aclrtMallocHost((void**)&output_host, output_total_byte_size);
    aclrtMalloc((void**)&input_device, input_total_byte_size, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&block_sums_device, block_sums_total_byte_size, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&output_device, output_total_byte_size, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&counter_device, sizeof(uint32_t), ACL_MEM_MALLOC_HUGE_FIRST);

    // 将counter初始化为0
    uint32_t init_count = 0;
    aclrtMemcpy(counter_device, sizeof(uint32_t), &init_count, sizeof(uint32_t), ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(input_device, input_total_byte_size, input_host, input_total_byte_size, ACL_MEMCPY_HOST_TO_DEVICE);

    kernel_memory_fence<<<blocks_per_grid, threads_per_block, dyn_ubuf_size, stream>>>(
        input_device, block_sums_device, output_device, counter_device, input_total_length);
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(output_host, output_total_byte_size, output_device, output_total_byte_size, ACL_MEMCPY_DEVICE_TO_HOST);
    float output = *reinterpret_cast<float*>(output_host);

    aclrtFree(input_device);
    aclrtFree(block_sums_device);
    aclrtFree(output_device);
    aclrtFree(counter_device);

    const char* err = aclGetRecentErrMsg();
    if (err != nullptr) {
        fprintf(stderr, "%s\n", err);
    }

    aclrtDestroyStream(stream);
    aclrtResetDevice(device_id);
    aclFinalize();

    // Host侧校验
    uint32_t WARP_SIZE = 32;

    std::vector<float> host_block_sums(blocks_per_grid);
    for (uint32_t b = 0; b < blocks_per_grid; b++) {
        uint32_t base = b * threads_per_block;
        std::vector<float> reduce_buf(input.begin() + base, input.begin() + base + threads_per_block);
        host_block_sums[b] = host_block_reduce(reduce_buf, WARP_SIZE, threads_per_block);
    }

    std::vector<float> grid_partial(threads_per_block, 0.0f);
    for (uint32_t tid = 0; tid < threads_per_block; tid++) {
        float my_sum = 0;
        for (uint32_t i = tid; i < blocks_per_grid; i += threads_per_block) {
            my_sum += host_block_sums[i];
        }
        grid_partial[tid] = my_sum;
    }

    float golden = host_block_reduce(grid_partial, WARP_SIZE, threads_per_block);

    return verify_result(output, golden);
}
