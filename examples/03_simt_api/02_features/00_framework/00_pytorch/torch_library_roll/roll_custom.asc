#include <torch/extension.h>
#include "torch_npu/csrc/core/npu/NPUStream.h"

namespace {
    constexpr uint32_t THREAD_COUNT = 2048;
}

__global__ __launch_bounds__(THREAD_COUNT) void roll_custom(
    float* input, float* output,
    int32_t shift, int32_t total_length, int32_t dim_size, int32_t stride)
{
    int32_t idx = blockIdx.x * blockDim.x + threadIdx.x;
    if (idx >= total_length) {
        return;
    }

    // dst_coord 是 idx 在目标 dim 上的坐标，src_coord 是 roll 后对应的源坐标。
    int32_t dst_coord = (idx / stride) % dim_size;
    int32_t src_coord = dst_coord - shift;
    if (src_coord < 0) {
        src_coord += dim_size;
    }
    // 只替换目标 dim 上的坐标，其他维度坐标保持不变。
    int32_t src_idx = idx + (src_coord - dst_coord) * stride;
    output[idx] = input[src_idx];
}

namespace ascendc_ops {

at::Tensor ascendc_roll(const at::Tensor& x, at::IntArrayRef shifts, at::IntArrayRef dims)
{
    auto aclStream = c10_npu::getCurrentNPUStream().stream(false);
    at::Tensor z = at::empty(x.sizes(), x.options());

    int32_t total_length = 1;
    std::vector<int64_t> shape = x.sizes().vec();
    for (auto s : shape) {
        total_length *= s;
    }

    // dim_size 是目标维度长度，stride 是目标维度坐标变化 1 对应的线性偏移。
    int32_t dim_shift = 0;
    int32_t dim_size = total_length;
    int32_t stride = 1;
    if (!dims.empty() && !shifts.empty()) {
        int64_t dim = dims[0];
        if (dim < 0) {
            dim += shape.size();
        }
        dim_size = shape[dim];

        for (int64_t d = dim + 1; d < shape.size(); d++) {
            stride *= shape[d];
        }
        // 处理负数滚动步数，将结果映射到 [0, dim_size) 范围内。
        dim_shift = (shifts[0] % dim_size + dim_size) % dim_size;
    }

    uint32_t threads_per_block = THREAD_COUNT;
    uint32_t blocks_per_grid = (total_length + threads_per_block - 1) / threads_per_block;

    roll_custom<<<blocks_per_grid, threads_per_block, 0, aclStream>>>(
        x.data_ptr<float>(), z.data_ptr<float>(), dim_shift, total_length, dim_size, stride);

    return z;
}

} // namespace ascendc_ops

TORCH_LIBRARY(ascendc_ops, m)
{
    m.def("ascendc_roll(Tensor x, int[] shifts, int[] dims) -> Tensor");
}

TORCH_LIBRARY_IMPL(ascendc_ops, PrivateUse1, m)
{
    m.impl("ascendc_roll", TORCH_FN(ascendc_ops::ascendc_roll));
}
