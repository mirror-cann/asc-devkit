/* !
 * \file gather_kernel.asc
 * \brief
 */

#include "acl/acl.h"

namespace {
    constexpr uint32_t THREAD_COUNT = 2048;
}

extern __aicore__ float gather_element(float input_val, int32_t input_idx, uint32_t input_total_length);

__global__ __launch_bounds__(THREAD_COUNT) void gather_custom(
    float* input,
    int32_t* index,
    float* output,
    uint32_t input_total_length,
    uint32_t index_total_length)
{
    uint32_t begin = blockIdx.x * blockDim.x + threadIdx.x;
    uint32_t stride = gridDim.x * blockDim.x;

    for (uint32_t i = begin; i < index_total_length; i += stride) {
        int32_t input_idx = index[i];
        output[i] = gather_element(input[input_idx], input_idx, input_total_length);
    }
}

void run_gather_custom(float* input, int32_t* index, float* output,
                          uint32_t input_total_length, uint32_t index_total_length,
                          uint32_t blocks_per_grid, uint32_t threads_per_block, uint32_t dyn_ubuf_size,
                          aclrtStream stream)
{
    gather_custom<<<blocks_per_grid, threads_per_block, dyn_ubuf_size, stream>>>(
        input, index, output, input_total_length, index_total_length);
}
