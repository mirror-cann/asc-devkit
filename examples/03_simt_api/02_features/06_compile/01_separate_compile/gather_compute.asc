/* !
 * \file gather_compute.asc
 * \brief Separately compiled helper for validating gather indices.
 */

__aicore__ float gather_element(float input_val, int32_t input_idx, uint32_t input_total_length)
{
    if (input_idx >= 0 && input_idx < input_total_length) {
        return input_val;
    } else {
        return 0.0f;
    }
}
