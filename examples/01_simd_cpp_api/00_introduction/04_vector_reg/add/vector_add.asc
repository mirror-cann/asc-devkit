/* !
 * \file vector_add.asc
 * \brief 使用RegBase编程范式实现向量加法，展示SIMD RegBase编程范式的基本用法
 */

#include "acl/acl.h"
#include "kernel_operator.h"
#include "data_utils.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

template <typename T, uint32_t singleCoreLength>
__simd_vf__ inline void AddVF(__ubuf__ T* dstAddr, uint32_t count)
{
    // oneRepeatSize表示一个VF指令可处理的T类型元素个数；repeatTimes覆盖当前核负责的全部元素。
    constexpr uint32_t oneRepeatSize = AscendC::GetVecLen() / sizeof(T);
    uint32_t repeatTimes = AscendC::CeilDivision(singleCoreLength, oneRepeatSize);
    AscendC::Reg::MaskReg mask;
    AscendC::Reg::RegTensor<T> srcReg, dstReg;

    for (uint16_t i = 0; i < repeatTimes; ++i) {
        // UpdateMask用于生成当前repeat的有效元素掩码；本样例单核长度按整repeat配置。
        mask = AscendC::Reg::UpdateMask<T>(count);
        // 从UB加载数据到RegTensor，在寄存器上执行Add，再将结果写回UB。
        AscendC::Reg::LoadAlign(srcReg, dstAddr + i * oneRepeatSize);
        AscendC::Reg::LoadAlign(dstReg, dstAddr + i * oneRepeatSize);
        AscendC::Reg::Add(dstReg, dstReg, srcReg, mask);
        AscendC::Reg::StoreAlign(dstAddr + i * oneRepeatSize, dstReg, mask);
    }
}

template <uint32_t singleCoreLength>
__global__ __vector__ void vector_add(__gm__ uint8_t* x, __gm__ uint8_t* y)
{
    // 初始化核函数侧SOC状态。
    AscendC::InitSocState();
    // 使用GlobalTensor描述并绑定输入、输出GM地址。
    AscendC::GlobalTensor<float> xGm;
    AscendC::GlobalTensor<float> yGm;
    xGm.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(x));
    yGm.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(y));
    // 每个block处理连续的singleCoreLength个float元素。
    uint32_t coreOffset = AscendC::GetBlockIdx() * singleCoreLength;
    // 使用LocalMemAllocator在UB上申请当前核的临时输入/输出空间。
    AscendC::LocalMemAllocator<AscendC::Hardware::UB> ubAllocator;
    AscendC::LocalTensor<float> yLocal = ubAllocator.Alloc<float, singleCoreLength>();

    AscendC::DataCopy(yLocal, xGm[coreOffset], singleCoreLength);
    // MTE2完成GM到UB搬运后，Vector流水才能读取UB数据进行RegBase计算。
    AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
    AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);

    __ubuf__ float* dstAddr = reinterpret_cast<__ubuf__ float*>(yLocal.GetPhyAddr());
    // 调用VF函数完成yLocal = yLocal + yLocal，即输出y = x + x。
    asc_vf_call<AddVF<float, singleCoreLength>>(dstAddr, singleCoreLength);

    // Vector计算完成后，MTE3流水才能将UB中的结果写回GM。
    AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
    AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);

    AscendC::DataCopy(yGm[coreOffset], yLocal, singleCoreLength);
    AscendC::PipeBarrier<PIPE_ALL>();
}

int32_t main(int32_t argc, char* argv[])
{
    constexpr uint32_t totalLength = 512 * 512;
    constexpr uint32_t singleCoreLength = totalLength / 4;
    size_t inputByteSize = static_cast<size_t>(1) * totalLength * sizeof(float);
    size_t outputByteSize = static_cast<size_t>(1) * totalLength * sizeof(float);

    // 4个AIV block并行处理，每个block处理totalLength / 4个元素。
    uint32_t numBlocks = 4;
    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t *xHost, *yHost;
    uint8_t *xDevice, *yDevice;
    aclrtMallocHost((void**)(&xHost), inputByteSize);
    aclrtMallocHost((void**)(&yHost), outputByteSize);
    aclrtMalloc((void**)&xDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&yDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/input_x.bin", inputByteSize, xHost, inputByteSize);
    aclrtMemcpy(xDevice, inputByteSize, xHost, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
    vector_add<singleCoreLength><<<numBlocks, nullptr, stream>>>(xDevice, yDevice);
    aclrtSynchronizeStream(stream);
    aclrtMemcpy(yHost, outputByteSize, yDevice, outputByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", yHost, outputByteSize);
    aclrtFree(xDevice);
    aclrtFree(yDevice);
    aclrtFreeHost(xHost);
    aclrtFreeHost(yHost);
    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();
    return 0;
}
