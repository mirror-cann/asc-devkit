/* !
 * \file matmul_leakyrelu_advanced_api.asc
 * \brief 使用Matmul高级API实现矩阵乘与LeakyRelu激活函数融合计算
 */

#include "data_utils.h"
#include "kernel_tiling/kernel_tiling.h"
#include "tiling/platform/platform_ascendc.h"
#include "tiling/tiling_api.h"
#include "acl/acl.h"
#include "kernel_operator.h"
#include "lib/matmul_intf.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

/*
 * matmul_leakyrelu_custom完成矩阵乘、Bias加法和LeakyRelu激活的融合计算。
 *
 * __mix__(1, 2)表示核函数按Cube:Vector = 1:2的比例执行。
 * Host侧kernel launch的numBlocks表示Kernel直调时启动的AI Core组合数量；
 * 本样例numBlocks = 1，用于启动1个AI Core组合，对应1个AIC和2个AIV，与SetDim(2)生成的2个AIV逻辑核切分结果对应。
 *
 * 当前样例规格为M=512、N=128、K=128，SetDim(2)对应2个AIV逻辑核。
 * 当前tiling结果按N轴分核切分2份，每个逻辑核负责M * singleCoreN = 512 * 64的C矩阵输出区域。
 * 通过SetFixSplit(128, 64, 128)固定baseShape，Cube侧单次Iterate计算baseM * baseN = 128 * 64的输出块，
 * 每个逻辑核需要4次Iterate完成自身负责的512 * 64输出区域。
 * 每次Iterate完成后，Vector侧读取VECIN中的128 * 64个Matmul中间结果，执行同等数量元素的
 * LeakyRelu激活，再将激活结果搬运回GM中对应的C矩阵输出区域。
 *
 * MIX分离模式下Matmul API由AIV侧发起。AIV执行Iterate时通知AIC完成Cube矩阵计算，
 * AIC计算完成后再通知AIV获取结果并执行后续Vector侧融合计算。
 */
__global__ __mix__(1, 2) void matmul_leakyrelu_custom(__gm__ uint8_t* a, __gm__ uint8_t* b, __gm__ uint8_t* bias,
    __gm__ uint8_t* c, __kfc_workspace__ __gm__ uint8_t* workspace, AscendC::tiling::TCubeTiling tiling)
{
    // TPipe用于管理片上队列资源，通过TPipe完成内部资源初始化。
    AscendC::TPipe pipe;
    // GlobalTensor用于描述GM上的矩阵首地址。
    AscendC::GlobalTensor<half> aGlobal;
    AscendC::GlobalTensor<half> bGlobal;
    AscendC::GlobalTensor<float> cGlobal;
    AscendC::GlobalTensor<float> biasGlobal;
    // mmOutQueue用于管理Matmul输出到VECIN位置的中间结果缓存，后续LeakyRelu从该缓存读取输入。
    AscendC::TQue<AscendC::TPosition::VECIN, 1> mmOutQueue;
    // reluOutQueue用于管理Vector侧LeakyRelu输出使用的VECOUT缓存。队列深度为1，表示同一时刻该队列管理1块LocalTensor缓存。
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> reluOutQueue;
    // Matmul模板参数依次描述A、B、C、Bias的位置、格式和数据类型。
    // C使用VECIN，表示Matmul结果输出到Vector侧可读取的位置，便于后续执行LeakyRelu。
    matmul::Matmul<
        matmul::MatmulType<AscendC::TPosition::GM, CubeFormat::ND, half>,
        matmul::MatmulType<AscendC::TPosition::GM, CubeFormat::ND, half>,
        matmul::MatmulType<AscendC::TPosition::VECIN, CubeFormat::ND, float>,
        matmul::MatmulType<AscendC::TPosition::GM, CubeFormat::ND, float>>
        matmulObj;
    // 注册Matmul对象。系统workspace用于Matmul高阶API内部的临时资源管理。
    REGIST_MATMUL_OBJ(&pipe, GetSysWorkSpacePtr(), matmulObj, &tiling);
    // 将GM输入输出指针绑定到GlobalTensor。第二个参数表示该Tensor可访问的元素个数。
    aGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ half*>(a), tiling.M * tiling.Ka);
    bGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ half*>(b), tiling.Kb * tiling.N);
    cGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(c), tiling.M * tiling.N);
    biasGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(bias), tiling.N);
    // 本样例中GetTiling得到的tiling结果按N轴分2个核：
    // - A两个核都需要完整A矩阵参与K轴累加，因此从aGlobal[0]开始读取；
    // - B偏移 = blockIdx * singleCoreN，表示跳过前面核已经处理的B矩阵列；
    // - Bias偏移 = blockIdx * singleCoreN，表示读取当前N方向分片对应的Bias；
    // - C偏移 = blockIdx * singleCoreN，表示写回当前核负责的C矩阵列。
    uint32_t blockIdx = AscendC::GetBlockIdx();
    uint32_t nCoreOffset = blockIdx * tiling.singleCoreN;
    bGlobal = bGlobal[nCoreOffset];
    biasGlobal = biasGlobal[nCoreOffset];
    cGlobal = cGlobal[nCoreOffset];
    // 绑定当前核负责的A、B、Bias输入。Matmul内部会根据tiling完成分块搬运和Cube计算调度。
    matmulObj.SetTensorA(aGlobal);
    matmulObj.SetTensorB(bGlobal);
    matmulObj.SetBias(biasGlobal);

    // 初始化Vector侧队列缓存。mmOutQueue保存Matmul写入VECIN的中间结果，reluOutQueue保存LeakyRelu写入VECOUT的输出结果。
    // 每块缓存大小均为baseM * baseN个元素，对应当前逻辑核单次Iterate产生的输出分块。
    pipe.InitBuffer(mmOutQueue, 1, tiling.baseM * tiling.baseN * sizeof(float));
    pipe.InitBuffer(reluOutQueue, 1, tiling.baseM * tiling.baseN * sizeof(float));
    // 当前baseShape保持为128 * 64 * 128，每个AIV逻辑核负责512 * 64输出区域，需要通过4次Iterate完成。
    uint32_t computeRound = 0;
    while (matmulObj.template Iterate<true>()) {
        // 从VECIN队列申请LocalTensor缓存，用于承接Matmul输出分块。
        AscendC::LocalTensor<float> mmOutLocal = mmOutQueue.AllocTensor<float>();
        // 将Matmul结果获取到Vector侧LocalTensor中。第二个参数false表示不使能原子累加，
        // 第三个参数true表示按连续地址顺序写入，便于后续Vector计算直接读取。
        matmulObj.template GetTensorC<true>(mmOutLocal, false, true);
        // 将Matmul中间结果入队，建立Matmul结果写入与后续LeakyRelu读取之间的数据依赖。
        mmOutQueue.EnQue(mmOutLocal);
        // 从VECIN队列取出已经写入完成的Matmul中间结果，作为LeakyRelu的输入。
        mmOutLocal = mmOutQueue.DeQue<float>();
        // 从VECOUT队列申请LocalTensor缓存，用于保存LeakyRelu激活后的结果。
        AscendC::LocalTensor<float> reluOutLocal = reluOutQueue.AllocTensor<float>();
        // 对baseM * baseN个元素执行LeakyRelu逐元素激活。
        // 输入为Matmul中间结果mmOutLocal，输出为独立的reluOutLocal。
        AscendC::LeakyRelu(reluOutLocal, mmOutLocal, static_cast<float>(0.001), tiling.baseM * tiling.baseN);
        // 将完成激活计算的LocalTensor入队，建立后续搬出阶段的数据依赖。
        reluOutQueue.EnQue(reluOutLocal);
        // 从队列取出已就绪的LocalTensor，准备搬运到GM输出矩阵。
        reluOutLocal = reluOutQueue.DeQue<float>();
        // LeakyRelu已完成对mmOutLocal的读取，释放VECIN队列中的Matmul中间结果缓存。
        mmOutQueue.FreeTensor(mmOutLocal);
        // 当前逻辑核每次Iterate生成1个baseM * baseN输出分块。当前baseN等于singleCoreN，
        // 单核内部只沿M方向遍历base块，按Iterate轮次计算写回C矩阵的行偏移。
        uint64_t cOffset = static_cast<uint64_t>(computeRound) * tiling.baseM * tiling.N;
        // UB->GM调用DataCopy接口 + DataCopyParams结构体参数:{count, len, srcStrideIn, dstStrideIn}
        // count对应搬运行数baseM；len对应每行baseN个float类型元素折算后的32B块数；
        // srcStrideIn为0表示UB中相邻行连续存放；dstStrideIn跨过C矩阵同一行中当前baseN分块之外的元素。
        AscendC::DataCopy(cGlobal[cOffset], reluOutLocal,
            AscendC::DataCopyParams{static_cast<uint16_t>(tiling.baseM),
                static_cast<uint16_t>(tiling.baseN * sizeof(float) / 32), 0,
                static_cast<uint16_t>((tiling.N - tiling.baseN) * sizeof(float) / 32)});
        // 释放LocalTensor缓存，使该队列缓存可被下一轮Iterate复用。
        reluOutQueue.FreeTensor(reluOutLocal);
        computeRound++;
    }
    // 通知Matmul对象当前核计算结束，释放Matmul高阶API内部状态。
    matmulObj.End();
}

AscendC::tiling::TCubeTiling GenerateTiling(platform_ascendc::PlatformAscendC* ascendcPlatform)
{
    // 原始矩阵形状：A为M * K，B为K * N，C为M * N。
    constexpr int32_t M = 512;
    constexpr int32_t N = 128;
    constexpr int32_t K = 128;
    // baseM/baseN/baseK表示Matmul高阶API单次基础计算分块大小。
    // 本样例将base块固定为128 * 64 * 128，每个AIV逻辑核通过多次Iterate处理完整single shape。
    constexpr uint32_t baseM = 128;
    constexpr uint32_t baseN = 64;
    constexpr uint32_t baseK = 128;
    // usedCoreNum表示Matmul tiling侧参与任务切分的AIV逻辑核数量。
    int usedCoreNum = 2;

    matmul_tiling::MultiCoreMatmulTiling tilingApi(*ascendcPlatform);

    // SetDim设置Matmul tiling计算可使用的核数。分离架构MIX场景下，该值对应AIV逻辑核数。
    tilingApi.SetDim(usedCoreNum);
    // A、B输入位于GM，格式为ND，数据类型为half。最后一个参数false表示不转置输入矩阵。
    tilingApi.SetAType(matmul_tiling::TPosition::GM, matmul_tiling::CubeFormat::ND, matmul_tiling::DataType::DT_FLOAT16, false);
    tilingApi.SetBType(matmul_tiling::TPosition::GM, matmul_tiling::CubeFormat::ND, matmul_tiling::DataType::DT_FLOAT16, false);

    // C类型设置为VECIN，需要与核函数中Matmul模板参数的C位置保持一致。
    tilingApi.SetCType(matmul_tiling::TPosition::VECIN, matmul_tiling::CubeFormat::ND, matmul_tiling::DataType::DT_FLOAT);
    // Bias位于GM，格式为ND，数据类型为float。
    tilingApi.SetBiasType(matmul_tiling::TPosition::GM, matmul_tiling::CubeFormat::ND, matmul_tiling::DataType::DT_FLOAT);

    // OrgShape表示原始矩阵形状，Shape表示本次实际参与Matmul计算的形状；本样例计算完整矩阵。
    tilingApi.SetOrgShape(M, N, K);
    tilingApi.SetShape(M, N, K);
    // 使能Bias输入，使Matmul计算阶段完成A * B + Bias。
    tilingApi.EnableBias(true);

    // 固定Matmul基础分块大小，使kernel侧baseM/baseN相关搬出逻辑与tiling结果一致。
    tilingApi.SetFixSplit(baseM, baseN, baseK);

    // 查询当前AI处理器每个核可用的UB大小。
    uint64_t ubSize = 0;
    ascendcPlatform->GetCoreMemSize(platform_ascendc::CoreMemType::UB, ubSize);
    // LeakyRelu需要使用一块baseM * baseN * sizeof(float)大小的UB缓存，
    // 避免Matmul tiling生成时占用后续Vector融合计算需要的UB缓存。
    uint64_t usedUb = static_cast<uint64_t>(baseM) * baseN * sizeof(float);

    // 设置Matmul可使用的buffer空间。L1和L0C传入-1表示使用默认值，UB空间扣除Vector侧预留容量。
    tilingApi.SetBufferSpace(-1, -1, ubSize - usedUb);

    AscendC::tiling::TCubeTiling tilingData;
    // 根据上述矩阵规格、数据类型、分核数和base块配置生成TCubeTiling。
    int64_t res = tilingApi.GetTiling(tilingData);
    if (res == -1) {
        std::cout << "gen tiling failed" << std::endl;
    }
    return tilingData;
}

int32_t main(int32_t argc, char* argv[])
{
    auto ascendcPlatform = platform_ascendc::PlatformAscendCManager::GetInstance();
    size_t aFileSize = 512 * 128 * sizeof(uint16_t);
    size_t bFileSize = 128 * 128 * sizeof(uint16_t);
    size_t cFileSize = 512 * 128 * sizeof(float);
    size_t biasFileSize = 128 * sizeof(float);
    size_t tilingFileSize = sizeof(TCubeTiling);
    size_t userWorkspaceSize = 0;
    size_t systemWorkspaceSize = static_cast<size_t>(ascendcPlatform->GetLibApiWorkSpaceSize());
    size_t workspaceSize = userWorkspaceSize + systemWorkspaceSize;
    // Host侧生成tiling后作为kernel参数传入Device侧。
    auto tiling = GenerateTiling(ascendcPlatform);
    // __mix__(1, 2)场景下，Kernel直调的numBlocks用于启动AI Core组合数量。
    uint32_t numBlocks = 1;

    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t* inputAHost;
    uint8_t* inputADevice;
    aclrtMallocHost((void**)(&inputAHost), aFileSize);
    aclrtMalloc((void**)&inputADevice, aFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/x1_gm.bin", aFileSize, inputAHost, aFileSize);
    aclrtMemcpy(inputADevice, aFileSize, inputAHost, aFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t* inputBHost;
    uint8_t* inputBDevice;
    aclrtMallocHost((void**)(&inputBHost), bFileSize);
    aclrtMalloc((void**)&inputBDevice, bFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/x2_gm.bin", bFileSize, inputBHost, bFileSize);
    aclrtMemcpy(inputBDevice, bFileSize, inputBHost, bFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t* outputCHost;
    uint8_t* outputCDevice;
    aclrtMallocHost((void**)(&outputCHost), cFileSize);
    aclrtMalloc((void**)&outputCDevice, cFileSize, ACL_MEM_MALLOC_HUGE_FIRST);

    uint8_t* inputBiasHost;
    uint8_t* inputBiasDevice;
    aclrtMallocHost((void**)(&inputBiasHost), biasFileSize);
    aclrtMalloc((void**)&inputBiasDevice, biasFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/bias.bin", biasFileSize, inputBiasHost, biasFileSize);
    aclrtMemcpy(inputBiasDevice, biasFileSize, inputBiasHost, biasFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t* workspaceDevice;
    aclrtMalloc((void**)&workspaceDevice, workspaceSize, ACL_MEM_MALLOC_HUGE_FIRST);
    matmul_leakyrelu_custom<<<numBlocks, nullptr, stream>>>(
        inputADevice, inputBDevice, inputBiasDevice, outputCDevice, workspaceDevice, tiling);

    aclrtSynchronizeStream(stream);

    aclrtFree(inputADevice);
    aclrtFreeHost(inputAHost);
    aclrtFree(inputBDevice);
    aclrtFreeHost(inputBHost);
    aclrtMemcpy(outputCHost, cFileSize, outputCDevice, cFileSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", outputCHost, cFileSize);
    aclrtFree(outputCDevice);
    aclrtFreeHost(outputCHost);
    aclrtFree(inputBiasDevice);
    aclrtFreeHost(inputBiasHost);
    aclrtFree(workspaceDevice);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();
    return 0;
}
