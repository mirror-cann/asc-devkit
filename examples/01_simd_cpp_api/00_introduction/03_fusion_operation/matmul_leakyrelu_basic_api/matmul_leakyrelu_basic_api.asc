/* !
 * \file matmul_leakyrelu_basic_api.asc
 * \brief 基于静态Tensor编程模式实现Matmul和LeakyRelu融合计算，展示Cube单元和Vector单元协同计算的编程模式。
 *        样例矩阵规格为M=256、K=64、N=256，按singleCoreM=128、singleCoreN=256分核后，使用2个Cube核和4个Vector核完成计算。
 *        硬件Cube:Vector核数比例为1:2，2个Cube核负责Matmul计算，每个Cube核产生的结果再由2个Vector核协同完成LeakyRelu激活计算。
 */

#include "acl/acl.h"
#include "kernel_operator.h"
#include "data_utils.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

// half type, cube block: [16, 16]
constexpr uint32_t CUBE_BLOCK = 16;

template <
    uint32_t M, uint32_t K, uint32_t N, uint32_t singleCoreM, uint32_t singleCoreK, uint32_t singleCoreN,
    uint32_t baseM, uint32_t baseK, uint32_t baseN>
class KernelMatmul {
public:
    __aicore__ inline KernelMatmul() {}
    __aicore__ inline void Init(__gm__ uint8_t* a, __gm__ uint8_t* b, __gm__ uint8_t* c)
    {
        aGM.SetGlobalBuffer((__gm__ half*)a);
        bGM.SetGlobalBuffer((__gm__ half*)b);
        cGM.SetGlobalBuffer((__gm__ half*)c);
        // Cube核按M方向分核，每个Cube核负责singleCoreM * N大小输出块对应的A输入和C输出。
        if ASCEND_IS_AIC {
            aGM = aGM[AscendC::GetBlockIdx() * singleCoreM * K];
            cGM = cGM[AscendC::GetBlockIdx() * singleCoreM * N];
        }
        if ASCEND_IS_AIV {
            // Vector核数是Cube核数的2倍，1个Cube核的计算结果由2个Vector核继续完成LeakyRelu。
            // 因此这里用GetBlockIdx() / 2映射回对应的Cube核输出块起始地址。
            cGM = cGM[AscendC::GetBlockIdx() / 2 * singleCoreM * N];
        }
    }

    __aicore__ inline void Process()
    {
        if ASCEND_IS_AIC {
            // Matmul计算场景内存分配，需要在AIC侧执行。
            AscendC::LocalMemAllocator<AscendC::Hardware::L1> l1Allocator;
            AscendC::LocalMemAllocator<AscendC::Hardware::L0A> l0aAllocator;
            AscendC::LocalMemAllocator<AscendC::Hardware::L0B> l0bAllocator;
            AscendC::LocalMemAllocator<AscendC::Hardware::L0C> l0cAllocator;
            // 使用LocalMemAllocator按申请顺序分配片上内存，避免手动维护LocalTensor地址偏移。
            AscendC::LocalTensor<half> a1Local = l1Allocator.Alloc<AscendC::TPosition::A1, half>(baseM * baseK);
            AscendC::LocalTensor<half> b1Local = l1Allocator.Alloc<AscendC::TPosition::B1, half>(baseK * baseN);
            AscendC::LocalTensor<half> a2Local = l0aAllocator.Alloc<AscendC::TPosition::A2, half>(baseM * baseK);
            AscendC::LocalTensor<half> b2Local = l0bAllocator.Alloc<AscendC::TPosition::B2, half>(baseK * baseN);
            AscendC::LocalTensor<float> cLocal = l0cAllocator.Alloc<AscendC::TPosition::CO1, float>(baseM * baseN);
            // 矩阵计算逻辑，完成K方向累加，产生一个baseM*baseN的计算结果
            // A矩阵GM->L1调用DataCopy接口 + Nd2NzParams结构体参数:
            // {ndNum, nValue, dValue, srcNdMatrixStride, srcDValue, dstNzC0Stride, dstNzNStride, dstNzMatrixStride}
            AscendC::DataCopy(a1Local, aGM, AscendC::Nd2NzParams{1, baseM, baseK, 0, K, baseM, 1, 0});
            // B矩阵GM->L1调用DataCopy接口 + Nd2NzParams结构体参数:
            // {ndNum, nValue, dValue, srcNdMatrixStride, srcDValue, dstNzC0Stride, dstNzNStride, dstNzMatrixStride}
            AscendC::DataCopy(b1Local, bGM, AscendC::Nd2NzParams{1, baseK, baseN, 0, N, baseK, 1, 0});

            // GM->L1的DataCopy由MTE2流水完成，后续L1->L0的LoadData由MTE1流水读取L1数据；
            // 这里设置MTE2_MTE1事件，使MTE1等待MTE2，避免LoadData读取到尚未搬运完成的数据。
            AscendC::SetFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID0);
            AscendC::WaitFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID0);

            // A矩阵L1->L0A调用LoadData接口 + LoadData2DParams结构体参数:
            // {startIndex, repeatTimes, srcStride, sid, dstGap, ifTranspose, addrMode}
#if defined(__NPU_ARCH__) && (__NPU_ARCH__ == 2201) 
            // Nz->Zz, L0A上的排布格式为Zz
            for (int i = 0; i < baseM / CUBE_BLOCK; ++i) {
                AscendC::LoadData(a2Local[i * baseK * CUBE_BLOCK], a1Local[i * 512 / sizeof(half)],
                    AscendC::LoadData2DParams{0, baseK / CUBE_BLOCK, baseM / CUBE_BLOCK, 0, 0, false, 0});
            }
#elif defined(__NPU_ARCH__) && (__NPU_ARCH__ == 3510) 
            // Nz->Nz, L0A上的排布格式为Nz
            for (int i = 0; i < baseM / CUBE_BLOCK; ++i) {
                AscendC::LoadData(a2Local[i * 512 / sizeof(half)], a1Local[i * 512 / sizeof(half)],
                    AscendC::LoadData2DParams{0, baseK / CUBE_BLOCK, baseM / CUBE_BLOCK, 0, (baseM / CUBE_BLOCK -1), false, 0});
            }
#endif
            // B矩阵L1->L0B调用LoadData接口 + LoadData2DParams结构体参数:
            // {startIndex, repeatTimes, srcStride, sid, dstGap, ifTranspose, addrMode}
            for (int i = 0; i < baseK / CUBE_BLOCK; ++i) {
                AscendC::LoadData(b2Local[i * baseN * CUBE_BLOCK], b1Local[i * 512 / sizeof(half)],
                    AscendC::LoadData2DParams{0, baseN / CUBE_BLOCK, baseK / CUBE_BLOCK, 0, 0, true, 0});
            }

            // L1->L0的LoadData由MTE1流水完成，后续Mmad由M流水读取L0A/L0B数据；
            // 这里设置MTE1_M事件，使M流水等待MTE1，避免Mmad读取到尚未搬运完成的数据。
            AscendC::SetFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID0);
            AscendC::WaitFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID0);

            // 矩阵乘调用Mmad接口 + MmadParams结构体参数:{m, n, k, unitFlag, cmatrixSource, cmatrixInitVal}
            // 这里完成一个baseM * baseN大小tile的Matmul计算，结果保存在L0C中。
            AscendC::Mmad(cLocal, a2Local, b2Local, AscendC::MmadParams{baseM, baseN, baseK, 0, false, true});

            // M流水完成Mmad后，结果会先写入L0C，后续搬运侧才可以使用该结果。
            // 这里设置M_MTE2事件，使依赖该结果的后续搬运阶段在M流水完成后再继续。
            AscendC::SetFlag<AscendC::HardEvent::M_MTE2>(EVENT_ID0);
            AscendC::WaitFlag<AscendC::HardEvent::M_MTE2>(EVENT_ID0);
            // Fixpipe由FIX流水读取L0C并搬运到GM；
            // 这里设置M_FIX事件，使FIX流水等待M流水，避免Fixpipe读取到尚未计算完成的数据。
            AscendC::SetFlag<AscendC::HardEvent::M_FIX>(EVENT_ID0);
            AscendC::WaitFlag<AscendC::HardEvent::M_FIX>(EVENT_ID0);
            // L0C->GM搬运调用Fixpipe接口 + FixpipeParamsV220结构体参数:
            // {nSize, mSize, srcStride, dstStride, reluEn, quantPre, deqScalar, ndNum, srcNdStride, dstNdStride, unitFlag}
            // 搬运时同时完成Nz到ND的格式转换，以及float到half的数据类型转换。
            AscendC::Fixpipe(cGM, cLocal,
                AscendC::FixpipeParamsV220{baseN, baseM, baseM, N, false, QuantMode_t::F322F16, 0, 1, 0, 0, 0});
            // Cube核完成当前tile写回后，通过核间同步通知对应的2个Vector核可以开始读取该tile结果。
            AscendC::CrossCoreSetFlag<0x2, PIPE_FIX>(0);
        }
        if ASCEND_IS_AIV {
            // Vector计算场景内存分配，需要在AIV侧执行。
            AscendC::LocalMemAllocator<AscendC::Hardware::UB> ubAllocator;
            AscendC::LocalTensor<half> vecLocal =
                ubAllocator.Alloc<AscendC::TPosition::VECCALC, half>(baseM / 2 * baseN);
            // Vector核需要先等待对应Cube核完成Fixpipe写回，再开始读取当前baseM * baseN tile的结果。
            AscendC::CrossCoreWaitFlag(0);
            // 向量计算逻辑中，cube:vector=1:2，每个Vector核处理baseM / 2 * baseN大小的半块结果。
            LeaklyGeluCompute(vecLocal, 0, 0, baseM / 2 * baseN);
        }
    }

private:

    __aicore__ inline void LeaklyGeluCompute(
        const AscendC::LocalTensor<half>& vecLocal, uint32_t mIndex, uint32_t nIndex, uint32_t tileLen)
    {
        uint32_t blockLen = baseN * sizeof(half);
        uint32_t srcStride = (N - baseN) * sizeof(half);

        // 每个cube核产生的计算结果，由2个vector核完成计算，此处需要完成该2个vector核的起始地址偏移计算
        uint32_t gmOffset = (mIndex * baseM * N + nIndex * baseN) + AscendC::GetBlockIdx() % 2 * (baseM / 2 * N);

        // 先把当前Cube tile中的一半结果从GM搬到UB，供当前Vector核做激活计算。
        // GM->UB调用DataCopyPad接口 + DataCopyExtParams结构体参数:{blockCount, blockLen, srcStride, dstStride, rsv}
        // DataCopyPadExtParams结构体参数:{isPad, leftPadding, rightPadding, paddingValue}
        AscendC::DataCopyPad<half>(
            vecLocal, cGM[gmOffset],
            AscendC::DataCopyExtParams{static_cast<uint16_t>(baseM / 2), blockLen, srcStride, 0, 0},
            AscendC::DataCopyPadExtParams<half>{true, 0, 0, 0});

        // GM->UB的DataCopyPad由MTE2流水完成，后续LeakyRelu由V流水读取UB数据；
        // 这里设置MTE2_V事件，使V流水等待MTE2，避免向量计算读取到尚未搬运完成的数据。
        AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);

        // 对当前半块结果执行LeakyRelu激活，负值部分乘以0.001。
        AscendC::LeakyRelu(vecLocal, vecLocal, (half)0.001, tileLen);

        // LeakyRelu由V流水完成，后续DataCopyPad写回GM由MTE3流水执行；
        // 这里设置V_MTE3事件，使MTE3等待V流水，避免写回尚未计算完成的数据。
        AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);

        // 将当前Vector核负责的激活结果写回到原输出矩阵对应的半块区域。
        AscendC::DataCopyPad<half>(cGM[gmOffset], vecLocal,
            AscendC::DataCopyExtParams{static_cast<uint16_t>(baseM / 2), blockLen, 0, srcStride, 0});
    }

private:
    AscendC::GlobalTensor<half> aGM;
    AscendC::GlobalTensor<half> bGM;
    AscendC::GlobalTensor<half> cGM;
};

template <
    uint32_t M, uint32_t K, uint32_t N, uint32_t singleCoreM, uint32_t singleCoreK, uint32_t singleCoreN,
    uint32_t baseM, uint32_t baseK, uint32_t baseN>
__global__ __mix__(1, 2) void mmad_vec_custom(__gm__ uint8_t* a, __gm__ uint8_t* b, __gm__ uint8_t* c)
{
    AscendC::InitSocState();
    KernelMatmul<M, K, N, singleCoreM, singleCoreK, singleCoreN, baseM, baseK, baseN> op;
    op.Init(a, b, c);
    op.Process();
    AscendC::PipeBarrier<PIPE_ALL>();
}

int32_t main(int32_t argc, char* argv[])
{
    // matmul参数
    constexpr uint32_t M = 256;
    constexpr uint32_t K = 64;
    constexpr uint32_t N = 256;
    // 单核计算量
    constexpr uint32_t singleCoreM = 128;
    constexpr uint32_t singleCoreK = 64;
    constexpr uint32_t singleCoreN = 256;
    // 矩阵乘执行单元Tile参数
    constexpr uint32_t baseM = 128;
    constexpr uint32_t baseK = 64;
    constexpr uint32_t baseN = 256;

    size_t aFileSize = M * K * sizeof(half);
    size_t bFileSize = K * N * sizeof(half);
    size_t cFileSize = M * N * sizeof(half);
    uint32_t numBlocks = (M / singleCoreM) * (N / singleCoreN);

    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t* aHost;
    uint8_t* aDevice;
    aclrtMallocHost((void**)(&aHost), aFileSize);
    aclrtMalloc((void**)&aDevice, aFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/x1_gm.bin", aFileSize, aHost, aFileSize);
    aclrtMemcpy(aDevice, aFileSize, aHost, aFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t* bHost;
    uint8_t* bDevice;
    aclrtMallocHost((void**)(&bHost), bFileSize);
    aclrtMalloc((void**)&bDevice, bFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/x2_gm.bin", bFileSize, bHost, bFileSize);
    aclrtMemcpy(bDevice, bFileSize, bHost, bFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t* cHost;
    uint8_t* cDevice;
    aclrtMallocHost((void**)(&cHost), cFileSize);
    aclrtMalloc((void**)&cDevice, cFileSize, ACL_MEM_MALLOC_HUGE_FIRST);

    mmad_vec_custom<M, K, N, singleCoreM, singleCoreK, singleCoreN, baseM, baseK, baseN>
        <<<numBlocks, nullptr, stream>>>(aDevice, bDevice, cDevice);
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(cHost, cFileSize, cDevice, cFileSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", cHost, cFileSize);

    aclrtFree(aDevice);
    aclrtFreeHost(aHost);
    aclrtFree(bDevice);
    aclrtFreeHost(bHost);
    aclrtFree(cDevice);
    aclrtFreeHost(cHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();
    return 0;
}
