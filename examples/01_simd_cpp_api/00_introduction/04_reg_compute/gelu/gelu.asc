/* !
 * \file gelu.asc
 * \brief 简化版 GELU 向量计算样例。
 *
 * 本样例固定使用 2 个 Vector 核，只按 M 方向分核，每个核处理一整段连续的 GM 数据
 */

#include <cstdint>

#include "acl/acl.h"
#include "kernel_operator.h"
#include "data_utils.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

// GELU 公式里的两个系数，和 README 中的公式一一对应。
constexpr float COEFF_LINEAR = -1.595769f;
constexpr float COEFF_CUBIC = -0.071405f;

__simd_vf__ inline static void GeluVfMethod2(
    __ubuf__ float* xAddr, __ubuf__ float* yAddr, uint32_t count, uint32_t loopNum)
{
    // oneRepeatSize 表示一次向量重复能处理多少个 float 元素。
    constexpr uint32_t oneRepeatSize = AscendC::GetVecLen() / sizeof(float);
    AscendC::Reg::MaskReg mask;
    AscendC::Reg::RegTensor<float> xReg;
    AscendC::Reg::RegTensor<float> yReg;
    AscendC::Reg::RegTensor<float> tmpReg;
    for (uint32_t i = 0; i < loopNum; ++i) {
        mask = AscendC::Reg::UpdateMask<float>(count);
        // 从 UB 中取一段数据到寄存器。
        AscendC::Reg::LoadAlign(xReg, xAddr + i * oneRepeatSize);
        AscendC::Reg::Mul(yReg, xReg, xReg, mask);            // x^2
        AscendC::Reg::Mul(yReg, yReg, xReg, mask);            // x^3
        AscendC::Reg::Muls(yReg, yReg, COEFF_CUBIC, mask);    // -0.071405 * x^3
        AscendC::Reg::Muls(tmpReg, xReg, COEFF_LINEAR, mask); // -1.595769 * x
        AscendC::Reg::Add(yReg, tmpReg, yReg, mask);          // -1.595769 * x - 0.071405 * x^3
        AscendC::Reg::Exp(yReg, yReg, mask);                  // exp(...)
        AscendC::Reg::Adds(yReg, yReg, 1.0f, mask);           // 1 + exp(...)
        AscendC::Reg::Div(yReg, xReg, yReg, mask);            // x / (1 + exp(...))
        AscendC::Reg::StoreAlign(yAddr + i * oneRepeatSize, yReg, mask);
    }
}

template <uint32_t singleCoreLength>
__global__ __vector__ void gelu_custom(__gm__ uint8_t* x, __gm__ uint8_t* y)
{
    // 每个核只负责自己对应的连续数据段，起始位置由 block id 决定。
    AscendC::InitSocState();
    AscendC::GlobalTensor<float> xGm;
    AscendC::GlobalTensor<float> yGm;
    xGm.SetGlobalBuffer((__gm__ float*)x + AscendC::GetBlockIdx() * singleCoreLength);
    yGm.SetGlobalBuffer((__gm__ float*)y + AscendC::GetBlockIdx() * singleCoreLength);
    // UB 里准备一块完整的单核工作区，大小就是 singleCoreLength。
    AscendC::LocalMemAllocator<AscendC::Hardware::UB> ubAllocator;
    AscendC::LocalTensor<float> xLocal = ubAllocator.Alloc<float, singleCoreLength>();
    AscendC::LocalTensor<float> yLocal = ubAllocator.Alloc<float, singleCoreLength>();
    AscendC::DataCopy(xLocal, xGm[0], singleCoreLength);
    // SetFlag用于在GM->UB搬运完成后写入同步事件，WaitFlag用于让后续寄存器计算等待该事件；
    // 这里使用MTE2_V事件，表示MTE2完成对UB的数据搬运后，V流水再开始读取UB中的输入数据。
    AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
    AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
    // 在寄存器中完成 GELU 近似计算。
    constexpr uint32_t oneRepeatSize = AscendC::GetVecLen() / sizeof(float);
    uint32_t loopNum = AscendC::CeilDivision(singleCoreLength, oneRepeatSize);
    __ubuf__ float* xAddr = reinterpret_cast<__ubuf__ float*>(xLocal.GetPhyAddr());
    __ubuf__ float* yAddr = reinterpret_cast<__ubuf__ float*>(yLocal.GetPhyAddr());
    asc_vf_call<GeluVfMethod2>(xAddr, yAddr, singleCoreLength, loopNum);
    // SetFlag用于在寄存器计算完成后写入同步事件，WaitFlag用于让后续UB->GM回写等待该事件；
    // 这里使用V_MTE3事件，表示V流水完成GELU计算后，再由MTE3把结果写回GM。
    AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
    AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
    AscendC::DataCopy(yGm[0], yLocal, singleCoreLength);
    // PipeBarrier用于等待本核各流水阶段全部完成后再退出kernel。
    AscendC::PipeBarrier<PIPE_ALL>();
}

int32_t main(int32_t argc, char* argv[])
{
    // 输入 shape = [256, 32]，总元素数为 8192。
    constexpr uint32_t totalM = 256;
    constexpr uint32_t totalN = 32;
    // 固定使用 2 个核，M 方向平均分配。
    constexpr uint32_t numBlocks = 2;
    // 每个核一次完整处理 4096 个 float，即 128 x 32。
    constexpr uint32_t singleCoreLength = 4096;
    size_t totalByteSize = totalM * totalN * sizeof(float);

    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t* inputHost = nullptr;
    uint8_t* inputDevice = nullptr;
    aclrtMallocHost((void**)(&inputHost), totalByteSize);
    aclrtMalloc((void**)(&inputDevice), totalByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/input_x.bin", totalByteSize, inputHost, totalByteSize);
    aclrtMemcpy(inputDevice, totalByteSize, inputHost, totalByteSize, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t* outputHost = nullptr;
    uint8_t* outputDevice = nullptr;
    aclrtMallocHost((void**)(&outputHost), totalByteSize);
    aclrtMalloc((void**)(&outputDevice), totalByteSize, ACL_MEM_MALLOC_HUGE_FIRST);

    gelu_custom<singleCoreLength><<<numBlocks, nullptr, stream>>>(inputDevice, outputDevice);
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(outputHost, totalByteSize, outputDevice, totalByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", outputHost, totalByteSize);

    aclrtFree(inputDevice);
    aclrtFreeHost(inputHost);
    aclrtFree(outputDevice);
    aclrtFreeHost(outputHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();
    return 0;
}
