/* !
 * \file hello_world.asc
 * \brief 快速入门示例，演示最基本的Ascend C内核启动和printf输出
 */

#include "utils/debug/asc_printf.h"
#include "acl/acl.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

__global__ __vector__ void hello_world() { printf("Hello World!!!\n"); }

int main(int argc, char const* argv[])
{
    aclrtSetDevice(0); // 运行管理资源申请。
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);
    hello_world<<<8, 0, stream>>>();
    aclrtSynchronizeStream(stream);
    aclrtDestroyStream(stream);
    aclrtResetDevice(0); // 销毁运行资源。
    return 0;
}
