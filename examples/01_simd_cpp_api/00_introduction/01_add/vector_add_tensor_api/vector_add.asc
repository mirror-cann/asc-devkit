/* !
 * \file vector_add.asc
 * \brief Vector element-wise add based on tensor_api Transform<Add>
 */

#include "acl/acl.h"
#include "tensor_api/tensor.h"
#include "kernel_operator.h"
#include <cstdint>
#include <random>
#include <cmath>
#include <cstdio>

// T: data type, U: instruction type
template <typename T, typename U>
__global__ __vector__ void add_custom(__gm__ T* inputXPtr, __gm__ T* inputYPtr, __gm__ T* resultPtr, uint32_t totalLength)
{
    using namespace AscendC::Te;
    uint8_t mutexId = 0;

    // Create GM tensors (1D layout)
    auto gmInputX = MakeTensor(MakeMemPtr(inputXPtr), MakeFrameLayout<NDExtLayoutPtn>(_1{}, totalLength));
    auto gmInputY = MakeTensor(MakeMemPtr(inputYPtr), MakeFrameLayout<NDExtLayoutPtn>(_1{}, totalLength));
    auto gmResult = MakeTensor(MakeMemPtr(resultPtr), MakeFrameLayout<NDExtLayoutPtn>(_1{}, totalLength));

    // UB addr offset
    uint32_t ubInputXOffset = 0;
    uint32_t ubInputYOffset = totalLength * sizeof(T);
    uint32_t ubInputResultOffset = totalLength * sizeof(T) * 2;

    // Create UB tensors
    auto ubInputX = MakeTensor(MakeMemPtr<Location::UB, T>(ubInputXOffset), MakeFrameLayout<NDExtLayoutPtn>(_1{}, totalLength));
    auto ubInputY = MakeTensor(MakeMemPtr<Location::UB, T>(ubInputYOffset), MakeFrameLayout<NDExtLayoutPtn>(_1{}, totalLength));
    auto ubResult = MakeTensor(MakeMemPtr<Location::UB, T>(ubInputResultOffset), MakeFrameLayout<NDExtLayoutPtn>(_1{}, totalLength));

    // Create copy atoms
    auto copyGM2UBAtom = MakeCopy(CopyGM2UB{});
    auto copyUB2GMAtom = MakeCopy(CopyUB2GM{});

    // Copy inputs from GM to UB
    AscendC::Mutex::Lock<PIPE_MTE2>(mutexId);
    Copy(copyGM2UBAtom, ubInputX, gmInputX);
    Copy(copyGM2UBAtom, ubInputY, gmInputY);
    AscendC::Mutex::Unlock<PIPE_MTE2>(mutexId);

    // Perform element-wise instruction
    AscendC::Mutex::Lock<PIPE_V>(mutexId);
    Transform<U>(ubResult, ubInputX, ubInputY);
    AscendC::Mutex::Unlock<PIPE_V>(mutexId);

    // Copy result from UB to GM
    AscendC::Mutex::Lock<PIPE_MTE3>(mutexId);
    Copy(copyUB2GMAtom, gmResult, ubResult);
    AscendC::Mutex::Unlock<PIPE_MTE3>(mutexId);
}

int32_t main(int32_t argc, char* argv[])
{
    using dataType = float;
    uint32_t totalLength = 256;
    size_t fileSize = totalLength * sizeof(dataType);
    uint32_t numBlocks = 1;

    // Generate random input data and compute golden result
    std::random_device rd;
    std::mt19937 gen(rd());
    std::uniform_real_distribution<float> dis(-50.0f, 50.0f);

    dataType inputXHost[totalLength];
    dataType inputYHost[totalLength];
    dataType golden[totalLength];
    for (uint32_t i = 0; i < totalLength; ++i) {
        inputXHost[i] = dis(gen);
        inputYHost[i] = dis(gen);
        golden[i] = inputXHost[i] + inputYHost[i];
    }

    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    dataType* inputXDevice;
    aclrtMalloc((void**)&inputXDevice, fileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMemcpy(inputXDevice, fileSize, inputXHost, fileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    dataType* inputYDevice;
    aclrtMalloc((void**)&inputYDevice, fileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMemcpy(inputYDevice, fileSize, inputYHost, fileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    dataType* resultHost;
    dataType* resultDevice;
    aclrtMallocHost((void**)(&resultHost), fileSize);
    aclrtMalloc((void**)&resultDevice, fileSize, ACL_MEM_MALLOC_HUGE_FIRST);

    add_custom<dataType, AscendC::Te::Inst::Add><<<numBlocks, 0, stream>>>(inputXDevice, inputYDevice, resultDevice, totalLength);
    aclrtSynchronizeStream(stream);

    // Verify result
    aclrtMemcpy(resultHost, fileSize, resultDevice, fileSize, ACL_MEMCPY_DEVICE_TO_HOST);

    constexpr float EPS = 1e-6f;
    int64_t wrongNum = 0;
    for (uint32_t i = 0; i < totalLength; ++i) {
        dataType output = reinterpret_cast<dataType*>(resultHost)[i];
        dataType expected = golden[i];
        float diff = std::fabs(output - expected);
        if (diff > EPS) {
            printf("CompareResult failed at index %u: output is %f, golden is %f\n", i, output, expected);
            wrongNum++;
        }
    }

    if (wrongNum == 0) {
        printf("CompareResult passed, all %u elements are correct.\n", totalLength);
    } else {
        printf("CompareResult failed, %ld elements are wrong.\n", wrongNum);
    }

    aclrtFree(inputXDevice);
    aclrtFreeHost(inputXHost);
    aclrtFree(inputYDevice);
    aclrtFreeHost(inputYHost);
    aclrtFree(resultDevice);
    aclrtFreeHost(resultHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();
    return 0;
}
