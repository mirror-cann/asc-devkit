/* !
 * \file matmul.asc
 * \brief Static matmul based on tensor_api
 */

#include "acl/acl.h"
#include "tensor_api/tensor.h"
#include "basic_api/kernel_operator_block_sync_intf.h"
#include "data_utils.h"

using namespace AscendC::Te;

template <
    uint32_t M, uint32_t K, uint32_t N, uint32_t singleCoreM, uint32_t singleCoreK, uint32_t singleCoreN,
    uint32_t baseM, uint32_t baseK, uint32_t baseN>
class KernelMatmul {
public:
    __aicore__ inline KernelMatmul() {}

    __aicore__ inline void Init(__gm__ half* a, __gm__ half* b, __gm__ half* c)
    {
        a_ = a;
        b_ = b;
        c_ = c;

        constexpr uint32_t mIter = M / singleCoreM;
        mIterIdx_ = AscendC::GetBlockIdx() % mIter;
        nIterIdx_ = AscendC::GetBlockIdx() / mIter;
    }

    __aicore__ inline void Process()
    {
        auto gmPtrA = MakeMemPtr(a_);
        auto gmPtrB = MakeMemPtr(b_);
        auto gmPtrC = MakeMemPtr(c_);

        auto gmA = MakeTensor(gmPtrA, MakeFrameLayout<NDExtLayoutPtn>(M, K));
        auto gmB = MakeTensor(gmPtrB, MakeFrameLayout<NDExtLayoutPtn>(K, N));
        auto gmC = MakeTensor(gmPtrC, MakeFrameLayout<NDExtLayoutPtn>(M, N));

        auto shapeA = MakeShape(singleCoreM, singleCoreK);
        auto globalA = gmA.Slice(MakeCoord(mIterIdx_ * singleCoreM, 0), shapeA);

        auto shapeB = MakeShape(singleCoreK, singleCoreN);
        auto globalB = gmB.Slice(MakeCoord(0, nIterIdx_ * singleCoreN), shapeB);

        auto shapeC = MakeShape(singleCoreM, singleCoreN);
        auto globalC = gmC.Slice(MakeCoord(mIterIdx_ * singleCoreM, nIterIdx_ * singleCoreN), shapeC);

        auto l1ALayout = MakeFrameLayout<NZLayoutPtn>(baseM, baseK);
        auto l1BLayout = MakeFrameLayout<NZLayoutPtn>(baseK, baseN);
        auto l0ALayout = MakeFrameLayout<NZLayoutPtn>(baseM, baseK);
        auto l0BLayout = MakeFrameLayout<ZNLayoutPtn>(baseK, baseN);
        auto l0CLayout = MakeFrameLayout<NZLayoutPtn>(baseM, baseN);

        __cbuf__ half l1ABuf[baseM * baseK];
        __cbuf__ half l1BBuf[baseK * baseN];
        __ca__ half l0ABuf[baseM * baseK];
        __cb__ half l0BBuf[baseK * baseN];
        __cc__ float l0CBuf[baseM * baseN];

        auto l1ATensor = MakeTensor(MakeMemPtr(l1ABuf), l1ALayout);
        auto l1BTensor = MakeTensor(MakeMemPtr(l1BBuf), l1BLayout);
        auto l0ATensor = MakeTensor(MakeMemPtr(l0ABuf), l0ALayout);
        auto l0BTensor = MakeTensor(MakeMemPtr(l0BBuf), l0BLayout);
        auto l0CTensor = MakeTensor(MakeMemPtr(l0CBuf), l0CLayout);

        constexpr uint32_t mLoop = singleCoreM / baseM;
        constexpr uint32_t nLoop = singleCoreN / baseN;
        constexpr uint32_t kLoop = singleCoreK / baseK;

        AscendC::SetFlag<AscendC::HardEvent::MTE1_MTE2>(EVENT_ID0);
        AscendC::SetFlag<AscendC::HardEvent::M_MTE1>(EVENT_ID0);
        AscendC::SetFlag<AscendC::HardEvent::FIX_M>(EVENT_ID0);

        for (uint32_t i = 0; i < mLoop; i++) {
            for (uint32_t j = 0; j < nLoop; j++) {
                AscendC::WaitFlag<AscendC::HardEvent::FIX_M>(EVENT_ID0);
                for (uint32_t kIter = 0; kIter < kLoop; kIter++) {
                    AscendC::WaitFlag<AscendC::HardEvent::MTE1_MTE2>(EVENT_ID0);
                    Copy(l1ATensor, globalA.Slice(MakeCoord(i * baseM, kIter * baseK), MakeShape(baseM, baseK)));
                    Copy(l1BTensor, globalB.Slice(MakeCoord(kIter * baseK, j * baseN), MakeShape(baseK, baseN)));

                    AscendC::SetFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID0);
                    AscendC::WaitFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID0);

                    AscendC::WaitFlag<AscendC::HardEvent::M_MTE1>(EVENT_ID0);
                    Copy(l0ATensor, l1ATensor);
                    Copy(l0BTensor, l1BTensor);

                    AscendC::SetFlag<AscendC::HardEvent::MTE1_MTE2>(EVENT_ID0);
                    AscendC::SetFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID0);
                    AscendC::WaitFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID0);

                    MmadParams para{baseM, baseN, baseK, 0, kIter == 0};
                    Mmad(MmadAtom<MmadTraits<MmadOperation, MmadTraitDefault>>{}.with(para), l0CTensor, l0ATensor, l0BTensor);

                    AscendC::SetFlag<AscendC::HardEvent::M_MTE1>(EVENT_ID0);
                }
                AscendC::SetFlag<AscendC::HardEvent::M_FIX>(EVENT_ID0);
                AscendC::WaitFlag<AscendC::HardEvent::M_FIX>(EVENT_ID0);
                Copy(globalC.Slice(MakeCoord(i * baseM, j * baseN), MakeShape(baseM, baseN)), l0CTensor);
                AscendC::SetFlag<AscendC::HardEvent::FIX_M>(EVENT_ID0);
            }
        }

        AscendC::WaitFlag<AscendC::HardEvent::M_MTE1>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE1_MTE2>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::FIX_M>(EVENT_ID0);
    }

private:
    __gm__ half* a_ = nullptr;
    __gm__ half* b_ = nullptr;
    __gm__ half* c_ = nullptr;
    uint32_t mIterIdx_ = 0;
    uint32_t nIterIdx_ = 0;
};

template <
    uint32_t M, uint32_t K, uint32_t N, uint32_t singleCoreM, uint32_t singleCoreK, uint32_t singleCoreN,
    uint32_t baseM, uint32_t baseK, uint32_t baseN>
__global__ __cube__ void matmul_tensor_api(__gm__ half* a, __gm__ half* b, __gm__ half* c)
{
    KernelMatmul<M, K, N, singleCoreM, singleCoreK, singleCoreN, baseM, baseK, baseN> op;
    op.Init(a, b, c);
    op.Process();
    AscendC::PipeBarrier<PIPE_ALL>();
}

int32_t main(int32_t argc, char* argv[])
{
    // matmul参数
    constexpr uint32_t M = 512;
    constexpr uint32_t K = 512;
    constexpr uint32_t N = 1024;
    // 单核计算量
    constexpr uint32_t singleCoreM = 256;
    constexpr uint32_t singleCoreK = 512;
    constexpr uint32_t singleCoreN = 512;
    // 矩阵乘执行单元Tile参数
    constexpr uint32_t baseM = 128;
    constexpr uint32_t baseK = 64;
    constexpr uint32_t baseN = 256;
         
    size_t aFileSize = M * K * sizeof(half);
    size_t bFileSize = K * N * sizeof(half);
    size_t cFileSize = M * N * sizeof(half);
    uint32_t numBlocks = 4;

    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    half* aHost;
    half* aDevice;
    aclrtMallocHost((void**)(&aHost), aFileSize);
    aclrtMalloc((void**)&aDevice, aFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/x1_gm.bin", aFileSize, aHost, aFileSize);
    aclrtMemcpy(aDevice, aFileSize, aHost, aFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    half* bHost;
    half* bDevice;
    aclrtMallocHost((void**)(&bHost), bFileSize);
    aclrtMalloc((void**)&bDevice, bFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/x2_gm.bin", bFileSize, bHost, bFileSize);
    aclrtMemcpy(bDevice, bFileSize, bHost, bFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    half* cHost;
    half* cDevice;
    aclrtMallocHost((void**)(&cHost), cFileSize);
    aclrtMalloc((void**)&cDevice, cFileSize, ACL_MEM_MALLOC_HUGE_FIRST);

    matmul_tensor_api<M, K, N, singleCoreM, singleCoreK, singleCoreN, baseM, baseK, baseN>
        <<<numBlocks, nullptr, stream>>>(aDevice, bDevice, cDevice);
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(cHost, cFileSize, cDevice, cFileSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", cHost, cFileSize);

    aclrtFree(aDevice);
    aclrtFreeHost(aHost);
    aclrtFree(bDevice);
    aclrtFreeHost(bHost);
    aclrtFree(cDevice);
    aclrtFreeHost(cHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();
    return 0;
}
