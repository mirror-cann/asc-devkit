/**
 * \file matmul_s4.asc
 * \brief 本样例演示 int4 矩阵乘计算的端到端实现。
 */

#include "acl/acl.h"
#include "kernel_operator.h"
#include "data_utils.h"
#define ASCENDC_CUBE_ONLY
#include "lib/matmul_intf.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

__aicore__ __inline__ constexpr uint32_t DivCeil(uint32_t a, uint32_t b) { return (a + b - 1) / b; }

template <class A_TYPE, class B_TYPE, class C_TYPE>
__aicore__ inline void CalcGMOffset(
    int blockIdx, int usedCoreNum, TCubeTiling& param, int& offsetA, int& offsetB, int& offsetC)
{
    auto temp0 = DivCeil(param.M, param.singleCoreM);
    auto temp1 = DivCeil(param.N, param.singleCoreN);
    auto temp2 = DivCeil(param.Ka, param.singleCoreK);

    auto divideKcoreNum = usedCoreNum / temp2;

    auto mCoreIndx = (blockIdx % divideKcoreNum) % temp0;
    auto nCoreIndx = (blockIdx % divideKcoreNum) / temp0;
    auto subKindx = blockIdx / divideKcoreNum;

    offsetA = mCoreIndx * param.Ka * param.singleCoreM + subKindx * param.singleCoreK;
    offsetB = subKindx * param.singleCoreK * param.N + nCoreIndx * param.singleCoreN;
    offsetC = mCoreIndx * param.N * param.singleCoreM + nCoreIndx * param.singleCoreN;

    // 尾块M
    int gmUseM = param.M - mCoreIndx * param.singleCoreM;
    param.singleCoreM = gmUseM < param.singleCoreM ? gmUseM : param.singleCoreM;

    // 尾块N
    int gmUseN = param.N - nCoreIndx * param.singleCoreN;
    param.singleCoreN = gmUseN < param.singleCoreN ? gmUseN : param.singleCoreN;

    // 尾块K
    int gmUseK = param.Ka - subKindx * param.singleCoreK;
    param.singleCoreK = gmUseK < param.singleCoreK ? gmUseK : param.singleCoreK;
}

template <typename T, typename U>
__aicore__ inline void CopyTiling(T* tiling, __gm__ U* tilingGM, AscendC::TPipe* tpipe)
{
    uint32_t* ptr = reinterpret_cast<uint32_t*>(tiling);
    auto tiling32 = reinterpret_cast<__gm__ uint32_t*>(tilingGM);

    for (int i = 0; i < sizeof(T) / sizeof(uint32_t); i++, ptr++) {
        *ptr = *(tiling32 + i);
    }
    return;
}

template <class A_TYPE, class B_TYPE, class C_TYPE, class BIAS_TYPE, int32_t M, int32_t N, int32_t K>
class MatMulKernel {
public:
    __aicore__ inline MatMulKernel() {}

    __aicore__ inline void Init(
        __gm__ uint8_t* a4GM, __gm__ uint8_t* b4GM, __gm__ uint8_t* aGM, __gm__ uint8_t* bGM, __gm__ uint8_t* cGM,
        __gm__ uint8_t* tilingGM, AscendC::TPipe* pipeIn)
    {
        pipe = pipeIn;
        CopyTiling(&tiling, tilingGM, pipe);
        cGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ typename C_TYPE::T*>(cGM), tiling.M * tiling.N);
#if defined(__NPU_ARCH__) && (__NPU_ARCH__ == 2201)
        aGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ typename A_TYPE::T*>(a4GM), tiling.M * tiling.Ka);
        bGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ typename B_TYPE::T*>(b4GM), tiling.Kb * tiling.N);
#elif defined(__NPU_ARCH__) && (__NPU_ARCH__ == 3510)
        aGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ typename A_TYPE::T*>(aGM), tiling.M * tiling.Ka);
        a4Global.SetGlobalBuffer(reinterpret_cast<__gm__ int8_t*>(a4GM), tiling.M * tiling.Ka / 2);
        bGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ typename B_TYPE::T*>(bGM), tiling.Kb * tiling.N);
        b4Global.SetGlobalBuffer(reinterpret_cast<__gm__ int8_t*>(b4GM), tiling.Kb * tiling.N / 2);
        pipe->InitBuffer(inQueueSrc, 1, sizeof(int8_t) * M * K);
        pipe->InitBuffer(tmpQueue, 1, sizeof(half) * M * K);
        pipe->InitBuffer(outQueueDst, 1, sizeof(int8_t) * M * K);
#endif
    }

    __aicore__ inline void Process()
    {
#if defined(__NPU_ARCH__) && (__NPU_ARCH__ == 2201)
        if ASCEND_IS_AIC {
            RunMatmul();
        }
#elif defined(__NPU_ARCH__) && (__NPU_ARCH__ == 3510)
        if ASCEND_IS_AIV {
            Unzip(aGlobal, a4Global, tiling.M * tiling.Ka / 2);
            Unzip(bGlobal, b4Global, tiling.Kb * tiling.N / 2);
            AscendC::CrossCoreSetFlag<4, PIPE_MTE3>(8);
        }
        if ASCEND_IS_AIC {
            AscendC::CrossCoreWaitFlag<4, PIPE_MTE2>(8);
            RunMatmul();
        }
#endif
    }

private:
    __aicore__ inline void RunMatmul()
    {
        if (block_idx >= tiling.usedCoreNum) {
            return;
        }

        int offsetA = 0;
        int offsetB = 0;
        int offsetC = 0;
        CalcGMOffset<A_TYPE, B_TYPE, C_TYPE>(block_idx, tiling.usedCoreNum, tiling, offsetA, offsetB, offsetC);

        auto gmA = aGlobal[offsetA];
        auto gmB = bGlobal[offsetB];
        auto gmC = cGlobal[offsetC];

        AscendC::Matmul<A_TYPE, B_TYPE, C_TYPE, BIAS_TYPE, CFG_MDL> mm;
        mm.SetSubBlockIdx(0);
        mm.Init(&tiling, pipe);
        mm.SetTensorA(gmA, false);
        mm.SetTensorB(gmB, false);
        mm.IterateAll(gmC);
    }

    // int4 解压为 int8：搬运/计算阶段间用 EnQue/DeQue 衔接，自动完成 MTE2->V、V->MTE3 同步。
    __aicore__ inline void Unzip(
        AscendC::GlobalTensor<int8_t>& dstGlobalTensor, AscendC::GlobalTensor<int8_t>& srcGlobalTensor, uint32_t count)
    {
        AscendC::LocalTensor<int8_t> srcLocalTensor = inQueueSrc.AllocTensor<int8_t>();
        AscendC::DataCopy(srcLocalTensor, srcGlobalTensor, count);
        inQueueSrc.EnQue(srcLocalTensor);

        srcLocalTensor = inQueueSrc.DeQue<int8_t>();
        AscendC::LocalTensor<half> tmpTensor = tmpQueue.AllocTensor<half>();
        AscendC::LocalTensor<int8_t> dstLocalTensor = outQueueDst.AllocTensor<int8_t>();
        AscendC::LocalTensor<AscendC::int4b_t> int4SrcLocalTensor = srcLocalTensor.ReinterpretCast<AscendC::int4b_t>();
        AscendC::Cast<half, AscendC::int4b_t>(tmpTensor, int4SrcLocalTensor, AscendC::RoundMode::CAST_NONE, count * 2);
        AscendC::Cast<int8_t, half>(dstLocalTensor, tmpTensor, AscendC::RoundMode::CAST_CEIL, count * 2);
        outQueueDst.EnQue<int8_t>(dstLocalTensor);
        inQueueSrc.FreeTensor(srcLocalTensor);
        tmpQueue.FreeTensor(tmpTensor);

        dstLocalTensor = outQueueDst.DeQue<int8_t>();
        AscendC::DataCopy(dstGlobalTensor, dstLocalTensor, count * 2);
        outQueueDst.FreeTensor(dstLocalTensor);
    }

    AscendC::TPipe* pipe;
    TCubeTiling tiling;
    AscendC::GlobalTensor<typename A_TYPE::T> aGlobal;
    AscendC::GlobalTensor<typename B_TYPE::T> bGlobal;
    AscendC::GlobalTensor<typename C_TYPE::T> cGlobal;
    AscendC::GlobalTensor<int8_t> a4Global;
    AscendC::GlobalTensor<int8_t> b4Global;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> inQueueSrc;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> tmpQueue;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> outQueueDst;
};

template <int32_t M, int32_t N, int32_t K>
__global__ __mix__(1, 2) void matmul_s4(
    __gm__ uint8_t* a4GM, __gm__ uint8_t* b4GM, __gm__ uint8_t* aGM, __gm__ uint8_t* bGM, __gm__ uint8_t* cGM,
    __gm__ uint8_t* tilingGM)
{
#if defined(__NPU_ARCH__) && (__NPU_ARCH__ == 2201)
    typedef AscendC::MatmulType<AscendC::TPosition::GM, CubeFormat::ND, AscendC::int4b_t, false> aType;
    typedef AscendC::MatmulType<AscendC::TPosition::GM, CubeFormat::ND, AscendC::int4b_t, false> bType;
#elif defined(__NPU_ARCH__) && (__NPU_ARCH__ == 3510)
    typedef AscendC::MatmulType<AscendC::TPosition::GM, CubeFormat::ND, int8_t, false> aType;
    typedef AscendC::MatmulType<AscendC::TPosition::GM, CubeFormat::ND, int8_t, false> bType;
#endif
#if defined(__NPU_ARCH__) && ((__NPU_ARCH__ == 2201) || (__NPU_ARCH__ == 3510))
    typedef AscendC::MatmulType<AscendC::TPosition::GM, CubeFormat::ND_ALIGN, int32_t> cType;
    typedef AscendC::MatmulType<AscendC::TPosition::GM, CubeFormat::ND_ALIGN, int32_t> biasType;
    AscendC::TPipe pipe;
    MatMulKernel<aType, bType, cType, biasType, M, N, K> op;
    op.Init(a4GM, b4GM, aGM, bGM, cGM, tilingGM, &pipe);
    op.Process();
#endif
}

int32_t main(int32_t argc, char* argv[])
{
    constexpr uint32_t NUM_BLOCKS = 1;
    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);
    constexpr int32_t M = 256;
    constexpr int32_t N = 256;
    constexpr int32_t K = 256;
    size_t a4InputByteSize = M * K * sizeof(int8_t) / 2;
    size_t b4InputByteSize = K * N * sizeof(int8_t) / 2;
    size_t aInputByteSize = M * K * sizeof(int8_t);
    size_t bInputByteSize = K * N * sizeof(int8_t);
    size_t outputByteSize = M * N * sizeof(int32_t);
    size_t tilingInputByteSize = 64 * sizeof(int32_t);

    uint8_t *x4Host, *y4Host, *zHost, *tilingHost;
    uint8_t *xDevice, *x4Device, *yDevice, *y4Device, *zDevice, *tilingDevice;
    aclrtMallocHost((void**)(&x4Host), a4InputByteSize);
    aclrtMallocHost((void**)(&y4Host), b4InputByteSize);
    aclrtMallocHost((void**)(&zHost), outputByteSize);
    aclrtMallocHost((void**)(&tilingHost), tilingInputByteSize);
    aclrtMalloc((void**)&xDevice, aInputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&x4Device, a4InputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&yDevice, bInputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&y4Device, b4InputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&zDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&tilingDevice, tilingInputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/input_x4.bin", a4InputByteSize, x4Host, a4InputByteSize);
    ReadFile("./input/input_y4.bin", b4InputByteSize, y4Host, b4InputByteSize);
    ReadFile("./input/input_tiling.bin", tilingInputByteSize, tilingHost, tilingInputByteSize);
    aclrtMemset(xDevice, aInputByteSize, 0, aInputByteSize);
    aclrtMemset(yDevice, bInputByteSize, 0, bInputByteSize);
    aclrtMemcpy(x4Device, a4InputByteSize, x4Host, a4InputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(y4Device, b4InputByteSize, y4Host, b4InputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(tilingDevice, tilingInputByteSize, tilingHost, tilingInputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
    matmul_s4<M, N, K><<<NUM_BLOCKS, 0, stream>>>(x4Device, y4Device, xDevice, yDevice, zDevice, tilingDevice);
    aclrtSynchronizeStream(stream);
    aclrtMemcpy(zHost, outputByteSize, zDevice, outputByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", zHost, outputByteSize);
    aclrtFree(xDevice);
    aclrtFree(x4Device);
    aclrtFree(yDevice);
    aclrtFree(y4Device);
    aclrtFree(tilingDevice);
    aclrtFree(zDevice);
    aclrtFreeHost(x4Host);
    aclrtFreeHost(y4Host);
    aclrtFreeHost(tilingHost);
    aclrtFreeHost(zHost);
    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();
    return 0;
}
