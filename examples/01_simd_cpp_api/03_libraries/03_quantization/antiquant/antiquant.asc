/* !
 * \file antiquant.asc
 * \brief 本样例演示了基于AntiQuant类高阶API实现antiquant样例，按元素做反量化计算
 */

#include "acl/acl.h"
#include "data_utils.h"
#include "kernel_operator.h"
#include "tiling/tiling_api.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

namespace optiling {
BEGIN_TILING_DATA_DEF(AntiQuantCustomTilingData)
TILING_DATA_FIELD_DEF(uint32_t, elementCountOfInput);
TILING_DATA_FIELD_DEF(uint32_t, elementCountOfOffset);
TILING_DATA_FIELD_DEF(uint32_t, mK);
TILING_DATA_FIELD_DEF(uint32_t, sharedTmpBufferSize);
END_TILING_DATA_DEF;

REGISTER_TILING_DATA_CLASS(AntiQuantCustom, AntiQuantCustomTilingData)
} // namespace optiling

void ComputeTiling(const uint32_t elementCountOfInput, const uint32_t elementCountOfOffset, const uint32_t mK,
                 optiling::AntiQuantCustomTilingData& tiling)
{
    std::vector<int64_t> srcShapeVec = {static_cast<int64_t>(elementCountOfInput)};
    std::vector<int64_t> scaleShapeVec = {static_cast<int64_t>(elementCountOfOffset)};
    ge::Shape srcShape(srcShapeVec);
    ge::Shape scaleShape(scaleShapeVec);
    uint32_t maxTmpSize;
    uint32_t minTmpSize;

#if defined(__NPU_ARCH__) && (__NPU_ARCH__ == 3510)
    // 获取AntiQuantize接口完成计算所需的最大/最小临时空间大小
    AscendC::GetAntiQuantizeMaxMinTmpSize(srcShape, scaleShape, false, ge::DataType::DT_INT8,
        ge::DataType::DT_FLOAT16, maxTmpSize, minTmpSize);
#elif defined(__NPU_ARCH__) && (__NPU_ARCH__ == 2201)
    // 获取AscendAntiQuant接口完成计算所需的最大/最小临时空间大小
    AscendC::GetAscendAntiQuantMaxMinTmpSize(srcShape, scaleShape, false, ge::DataType::DT_INT8,
        ge::DataType::DT_FLOAT16, maxTmpSize, minTmpSize);
#endif

    uint32_t localWorkspaceSize = (minTmpSize == 0) ? 8 * 1024 : minTmpSize;
    tiling.set_elementCountOfInput(elementCountOfInput);
    tiling.set_elementCountOfOffset(elementCountOfOffset);
    tiling.set_mK(mK);
    tiling.set_sharedTmpBufferSize(localWorkspaceSize);
}

uint8_t* GetTilingBuf(optiling::AntiQuantCustomTilingData* tilingData)
{
    uint32_t tilingSize = sizeof(optiling::AntiQuantCustomTilingData);
    uint8_t* buf = (uint8_t*)malloc(tilingSize);
    tilingData->SaveToBuffer(buf, tilingSize);
    return buf;
}

uint8_t* GenerateTiling(uint32_t elementCountOfInput, uint32_t elementCountOfOffset, uint32_t mK)
{
    optiling::AntiQuantCustomTilingData tiling;
    ComputeTiling(elementCountOfInput, elementCountOfOffset, mK, tiling);
    return GetTilingBuf(&tiling);
}

namespace MyCustomKernel {
struct VecTiling {
    uint32_t elementCountOfInput;
    uint32_t elementCountOfOffset;
    uint32_t mK;
    uint32_t sharedTmpBufferSize;
};

template <typename T, typename U>
class KernelAntiQuant {
public:
    __aicore__ inline KernelAntiQuant() {}
    __aicore__ inline void Init(__gm__ uint8_t* dstGm, __gm__ uint8_t* srcGm, __gm__ uint8_t* offsetGm, __gm__ uint8_t* scaleGm,
                                uint32_t elementCountOfInputIn, uint32_t elementCountOfOffsetIn, uint32_t K,
                                uint32_t sharedTmpBufferSizeIn, AscendC::TPipe* pipeIn)
    {
        pipe = pipeIn;
        elementCountOfInput = elementCountOfInputIn;
        elementCountOfOffset = elementCountOfOffsetIn;
        mK = K;
        sharedTmpBufferSize = sharedTmpBufferSizeIn;

        dstGlobal.SetGlobalBuffer((__gm__ T*)dstGm);
        srcGlobal.SetGlobalBuffer((__gm__ U*)srcGm);
        offsetGlobal.SetGlobalBuffer((__gm__ T*)offsetGm);
        scaleGlobal.SetGlobalBuffer((__gm__ T*)scaleGm);

        pipe->InitBuffer(inQueueSrc, 1, elementCountOfInputIn * sizeof(U));
        pipe->InitBuffer(inQueueOffset, 1, elementCountOfOffsetIn * sizeof(T));
        pipe->InitBuffer(inQueueScale, 1, elementCountOfOffsetIn * sizeof(T));
        pipe->InitBuffer(outQueue, 1, elementCountOfInputIn * sizeof(T));
        pipe->InitBuffer(tmpQueue, 1, sharedTmpBufferSize);
    }
    __aicore__ inline void Process()
    {
        CopyIn();
        Compute();
        CopyOut();
    }

private:
    __aicore__ inline void CopyIn()
    {
        AscendC::LocalTensor<U> srcLocal = inQueueSrc.AllocTensor<U>();
        AscendC::DataCopy(srcLocal, srcGlobal, elementCountOfInput);
        inQueueSrc.EnQue(srcLocal);

        AscendC::LocalTensor<T> offsetLocal = inQueueOffset.AllocTensor<T>();
        AscendC::DataCopy(offsetLocal, offsetGlobal, elementCountOfOffset);
        inQueueOffset.EnQue(offsetLocal);

        AscendC::LocalTensor<T> scaleLocal = inQueueScale.AllocTensor<T>();
        AscendC::DataCopy(scaleLocal, scaleGlobal, elementCountOfOffset);
        inQueueScale.EnQue(scaleLocal);
    }
    __aicore__ inline void Compute()
    {
        AscendC::LocalTensor<U> srcLocal = inQueueSrc.DeQue<U>();
        AscendC::LocalTensor<T> offsetLocal = inQueueOffset.DeQue<T>();
        AscendC::LocalTensor<T> scaleLocal = inQueueScale.DeQue<T>();
        AscendC::LocalTensor<T> dstLocal = outQueue.AllocTensor<T>();
        AscendC::LocalTensor<uint8_t> sharedTmpBuffer = tmpQueue.AllocTensor<uint8_t>();

#if defined(__NPU_ARCH__) && (__NPU_ARCH__ == 2201)

        uint32_t offsetShape[] = {static_cast<uint32_t>(1), static_cast<uint32_t>(elementCountOfOffset)};
        offsetLocal.SetShapeInfo(AscendC::ShapeInfo(2, offsetShape, AscendC::DataFormat::ND));
        // AscendAntiQuant接口：实现伪量化计算，将量化数据还原为浮点数据（用于A2A3）
        // 模板参数：U=输入数据类型(int8_t), T=输出数据类型(half), false=不使能输入转置
        // 参数说明：
        //   dstLocal: 输出Tensor，类型为half，shape为[8, 128]
        //   srcLocal: 输入Tensor，类型为int8_t，shape为[8, 128]
        //   offsetLocal: 偏移量Tensor，类型为half，shape为[1, 128]
        //   scaleLocal: 缩放因子Tensor，类型为half，shape为[1, 128]
        //   sharedTmpBuffer: 临时缓冲区，用于内部计算
        //   mK: K轴大小，值为8，用于PER_CHANNEL场景的分组计算
        AscendC::AscendAntiQuant<U, T, false>(dstLocal, srcLocal, offsetLocal, scaleLocal, sharedTmpBuffer, mK);

#elif defined(__NPU_ARCH__) && (__NPU_ARCH__ == 3510)
        constexpr static AscendC::AntiQuantizePolicy policy = AscendC::AntiQuantizePolicy::PER_CHANNEL;
        constexpr static bool hasOffset = true;
        constexpr static AscendC::AntiQuantizeConfig config = {policy, hasOffset, -1};
        AscendC::AntiQuantizeParams params;
        params.m = 8;
        params.n = 128;
        params.groupSize = 0;
        // AntiQuantize接口：实现伪量化计算，将量化数据还原为浮点数据（950系列推荐接口）
        // 模板参数config：配置结构体，包含policy=PER_CHANNEL（按通道量化）、hasOffset=true（使用偏移量）、groupSize=-1（自动计算）
        // 参数说明：
        //   dstLocal: 输出Tensor，类型为half，shape为[8, 128]
        //   srcLocal: 输入Tensor，类型为int8_t，shape为[8, 128]
        //   scaleLocal: 缩放因子Tensor，类型为half，shape为[1, 128]
        //   offsetLocal: 偏移量Tensor，类型为half，shape为[1, 128]
        //   sharedTmpBuffer: 临时缓冲区，用于内部计算
        //   params: 参数结构体，包含m=8（M轴大小）、n=128（N轴大小）、groupSize=0（自动计算分组大小）
        AscendC::AntiQuantize<config>(dstLocal, srcLocal, scaleLocal, offsetLocal, sharedTmpBuffer, params);
#endif

        inQueueSrc.FreeTensor(srcLocal);
        inQueueOffset.FreeTensor(offsetLocal);
        inQueueScale.FreeTensor(scaleLocal);
        tmpQueue.FreeTensor(sharedTmpBuffer);
        outQueue.EnQue(dstLocal);
    }
    
    __aicore__ inline void CopyOut()
    {
        AscendC::LocalTensor<T> dstLocal = outQueue.DeQue<T>();
        AscendC::DataCopy(dstGlobal, dstLocal, elementCountOfInput);
        outQueue.FreeTensor(dstLocal);
    }

private:
    AscendC::TPipe* pipe;
    AscendC::TQue<AscendC::QuePosition::VECIN, 1> inQueueSrc;
    AscendC::TQue<AscendC::QuePosition::VECIN, 1> inQueueOffset;
    AscendC::TQue<AscendC::QuePosition::VECIN, 1> inQueueScale;
    AscendC::TQue<AscendC::QuePosition::VECOUT, 1> tmpQueue;
    AscendC::TQue<AscendC::QuePosition::VECOUT, 1> outQueue;

    AscendC::GlobalTensor<T> dstGlobal;
    AscendC::GlobalTensor<U> srcGlobal;
    AscendC::GlobalTensor<T> offsetGlobal;
    AscendC::GlobalTensor<T> scaleGlobal;

    uint32_t elementCountOfInput;
    uint32_t elementCountOfOffset;
    uint32_t mK;
    uint32_t sharedTmpBufferSize;
};

} // namespace MyCustomKernel

__aicore__ inline void CopyTiling(MyCustomKernel::VecTiling* tiling, __gm__ uint8_t* tilingGM)
{
    uint32_t* ptr = reinterpret_cast<uint32_t*>(tiling);
    auto tiling32 = reinterpret_cast<__gm__ uint32_t*>(tilingGM);

    for (uint32_t i = 0; i < sizeof(MyCustomKernel::VecTiling) / sizeof(uint32_t); i++, ptr++) {
        *ptr = *(tiling32 + i);
    }
    return;
}

extern "C" __global__ __vector__ void antiquant_custom(__gm__ uint8_t* dstGm, __gm__ uint8_t* srcGm, __gm__ uint8_t* offsetGm, __gm__ uint8_t* scaleGm,
                                                  __gm__ uint8_t* workspace, __gm__ uint8_t* tiling)
{
    AscendC::TPipe pipe;
    MyCustomKernel::KernelAntiQuant<half, int8_t> op;
    MyCustomKernel::VecTiling tilingData;
    CopyTiling(&tilingData, tiling);
    op.Init(dstGm, srcGm, offsetGm, scaleGm, tilingData.elementCountOfInput, tilingData.elementCountOfOffset,
            tilingData.mK, tilingData.sharedTmpBufferSize, &pipe);
    op.Process();
}

static bool CompareResult(const void* outputData, uint32_t outSize)
{
    void* goldenData;
    aclrtMallocHost((void**)(&goldenData), outSize);
    size_t goldenSize = outSize;
    bool ret = ReadFile("./output/golden.bin", goldenSize, goldenData, goldenSize);
    if (ret) {
        printf("ReadFile golden.bin success!\n");
    } else {
        printf("test failed!\n");
        return false;
    }
    constexpr float EPS = 1e-4;
    int64_t wrongNum = 0;

    for (size_t i = 0; i < outSize / sizeof(float); i++) {
        float a = (reinterpret_cast<const float*>(outputData))[i];
        float b = (reinterpret_cast<const float*>(goldenData))[i];
        float ae = std::abs(a - b);
        float re = ae / std::abs(b + EPS);
        if (ae > EPS && re > EPS) {
            printf("CompareResult golden.bin failed output is %lf, golden is %lf\n", a, b);
            wrongNum++;
        }
    }
    aclrtFreeHost(goldenData);
    if (wrongNum != 0) {
        printf("wrongNum: %ld\n", wrongNum);
        return false;
    } else {
        printf("CompareResult golden.bin success!\n");
        return true;
    }
}

constexpr uint32_t NUM_BLOCKS = 1;
constexpr uint32_t ELEMENT_COUNT_OF_INPUT = 1024;
constexpr uint32_t ELEMENT_COUNT_OF_OFFSET = 128;
constexpr uint32_t K = 8;
constexpr uint32_t TILINGDATA_SIZE = 4;
constexpr uint32_t WORKSPACE_SIZE = 16 * 1024 * 1024;

int32_t main(int32_t argc, char* argv[])
{
    uint32_t numBlocks = NUM_BLOCKS;
    size_t elementCountOfInput = ELEMENT_COUNT_OF_INPUT;
    size_t elementCountOfOffset = ELEMENT_COUNT_OF_OFFSET;
    size_t param1FileSize = elementCountOfInput * sizeof(half);
    size_t param2FileSize = elementCountOfInput * sizeof(int8_t);
    size_t param3FileSize = elementCountOfOffset * sizeof(half);
    size_t param4FileSize = elementCountOfOffset * sizeof(half);
    size_t tilingFileSize = TILINGDATA_SIZE * sizeof(uint32_t);
    size_t workspaceSize = WORKSPACE_SIZE;
    uint8_t* tilingBuf = GenerateTiling(elementCountOfInput, elementCountOfOffset, K);

    aclInit(nullptr);
    aclrtContext context;
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtCreateContext(&context, deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t *param1Host, *param2Host, *param3Host, *param4Host, *workspaceHost, *tilingHost;
    uint8_t *param1Device, *param2Device, *param3Device, *param4Device, *workspaceDevice, *tilingDevice;

    aclrtMallocHost((void**)(&param1Host), param1FileSize);
    aclrtMallocHost((void**)(&param2Host), param2FileSize);
    aclrtMallocHost((void**)(&param3Host), param3FileSize);
    aclrtMallocHost((void**)(&param4Host), param4FileSize);
    aclrtMallocHost((void**)(&workspaceHost), workspaceSize);
    aclrtMallocHost((void**)(&tilingHost), tilingFileSize);
    aclrtMalloc((void**)&param1Device, param1FileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&param2Device, param2FileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&param3Device, param3FileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&param4Device, param4FileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&workspaceDevice, workspaceSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&tilingDevice, tilingFileSize, ACL_MEM_MALLOC_HUGE_FIRST);

    ReadFile("./input/input_src.bin", param2FileSize, param2Host, param2FileSize);
    ReadFile("./input/input_offset.bin", param3FileSize, param3Host, param3FileSize);
    ReadFile("./input/input_scale.bin", param4FileSize, param4Host, param4FileSize);

    aclrtMemcpy(tilingDevice, tilingFileSize, tilingBuf, tilingFileSize, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(param2Device, param2FileSize, param2Host, param2FileSize, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(param3Device, param3FileSize, param3Host, param3FileSize, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(param4Device, param4FileSize, param4Host, param4FileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    antiquant_custom<<<numBlocks, nullptr, stream>>>(param1Device, param2Device, param3Device, param4Device,
                                                   workspaceDevice, tilingDevice);
    aclrtSynchronizeStream(stream);
    aclrtMemcpy(param1Host, param1FileSize, param1Device, param1FileSize, ACL_MEMCPY_DEVICE_TO_HOST);

    WriteFile("./output/output.bin", param1Host, param1FileSize);

    bool goldenResult = CompareResult(param1Host, param1FileSize);
    if (goldenResult) {
        printf("test pass!\n");
    } else {
        printf("test failed!\n");
    }

    aclrtFree(param1Device);
    aclrtFree(param2Device);
    aclrtFree(param3Device);
    aclrtFree(param4Device);
    aclrtFree(tilingDevice);
    aclrtFree(workspaceDevice);
    aclrtFreeHost(param1Host);
    aclrtFreeHost(param2Host);
    aclrtFreeHost(param3Host);
    aclrtFreeHost(param4Host);
    aclrtFreeHost(tilingHost);
    aclrtFreeHost(workspaceHost);

    aclrtDestroyStream(stream);
    aclrtDestroyContext(context);
    aclrtResetDevice(deviceId);
    aclFinalize();
    free(tilingBuf);

    return 0;
}
