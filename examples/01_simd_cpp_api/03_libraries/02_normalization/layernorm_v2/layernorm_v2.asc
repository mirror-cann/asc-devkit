/* !
 * \file layernorm_v2.asc
 * \brief 调用LayerNorm和Normalize高阶API，实现对输入tensor按行做归一化计算
 */

#include "acl/acl.h"
#include "data_utils.h"
#include "kernel_operator.h"
#include "tiling/tiling_api.h"
#include <algorithm>
#include <cmath>

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

constexpr uint32_t A_LENGTH = 32;
constexpr uint32_t R_LENGTH = 32;
constexpr uint32_t R_LENGTH_WITH_PAD = 32;
constexpr float EPSILON = 0.0001f;
constexpr uint32_t NUM_BLOCKS = 1;
constexpr uint32_t WORKSPACE_SIZE = 16 * 1024 * 1024;
constexpr uint32_t TILINGDATA_SIZE = 1024;

namespace optiling {
struct LayerNormV2Tiling {
    AscendC::tiling::LayerNormSeparateTiling layernormTiling;

    uint32_t normalizeTmpSize = 0;
    uint32_t aLength = 0;
    uint32_t rLength = 0;
    uint32_t rLengthWithPad = 0;
    float epsilon = 0.0f;
};
} // namespace optiling

uint8_t* GenerateLayerNormV2Tiling()
{
    std::vector<int64_t> shapeVec = {A_LENGTH, R_LENGTH};
    ge::Shape srcShape(shapeVec);

    optiling::LayerNormV2Tiling tilingData;
    tilingData.aLength = A_LENGTH;
    tilingData.rLength = R_LENGTH;
    tilingData.rLengthWithPad = R_LENGTH_WITH_PAD;
    tilingData.epsilon = EPSILON;

    // 1. 获取LayerNorm的Tiling
    bool isReuseSource = false;
    bool isComputeRstd = true;
    bool isOnlyOutput = false;

    uint32_t layernormMinValue = 0, layernormMaxValue = 0;
    AscendC::GetLayerNormMaxMinTmpSize(srcShape, sizeof(float), isReuseSource, isComputeRstd, isOnlyOutput,
                                       layernormMaxValue, layernormMinValue);

    uint32_t layernormWorkspaceSize = layernormMinValue;

    AscendC::tiling::LayerNormSeparateTiling layernormTiling;
    AscendC::GetLayerNormNDTilingInfo(srcShape, layernormWorkspaceSize, sizeof(float), isReuseSource, isComputeRstd,
                                      layernormTiling);

    tilingData.layernormTiling = layernormTiling;

    // 2. 获取Normalize的Tiling
    uint32_t normalizeMinValue = 0, normalizeMaxValue = 0;
    uint32_t typeSizeU = sizeof(float);
    uint32_t typeSizeT = sizeof(float);

    AscendC::GetNormalizeMaxMinTmpSize(srcShape, typeSizeU, typeSizeT, isReuseSource, isComputeRstd, isOnlyOutput,
                                       normalizeMaxValue, normalizeMinValue);

    tilingData.normalizeTmpSize = normalizeMinValue;

    uint8_t* buf = (uint8_t*)malloc(sizeof(optiling::LayerNormV2Tiling));
    if (buf) {
        memcpy_s(buf, sizeof(optiling::LayerNormV2Tiling), &tilingData, sizeof(optiling::LayerNormV2Tiling));
    }

    return buf;
}

__aicore__ inline void CopyTilingData(optiling::LayerNormV2Tiling* tilingData, __gm__ uint8_t* tilingGM)
{
    uint32_t* ptr = reinterpret_cast<uint32_t*>(tilingData);
    auto tiling32 = reinterpret_cast<__gm__ uint32_t*>(tilingGM);

    for (int i = 0; i < sizeof(optiling::LayerNormV2Tiling) / sizeof(uint32_t); i++, ptr++) {
        *ptr = *(tiling32 + i);
    }
}

class KernelLayerNormV2 {
public:
    __aicore__ inline KernelLayerNormV2() {}

    __aicore__ inline void Init(__gm__ uint8_t* inputXGm, __gm__ uint8_t* gammaGm, __gm__ uint8_t* betaGm, __gm__ uint8_t* layernormYGm, __gm__ uint8_t* meanGm,
                                __gm__ uint8_t* rstdGm, __gm__ uint8_t* varGm, __gm__ uint8_t* normalizeYGm,
                                const optiling::LayerNormV2Tiling& tilingData, AscendC::TPipe* pipeIn)
    {
        pipe = pipeIn;
        this->tilingData = tilingData;

        uint32_t totalElements = tilingData.aLength * tilingData.rLengthWithPad;

        inputX_global.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(inputXGm), totalElements);
        gamma_global.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(gammaGm), tilingData.rLengthWithPad);
        beta_global.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(betaGm), tilingData.rLengthWithPad);

        layernormY_global.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(layernormYGm), totalElements);
        mean_global.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(meanGm), tilingData.aLength);
        rstd_global.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(rstdGm), tilingData.aLength);
        var_global.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(varGm), tilingData.aLength);
        normalizeY_global.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(normalizeYGm), totalElements);

        pipe->InitBuffer(inQueueX, 1, sizeof(float) * totalElements);
        pipe->InitBuffer(inQueueGamma, 1, sizeof(float) * tilingData.rLengthWithPad);
        pipe->InitBuffer(inQueueBeta, 1, sizeof(float) * tilingData.rLengthWithPad);

        pipe->InitBuffer(outQueueLayernormY, 1, sizeof(float) * totalElements);
        pipe->InitBuffer(outQueueMean, 1, sizeof(float) * tilingData.aLength);
        pipe->InitBuffer(outQueueRstd, 1, sizeof(float) * tilingData.aLength);
        pipe->InitBuffer(outQueueVar, 1, sizeof(float) * tilingData.aLength);
        pipe->InitBuffer(outQueueNormalizeY, 1, sizeof(float) * totalElements);
        pipe->InitBuffer(outQueueNormalizeRstd, 1, sizeof(float) * tilingData.aLength);
        pipe->InitBuffer(tmpBufNormalize, tilingData.normalizeTmpSize);
        pipe->InitBuffer(tmpBufRstdSquare, sizeof(float) * tilingData.aLength);
    }

    __aicore__ inline void Process()
    {
        AscendC::AscendCUtils::SetOverflow(1);
        CopyIn();
        Compute();
        CopyOut();
        AscendC::AscendCUtils::SetOverflow(0);
    }

private:
    __aicore__ inline void CopyIn()
    {
        uint32_t totalElements = tilingData.aLength * tilingData.rLengthWithPad;

        AscendC::LocalTensor<float> inputXLocal = inQueueX.AllocTensor<float>();
        AscendC::LocalTensor<float> gammaLocal = inQueueGamma.AllocTensor<float>();
        AscendC::LocalTensor<float> betaLocal = inQueueBeta.AllocTensor<float>();

        AscendC::DataCopy(inputXLocal, inputX_global, totalElements);
        AscendC::DataCopy(gammaLocal, gamma_global, tilingData.rLengthWithPad);
        AscendC::DataCopy(betaLocal, beta_global, tilingData.rLengthWithPad);

        inQueueX.EnQue(inputXLocal);
        inQueueGamma.EnQue(gammaLocal);
        inQueueBeta.EnQue(betaLocal);
    }

    __aicore__ inline void Compute()
    {
        uint32_t totalElements = tilingData.aLength * tilingData.rLengthWithPad;

        AscendC::LocalTensor<float> inputXLocal = inQueueX.DeQue<float>();
        AscendC::LocalTensor<float> gammaLocal = inQueueGamma.DeQue<float>();
        AscendC::LocalTensor<float> betaLocal = inQueueBeta.DeQue<float>();

        AscendC::LocalTensor<float> layernormYLocal = outQueueLayernormY.AllocTensor<float>();
        AscendC::LocalTensor<float> meanLocal = outQueueMean.AllocTensor<float>();
        AscendC::LocalTensor<float> rstdLocal = outQueueRstd.AllocTensor<float>();
        AscendC::LocalTensor<float> varLocal = outQueueVar.AllocTensor<float>();
        AscendC::LocalTensor<float> normalizeYLocal = outQueueNormalizeY.AllocTensor<float>();

        // ==================== LayerNorm计算 ====================
        // A2/A3系列: isOutputRstd=true 输出rstd，需要手动计算variance
        static constexpr AscendC::LayerNormConfig layernormConfig = AscendC::LayerNormConfig{false, false, false, true};

        AscendC::LayerNormPara layernormPara = {tilingData.aLength, tilingData.rLength, tilingData.rLengthWithPad};

        AscendC::LayerNorm<float, float, false, layernormConfig>(layernormYLocal, meanLocal, rstdLocal, inputXLocal,
                                                                 gammaLocal, betaLocal, tilingData.epsilon,
                                                                 layernormPara, tilingData.layernormTiling);

        // 从rstd计算variance: var = 1/(rstd*rstd) - epsilon
        AscendC::LocalTensor<float> rstdSquareLocal = tmpBufRstdSquare.Get<float>();
        AscendC::Mul(rstdSquareLocal, rstdLocal, rstdLocal, tilingData.aLength);    // rstd^2 = rstd * rstd
        AscendC::Reciprocal(varLocal, rstdSquareLocal, tilingData.aLength);         // var = 1 / rstd^2
        AscendC::Adds(varLocal, varLocal, -tilingData.epsilon, tilingData.aLength); // var -= epsilon

        // ==================== Normalize计算 ====================
        // Normalize使用LayerNorm的原始输入inputXLocal，统计量使用LayerNorm计算的meanLocal和varLocal
        static constexpr AscendC::NormalizeConfig normalizeConfig =
            AscendC::NormalizeConfig{AscendC::ReducePattern::AR, -1, false, false, false};

        AscendC::NormalizePara normalizePara = {tilingData.aLength, tilingData.rLength, tilingData.rLengthWithPad};

        AscendC::LocalTensor<uint8_t> sharedTmpBuffer = tmpBufNormalize.AllocTensor<uint8_t>();
        AscendC::LocalTensor<float> normalizeRstdLocal = outQueueNormalizeRstd.AllocTensor<float>();
        AscendC::Duplicate(normalizeRstdLocal, 0.0f, tilingData.aLength);

        AscendC::Normalize<float, float, false, normalizeConfig>(normalizeYLocal, normalizeRstdLocal, meanLocal,
                                                                 varLocal, inputXLocal, gammaLocal, betaLocal,
                                                                 sharedTmpBuffer, tilingData.epsilon, normalizePara);

        outQueueNormalizeRstd.FreeTensor(normalizeRstdLocal);
        tmpBufNormalize.FreeTensor(sharedTmpBuffer);

        outQueueLayernormY.EnQue<float>(layernormYLocal);
        outQueueMean.EnQue<float>(meanLocal);
        outQueueRstd.EnQue<float>(rstdLocal);
        outQueueVar.EnQue<float>(varLocal);
        outQueueNormalizeY.EnQue<float>(normalizeYLocal);

        inQueueX.FreeTensor(inputXLocal);
        inQueueGamma.FreeTensor(gammaLocal);
        inQueueBeta.FreeTensor(betaLocal);
    }

    __aicore__ inline void CopyOut()
    {
        uint32_t totalElements = tilingData.aLength * tilingData.rLengthWithPad;

        AscendC::LocalTensor<float> layernormYLocal = outQueueLayernormY.DeQue<float>();
        AscendC::LocalTensor<float> meanLocal = outQueueMean.DeQue<float>();
        AscendC::LocalTensor<float> rstdLocal = outQueueRstd.DeQue<float>();
        AscendC::LocalTensor<float> varLocal = outQueueVar.DeQue<float>();
        AscendC::LocalTensor<float> normalizeYLocal = outQueueNormalizeY.DeQue<float>();

        AscendC::DataCopy(layernormY_global, layernormYLocal, totalElements);
        AscendC::DataCopy(mean_global, meanLocal, tilingData.aLength);
        AscendC::DataCopy(rstd_global, rstdLocal, tilingData.aLength);
        AscendC::DataCopy(var_global, varLocal, tilingData.aLength);
        AscendC::DataCopy(normalizeY_global, normalizeYLocal, totalElements);

        outQueueLayernormY.FreeTensor(layernormYLocal);
        outQueueMean.FreeTensor(meanLocal);
        outQueueRstd.FreeTensor(rstdLocal);
        outQueueVar.FreeTensor(varLocal);
        outQueueNormalizeY.FreeTensor(normalizeYLocal);
    }

private:
    AscendC::GlobalTensor<float> inputX_global;
    AscendC::GlobalTensor<float> gamma_global;
    AscendC::GlobalTensor<float> beta_global;
    AscendC::GlobalTensor<float> layernormY_global;
    AscendC::GlobalTensor<float> mean_global;
    AscendC::GlobalTensor<float> rstd_global;
    AscendC::GlobalTensor<float> var_global;
    AscendC::GlobalTensor<float> normalizeY_global;

    AscendC::TPipe* pipe;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> inQueueX;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> inQueueGamma;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> inQueueBeta;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> outQueueLayernormY;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> outQueueMean;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> outQueueRstd;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> outQueueVar;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> outQueueNormalizeY;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> outQueueNormalizeRstd;
    AscendC::TBuf<AscendC::TPosition::VECCALC> tmpBufNormalize;
    AscendC::TBuf<AscendC::TPosition::VECCALC> tmpBufRstdSquare;

    optiling::LayerNormV2Tiling tilingData;
};

extern "C" __global__ __vector__ void layernormv2_custom(__gm__ uint8_t* inputXGm, __gm__ uint8_t* gammaGm, __gm__ uint8_t* betaGm,
                                                              __gm__ uint8_t* layernormYGm, __gm__ uint8_t* meanGm, __gm__ uint8_t* rstdGm,
                                                              __gm__ uint8_t* varGm, __gm__ uint8_t* normalizeYGm, __gm__ uint8_t* workspace,
                                                              __gm__ uint8_t* tiling)
{
    AscendC::TPipe pipe;

    optiling::LayerNormV2Tiling tilingData;
    CopyTilingData(&tilingData, tiling);

    KernelLayerNormV2 op;
    op.Init(inputXGm, gammaGm, betaGm, layernormYGm, meanGm, rstdGm, varGm, normalizeYGm, tilingData, &pipe);
    op.Process();
}

static bool CompareResult(const void* outputData, int64_t outSize, const char* goldenName, float eps = 1e-4f)
{
    void* goldenData = nullptr;
    aclrtMallocHost((void**)(&goldenData), outSize);
    if (!goldenData) {
        printf("Error: Failed to allocate host memory for golden data\n");
        return false;
    }

    std::string goldenPath = std::string("./output/golden_") + goldenName + ".bin";
    size_t goldenSize = outSize;
    bool ret = ReadFile(goldenPath.c_str(), goldenSize, goldenData, goldenSize);
    if (!ret) {
        printf("Error: Failed to read golden file: %s\n", goldenPath.c_str());
        aclrtFreeHost(goldenData);
        return false;
    }

    printf("ReadFile %s success!\n", goldenPath.c_str());

    int64_t wrongNum = 0;
    int64_t totalNum = outSize / sizeof(float);
    const float* outputPtr = reinterpret_cast<const float*>(outputData);
    const float* goldenPtr = reinterpret_cast<const float*>(goldenData);

    float maxAbsError = 0.0f;
    float maxRelError = 0.0f;

    for (int i = 0; i < totalNum; i++) {
        float a = outputPtr[i];
        float b = goldenPtr[i];
        float ae = std::abs(a - b);
        float re = (std::abs(b) > 1e-10f) ? (ae / std::abs(b)) : ae;

        maxAbsError = std::max(maxAbsError, ae);
        maxRelError = std::max(maxRelError, re);

        if (ae > eps && re > eps) {
            if (wrongNum < 3) {
                printf("CompareResult %s failed at [%d]: output=%.8f, golden=%.8f, abs_err=%.8f, rel_err=%.8f\n",
                       goldenName, i, a, b, ae, re);
            }
            wrongNum++;
        }
    }

    aclrtFreeHost(goldenData);

    if (wrongNum > 0) {
        printf("CompareResult %s failed: wrongNum=%ld, totalNum=%ld, maxAbsError=%.8f, maxRelError=%.8f\n", goldenName,
               wrongNum, totalNum, maxAbsError, maxRelError);
        return false;
    } else {
        printf("CompareResult %s success! (total=%ld, maxAbsError=%.8f, maxRelError=%.8f)\n", goldenName, totalNum,
               maxAbsError, maxRelError);
        return true;
    }
}

int32_t main(int32_t argc, char* argv[])
{
    uint32_t numBlocks = NUM_BLOCKS;
    uint32_t totalElements = A_LENGTH * R_LENGTH_WITH_PAD;

    size_t workspaceSize = WORKSPACE_SIZE;
    size_t inputXSize = totalElements * sizeof(float);
    size_t gammaSize = R_LENGTH_WITH_PAD * sizeof(float);
    size_t betaSize = R_LENGTH_WITH_PAD * sizeof(float);
    size_t layernormYSize = totalElements * sizeof(float);
    size_t meanSize = A_LENGTH * sizeof(float);
    size_t rstdSize = A_LENGTH * sizeof(float);
    size_t varSize = A_LENGTH * sizeof(float);
    size_t normalizeYSize = totalElements * sizeof(float);
    size_t tilingFileSize = sizeof(optiling::LayerNormV2Tiling);

    uint8_t* tilingBuf = GenerateLayerNormV2Tiling();
    if (!tilingBuf) {
        printf("Error: Failed to generate tiling data\n");
        return -1;
    }

    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t *inputXHost, *gammaHost, *betaHost;
    uint8_t *layernormYHost, *meanHost, *rstdHost, *varHost,*normalizeYHost;
    uint8_t *workspaceHost, *tilingHost;

    aclrtMallocHost((void**)(&inputXHost), inputXSize);
    aclrtMallocHost((void**)(&gammaHost), gammaSize);
    aclrtMallocHost((void**)(&betaHost), betaSize);
    aclrtMallocHost((void**)(&layernormYHost), layernormYSize);
    aclrtMallocHost((void**)(&meanHost), meanSize);
    aclrtMallocHost((void**)(&rstdHost), rstdSize);
    aclrtMallocHost((void**)(&varHost), varSize);
    aclrtMallocHost((void**)(&normalizeYHost), normalizeYSize);
    aclrtMallocHost((void**)(&workspaceHost), workspaceSize);
    aclrtMallocHost((void**)(&tilingHost), tilingFileSize);

    ReadFile("./input/coop_inputX.bin", inputXSize, inputXHost, inputXSize);
    ReadFile("./input/coop_gamma.bin", gammaSize, gammaHost, gammaSize);
    ReadFile("./input/coop_beta.bin", betaSize, betaHost, betaSize);

    memcpy_s(tilingHost, tilingFileSize, tilingBuf, tilingFileSize);

    uint8_t *inputXDevice, *gammaDevice, *betaDevice;
    uint8_t *layernormYDevice, *meanDevice, *rstdDevice, *varDevice, *normalizeYDevice;
    uint8_t *workspaceDevice, *tilingDevice;

    aclrtMalloc((void**)&inputXDevice, inputXSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&gammaDevice, gammaSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&betaDevice, betaSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&layernormYDevice, layernormYSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&meanDevice, meanSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&rstdDevice, rstdSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&varDevice, varSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&normalizeYDevice, normalizeYSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&workspaceDevice, workspaceSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&tilingDevice, tilingFileSize, ACL_MEM_MALLOC_HUGE_FIRST);

    aclrtMemcpy(inputXDevice, inputXSize, inputXHost, inputXSize, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(gammaDevice, gammaSize, gammaHost, gammaSize, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(betaDevice, betaSize, betaHost, betaSize, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(workspaceDevice, workspaceSize, workspaceHost, workspaceSize, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(tilingDevice, tilingFileSize, tilingHost, tilingFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    layernormv2_custom<<<numBlocks, nullptr, stream>>>(inputXDevice, gammaDevice, betaDevice, layernormYDevice,
                                                            meanDevice, rstdDevice, varDevice, normalizeYDevice,
                                                            workspaceDevice, tilingDevice);

    aclrtSynchronizeStream(stream);
    aclrtMemcpy(layernormYHost, layernormYSize, layernormYDevice, layernormYSize, ACL_MEMCPY_DEVICE_TO_HOST);
    aclrtMemcpy(meanHost, meanSize, meanDevice, meanSize, ACL_MEMCPY_DEVICE_TO_HOST);
    aclrtMemcpy(rstdHost, rstdSize, rstdDevice, rstdSize, ACL_MEMCPY_DEVICE_TO_HOST);
    aclrtMemcpy(varHost, varSize, varDevice, varSize, ACL_MEMCPY_DEVICE_TO_HOST);
    aclrtMemcpy(normalizeYHost, normalizeYSize, normalizeYDevice, normalizeYSize, ACL_MEMCPY_DEVICE_TO_HOST);

    WriteFile("./output/output_coop_layernormY.bin", layernormYHost, layernormYSize);
    WriteFile("./output/output_coop_mean.bin", meanHost, meanSize);
    WriteFile("./output/output_coop_rstd.bin", rstdHost, rstdSize);
    WriteFile("./output/output_coop_var.bin", varHost, varSize);
    WriteFile("./output/output_coop_normalizeY.bin", normalizeYHost, normalizeYSize);

    bool goldenResult = true;

    // 验证LayerNorm输出
    goldenResult &= CompareResult(layernormYHost, layernormYSize, "coop_layernormY");

    // 验证均值
    goldenResult &= CompareResult(meanHost, meanSize, "coop_mean", 1e-3f);

    // 验证rstd
    goldenResult &= CompareResult(rstdHost, rstdSize, "coop_rstd", 1e-3f);

    // 验证方差
    goldenResult &= CompareResult(varHost, varSize, "coop_var", 1e-3f);

    // 验证Normalize输出
    goldenResult &= CompareResult(normalizeYHost, normalizeYSize, "coop_normalizeY");

    // 验证LayerNorm和Normalize输出是否一致
    int64_t diffCount = 0;
    float maxDiff = 0.0f;
    for (int i = 0; i < totalElements; i++) {
        float a = reinterpret_cast<float*>(layernormYHost)[i];
        float b = reinterpret_cast<float*>(normalizeYHost)[i];
        float diff = std::abs(a - b);
        if (diff > 1e-4f) {
            diffCount++;
            if (diffCount <= 3) {
                printf("  Diff at [%d]: %.8f vs %.8f, diff=%.8f\n", i, a, b, diff);
            }
        }
        maxDiff = std::max(maxDiff, diff);
    }

    if (diffCount > 0) {
        printf("Warning: Found %ld differences, maxDiff=%.8f\n", diffCount, maxDiff);
    } else {
        printf("LayerNorm and Normalize outputs are identical (maxDiff=%.8f)\n", maxDiff);
    }

    aclrtFree(inputXDevice);
    aclrtFree(gammaDevice);
    aclrtFree(betaDevice);
    aclrtFree(layernormYDevice);
    aclrtFree(meanDevice);
    aclrtFree(rstdDevice);
    aclrtFree(varDevice);
    aclrtFree(normalizeYDevice);
    aclrtFree(workspaceDevice);
    aclrtFree(tilingDevice);

    aclrtFreeHost(inputXHost);
    aclrtFreeHost(gammaHost);
    aclrtFreeHost(betaHost);
    aclrtFreeHost(layernormYHost);
    aclrtFreeHost(meanHost);
    aclrtFreeHost(rstdHost);
    aclrtFreeHost(varHost);
    aclrtFreeHost(normalizeYHost);
    aclrtFreeHost(workspaceHost);
    aclrtFreeHost(tilingHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();
    free(tilingBuf);

    // 输出最终结果
    if (goldenResult) {
        printf("test pass!\n");
        return 0;
    } else {
        printf("test failed!\n");
        return -1;
    }
}
