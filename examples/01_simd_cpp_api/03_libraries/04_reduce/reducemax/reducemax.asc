/* !
 * \file reducemax.asc
 * \brief ReduceMax样例：实现对输入矩阵的每列求最大值
 */

#include "acl/acl.h"
#include "data_utils.h"
#include "kernel_operator.h"
#include "tiling/tiling_api.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

namespace optiling {
BEGIN_TILING_DATA_DEF(ReduceCustomTilingData)
TILING_DATA_FIELD_DEF(uint32_t, aLength);            // 归约后输出的长度
TILING_DATA_FIELD_DEF(uint32_t, rLength);            // 归约维度长度
TILING_DATA_FIELD_DEF(uint32_t, xExtent);            // 输入Tensor的元素个数
TILING_DATA_FIELD_DEF(uint32_t, yExtent);            // 输出Tensor的元素个数
TILING_DATA_FIELD_DEF(uint32_t, srcInnerPad);        // 输入是否需要padding：0=不padding，1=padding
TILING_DATA_FIELD_DEF(uint32_t, pattern);            // 归约模式：0=AR(沿第二个维度归约)，1=RA(沿第一个维度归约)
TILING_DATA_FIELD_DEF(uint32_t, isReuseSource);      // 是否复用输入buffer：0=不复用，1=复用
TILING_DATA_FIELD_DEF(uint32_t, sharedTmpBufferSize); // 共享临时buffer大小
END_TILING_DATA_DEF;

REGISTER_TILING_DATA_CLASS(ReduceCustom, ReduceCustomTilingData)
}

void ComputeTiling(const uint32_t aLength, const uint32_t rLength, const uint32_t xExtent,
                  const uint32_t yExtent, const uint32_t srcInnerPad, const uint32_t pattern,
                  const uint32_t isReuseSource, optiling::ReduceCustomTilingData& tiling)
{
    std::vector<int64_t> shapeVec = {aLength, rLength};
    ge::Shape srcShape(shapeVec);
    ge::DataType dataType = ge::DataType::DT_FLOAT;
    AscendC::ReducePattern reducePattern = (pattern == 0) ? AscendC::ReducePattern::AR : AscendC::ReducePattern::RA;
    bool isSrcInnerPad = (srcInnerPad == 1) ? true : false;
    bool isReuse = (isReuseSource == 1) ? true : false;
    uint32_t maxTmpSize;
    uint32_t minTmpSize;
    // srcShape: 输入数据的shape信息
    // dataType: 数据类型，此处为DT_FLOAT（float类型）
    // reducePattern: 归约模式，AR表示沿第二个维度归约，RA表示沿第一个维度归约
    // isSrcInnerPad: 输入是否需要padding，true表示需要，false表示不需要
    // isReuse: 是否复用输入内存，true表示复用，false表示不复用
    // maxTmpSize: 输出参数，返回所需最大临时空间大小
    // minTmpSize: 输出参数，返回所需最小临时空间大小
    AscendC::GetReduceMaxMaxMinTmpSize(srcShape, dataType, reducePattern, isSrcInnerPad, isReuse, maxTmpSize, minTmpSize);
    uint32_t localWorkspaceSize = minTmpSize;
    tiling.set_aLength(aLength);
    tiling.set_rLength(rLength);
    tiling.set_xExtent(xExtent);
    tiling.set_yExtent(yExtent);
    tiling.set_srcInnerPad(srcInnerPad);
    tiling.set_pattern(pattern);
    tiling.set_isReuseSource(isReuseSource);
    tiling.set_sharedTmpBufferSize(localWorkspaceSize);
}

uint8_t* GetTilingBuf(optiling::ReduceCustomTilingData* tilingData)
{
    uint32_t tilingSize = sizeof(optiling::ReduceCustomTilingData);
    uint8_t* buf = (uint8_t*)malloc(tilingSize);
    if (buf == nullptr) {
        return nullptr;
    }
    tilingData->SaveToBuffer(buf, tilingSize);
    return buf;
}

uint8_t* GenerateTiling(uint32_t aLength, uint32_t rLength, uint32_t xExtent, uint32_t yExtent,
                        uint32_t srcInnerPad, uint32_t pattern, uint32_t isReuseSource)
{
    optiling::ReduceCustomTilingData tiling;
    ComputeTiling(aLength, rLength, xExtent, yExtent, srcInnerPad, pattern, isReuseSource, tiling);
    return GetTilingBuf(&tiling);
}

constexpr int32_t BUFFER_NUM = 1;

template <typename TYPE, int32_t EXTENT>
struct ReduceType {
    using T = TYPE;
    constexpr static int32_t extent = EXTENT;
};

template <class Type>
__aicore__ inline constexpr uint32_t Align32B()
{
    const int alignSize = 32 / sizeof(typename Type::T);
    return (Type::extent + alignSize - 1) / alignSize * alignSize;
}

/**
 * @brief ReduceMax归约核函数类
 */
template <class X_TYPE, class Y_TYPE, uint32_t Pattern, uint32_t IsReuseSource>
class KernelReduceMax {
public:
    using T_TYPE = typename X_TYPE::T;

    __aicore__ inline KernelReduceMax() {}

    __aicore__ inline void Init(__gm__ uint8_t* x, __gm__ uint8_t* y, const uint32_t aLength, const uint32_t rLength,
                                const uint32_t srcInnerPad, const uint32_t sharedTmpBufferSize, AscendC::TPipe* pipeIn)
    {
        pipe = pipeIn;
        xGm.SetGlobalBuffer((__gm__ T_TYPE*)x, X_TYPE::extent);
        yGm.SetGlobalBuffer((__gm__ T_TYPE*)y, Y_TYPE::extent);
        pipe->InitBuffer(inQueueX, BUFFER_NUM, Align32B<X_TYPE>() * sizeof(T_TYPE));
        pipe->InitBuffer(outQueueY, BUFFER_NUM, Align32B<Y_TYPE>() * sizeof(T_TYPE));
        if constexpr (IsReuseSource == 0) {
            pipe->InitBuffer(tmpQueue, BUFFER_NUM, sharedTmpBufferSize);
        }

        const uint32_t alignSize = 32 / sizeof(T_TYPE);

        this->aLength = aLength;
        this->rLength = rLength;
        this->aLengthAlign = (aLength + alignSize - 1) / alignSize * alignSize;
        this->rLengthAlign = (rLength + alignSize - 1) / alignSize * alignSize;
        this->srcInnerPad = (srcInnerPad == 1) ? true : false;
    }

    __aicore__ inline void Compute()
    {
        AscendC::LocalTensor<T_TYPE> xLocal = inQueueX.DeQue<T_TYPE>();
        AscendC::LocalTensor<T_TYPE> yLocal = outQueueY.AllocTensor<T_TYPE>();

        constexpr bool isReuse = (IsReuseSource == 1) ? true : false;

        if constexpr (Pattern == 0) {
            uint32_t srcShape[2] = {aLength, rLength};
            if constexpr (isReuse) {
                // ReduceMax: 沿第二个维度归约求最大值（AR模式）
                // T_TYPE: 数据类型
                // Pattern::Reduce::AR: 归约模式，沿第二个维度归约
                // isReuse: 是否复用输入buffer（复用时可节省内存但会修改输入数据）
                // yLocal: 输出张量，存储归约结果
                // xLocal: 输入张量，待归约的数据
                // srcShape: 源数据shape，格式为{行数, 列数}
                // srcInnerPad: 是否需要对输入进行padding对齐
                AscendC::ReduceMax<T_TYPE, AscendC::Pattern::Reduce::AR, isReuse>(yLocal, xLocal, srcShape, true);
            } else {
                AscendC::LocalTensor<uint8_t> sharedTmpBuffer = tmpQueue.AllocTensor<uint8_t>();
                AscendC::ReduceMax<T_TYPE, AscendC::Pattern::Reduce::AR, isReuse>(yLocal, xLocal, sharedTmpBuffer, srcShape, true);
                tmpQueue.FreeTensor(sharedTmpBuffer);
            }
        } else if constexpr (Pattern == 1) {
            uint32_t srcShape[2] = {rLength, aLength};
            if constexpr (isReuse) {
                AscendC::ReduceMax<T_TYPE, AscendC::Pattern::Reduce::RA, isReuse>(yLocal, xLocal, srcShape, true);
            } else {
                AscendC::LocalTensor<uint8_t> sharedTmpBuffer = tmpQueue.AllocTensor<uint8_t>();
                AscendC::ReduceMax<T_TYPE, AscendC::Pattern::Reduce::RA, isReuse>(yLocal, xLocal, sharedTmpBuffer, srcShape, true);
                tmpQueue.FreeTensor(sharedTmpBuffer);
            }
        }

        outQueueY.EnQue<T_TYPE>(yLocal);
        inQueueX.FreeTensor(xLocal);
    }

    __aicore__ inline void Process()
    {
        CopyIn();
        Compute();
        CopyOut();
    }

private:
    __aicore__ inline void CopyIn()
    {
        AscendC::LocalTensor<T_TYPE> xLocal = inQueueX.AllocTensor<T_TYPE>();
        AscendC::DataCopyPadExtParams<T_TYPE> padParams;
        AscendC::DataCopyExtParams copyParams;

        // srcInnerPad=0: 输入不涉及padding，直接整块拷贝
        if (srcInnerPad == 0) {
            copyParams.blockCount = 1;
            copyParams.blockLen = X_TYPE::extent * sizeof(T_TYPE);
            copyParams.srcStride = 0;
            copyParams.dstStride = 0;
            padParams.isPad = 0;
            padParams.leftPadding = 0;
            padParams.rightPadding = 0;
            padParams.paddingValue = 0;
            DataCopyPad(xLocal, xGm, copyParams, padParams);
        } else {
            // srcInnerPad=1: 输入需要padding，按block拷贝并填充padding
            padParams.isPad = 1;
            padParams.leftPadding = 0;
            padParams.paddingValue = 0;
            if constexpr (Pattern == 0) {
                copyParams.blockCount = aLength;
                copyParams.blockLen = rLength * sizeof(T_TYPE);
                copyParams.srcStride = rLength * sizeof(T_TYPE);
                copyParams.dstStride = rLengthAlign * sizeof(T_TYPE) / 32;
                padParams.rightPadding = rLengthAlign - rLength;
            } else {
                padParams.rightPadding = aLengthAlign - aLength;
            }
            DataCopyPad(xLocal, xGm, copyParams, padParams);
        }

        inQueueX.EnQue(xLocal);
    }

    __aicore__ inline void CopyOut()
    {
        AscendC::LocalTensor<T_TYPE> yLocal = outQueueY.DeQue<T_TYPE>();
        AscendC::DataCopyExtParams copyParams;

        // srcInnerPad=0: 输出不涉及padding，直接整块拷贝
        if (srcInnerPad == 0) {
            copyParams.blockCount = 1;
            copyParams.blockLen = Y_TYPE::extent * sizeof(T_TYPE);
            copyParams.srcStride = 0;
            copyParams.dstStride = 0;
            DataCopyPad(yGm, yLocal, copyParams);
        } else {
            // srcInnerPad=1: 输出需要padding，按block拷贝
            copyParams.blockCount = aLength;
            copyParams.blockLen = rLength * sizeof(T_TYPE);
            copyParams.srcStride = rLength * sizeof(T_TYPE);
            copyParams.dstStride = rLengthAlign * sizeof(T_TYPE) / 32;
            DataCopyPad(yGm, yLocal, copyParams);
        }

        outQueueY.FreeTensor(yLocal);
    }

private:
    AscendC::TPipe* pipe;
    AscendC::TQue<AscendC::QuePosition::VECIN, BUFFER_NUM> inQueueX;
    AscendC::TQue<AscendC::QuePosition::VECOUT, BUFFER_NUM> tmpQueue;
    AscendC::TQue<AscendC::QuePosition::VECOUT, BUFFER_NUM> outQueueY;
    AscendC::GlobalTensor<T_TYPE> xGm;
    AscendC::GlobalTensor<T_TYPE> yGm;
    uint32_t aLength;
    uint32_t rLength;
    uint32_t aLengthAlign;
    uint32_t rLengthAlign;
    bool srcInnerPad;
};

/**
 * @brief 核函数Tiling参数结构体，用于传递归约操作的配置参数
 */
struct VecTiling {
    uint32_t aLength;           // 归约后输出的长度
    uint32_t rLength;           // 归约维度长度
    uint32_t xExtent;           // 输入Tensor的元素个数
    uint32_t yExtent;           // 输出Tensor的元素个数
    uint32_t srcInnerPad;       // 输入是否需要padding：0=不padding，1=padding
    uint32_t pattern;           // 归约模式：0=AR(沿第二个维度归约)，1=RA(沿第一个维度归约)
    uint32_t isReuseSource;     // 是否复用输入buffer：0=不复用，1=复用
    uint32_t sharedTmpBufferSize; // 共享临时buffer大小
};

__aicore__ inline void CopyTiling(VecTiling* tiling, __gm__ uint8_t* tilingGM)
{
    uint32_t* ptr = reinterpret_cast<uint32_t*>(tiling);
    auto tiling32 = reinterpret_cast<__gm__ uint32_t*>(tilingGM);

    for (uint32_t i = 0; i < sizeof(VecTiling) / sizeof(uint32_t); i++, ptr++) {
        *ptr = *(tiling32 + i);
    }

    return;
}

extern "C" __global__ __vector__ void reduce_custom(__gm__ uint8_t* src_gm, __gm__ uint8_t* dst_gm, __gm__ uint8_t* workspace, __gm__ uint8_t* tiling)
{
    AscendC::TPipe pipe;
    VecTiling tilingData;
    CopyTiling(&tilingData, tiling);
    typedef ReduceType<float, 4352> xType;
    typedef ReduceType<float, 136> yType;
    KernelReduceMax<xType, yType, 1, 1> op;
    op.Init(src_gm, dst_gm, tilingData.aLength, tilingData.rLength, tilingData.srcInnerPad, tilingData.sharedTmpBufferSize, &pipe);
    op.Process();
}

static bool CompareResult(const void* outputData, uint32_t outSize)
{
    void* goldenData;
    aclrtMallocHost((void**)(&goldenData), outSize);
    size_t goldenSize = outSize;
    bool ret = ReadFile("./output/golden.bin", goldenSize, goldenData, goldenSize);
    if (ret) {
        printf("ReadFile golden.bin success!\n");
    } else {
        printf("test failed!\n");
        return false;
    }
    constexpr float EPS = 1e-4;
    int64_t wrongNum = 0;

    for (size_t i = 0; i < outSize / sizeof(float); i++) {
        float a = (reinterpret_cast<const float*>(outputData))[i];
        float b = (reinterpret_cast<const float*>(goldenData))[i];
        float ae = std::abs(a - b);
        float re = ae / std::abs(b);
        if (ae > EPS && re > EPS) {
            printf("CompareResult golden.bin failed output is %lf, golden is %lf\n", a, b);
            wrongNum++;
        }
    }
    aclrtFreeHost(goldenData);
    if (wrongNum != 0) {
        printf("wrongNum: %ld\n", wrongNum);
        return false;
    } else {
        printf("CompareResult golden.bin success!\n");
        return true;
    }
}

constexpr uint32_t NUM_BLOCKS = 1;
constexpr uint32_t A_LENGTH = 136;
constexpr uint32_t R_LENGTH = 32;
constexpr uint32_t X_EXTENT = 4352;
constexpr uint32_t Y_EXTENT = 136;
constexpr uint32_t SRC_INNER_PAD = 0;
constexpr uint32_t PATTERN = 1;
constexpr uint32_t IS_REUSE_SOURCE = 1;
constexpr uint32_t TILINGDATA_SIZE = 8;
constexpr uint32_t WORKSPACE_SIZE = 16 * 512 * 512;

int32_t main(int32_t argc, char* argv[])
{
    uint32_t numBlocks = NUM_BLOCKS;
    size_t aLength = A_LENGTH;
    size_t rLength = R_LENGTH;
    size_t xExtent = X_EXTENT;
    size_t yExtent = Y_EXTENT;
    size_t srcInnerPad = SRC_INNER_PAD;
    size_t pattern = PATTERN;
    size_t isReuseSource = IS_REUSE_SOURCE;
    size_t inpSize = X_EXTENT * sizeof(float);
    size_t outSize = Y_EXTENT * sizeof(float);
    size_t tilingFileSize = TILINGDATA_SIZE * sizeof(uint32_t);
    size_t workspaceSize = WORKSPACE_SIZE;
    uint8_t* tilingBuf = GenerateTiling(aLength, rLength, xExtent, yExtent, srcInnerPad, pattern, isReuseSource);

    aclInit(nullptr);
    aclrtContext context;
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtCreateContext(&context, deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t *inputHost, *outputHost, *workspaceHost, *tilingHost;
    uint8_t *inputDevice, *outputDevice, *workspaceDevice, *tilingDevice;

    aclrtMallocHost((void**)(&inputHost), inpSize);
    aclrtMallocHost((void**)(&outputHost), outSize);
    aclrtMallocHost((void**)(&workspaceHost), workspaceSize);
    aclrtMallocHost((void**)(&tilingHost), tilingFileSize);
    aclrtMalloc((void**)&inputDevice, inpSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&outputDevice, outSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&workspaceDevice, workspaceSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&tilingDevice, tilingFileSize, ACL_MEM_MALLOC_HUGE_FIRST);

    ReadFile("./input/input_x.bin", inpSize, inputHost, inpSize);
    aclrtMemcpy(tilingDevice, tilingFileSize, tilingBuf, tilingFileSize, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(inputDevice, inpSize, inputHost, inpSize, ACL_MEMCPY_HOST_TO_DEVICE);

    reduce_custom<<<numBlocks, nullptr, stream>>>(inputDevice, outputDevice, workspaceDevice, tilingDevice);
    aclrtSynchronizeStream(stream);
    aclrtMemcpy(outputHost, outSize, outputDevice, outSize, ACL_MEMCPY_DEVICE_TO_HOST);

    WriteFile("./output/output.bin", outputHost, outSize);

    bool goldenResult = CompareResult(outputHost, outSize);
    if (goldenResult) {
        printf("test pass!\n");
    } else {
        printf("test failed!\n");
    }

    aclrtFree(inputDevice);
    aclrtFree(outputDevice);
    aclrtFree(tilingDevice);
    aclrtFreeHost(inputHost);
    aclrtFreeHost(outputHost);
    aclrtFreeHost(tilingHost);
    aclrtFree(workspaceDevice);
    aclrtFreeHost(workspaceHost);

    aclrtDestroyStream(stream);
    aclrtDestroyContext(context);
    aclrtResetDevice(deviceId);
    aclFinalize();

    free(tilingBuf);
    return 0;
}
