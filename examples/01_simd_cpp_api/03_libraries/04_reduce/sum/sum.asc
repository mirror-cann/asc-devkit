/* !
 * \file sum.asc
 * \brief Sum高阶API对矩阵的每行元素求和
 */

#include "acl/acl.h"
#include "data_utils.h"
#include "kernel_operator.h"
#include "tiling/tiling_api.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

struct SumCustomTilingData {
    uint32_t inner;              // 输入数据的内轴长度，需满足32字节对齐
    uint32_t outter;             // 输入数据的外轴长度（行数）
    uint32_t n;                  // 输入数据内轴的实际长度
    uint32_t tmpBufSize;         // 临时空间大小
    uint32_t outInner;           // 输出数据的内轴长度
};

namespace {
constexpr uint32_t PADDING_BYTE = 32U;

uint32_t PaddingAlign(const uint32_t n1, const uint32_t typeSize)
{
    if (typeSize == 0) {
        return 0;
    }
    return (n1 * typeSize + PADDING_BYTE - 1U) / PADDING_BYTE * PADDING_BYTE / typeSize;
}
}

void GenerateTilingData(uint8_t* tilingBuf, const uint32_t m, const uint32_t n)
{
    uint32_t minValue = 0;
    uint32_t maxValue = 0;
    // n: 输入数据的内轴长度（归约维度）
    // sizeof(uint32_t): 数据类型大小
    // false: 是否使用大临时空间，false表示使用最小临时空间
    // maxValue: 输出参数，返回所需最大临时空间大小
    // minValue: 输出参数，返回所需最小临时空间大小
    AscendC::GetSumMaxMinTmpSize(n, sizeof(uint32_t), false, maxValue, minValue);

    SumCustomTilingData* tiling = reinterpret_cast<SumCustomTilingData*>(tilingBuf);

    tiling->outter = m;
    tiling->inner = PaddingAlign(n, sizeof(uint32_t));
    tiling->n = n;
    tiling->tmpBufSize = minValue;

    tiling->outInner = PaddingAlign(m, sizeof(uint32_t));
}

namespace MyCustomKernel {
template <typename T>
class KernelMeanSum {
public:
    __aicore__ inline KernelMeanSum() {}
    __aicore__ inline void Init(__gm__ uint8_t* srcGm, __gm__ uint8_t* dstGm, SumCustomTilingData tilingData,
                                AscendC::TPipe* pipeIn)
    {
        ASCENDC_ASSERT(AscendC::GetBlockNum() != 0, { KERNEL_LOG(KERNEL_ERROR, "block dim can not be zero!"); });

        inner = tilingData.inner;
        outter = tilingData.outter;
        n = tilingData.n;
        tmpBufSize = tilingData.tmpBufSize;
        outInner = tilingData.outInner;

        // 设置参数结构体
        params.inner = inner;
        params.outter = outter;
        params.n = n;

        srcGlobal.SetGlobalBuffer((__gm__ T*)srcGm);
        dstGlobal.SetGlobalBuffer((__gm__ T*)dstGm);

        pipe = pipeIn;
        pipe->InitBuffer(inQueue, 1, inner * outter * sizeof(T));
        pipe->InitBuffer(outQueue, 1, outInner * sizeof(T));
        pipe->InitBuffer(tmpBuf, tmpBufSize);
    }
    __aicore__ inline void Process()
    {
        CopyIn();
        Compute();
        CopyOut();
    }

private:
    __aicore__ inline void CopyIn()
    {
        AscendC::LocalTensor<T> srcLocal = inQueue.AllocTensor<T>();
        AscendC::DataCopy(srcLocal, srcGlobal, inner * outter);
        inQueue.EnQue(srcLocal);
    }
    __aicore__ inline void Compute()
    {
        AscendC::LocalTensor<T> srcLocal = inQueue.DeQue<T>();
        AscendC::LocalTensor<T> dstLocal = outQueue.AllocTensor<T>();

        // 初始化输出为0
        T scalar(0);
        AscendC::Duplicate<T>(dstLocal, scalar, outInner);

        AscendC::LocalTensor<uint8_t> sharedTmpBuffer = tmpBuf.Get<uint8_t>();
        // params: Sum参数结构体，包含inner、outter、n等配置
        AscendC::Sum(dstLocal, srcLocal, sharedTmpBuffer, params);
        tmpBuf.FreeTensor(sharedTmpBuffer);

        outQueue.EnQue<T>(dstLocal);
        inQueue.FreeTensor(srcLocal);
    }
    __aicore__ inline void CopyOut()
    {
        AscendC::LocalTensor<T> dstLocal = outQueue.DeQue<T>();
        AscendC::DataCopy(dstGlobal, dstLocal, outInner);
        outQueue.FreeTensor(dstLocal);
    }

private:
    AscendC::TPipe* pipe;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> inQueue;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> outQueue;
    AscendC::TBuf<AscendC::TPosition::VECCALC> tmpBuf;
    AscendC::GlobalTensor<T> srcGlobal;
    AscendC::GlobalTensor<T> dstGlobal;

    uint32_t inner = 0;
    uint32_t outter = 0;
    uint32_t n = 0;
    uint32_t tmpBufSize = 0;
    uint32_t outInner = 0;

    AscendC::SumParams params;       // Sum API 参数
};
} // namespace MyCustomKernel

extern "C" __global__ __vector__ void sum_custom(__gm__ uint8_t* srcGm, __gm__ uint8_t* dstGm, SumCustomTilingData tiling)
{
    AscendC::TPipe pipe;
    MyCustomKernel::KernelMeanSum<float> op;
    op.Init(srcGm, dstGm, tiling, &pipe);
    op.Process();
}

namespace {
constexpr uint32_t USED_CORE_NUM = 1;
constexpr uint32_t TILINGDATA_SIZE = 5;
constexpr uint32_t M = 3;  // outter
constexpr uint32_t N = 32; // inner_actual
} // namespace

static bool CompareResult(const void* outputData, uint32_t outSize)
{
    void* goldenData;
    aclrtMallocHost((void**)(&goldenData), outSize);
    size_t goldenSize = outSize;
    bool ret = ReadFile("./output/golden.bin", goldenSize, goldenData, goldenSize);
    if (ret) {
        printf("ReadFile golden.bin success!\n");
    } else {
        printf("test failed!\n");
        return false;
    }
    constexpr float EPS = 1e-4;
    int64_t wrongNum = 0;

    for (size_t i = 0; i < outSize / sizeof(float); i++) {
        float a = (reinterpret_cast<const float*>(outputData))[i];
        float b = (reinterpret_cast<const float*>(goldenData))[i];
        float ae = std::abs(a - b);
        float re = ae / std::abs(b);
        if (ae > EPS && re > EPS) {
            printf("CompareResult golden.bin failed output is %lf, golden is %lf\n", a, b);
            wrongNum++;
        }
    }
    aclrtFreeHost(goldenData);
    if (wrongNum != 0) {
        printf("wrongNum: %ld\n", wrongNum);
        return false;
    } else {
        printf("CompareResult golden.bin success!\n");
        return true;
    }
}

int32_t main(int32_t argc, char* argv[])
{
    uint8_t* tiling = nullptr;
    size_t tilingSize = TILINGDATA_SIZE * sizeof(uint32_t);

    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t *xHost, *yHost;
    uint8_t *xDevice, *yDevice;

    aclrtMallocHost((void**)(&tiling), tilingSize);
    GenerateTilingData(tiling, M, N);

    auto tilingData = reinterpret_cast<SumCustomTilingData*>(tiling);

    size_t inputSize = tilingData->outter * tilingData->inner * sizeof(uint32_t);
    size_t outputSize = tilingData->outInner * sizeof(uint32_t);

    aclrtMallocHost((void**)(&xHost), inputSize);
    aclrtMallocHost((void**)(&yHost), outputSize);

    aclrtMalloc((void**)&xDevice, inputSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&yDevice, outputSize, ACL_MEM_MALLOC_HUGE_FIRST);

    ReadFile("./input/input_x.bin", inputSize, xHost, inputSize);

    aclrtMemcpy(xDevice, inputSize, xHost, inputSize, ACL_MEMCPY_HOST_TO_DEVICE);

    sum_custom<<<USED_CORE_NUM, nullptr, stream>>>(xDevice, yDevice, *reinterpret_cast<SumCustomTilingData*>(tiling));

    aclrtSynchronizeStream(stream);

    aclrtMemcpy(yHost, outputSize, yDevice, outputSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", yHost, outputSize);

    bool goldenResult = true;
    goldenResult = CompareResult(yHost, outputSize);

    aclrtFree(xDevice);
    aclrtFree(yDevice);
    aclrtFreeHost(xHost);
    aclrtFreeHost(yHost);
    aclrtFreeHost(tiling);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();

    if (goldenResult) {
        printf("test pass!\n");
    } else {
        printf("test failed!\n");
    }
    return 0;
}
