/* !
 * \file axpy_half_float.asc
 * \brief 基于Axpy高阶API实现half到float类型的向量标量乘加运算
 */

#include "acl/acl.h"
#include "data_utils.h"
#include "kernel_operator.h"
#include "tiling/tiling_api.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

/**
 * @brief Axpy算子Kernel类，实现向量标量乘加运算
 */
class KernelAxpy {
public:
    __aicore__ inline KernelAxpy() {}
    __aicore__ inline void Init(__gm__ uint8_t* srcGm, __gm__ uint8_t* dstGm, uint32_t tmpBufSize, AscendC::TPipe* pipeIn)
    {
        pipe = pipeIn;
        srcGlobal.SetGlobalBuffer((__gm__ half*)srcGm);
        dstGlobal.SetGlobalBuffer((__gm__ float*)dstGm);
        pipe->InitBuffer(outQueueDst, 1, 512 * sizeof(float));
        pipe->InitBuffer(inQueueSrc, 1, 512 * sizeof(half));
        pipe->InitBuffer(buf, tmpBufSize * sizeof(uint8_t));
    }
    __aicore__ inline void Process()
    {
        CopyIn();
        Compute();
        CopyOut();
    }
private:
    __aicore__ inline void CopyIn()
    {
        AscendC::LocalTensor<half> srcLocal = inQueueSrc.AllocTensor<half>();
        AscendC::DataCopy(srcLocal, srcGlobal, 512);
        inQueueSrc.EnQue(srcLocal);
    }
    __aicore__ inline void Compute()
    {
        AscendC::LocalTensor<half> srcLocal = inQueueSrc.DeQue<half>();
        AscendC::LocalTensor<float> dstLocal = outQueueDst.AllocTensor<float>();
        AscendC::LocalTensor<uint8_t> sharedTmpBuffer = buf.Get<uint8_t>();
 
        // 初始化输出tensor为0
        AscendC::Duplicate(dstLocal, 0.0f, 512);
        // 使用Axpy高阶API进行向量标量乘加运算
        // 参数说明：
        //   - dstLocal: 输出Tensor，存储计算结果（float类型）
        //   - srcLocal: 输入Tensor（half类型）
        //   - scalar: 标量值（half类型）
        //   - sharedTmpBuffer: 临时空间，用于类型转换
        //   - calCount: 计算元素个数
        AscendC::Axpy(dstLocal, srcLocal, static_cast<half>(2.0), sharedTmpBuffer, 512);
 
        outQueueDst.EnQue<float>(dstLocal);
        inQueueSrc.FreeTensor(srcLocal);
    }
    __aicore__ inline void CopyOut()
    {
        AscendC::LocalTensor<float> dstLocal = outQueueDst.DeQue<float>();
        AscendC::DataCopy(dstGlobal, dstLocal, 512);
        outQueueDst.FreeTensor(dstLocal);
    }
private:
    AscendC::TPipe* pipe;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> inQueueSrc;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> outQueueDst;
    AscendC::TBuf<AscendC::TPosition::VECCALC> buf;
    AscendC::GlobalTensor<half> srcGlobal;
    AscendC::GlobalTensor<float> dstGlobal;
};

__global__ __vector__ void kernel_vec_ternary_scalar_Axpy_half_2_float(__gm__ uint8_t* srcGm, __gm__ uint8_t* dstGm, uint32_t tmpBufSize)
{
    AscendC::TPipe pipe;
    KernelAxpy op;
    op.Init(srcGm, dstGm, tmpBufSize, &pipe);
    op.Process();
}

int32_t main(int32_t argc, char *argv[]) {
  uint32_t numBlocks = 8;
  size_t inputByteSize = 4 * 128 * sizeof(uint16_t);
  size_t outputByteSize = 4 * 128 * sizeof(uint32_t);

  ge::Shape shape{{512}};
  uint32_t maxValue = 0;
  uint32_t minValue = 0;
  AscendC::GetAxpyMaxMinTmpSize(shape, sizeof(half), false, maxValue, minValue);

  int32_t deviceId = 0;
  aclrtSetDevice(deviceId);
  aclrtStream stream = nullptr;
  aclrtCreateStream(&stream);

  uint8_t *xHost, *outHost;
  uint8_t *xDevice, *outDevice;

  aclrtMallocHost((void **)(&xHost), inputByteSize);
  aclrtMallocHost((void **)(&outHost), outputByteSize);
  aclrtMalloc((void **)&xDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
  aclrtMalloc((void **)&outDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);

  ReadFile("./input/input_x.bin", inputByteSize, xHost, inputByteSize);

  aclrtMemcpy(xDevice, inputByteSize, xHost, inputByteSize,
              ACL_MEMCPY_HOST_TO_DEVICE);

  kernel_vec_ternary_scalar_Axpy_half_2_float<<<numBlocks, nullptr, stream>>>(xDevice, outDevice, minValue);
  aclrtSynchronizeStream(stream);

  aclrtMemcpy(outHost, outputByteSize, outDevice, outputByteSize,
              ACL_MEMCPY_DEVICE_TO_HOST);
  WriteFile("./output/output.bin", outHost, outputByteSize);

  aclrtFree(xDevice);
  aclrtFree(outDevice);
  aclrtFreeHost(xHost);
  aclrtFreeHost(outHost);

  aclrtDestroyStream(stream);
  aclrtResetDevice(deviceId);
  aclFinalize();

  return 0;
}
