/**
 * @file sigmoid.asc
 * @brief 基于Sigmoid高阶API实现Sigmoid激活函数计算
 *
 * Sigmoid 激活函数将输入值映射到 (0, 1) 区间，常用于二分类任务的输出层、
 * 门控机制（如 LSTM、GRU）。本样例展示了 Sigmoid API 的多种调用方式，
 * 通过模板参数 apiMode 控制不同的接口重载形式。
 */

#include "acl/acl.h"
#include "data_utils.h"
#include "kernel_operator.h"
#include "tiling/tiling_api.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

// ============================================================================
// Kernel 实现
// ============================================================================

/**
 * @brief Sigmoid 激活函数计算 Kernel 类
 *
 * 模板参数说明：
 *   - T: 数据类型（如 float、half）
 *   - apiMode: API 调用模式
 *     - 0: Sigmoid(dst, src)
 *     - 1: Sigmoid(dst, src, count)
 *     - 2: Sigmoid(dst, src, tmpBuf, count)
 *     - 3: Sigmoid(dst, src, tmpBuf)
 */
template <typename T, int32_t apiMode>
class KernelSigmoid {
public:
    __aicore__ inline KernelSigmoid() {}

    __aicore__ inline void Init(
        __gm__ uint8_t* srcGm, __gm__ uint8_t* dstGm, uint32_t srcSize, uint32_t calCount, uint32_t tmpBufSize, AscendC::TPipe* pipeIn)
    {
        pipe = pipeIn;
        srcGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(srcGm));
        dstGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(dstGm));

        // 按 32 字节对齐，确保 DataCopy 满足对齐要求
        bufferSize = srcSize;
        count = calCount;
        alignDataSize = AscendC::DivCeil(srcSize * sizeof(T), 32) * 32;
        alignDataNum = alignDataSize / sizeof(T);
        this->tmpBufSize = tmpBufSize;

        pipe->InitBuffer(inQueueX, 1, alignDataSize);
        if (tmpBufSize > 0) {
            pipe->InitBuffer(bufQueue, tmpBufSize);
        }
        pipe->InitBuffer(outQueue, 1, alignDataSize);
    }

    __aicore__ inline void Process()
    {
        CopyIn();
        Compute();
        CopyOut();
    }

private:
    // GM -> LM 数据搬运
    __aicore__ inline void CopyIn()
    {
        AscendC::LocalTensor<T> srcLocal = inQueueX.AllocTensor<T>();
        AscendC::DataCopy(srcLocal, srcGlobal, alignDataNum);
        inQueueX.EnQue(srcLocal);
    }

    // 根据 apiMode 调用不同重载形式的 Sigmoid API
    __aicore__ inline void Compute()
    {
        AscendC::LocalTensor<T> dstLocal = outQueue.AllocTensor<T>();
        AscendC::LocalTensor<T> srcLocal = inQueueX.DeQue<T>();
        T zero = 0;
        AscendC::Duplicate(dstLocal, zero, alignDataNum);

        AscendC::LocalTensor<uint8_t> tmpBuf;
        if (this->tmpBufSize > 0) {
            tmpBuf = bufQueue.Get<uint8_t>();
        }

        // isBasicBlock = false，根据 apiMode 选择不同接口重载
        if constexpr (apiMode == 0) {
            AscendC::Sigmoid<T, false>(dstLocal, srcLocal);
        } else if constexpr (apiMode == 1) {
            AscendC::Sigmoid<T, false>(dstLocal, srcLocal, count);
        } else if constexpr (apiMode == 2) {
            AscendC::Sigmoid<T, false>(dstLocal, srcLocal, tmpBuf, count);
        } else {
            AscendC::Sigmoid<T, false>(dstLocal, srcLocal, tmpBuf);
        }

        outQueue.EnQue<T>(dstLocal);
        inQueueX.FreeTensor(srcLocal);
    }

    // LM -> GM 数据搬运
    __aicore__ inline void CopyOut()
    {
        AscendC::LocalTensor<T> dstLocal = outQueue.DeQue<T>();
        AscendC::DataCopy(dstGlobal, dstLocal, alignDataNum);
        outQueue.FreeTensor(dstLocal);
    }

private:
    AscendC::GlobalTensor<T> srcGlobal;
    AscendC::GlobalTensor<T> dstGlobal;
    AscendC::TPipe* pipe;
    AscendC::TQue<AscendC::QuePosition::VECIN, 1> inQueueX;
    AscendC::TBuf<AscendC::TPosition::VECCALC> bufQueue;
    AscendC::TQue<AscendC::QuePosition::VECOUT, 1> outQueue;
    uint32_t bufferSize = 0;
    uint32_t alignDataSize = 0;
    uint32_t alignDataNum = 0;
    uint32_t count = 0;
    uint32_t tmpBufSize = 0;
};

__global__ __vector__ void sigmoid_custom(
    __gm__ uint8_t* srcGm, __gm__ uint8_t* dstGm, uint32_t srcSize, uint32_t calCount, uint32_t tmpBufSize)
{
    AscendC::TPipe pipe;
    constexpr int32_t apiMode = 0;
    KernelSigmoid<float, apiMode> op;
    op.Init(srcGm, dstGm, srcSize, calCount, tmpBufSize, &pipe);
    op.Process();
}

// ============================================================================
// Host 端
// ============================================================================

static bool CompareResult(const void* outputData, uint32_t outSize)
{
    void* goldenData;
    aclrtMallocHost((void**)(&goldenData), outSize);
    size_t goldenSize = outSize;
    bool ret = ReadFile("./output/golden.bin", goldenSize, goldenData, goldenSize);
    if (ret) {
        printf("ReadFile golden.bin success!\n");
    } else {
        printf("test failed!\n");
        return false;
    }
    constexpr float EPS = 1e-4;
    int64_t wrongNum = 0;

    for (size_t i = 0; i < outSize / sizeof(float); i++) {
        float a = (reinterpret_cast<const float*>(outputData))[i];
        float b = (reinterpret_cast<const float*>(goldenData))[i];
        float ae = std::abs(a - b);
        float re = ae / std::abs(b);
        if (ae > EPS && re > EPS) {
            printf("CompareResult golden.bin failed output is %lf, golden is %lf\n", a, b);
            wrongNum++;
        }
    }
    aclrtFreeHost(goldenData);
    if (wrongNum != 0) {
        return false;
    } else {
        printf("CompareResult golden.bin success!\n");
        return true;
    }
}

int32_t main(int32_t argc, char* argv[])
{
    uint32_t srcSize = 1024;
    uint32_t calCount = 1024;
    uint32_t numBlocks = 1;

    // 获取 Sigmoid 接口所需的最大/最小临时空间大小
    std::vector<int64_t> shapeVec = {srcSize};
    ge::Shape srcShape(shapeVec);
    uint32_t maxValue = 0;
    uint32_t minValue = 0;
    AscendC::GetSigmoidMaxMinTmpSize(srcShape, sizeof(float), false, maxValue, minValue);

    size_t param1FileSize = srcSize * sizeof(float);
    size_t param2FileSize = srcSize * sizeof(float);

    aclInit(nullptr);
    aclrtContext context;
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtCreateContext(&context, deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    // 分配内存并拷贝输入数据
    uint8_t* param1Host;
    uint8_t* param1Device;
    aclrtMallocHost((void**)(&param1Host), param1FileSize);
    aclrtMalloc((void**)&param1Device, param1FileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/input_src.bin", param1FileSize, param1Host, param1FileSize);
    aclrtMemcpy(param1Device, param1FileSize, param1Host, param1FileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    // 分配输出内存
    uint8_t* param2Host;
    uint8_t* param2Device;
    aclrtMallocHost((void**)(&param2Host), param2FileSize);
    aclrtMalloc((void**)&param2Device, param2FileSize, ACL_MEM_MALLOC_HUGE_FIRST);

    sigmoid_custom<<<numBlocks, nullptr, stream>>>(param1Device, param2Device, srcSize, calCount, minValue);
    aclrtSynchronizeStream(stream);

    aclrtFree(param1Device);
    aclrtFreeHost(param1Host);

    // 拷贝输出结果并对比真值
    aclrtMemcpy(param2Host, param2FileSize, param2Device, param2FileSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", param2Host, param2FileSize);

    bool goldenResult = CompareResult(param2Host, param2FileSize);
    if (goldenResult) {
        printf("test pass!\n");
    } else {
        printf("test failed!\n");
    }

    aclrtFree(param2Device);
    aclrtFreeHost(param2Host);

    aclrtDestroyStream(stream);
    aclrtDestroyContext(context);
    aclrtResetDevice(deviceId);
    aclFinalize();

    return 0;
}
