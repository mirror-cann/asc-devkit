/**
 * @file logsoftmax.asc
 * @brief 基于LogSoftMax高阶API实现LogSoftMax激活函数计算
 *
 * LogSoftMax 对输入 Tensor 按行执行 LogSoftMax 计算，计算过程包括：
 * 对 last 轴求行最大值、用输入减去最大值后求 exp、最后将 exp 结果按行归一化并做 log 计算。
 * 该操作数值稳定性优于直接计算 log(softmax(x))，常用于多分类任务的输出层。
 */

#include "acl/acl.h"
#include "data_utils.h"
#include "kernel_operator.h"
#include "tiling/tiling_api.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

// ============================================================================
// Kernel 实现
// ============================================================================

/**
 * @brief LogSoftMax 计算 Kernel 类
 *
 * 模板参数说明：
 *   - T: 数据类型（如 float、half）
 *   - isDataFormatNZ: 是否使用 NZ 数据格式（默认 false）
 */
template <typename T, bool isDataFormatNZ = false>
class KernelLogSoftMax {
public:
    __aicore__ inline KernelLogSoftMax() {}

    __aicore__ inline void Init(
        __gm__ uint8_t* srcGm, __gm__ uint8_t* dstGm, __gm__ uint8_t* shapeInfo, uint32_t tmpBufSize, AscendC::TPipe* pipeIn)
    {
        pipe = pipeIn;
        // 计算每个 Block 的元素数：32 字节 / 数据类型大小
        elementNumPerBlk = 32 / sizeof(T);

        // 设置 Shape 信息全局缓冲区
        AscendC::GlobalTensor<uint32_t> shapeInfoGlobal;
        shapeInfoGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ uint32_t*>(shapeInfo), 8);

        // 设置输入输出全局缓冲区
        srcGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(srcGm));
        dstGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(dstGm));

        // 初始化 Local Memory 缓冲区
        pipe->InitBuffer(inQueueX, 1, height * width * sizeof(T));            // 输入数据队列
        pipe->InitBuffer(maxQueue, 1, height * elementNumPerBlk * sizeof(T)); // 行最大值缓冲区
        pipe->InitBuffer(sumQueue, 1, height * elementNumPerBlk * sizeof(T)); // 行指数和缓冲区
        pipe->InitBuffer(outQueue, 1, height * width * sizeof(T));            // 输出数据队列

        this->tmpBufSize = tmpBufSize;
        if (tmpBufSize > 0) {
            pipe->InitBuffer(tmpQueue, tmpBufSize);
        }
    }

    __aicore__ inline void Process()
    {
        CopyIn();
        Compute();
        CopyOut();
    }

private:
    __aicore__ inline void CopyIn()
    {
        AscendC::LocalTensor<T> srcLocal = inQueueX.AllocTensor<T>();
        AscendC::DataCopy(srcLocal, srcGlobal, height * width);
        inQueueX.EnQue(srcLocal);
    }

    __aicore__ inline void Compute()
    {
        AscendC::LocalTensor<T> srcLocal = inQueueX.DeQue<T>();
        AscendC::LocalTensor<T> sumTempLocal = sumQueue.AllocTensor<T>();
        AscendC::LocalTensor<T> maxTempLocal = maxQueue.AllocTensor<T>();
        AscendC::LocalTensor<T> dstLocal = outQueue.AllocTensor<T>();

        const uint32_t shapeDim = 2;
        AscendC::DataFormat dataFormat{AscendC::DataFormat::ND};
        if (isDataFormatNZ) {
            dataFormat = AscendC::DataFormat::NZ;
        }
        AscendC::SoftMaxShapeInfo srcShape = {height, width, height, width};

        LogSoftMaxTiling tiling;
        AscendC::LocalTensor<uint8_t> sharedTmpBuffer;
        if (tmpBufSize > 0) {
            sharedTmpBuffer = tmpQueue.Get<uint8_t>();
        }

        // 调用 LogSoftMax 高阶 API
        AscendC::LogSoftMax<T, false, isDataFormatNZ>(
            dstLocal, sumTempLocal, maxTempLocal, srcLocal, sharedTmpBuffer, tiling, srcShape);

        outQueue.EnQue<T>(dstLocal);
        sumQueue.FreeTensor(sumTempLocal);
        maxQueue.FreeTensor(maxTempLocal);
        inQueueX.FreeTensor(srcLocal);
    }

    __aicore__ inline void CopyOut()
    {
        AscendC::LocalTensor<T> dstLocal = outQueue.DeQue<T>();
        AscendC::DataCopy(dstGlobal, dstLocal, height * width);
        outQueue.FreeTensor(dstLocal);
    }

private:
    AscendC::TPipe* pipe;
    AscendC::TQue<AscendC::QuePosition::VECIN, 1> inQueueX;
    AscendC::TQue<AscendC::QuePosition::VECOUT, 1> outQueue;
    AscendC::TQue<AscendC::QuePosition::VECIN, 1> sumQueue;
    AscendC::TQue<AscendC::QuePosition::VECIN, 1> maxQueue;
    AscendC::TBuf<AscendC::TPosition::VECCALC> tmpQueue;
    AscendC::GlobalTensor<T> srcGlobal;
    AscendC::GlobalTensor<T> dstGlobal;
    uint32_t elementNumPerBlk = 0;
    uint32_t height = 128;
    uint32_t width = 128;
    uint32_t tmpBufSize = 0;
};

__global__ __vector__ void logsoftmax_custom(__gm__ uint8_t* shapeInfo, __gm__ uint8_t* srcGm, __gm__ uint8_t* dstGm, uint32_t tmpBufSize)
{
    AscendC::TPipe pipe;
    KernelLogSoftMax<float, false> op;
    op.Init(srcGm, dstGm, shapeInfo, tmpBufSize, &pipe);
    op.Process();
}

// ============================================================================
// Host 端
// ============================================================================

static bool CompareResult(const void* outputData, uint32_t outSize)
{
    void* goldenData;
    aclrtMallocHost((void**)(&goldenData), outSize);
    size_t goldenSize = outSize;
    bool ret = ReadFile("./output/golden.bin", goldenSize, goldenData, goldenSize);
    if (ret) {
        printf("ReadFile golden.bin success!\n");
    } else {
        printf("test failed!\n");
        return false;
    }
    constexpr float EPS = 1e-4;
    int64_t wrongNum = 0;

    for (size_t i = 0; i < outSize / sizeof(float); i++) {
        float a = (reinterpret_cast<const float*>(outputData))[i];
        float b = (reinterpret_cast<const float*>(goldenData))[i];
        float ae = std::abs(a - b);
        float re = ae / std::abs(b);
        if (ae > EPS && re > EPS) {
            printf("CompareResult golden.bin failed output is %lf, golden is %lf\n", a, b);
            wrongNum++;
        }
    }
    aclrtFreeHost(goldenData);
    if (wrongNum != 0) {
        return false;
    } else {
        printf("CompareResult golden.bin success!\n");
        return true;
    }
}

int32_t main(int32_t argc, char* argv[])
{
    uint32_t numBlocks = 1;
    constexpr uint32_t height = 128;
    constexpr uint32_t width = 128;

    // 获取 LogSoftMax 接口所需的最小临时空间大小
    std::vector<int64_t> shapeVec = {height, width};
    ge::Shape srcShape(shapeVec);
    uint32_t minValue = AscendC::GetLogSoftMaxMinTmpSize(srcShape, sizeof(float), false);

    size_t param1FileSize = 8 * sizeof(uint32_t);
    size_t param2FileSize = height * width * sizeof(float);
    size_t param3FileSize = height * width * sizeof(float);

    aclInit(nullptr);
    aclrtContext context;
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtCreateContext(&context, deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    // 分配 Host/Device 内存并拷贝 shapeInfo 数据
    uint8_t* param1Host;
    uint8_t* param1Device;
    aclrtMallocHost((void**)(&param1Host), param1FileSize);
    aclrtMalloc((void**)&param1Device, param1FileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/shapeInfo.bin", param1FileSize, param1Host, param1FileSize);
    aclrtMemcpy(param1Device, param1FileSize, param1Host, param1FileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    // 分配 Host/Device 内存并拷贝输入数据
    uint8_t* param2Host;
    uint8_t* param2Device;
    aclrtMallocHost((void**)(&param2Host), param2FileSize);
    aclrtMalloc((void**)&param2Device, param2FileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/input_src.bin", param2FileSize, param2Host, param2FileSize);
    aclrtMemcpy(param2Device, param2FileSize, param2Host, param2FileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    // 分配输出数据的 Host/Device 内存
    uint8_t* param3Host;
    uint8_t* param3Device;
    aclrtMallocHost((void**)(&param3Host), param3FileSize);
    aclrtMalloc((void**)&param3Device, param3FileSize, ACL_MEM_MALLOC_HUGE_FIRST);

    logsoftmax_custom<<<numBlocks, nullptr, stream>>>(param1Device, param2Device, param3Device, minValue);
    aclrtSynchronizeStream(stream);

    aclrtFree(param1Device);
    aclrtFreeHost(param1Host);
    aclrtFree(param2Device);
    aclrtFreeHost(param2Host);

    // 拷贝输出结果到 Host 并写入文件
    aclrtMemcpy(param3Host, param3FileSize, param3Device, param3FileSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", param3Host, param3FileSize);

    bool goldenResult = CompareResult(param3Host, param3FileSize);
    if (goldenResult) {
        printf("test pass!\n");
    } else {
        printf("test failed!\n");
    }

    aclrtFree(param3Device);
    aclrtFreeHost(param3Host);

    aclrtDestroyStream(stream);
    aclrtDestroyContext(context);
    aclrtResetDevice(deviceId);
    aclFinalize();

    return 0;
}
