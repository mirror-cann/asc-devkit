/* !
 * \file swiglu.asc
 * \brief 演示SwiGLU高阶API的Kernel直调用法
 *
 * 本样例展示SwiGLU API的调用方式：
 * - SwiGLU: dst_i = src0_i * Swish(src1_i, beta)，其中 Swish(x) = x/(1+exp(-beta*x))
 * - 支持通过tiling传递计算参数（dataLength、sharedTmpBufferSize）
 */

#include "acl/acl.h"
#include "data_utils.h"
#include "kernel_operator.h"
#include "tiling/tiling_api.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

// ============================================================================
// Tiling 定义（Host 端）
// ============================================================================

namespace optiling {
BEGIN_TILING_DATA_DEF(SwiGLUCustomTilingData)
TILING_DATA_FIELD_DEF(uint32_t, dataLength);
TILING_DATA_FIELD_DEF(uint32_t, sharedTmpBufferSize);
END_TILING_DATA_DEF;

REGISTER_TILING_DATA_CLASS(SwiGLUCustom, SwiGLUCustomTilingData)
} // namespace optiling

void ComputeTiling(const uint32_t dataLength, optiling::SwiGLUCustomTilingData& tiling)
{
    std::vector<int64_t> shapeVec = {dataLength};
    ge::Shape srcShape(shapeVec);
    uint32_t typeSize = sizeof(float);
    uint32_t maxTmpSize;
    uint32_t minTmpSize;

    // 获取SwiGLU接口完成计算所需的最大/最小临时空间大小
    AscendC::GetSwiGLUMaxMinTmpSize(srcShape, typeSize, maxTmpSize, minTmpSize, false);

    tiling.set_dataLength(dataLength);
    tiling.set_sharedTmpBufferSize(minTmpSize);
}

uint8_t* GetTilingBuf(optiling::SwiGLUCustomTilingData* tilingData)
{
    uint32_t tilingSize = sizeof(optiling::SwiGLUCustomTilingData);
    uint8_t* buf = (uint8_t*)malloc(tilingSize);
    tilingData->SaveToBuffer(buf, tilingSize);
    return buf;
}

uint8_t* GenerateTiling(uint32_t dataLength)
{
    optiling::SwiGLUCustomTilingData tiling;
    ComputeTiling(dataLength, tiling);
    return GetTilingBuf(&tiling);
}

// ============================================================================
// Kernel 实现（Device 端）
// ============================================================================

namespace MyCustomKernel {
struct VecTiling {
    uint32_t dataLength;
    uint32_t sharedTmpBufferSize;
};

/**
 * @brief SwiGLU Kernel实现类，支持双输入SwiGLU计算
 */
template <typename T>
class KernelSwiGLU {
public:
    __aicore__ inline KernelSwiGLU() {}

    __aicore__ inline void Init(
        __gm__ uint8_t* src0Gm, __gm__ uint8_t* src1Gm, __gm__ uint8_t* dstGm, uint32_t inputSize,
        uint32_t tmpBufSizeIn, T beta, AscendC::TPipe* pipeIn)
    {
        pipe = pipeIn;
        betaValue = beta;
        dataSize = inputSize;
        tmpBufSize = tmpBufSizeIn;

        src0Global.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(src0Gm), dataSize);
        src1Global.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(src1Gm), dataSize);
        dstGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(dstGm), dataSize);
        pipe->InitBuffer(inQueue0, 1, dataSize * sizeof(T));
        pipe->InitBuffer(inQueue1, 1, dataSize * sizeof(T));
        pipe->InitBuffer(outQueue, 1, dataSize * sizeof(T));
        if (tmpBufSize > 0) {
            pipe->InitBuffer(bufQueue, (tmpBufSizeIn + 31) / 32 * 32);
        }
    }

    __aicore__ inline void Process()
    {
        CopyIn();
        Compute();
        CopyOut();
    }

private:
    __aicore__ inline void CopyIn()
    {
        AscendC::LocalTensor<T> src0Local = inQueue0.AllocTensor<T>();
        AscendC::LocalTensor<T> src1Local = inQueue1.AllocTensor<T>();
        AscendC::DataCopy(src0Local, src0Global, dataSize);
        AscendC::DataCopy(src1Local, src1Global, dataSize);
        inQueue0.EnQue(src0Local);
        inQueue1.EnQue(src1Local);
    }

    __aicore__ inline void Compute()
    {
        AscendC::LocalTensor<T> dstLocal = outQueue.AllocTensor<T>();
        AscendC::LocalTensor<T> src0Local = inQueue0.DeQue<T>();
        AscendC::LocalTensor<T> src1Local = inQueue1.DeQue<T>();

        if (tmpBufSize > 0) {
            // 传入临时buffer：由开发者管理临时空间，全部元素参与计算
            AscendC::LocalTensor<uint8_t> tmpLocal = bufQueue.Get<uint8_t>();
            AscendC::SwiGLU(dstLocal, src0Local, src1Local, betaValue, tmpLocal);
        } else {
            // 基础接口：由框架申请临时空间，全部元素参与计算
            AscendC::SwiGLU(dstLocal, src0Local, src1Local, betaValue);
        }
        outQueue.EnQue<T>(dstLocal);
        inQueue0.FreeTensor(src0Local);
        inQueue1.FreeTensor(src1Local);
    }

    __aicore__ inline void CopyOut()
    {
        AscendC::LocalTensor<T> dstLocal = outQueue.DeQue<T>();
        AscendC::DataCopy(dstGlobal, dstLocal, dataSize);
        outQueue.FreeTensor(dstLocal);
    }

private:
    AscendC::TPipe* pipe = nullptr;
    AscendC::TQue<AscendC::QuePosition::VECIN, 1> inQueue0;
    AscendC::TQue<AscendC::QuePosition::VECIN, 1> inQueue1;
    AscendC::TQue<AscendC::QuePosition::VECOUT, 1> outQueue;
    AscendC::TBuf<AscendC::TPosition::VECCALC> bufQueue;
    AscendC::GlobalTensor<T> src0Global;
    AscendC::GlobalTensor<T> src1Global;
    AscendC::GlobalTensor<T> dstGlobal;
    uint32_t dataSize = 0;
    T betaValue = 0;
    uint32_t tmpBufSize = 0;
};

} // namespace MyCustomKernel

// ---- Tiling 数据拷贝（Device 端） ----
__aicore__ inline void CopyTiling(MyCustomKernel::VecTiling* tiling, __gm__ uint8_t* tilingGM)
{
    uint32_t* ptr = reinterpret_cast<uint32_t*>(tiling);
    auto tiling32 = reinterpret_cast<__gm__ uint32_t*>(tilingGM);

    for (uint32_t i = 0; i < sizeof(MyCustomKernel::VecTiling) / sizeof(uint32_t); i++, ptr++) {
        *ptr = *(tiling32 + i);
    }
    return;
}

// ---- Kernel 入口函数 ----
extern "C" __global__ __vector__ void swiglu_custom(
    __gm__ uint8_t* src0Gm, __gm__ uint8_t* src1Gm, __gm__ uint8_t* dstGm, __gm__ uint8_t* workspace,
    __gm__ uint8_t* tiling)
{
    AscendC::TPipe pipe;
    MyCustomKernel::VecTiling tilingData;
    CopyTiling(&tilingData, tiling);

    constexpr float scalarValue = 1.0f;
    MyCustomKernel::KernelSwiGLU<float> op;
    op.Init(src0Gm, src1Gm, dstGm, tilingData.dataLength, tilingData.sharedTmpBufferSize, scalarValue, &pipe);
    op.Process();
}

// ============================================================================
// Host 端
// ============================================================================

constexpr uint32_t NUM_BLOCKS = 1;
constexpr uint32_t DATALENGTH = 32;
constexpr uint32_t TILINGDATA_SIZE = 2;
constexpr uint32_t WORKSPACE_SIZE = 16 * 1024 * 1024;

static bool CompareResult(const void* outputData, uint32_t outSize)
{
    void* goldenData;
    aclrtMallocHost((void**)(&goldenData), outSize);
    size_t goldenSize = outSize;
    bool ret = ReadFile("./output/golden.bin", goldenSize, goldenData, goldenSize);
    if (!ret) {
        printf("ReadFile golden.bin failed!\n");
        aclrtFreeHost(goldenData);
        return false;
    }
    constexpr float EPS = 1e-4;
    int64_t wrongNum = 0;
    for (size_t i = 0; i < outSize / sizeof(float); i++) {
        float a = (reinterpret_cast<const float*>(outputData))[i];
        float b = (reinterpret_cast<const float*>(goldenData))[i];
        float ae = std::abs(a - b);
        float re = ae / std::abs(b);
        if (ae > EPS && re > EPS) {
            printf("CompareResult golden.bin failed output is %lf, golden is %lf\n", a, b);
            wrongNum++;
        }
    }
    aclrtFreeHost(goldenData);
    if (wrongNum != 0) {
        return false;
    }
    printf("CompareResult golden.bin success!\n");
    return true;
}

int32_t main(int32_t argc, char* argv[])
{
    uint32_t numBlocks = NUM_BLOCKS;
    size_t dataLength = DATALENGTH;
    size_t fileSize = dataLength * sizeof(float);
    size_t tilingFileSize = TILINGDATA_SIZE * sizeof(uint32_t);
    size_t workspaceSize = WORKSPACE_SIZE;
    uint8_t* tilingBuf = GenerateTiling(dataLength);
    bool goldenResult = false;

    // 初始化ACL环境
    aclInit(nullptr);
    aclrtContext context;
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtCreateContext(&context, deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    // 分配内存
    uint8_t *src0Host, *src0Device, *src1Host, *src1Device, *dstHost, *dstDevice;
    uint8_t *workspaceHost, *workspaceDevice, *tilingHost, *tilingDevice;
    aclrtMallocHost((void**)(&src0Host), fileSize);
    aclrtMalloc((void**)&src0Device, fileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMallocHost((void**)(&src1Host), fileSize);
    aclrtMalloc((void**)&src1Device, fileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMallocHost((void**)(&dstHost), fileSize);
    aclrtMalloc((void**)&dstDevice, fileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMallocHost((void**)(&workspaceHost), workspaceSize);
    aclrtMalloc((void**)&workspaceDevice, workspaceSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMallocHost((void**)(&tilingHost), tilingFileSize);
    aclrtMalloc((void**)&tilingDevice, tilingFileSize, ACL_MEM_MALLOC_HUGE_FIRST);

    // 读取输入数据
    ReadFile("./input/input_src0.bin", fileSize, src0Host, fileSize);
    ReadFile("./input/input_src1.bin", fileSize, src1Host, fileSize);

    // 拷贝tiling和输入数据到Device
    aclrtMemcpy(tilingDevice, tilingFileSize, tilingBuf, tilingFileSize, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(src0Device, fileSize, src0Host, fileSize, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(src1Device, fileSize, src1Host, fileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    // 执行Kernel
    swiglu_custom<<<numBlocks, nullptr, stream>>>(src0Device, src1Device, dstDevice, workspaceDevice, tilingDevice);
    aclrtSynchronizeStream(stream);

    // 拷贝输出结果并对比真值
    aclrtMemcpy(dstHost, fileSize, dstDevice, fileSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", dstHost, fileSize);
    goldenResult = CompareResult(dstHost, fileSize);

    // 释放内存和ACL资源
    aclrtFree(src0Device);
    aclrtFreeHost(src0Host);
    aclrtFree(src1Device);
    aclrtFreeHost(src1Host);
    aclrtFree(dstDevice);
    aclrtFreeHost(dstHost);
    aclrtFree(workspaceDevice);
    aclrtFreeHost(workspaceHost);
    aclrtFree(tilingDevice);
    aclrtFreeHost(tilingHost);

    aclrtDestroyStream(stream);
    aclrtDestroyContext(context);
    aclrtResetDevice(deviceId);
    aclFinalize();

    free(tilingBuf);

    if (goldenResult) {
        printf("test pass!\n");
    } else {
        printf("test failed!\n");
    }
    return 0;
}
