/* !
 * \file cumsum.asc
 * \brief CumSum样例实现，对输入张量按行或列进行累加和操作
 */

#include "acl/acl.h"
#include "data_utils.h"
#include "kernel_operator.h"
#include "tiling/tiling_api.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

constexpr int32_t BUFFER_NUM = 1;

template <typename T>
__aicore__ inline uint32_t Align32B(uint32_t len)
{
    const int alignSize = 32 / sizeof(T);
    return (len + alignSize - 1) / alignSize * alignSize;
}

/**
 * @brief CumSum核函数类，实现按行或列进行累加和操作
 * @tparam T 输入输出数据类型
 * @tparam CONFIG CumSum配置参数
 */
template <typename T, const AscendC::CumSumConfig& CONFIG>
class KernelCumSum {
public:
    __aicore__ inline KernelCumSum() {}
    __aicore__ inline void Init(
        __gm__ uint8_t* srcGm, __gm__ uint8_t* dstGm, __gm__ uint8_t* lastRowGm, uint32_t outter, uint32_t inner,
        uint32_t gmOutter, uint32_t gmInner, uint32_t tmpBufSize, AscendC::TPipe* tPipe)
    {
        this->outter = outter;
        this->inner = inner;
        this->gmOutter = gmOutter;
        this->gmInner = gmInner;
        this->pipe = tPipe;

        srcGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(srcGm), this->gmOutter * this->gmInner);
        dstGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(dstGm), this->gmOutter * this->gmInner);
        lastRowGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(lastRowGm), this->gmInner);

        this->pipe->InitBuffer(inQueueX, BUFFER_NUM, Align32B<T>(outter * inner) * sizeof(T));
        this->pipe->InitBuffer(outQueue, BUFFER_NUM, Align32B<T>(outter * inner) * sizeof(T));
        this->pipe->InitBuffer(lastRowQueue, BUFFER_NUM, Align32B<T>(inner) * sizeof(T));
        this->pipe->InitBuffer(buf, tmpBufSize * sizeof(uint8_t));
    }
    __aicore__ inline void Process()
    {
        CopyIn();
        Compute();
        CopyOut();
    }

private:
    __aicore__ inline void CopyIn()
    {
        AscendC::LocalTensor<T> srcLocal = inQueueX.AllocTensor<T>();
        AscendC::DataCopyPadParams dataCopyPadParams;
        for (int32_t i = 0; i < gmOutter; i++) {
            AscendC::DataCopyPad(
                srcLocal[i * inner], srcGlobal[i * gmInner], {1, static_cast<uint16_t>(gmInner * sizeof(T)), 0, 0},
                dataCopyPadParams);
        }

        inQueueX.EnQue(srcLocal);
    }
    __aicore__ inline void Compute()
    {
        AscendC::LocalTensor<T> dstLocal = outQueue.AllocTensor<T>();
        AscendC::LocalTensor<T> lastRowLocal = lastRowQueue.AllocTensor<T>();
        AscendC::LocalTensor<T> srcLocal = inQueueX.DeQue<T>();
        AscendC::LocalTensor<uint8_t> sharedTmpBuffer = buf.Get<uint8_t>();
        // outter：输入数据的外轴长度
        // inner： 输入数据的内轴长度
        const AscendC::CumSumInfo cumSumInfo{outter, inner};
        // 使用CumSum高阶API进行累加和计算
        // 模板参数：
        //   - T: 输入输出数据类型
        //   - CONFIG: CumSum配置参数，包含axis、isReverse等
        // 参数说明：
        //   - dstLocal: 输出Tensor，存储累加结果
        //   - lastRowLocal: 最后一行结果Tensor
        //   - srcLocal: 输入Tensor
        //   - sharedTmpBuffer: 临时空间
        //   - cumSumInfo: 累加配置信息（outter, inner）
        AscendC::CumSum<T, CONFIG>(dstLocal, lastRowLocal, srcLocal, sharedTmpBuffer, cumSumInfo);
        outQueue.EnQue<T>(dstLocal);
        lastRowQueue.EnQue<T>(lastRowLocal);
        inQueueX.FreeTensor(srcLocal);
    }
    __aicore__ inline void CopyOut()
    {
        AscendC::LocalTensor<T> dstLocal = outQueue.DeQue<T>();
        for (int32_t i = 0; i < gmOutter; i++) {
            AscendC::DataCopyPad(
                dstGlobal[i * gmInner], dstLocal[i * inner], {1, static_cast<uint16_t>(gmInner * sizeof(T)), 0, 0});
        }
        outQueue.FreeTensor(dstLocal);
        AscendC::LocalTensor<T> lastRowLocal = lastRowQueue.DeQue<T>();
        AscendC::DataCopyPad(lastRowGlobal, lastRowLocal, {1, static_cast<uint16_t>(gmInner * sizeof(T)), 0, 0});
        lastRowQueue.FreeTensor(lastRowLocal);
    }

private:
    AscendC::GlobalTensor<T> srcGlobal;
    AscendC::GlobalTensor<T> dstGlobal;
    AscendC::GlobalTensor<T> lastRowGlobal;

    AscendC::TQue<AscendC::QuePosition::VECIN, 1> inQueueX;
    AscendC::TQue<AscendC::QuePosition::VECOUT, 1> outQueue;
    AscendC::TQue<AscendC::QuePosition::VECOUT, 1> lastRowQueue;
    AscendC::TBuf<AscendC::QuePosition::VECCALC> buf;

    AscendC::TPipe* pipe;

    uint32_t outter{1};
    uint32_t inner{1};
    uint32_t gmOutter{1};
    uint32_t gmInner{1};
};

__aicore__ constexpr AscendC::CumSumConfig GetConfig() { return {0, 0, 1, static_cast<AscendC::CumSumAlgorithm>(0)}; }

constexpr AscendC::CumSumConfig CONFIG = GetConfig();

__global__ __vector__ void cumsum_custom(
    __gm__ uint8_t* srcGm, __gm__ uint8_t* dstGm, __gm__ uint8_t* lastRowGm, __gm__ uint8_t* tilingGm,
    uint32_t tmpBufSize)
{
    AscendC::TPipe tPipe;
    KernelCumSum<float, CONFIG> op;
    constexpr uint32_t outer = 32;
    constexpr uint32_t inner = 160;
    constexpr uint32_t GM_OUTER = 32;
    constexpr uint32_t GM_INNER = 160;
    op.Init(srcGm, dstGm, lastRowGm, outer, inner, GM_OUTER, GM_INNER, tmpBufSize, &tPipe);
    op.Process();
}

static bool CompareResult(const void* outputData, int64_t outSize, std::string goldenName)
{
    void* goldenData;
    aclrtMallocHost((void**)(&goldenData), outSize);
    size_t goldenSize = outSize;
    bool ret = ReadFile("./output/golden_output_" + goldenName + ".bin", goldenSize, goldenData, goldenSize);
    if (ret) {
        printf("ReadFile golden_output_%s.bin success!\n", goldenName.c_str());
    } else {
        aclrtFreeHost(goldenData);
        return false;
    }
    constexpr float EPS = 1e-5;
    int64_t wrongNum = 0;

    for (int i = 0; i < outSize / sizeof(float); i++) {
        float a = (reinterpret_cast<const float*>(outputData))[i];
        float b = (reinterpret_cast<const float*>(goldenData))[i];
        float ae = std::abs(a - b);
        float re = ae / std::abs(b);
        if (ae > EPS && re > EPS) {
            printf(
                "CompareResult golden_output_%s.bin failed output is %lf, golden is %lf\n", goldenName.c_str(), a, b);
            wrongNum++;
        }
    }
    aclrtFreeHost(goldenData);
    if (wrongNum != 0) {
        return false;
    } else {
        printf("CompareResult golden_output_%s.bin success!\n", goldenName.c_str());
        return true;
    }
}

int32_t main(int32_t argc, char* argv[])
{
    size_t param1FileSize = 5120 * sizeof(float);
    size_t param2FileSize = 5120 * sizeof(float);
    size_t param3FileSize = 160 * sizeof(float);
    size_t param4FileSize = 2 * sizeof(uint32_t);
    uint32_t numBlocks = 1;

    ge::Shape shape{{32, 160}};
    uint32_t maxValue = 0;
    uint32_t minValue = 0;
    AscendC::GetCumSumMaxMinTmpSize(
        shape, sizeof(float), /*isReuseSource*/ true, /*isLastAxis*/ false, maxValue, minValue);

    aclInit(nullptr);
    aclrtContext context;
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtCreateContext(&context, deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t* param1Host;
    uint8_t* param1Device;
    aclrtMallocHost((void**)(&param1Host), param1FileSize);
    aclrtMalloc((void**)&param1Device, param1FileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/input_x.bin", param1FileSize, param1Host, param1FileSize);
    aclrtMemcpy(param1Device, param1FileSize, param1Host, param1FileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t* param2Host;
    uint8_t* param2Device;
    aclrtMallocHost((void**)(&param2Host), param2FileSize);
    aclrtMalloc((void**)&param2Device, param2FileSize, ACL_MEM_MALLOC_HUGE_FIRST);

    uint8_t* param3Host;
    uint8_t* param3Device;
    aclrtMallocHost((void**)(&param3Host), param3FileSize);
    aclrtMalloc((void**)&param3Device, param3FileSize, ACL_MEM_MALLOC_HUGE_FIRST);

    uint8_t* param4Host;
    uint8_t* param4Device;
    aclrtMallocHost((void**)(&param4Host), param4FileSize);
    aclrtMalloc((void**)&param4Device, param4FileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/input_tiling.bin", param4FileSize, param4Host, param4FileSize);
    aclrtMemcpy(param4Device, param4FileSize, param4Host, param4FileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    cumsum_custom<<<numBlocks, nullptr, stream>>>(param1Device, param2Device, param3Device, param4Device, minValue);
    aclrtSynchronizeStream(stream);

    aclrtFree(param1Device);
    aclrtFreeHost(param1Host);
    aclrtFree(param4Device);
    aclrtFreeHost(param4Host);

    aclrtMemcpy(param2Host, param2FileSize, param2Device, param2FileSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output_result.bin", param2Host, param2FileSize);
    aclrtFree(param2Device);

    aclrtMemcpy(param3Host, param3FileSize, param3Device, param3FileSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output_last_row.bin", param3Host, param3FileSize);
    aclrtFree(param3Device);

    bool goldenResult = true;
    goldenResult &= CompareResult(param2Host, param2FileSize, "result");
    goldenResult &= CompareResult(param3Host, param3FileSize, "last_row");
    if (goldenResult) {
        printf("test pass!\n");
    } else {
        printf("test failed!\n");
    }

    aclrtFreeHost(param2Host);
    aclrtFreeHost(param3Host);

    aclrtDestroyStream(stream);
    aclrtDestroyContext(context);
    aclrtResetDevice(deviceId);
    aclFinalize();

    return 0;
}
