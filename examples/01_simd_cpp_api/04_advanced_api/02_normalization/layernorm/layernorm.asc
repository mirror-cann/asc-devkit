/* !
 * \file layernorm.asc
 * \brief 调用LayerNorm、LayerNormGrad、LayerNormGradBeta三个高阶API实现LayerNorm的完整前向和反向传播
 */

#include "acl/acl.h"
#include "data_utils.h"
#include "kernel_operator.h"
#include "tiling/tiling_api.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

namespace optiling {
// 融合Tiling数据结构
BEGIN_TILING_DATA_DEF(LayerNormTilingData)
TILING_DATA_FIELD_DEF_STRUCT(LayerNormTiling, layernormTilingData);
TILING_DATA_FIELD_DEF_STRUCT(LayerNormGradTiling, layernormGradTilingData);
TILING_DATA_FIELD_DEF_STRUCT(LayerNormGradBetaTiling, layernormGradBetaTilingData);
TILING_DATA_FIELD_DEF(float, epsilon);
END_TILING_DATA_DEF;

REGISTER_TILING_DATA_CLASS(LayerNorm, LayerNormTilingData)
} // namespace optiling

// 计算融合Tiling
void ComputeTiling(
    const uint32_t bLength, const uint32_t sLength, const uint32_t hLength, optiling::LayerNormTilingData& tiling)
{
    ge::Shape geShape({bLength, sLength, hLength, hLength});

    bool isReuseSource = false;

    // 分别获取三个接口的最大/最小临时空间
    uint32_t maxTmpSize1 = 0, minTmpSize1 = 0; // LayerNorm
    uint32_t maxTmpSize2 = 0, minTmpSize2 = 0; // LayerNormGrad
    uint32_t maxTmpSize3 = 0, minTmpSize3 = 0; // LayerNormGradBeta

    AscendC::GetLayerNormMaxMinTmpSize(geShape, sizeof(float), isReuseSource, maxTmpSize1, minTmpSize1);
    AscendC::GetLayerNormGradMaxMinTmpSize(geShape, sizeof(float), isReuseSource, maxTmpSize2, minTmpSize2);
    AscendC::GetLayerNormGradBetaMaxMinTmpSize(geShape, sizeof(float), isReuseSource, maxTmpSize3, minTmpSize3);

    // 计算统一的工作空间大小，选择满足所有接口的最小值
    uint32_t minRequired = std::max(std::max(minTmpSize1, minTmpSize2), minTmpSize3);
    uint32_t localWorkspaceSize = minRequired;

    // LayerNorm Tiling
    AscendC::GetLayerNormNDTilingInfo(
        geShape, localWorkspaceSize, sizeof(float), isReuseSource, tiling.layernormTilingData);

    // LayerNormGrad Tiling
    AscendC::GetLayerNormGradNDTilingInfo(
        geShape, localWorkspaceSize, sizeof(float), isReuseSource, tiling.layernormGradTilingData);

    // LayerNormGradBeta Tiling
    AscendC::GetLayerNormGradBetaNDTilingInfo(
        geShape, localWorkspaceSize, sizeof(float), isReuseSource, tiling.layernormGradBetaTilingData);

    // 设置LayerNorm公式中的极小常数epsilon，防止方差为0时出现除零错误
    tiling.set_epsilon(0.0001f);
}

uint8_t* GetTilingBuf(optiling::LayerNormTilingData* tilingData)
{
    uint32_t tilingSize = sizeof(optiling::LayerNormTilingData);
    uint8_t* buf = (uint8_t*)malloc(tilingSize);
    tilingData->SaveToBuffer(buf, tilingSize);
    return buf;
}

uint8_t* GenerateTiling(uint32_t bLength, uint32_t sLength, uint32_t hLength)
{
    optiling::LayerNormTilingData tiling;
    ComputeTiling(bLength, sLength, hLength, tiling);
    return GetTilingBuf(&tiling);
}

namespace MyCustomKernel {
struct VecTiling {
    LayerNormTiling layernormTilingData;
    LayerNormGradTiling layernormGradTilingData;
    LayerNormGradBetaTiling layernormGradBetaTilingData;
    float epsilon = 0;
};

class KernelLayerNorm {
public:
    __aicore__ inline KernelLayerNorm() {}

    __aicore__ inline void Init(
        __gm__ uint8_t* inputXGm, __gm__ uint8_t* gammaGm, __gm__ uint8_t* betaGm, __gm__ uint8_t* dyGm,
        __gm__ uint8_t* outputYGm, __gm__ uint8_t* outputMeanGm, __gm__ uint8_t* outputVarGm,
        __gm__ uint8_t* outputPdXGm, __gm__ uint8_t* outputPdGammaGm, __gm__ uint8_t* outputPdBetaGm,
        VecTiling tilingData, AscendC::TPipe* pipeIn)
    {
        pipe = pipeIn;
        this->epsilon = tilingData.epsilon;
        layernormTiling_ = tilingData.layernormTilingData;
        layernormGradTiling_ = tilingData.layernormGradTilingData;
        layernormGradBetaTiling_ = tilingData.layernormGradBetaTilingData;

        this->bLength = layernormTiling_.bLength;
        this->sLength = layernormTiling_.sLength;
        this->hLength = layernormTiling_.hLength;

        bshLength = bLength * sLength * hLength;
        bsLength = bLength * sLength;

        inputXGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(inputXGm), bshLength);
        gammaGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(gammaGm), hLength);
        betaGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(betaGm), hLength);
        dyGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(dyGm), bshLength);

        outputYGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(outputYGm), bshLength);
        outputMeanGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(outputMeanGm), bsLength);
        outputVarGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(outputVarGm), bsLength);
        outputPdXGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(outputPdXGm), bshLength);
        outputPdGammaGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(outputPdGammaGm), hLength);
        outputPdBetaGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(outputPdBetaGm), hLength);

        pipe->InitBuffer(inQueueX, 1, sizeof(float) * bshLength);
        pipe->InitBuffer(inQueueGamma, 1, sizeof(float) * hLength);
        pipe->InitBuffer(inQueueBeta, 1, sizeof(float) * hLength);
        pipe->InitBuffer(inQueueDy, 1, sizeof(float) * bshLength);

        // LayerNorm输出队列
        pipe->InitBuffer(outQueueY, 1, sizeof(float) * bshLength);
        pipe->InitBuffer(outQueueMean, 1, sizeof(float) * bsLength);
        pipe->InitBuffer(outQueueVar, 1, sizeof(float) * bsLength);

        // LayerNormGrad输出队列
        pipe->InitBuffer(outQueuePdX, 1, sizeof(float) * bshLength);

        // LayerNormGradBeta输出队列
        pipe->InitBuffer(outQueuePdGamma, 1, sizeof(float) * hLength);
        pipe->InitBuffer(outQueuePdBeta, 1, sizeof(float) * hLength);

        pipe->InitBuffer(tmpQueueResForGamma, 1, sizeof(float) * bshLength);
    }

    __aicore__ inline void Process()
    {
        CopyIn();
        Compute();
        CopyOut();
    }

private:
    __aicore__ inline void CopyIn()
    {
        AscendC::LocalTensor<float> xLocal = inQueueX.AllocTensor<float>();
        AscendC::DataCopy(xLocal, inputXGlobal, bshLength);
        inQueueX.EnQue(xLocal);

        AscendC::LocalTensor<float> gammaLocal = inQueueGamma.AllocTensor<float>();
        AscendC::DataCopy(gammaLocal, gammaGlobal, hLength);
        inQueueGamma.EnQue(gammaLocal);

        AscendC::LocalTensor<float> betaLocal = inQueueBeta.AllocTensor<float>();
        AscendC::DataCopy(betaLocal, betaGlobal, hLength);
        inQueueBeta.EnQue(betaLocal);

        AscendC::LocalTensor<float> dyLocal = inQueueDy.AllocTensor<float>();
        AscendC::DataCopy(dyLocal, dyGlobal, bshLength);
        inQueueDy.EnQue(dyLocal);
    }

    __aicore__ inline void Compute()
    {
        AscendC::LocalTensor<float> xLocal = inQueueX.DeQue<float>();
        AscendC::LocalTensor<float> gammaLocal = inQueueGamma.DeQue<float>();
        AscendC::LocalTensor<float> betaLocal = inQueueBeta.DeQue<float>();
        AscendC::LocalTensor<float> dyLocal = inQueueDy.DeQue<float>();

        // LayerNorm输出
        AscendC::LocalTensor<float> yLocal = outQueueY.AllocTensor<float>();
        AscendC::LocalTensor<float> meanLocal = outQueueMean.AllocTensor<float>();
        AscendC::LocalTensor<float> varLocal = outQueueVar.AllocTensor<float>();

        // LayerNormGrad输出
        AscendC::LocalTensor<float> pdXLocal = outQueuePdX.AllocTensor<float>();

        // LayerNormGradBeta输出
        AscendC::LocalTensor<float> pdGammaLocal = outQueuePdGamma.AllocTensor<float>();
        AscendC::LocalTensor<float> pdBetaLocal = outQueuePdBeta.AllocTensor<float>();

        // 中间结果
        AscendC::LocalTensor<float> resForGammaLocal = tmpQueueResForGamma.AllocTensor<float>();

        // ==================== 第1步：LayerNorm 前向计算 ====================
        // 输入：inputX, gamma, beta
        // 输出：outputY, mean, variance
        AscendC::LayerNorm<float, false>(
            yLocal, meanLocal, varLocal, xLocal, gammaLocal, betaLocal, epsilon, layernormTiling_);

        // ==================== 第2步：LayerNormGrad 反向计算 ====================
        // 输入：inputDy, inputX, variance, mean, gamma
        // 输出：pd_x, resForGamma
        AscendC::LayerNormGrad<float, false>(
            pdXLocal, resForGammaLocal, dyLocal, xLocal, varLocal, meanLocal, gammaLocal, epsilon,
            layernormGradTiling_);

        // ==================== 第3步：LayerNormGradBeta gamma/beta梯度计算 ====================
        // 输入：inputDy, resForGamma
        // 输出：pd_gamma, pd_beta
        AscendC::LayerNormGradBeta<float, false>(
            pdGammaLocal, pdBetaLocal, resForGammaLocal, dyLocal, layernormGradBetaTiling_);

        outQueueY.EnQue<float>(yLocal);
        outQueueMean.EnQue<float>(meanLocal);
        outQueueVar.EnQue<float>(varLocal);
        outQueuePdX.EnQue<float>(pdXLocal);
        outQueuePdGamma.EnQue<float>(pdGammaLocal);
        outQueuePdBeta.EnQue<float>(pdBetaLocal);

        inQueueX.FreeTensor(xLocal);
        inQueueGamma.FreeTensor(gammaLocal);
        inQueueBeta.FreeTensor(betaLocal);
        inQueueDy.FreeTensor(dyLocal);
    }

    __aicore__ inline void CopyOut()
    {
        // LayerNorm输出
        AscendC::LocalTensor<float> yLocal = outQueueY.DeQue<float>();
        AscendC::LocalTensor<float> meanLocal = outQueueMean.DeQue<float>();
        AscendC::LocalTensor<float> varLocal = outQueueVar.DeQue<float>();

        // LayerNormGrad输出
        AscendC::LocalTensor<float> pdXLocal = outQueuePdX.DeQue<float>();

        // LayerNormGradBeta输出
        AscendC::LocalTensor<float> pdGammaLocal = outQueuePdGamma.DeQue<float>();
        AscendC::LocalTensor<float> pdBetaLocal = outQueuePdBeta.DeQue<float>();

        AscendC::DataCopy(outputYGlobal, yLocal, bshLength);
        AscendC::DataCopy(outputMeanGlobal, meanLocal, bsLength);
        AscendC::DataCopy(outputVarGlobal, varLocal, bsLength);
        AscendC::DataCopy(outputPdXGlobal, pdXLocal, bshLength);
        AscendC::DataCopy(outputPdGammaGlobal, pdGammaLocal, hLength);
        AscendC::DataCopy(outputPdBetaGlobal, pdBetaLocal, hLength);

        outQueueY.FreeTensor(yLocal);
        outQueueMean.FreeTensor(meanLocal);
        outQueueVar.FreeTensor(varLocal);
        outQueuePdX.FreeTensor(pdXLocal);
        outQueuePdGamma.FreeTensor(pdGammaLocal);
        outQueuePdBeta.FreeTensor(pdBetaLocal);
    }

private:
    AscendC::GlobalTensor<float> inputXGlobal;
    AscendC::GlobalTensor<float> gammaGlobal;
    AscendC::GlobalTensor<float> betaGlobal;
    AscendC::GlobalTensor<float> dyGlobal;

    AscendC::GlobalTensor<float> outputYGlobal;
    AscendC::GlobalTensor<float> outputMeanGlobal;
    AscendC::GlobalTensor<float> outputVarGlobal;
    AscendC::GlobalTensor<float> outputPdXGlobal;
    AscendC::GlobalTensor<float> outputPdGammaGlobal;
    AscendC::GlobalTensor<float> outputPdBetaGlobal;

    AscendC::TPipe* pipe;

    AscendC::TQue<AscendC::TPosition::VECIN, 1> inQueueX;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> inQueueGamma;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> inQueueBeta;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> inQueueDy;

    AscendC::TQue<AscendC::TPosition::VECOUT, 1> outQueueY;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> outQueueMean;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> outQueueVar;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> outQueuePdX;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> outQueuePdGamma;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> outQueuePdBeta;

    AscendC::TQue<AscendC::TPosition::VECOUT, 1> tmpQueueResForGamma;

    uint32_t bLength;
    uint32_t sLength;
    uint32_t hLength;
    float epsilon;

    LayerNormTiling layernormTiling_;
    LayerNormGradTiling layernormGradTiling_;
    LayerNormGradBetaTiling layernormGradBetaTiling_;

    uint32_t bshLength;
    uint32_t bsLength;
};
} // namespace MyCustomKernel

__aicore__ inline void CopyTiling(MyCustomKernel::VecTiling* tiling, __gm__ uint8_t* tilingGM)
{
    uint32_t* ptr = reinterpret_cast<uint32_t*>(tiling);
    auto tiling32 = reinterpret_cast<__gm__ uint32_t*>(tilingGM);

    for (int i = 0; i < sizeof(MyCustomKernel::VecTiling) / sizeof(uint32_t); i++, ptr++) {
        *ptr = *(tiling32 + i);
    }
    return;
}

__global__ __vector__ void layernorm_custom(
    __gm__ uint8_t* inputXGm, __gm__ uint8_t* gammaGm, __gm__ uint8_t* betaGm, __gm__ uint8_t* dyGm,
    __gm__ uint8_t* outputYGm, __gm__ uint8_t* outputMeanGm, __gm__ uint8_t* outputVarGm, __gm__ uint8_t* outputPdXGm,
    __gm__ uint8_t* outputPdGammaGm, __gm__ uint8_t* outputPdBetaGm, __gm__ uint8_t* workspace, __gm__ uint8_t* tiling)
{
    AscendC::TPipe pipe;
    MyCustomKernel::VecTiling tilingData;
    CopyTiling(&tilingData, tiling);

    MyCustomKernel::KernelLayerNorm op;
    op.Init(
        inputXGm, gammaGm, betaGm, dyGm, outputYGm, outputMeanGm, outputVarGm, outputPdXGm, outputPdGammaGm,
        outputPdBetaGm, tilingData, &pipe);
    op.Process();
}

constexpr uint32_t BLENGTH = 2;
constexpr uint32_t SLENGTH = 32;
constexpr uint32_t HLENGTH = 16;
constexpr uint32_t NUM_BLOCKS = 1;
constexpr uint32_t TILINGDATA_SIZE = 100;
constexpr uint32_t WORKSPACE_SIZE = 16 * 1024 * 1024;

static bool CompareResult(const void* outputData, int64_t outSize, std::string goldenName)
{
    void* goldenData;
    aclrtMallocHost((void**)(&goldenData), outSize);
    size_t goldenSize = outSize;
    bool ret = ReadFile("./output/golden_" + goldenName + ".bin", goldenSize, goldenData, goldenSize);
    if (ret) {
        printf("ReadFile golden_%s.bin success!\n", goldenName.c_str());
    } else {
        aclrtFreeHost(goldenData);
        return false;
    }
    constexpr float EPS = 1e-4;
    int64_t wrongNum = 0;

    for (int i = 0; i < outSize / sizeof(float); i++) {
        float a = (reinterpret_cast<const float*>(outputData))[i];
        float b = (reinterpret_cast<const float*>(goldenData))[i];
        float ae = std::abs(a - b);
        float re = ae / std::abs(b);
        if (ae > EPS && re > EPS) {
            printf("CompareResult golden_%s.bin failed output is %lf, golden is %lf\n", goldenName.c_str(), a, b);
            wrongNum++;
        }
    }
    aclrtFreeHost(goldenData);
    if (wrongNum != 0) {
        return false;
    } else {
        printf("CompareResult golden_%s.bin success!\n", goldenName.c_str());
        return true;
    }
}

int32_t main(int32_t argc, char* argv[])
{
    uint32_t numBlocks = NUM_BLOCKS;

    size_t workspaceSize = WORKSPACE_SIZE;
    size_t inputXSize = BLENGTH * SLENGTH * HLENGTH * sizeof(float);
    size_t gammaSize = HLENGTH * sizeof(float);
    size_t betaSize = HLENGTH * sizeof(float);
    size_t dySize = BLENGTH * SLENGTH * HLENGTH * sizeof(float);
    size_t outputYSize = BLENGTH * SLENGTH * HLENGTH * sizeof(float);
    size_t outputMeanSize = BLENGTH * SLENGTH * sizeof(float);
    size_t outputVarSize = BLENGTH * SLENGTH * sizeof(float);
    size_t outputPdXSize = BLENGTH * SLENGTH * HLENGTH * sizeof(float);
    size_t outputPdGammaSize = HLENGTH * sizeof(float);
    size_t outputPdBetaSize = HLENGTH * sizeof(float);
    size_t tilingFileSize = TILINGDATA_SIZE * sizeof(uint32_t);

    uint8_t* tilingBuf = GenerateTiling(BLENGTH, SLENGTH, HLENGTH);

    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t *inputXHost, *gammaHost, *betaHost, *dyHost;
    uint8_t *outputYHost, *outputMeanHost, *outputVarHost, *outputPdXHost, *outputPdGammaHost, *outputPdBetaHost;
    uint8_t *workspaceHost, *tilingHost;

    aclrtMallocHost((void**)(&inputXHost), inputXSize);
    aclrtMallocHost((void**)(&gammaHost), gammaSize);
    aclrtMallocHost((void**)(&betaHost), betaSize);
    aclrtMallocHost((void**)(&dyHost), dySize);
    aclrtMallocHost((void**)(&outputYHost), outputYSize);
    aclrtMallocHost((void**)(&outputMeanHost), outputMeanSize);
    aclrtMallocHost((void**)(&outputVarHost), outputVarSize);
    aclrtMallocHost((void**)(&outputPdXHost), outputPdXSize);
    aclrtMallocHost((void**)(&outputPdGammaHost), outputPdGammaSize);
    aclrtMallocHost((void**)(&outputPdBetaHost), outputPdBetaSize);
    aclrtMallocHost((void**)(&workspaceHost), workspaceSize);
    aclrtMallocHost((void**)(&tilingHost), tilingFileSize);

    uint8_t *inputXDevice, *gammaDevice, *betaDevice, *dyDevice;
    uint8_t *outputYDevice, *outputMeanDevice, *outputVarDevice, *outputPdXDevice, *outputPdGammaDevice,
        *outputPdBetaDevice;
    uint8_t *workspaceDevice, *tilingDevice;

    aclrtMalloc((void**)&inputXDevice, inputXSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&gammaDevice, gammaSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&betaDevice, betaSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&dyDevice, dySize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&outputYDevice, outputYSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&outputMeanDevice, outputMeanSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&outputVarDevice, outputVarSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&outputPdXDevice, outputPdXSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&outputPdGammaDevice, outputPdGammaSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&outputPdBetaDevice, outputPdBetaSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&workspaceDevice, workspaceSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&tilingDevice, tilingFileSize, ACL_MEM_MALLOC_HUGE_FIRST);

    ReadFile("./input/input_inputX.bin", inputXSize, inputXHost, inputXSize);
    ReadFile("./input/input_gamma.bin", gammaSize, gammaHost, gammaSize);
    ReadFile("./input/input_beta.bin", betaSize, betaHost, betaSize);
    ReadFile("./input/input_dy.bin", dySize, dyHost, dySize);

    aclrtMemcpy(inputXDevice, inputXSize, inputXHost, inputXSize, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(gammaDevice, gammaSize, gammaHost, gammaSize, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(betaDevice, betaSize, betaHost, betaSize, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(dyDevice, dySize, dyHost, dySize, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(workspaceDevice, workspaceSize, workspaceHost, workspaceSize, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(tilingDevice, tilingFileSize, tilingBuf, tilingFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    // 启动核函数
    layernorm_custom<<<numBlocks, nullptr, stream>>>(
        inputXDevice, gammaDevice, betaDevice, dyDevice, outputYDevice, outputMeanDevice, outputVarDevice,
        outputPdXDevice, outputPdGammaDevice, outputPdBetaDevice, workspaceDevice, tilingDevice);

    aclrtSynchronizeStream(stream);

    aclrtMemcpy(outputYHost, outputYSize, outputYDevice, outputYSize, ACL_MEMCPY_DEVICE_TO_HOST);
    aclrtMemcpy(outputMeanHost, outputMeanSize, outputMeanDevice, outputMeanSize, ACL_MEMCPY_DEVICE_TO_HOST);
    aclrtMemcpy(outputVarHost, outputVarSize, outputVarDevice, outputVarSize, ACL_MEMCPY_DEVICE_TO_HOST);
    aclrtMemcpy(outputPdXHost, outputPdXSize, outputPdXDevice, outputPdXSize, ACL_MEMCPY_DEVICE_TO_HOST);
    aclrtMemcpy(
        outputPdGammaHost, outputPdGammaSize, outputPdGammaDevice, outputPdGammaSize, ACL_MEMCPY_DEVICE_TO_HOST);
    aclrtMemcpy(outputPdBetaHost, outputPdBetaSize, outputPdBetaDevice, outputPdBetaSize, ACL_MEMCPY_DEVICE_TO_HOST);

    WriteFile("./output/outputY.bin", outputYHost, outputYSize);
    WriteFile("./output/outputMean.bin", outputMeanHost, outputMeanSize);
    WriteFile("./output/outputVar.bin", outputVarHost, outputVarSize);
    WriteFile("./output/outputPdX.bin", outputPdXHost, outputPdXSize);
    WriteFile("./output/outputPdGamma.bin", outputPdGammaHost, outputPdGammaSize);
    WriteFile("./output/outputPdBeta.bin", outputPdBetaHost, outputPdBetaSize);

    bool goldenResult = true;
    goldenResult &= CompareResult(outputYHost, outputYSize, "Y");
    goldenResult &= CompareResult(outputMeanHost, outputMeanSize, "Mean");
    goldenResult &= CompareResult(outputVarHost, outputVarSize, "Var");
    goldenResult &= CompareResult(outputPdXHost, outputPdXSize, "PdX");
    goldenResult &= CompareResult(outputPdGammaHost, outputPdGammaSize, "PdGamma");
    goldenResult &= CompareResult(outputPdBetaHost, outputPdBetaSize, "PdBeta");

    if (goldenResult) {
        printf("test pass!\n");
    } else {
        printf("test failed!\n");
    }

    aclrtFree(inputXDevice);
    aclrtFree(gammaDevice);
    aclrtFree(betaDevice);
    aclrtFree(dyDevice);
    aclrtFree(outputYDevice);
    aclrtFree(outputMeanDevice);
    aclrtFree(outputVarDevice);
    aclrtFree(outputPdXDevice);
    aclrtFree(outputPdGammaDevice);
    aclrtFree(outputPdBetaDevice);
    aclrtFree(workspaceDevice);
    aclrtFree(tilingDevice);

    aclrtFreeHost(inputXHost);
    aclrtFreeHost(gammaHost);
    aclrtFreeHost(betaHost);
    aclrtFreeHost(dyHost);
    aclrtFreeHost(outputYHost);
    aclrtFreeHost(outputMeanHost);
    aclrtFreeHost(outputVarHost);
    aclrtFreeHost(outputPdXHost);
    aclrtFreeHost(outputPdGammaHost);
    aclrtFreeHost(outputPdBetaHost);
    aclrtFreeHost(workspaceHost);
    aclrtFreeHost(tilingHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();
    free(tilingBuf);

    return 0;
}
