/* !
 * \file welford.asc
 * \brief 调用WelfordUpdate和WelfordFinalize高阶API，实现完整的Welford在线算法
 */

#include "acl/acl.h"
#include "data_utils.h"
#include "kernel_operator.h"
#include "tiling/tiling_api.h"
#include <cstdint>

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

// 使用WelfordUpdate样例的常量
constexpr uint32_t RN_SIZE = 1;            // 块数
constexpr uint32_t AB_SIZE = 64;           // 每块大小
constexpr uint32_t AB_COMPUTE_LENGTH = 35; // 实际计算长度
constexpr float NREC = 1.0f / 8.0f;        // 1/8
constexpr uint32_t NUM_BLOCKS = 1;
constexpr uint32_t WORKSPACE_SIZE = 1024 * 1024;
constexpr uint32_t LOCAL_BYTES = 32;

// 简化Tiling结构
struct WelfordCoopTiling {
    // WelfordUpdate参数
    uint32_t nLength = RN_SIZE;
    uint32_t rLength = AB_SIZE;
    uint32_t abComputeLength = AB_COMPUTE_LENGTH;
    float nRec = NREC;
    uint32_t tmpLocalSize = 0;
    bool inplace = true;

    // WelfordFinalize参数
    uint32_t rnLength = 1;
    uint32_t abLength = 8; // 对齐到8
    uint32_t head = 0;
    uint32_t headLength = 0;
    uint32_t tail = 0;
    uint32_t tailLength = 0;
    float abRec = 1.0f;
    float rRec = 1.0f;
};

// 生成Tiling数据
uint8_t* GenerateWelfordCoopTiling()
{
    WelfordCoopTiling tilingData;

    // 获取临时空间大小
    std::vector<int64_t> shapeVec = {RN_SIZE, AB_SIZE};
    ge::Shape srcShape(shapeVec);

    uint32_t maxsize = 0, minsize = 0;
    uint32_t dtypesizeT = 4; // float类型
    uint32_t dtypesizeU = 4; // float类型

    AscendC::GetWelfordUpdateMaxMinTmpSize(
        srcShape, dtypesizeT, dtypesizeU, false, tilingData.inplace, maxsize, minsize);

    tilingData.tmpLocalSize = minsize;
    tilingData.abRec = 1.0f / static_cast<float>(tilingData.abLength);

    uint8_t* buf = (uint8_t*)malloc(sizeof(WelfordCoopTiling));
    if (buf) {
        memcpy_s(buf, sizeof(WelfordCoopTiling), &tilingData, sizeof(WelfordCoopTiling));
    }

    printf("Generated tiling: tmpLocalSize=%u\n", tilingData.tmpLocalSize);

    return buf;
}

// 从全局内存复制Tiling数据
__aicore__ inline void CopyTilingData(WelfordCoopTiling* tilingData, __gm__ uint8_t* tilingGM)
{
    uint32_t* ptr = reinterpret_cast<uint32_t*>(tilingData);
    auto tiling32 = reinterpret_cast<__gm__ uint32_t*>(tilingGM);

    for (uint32_t i = 0; i < sizeof(WelfordCoopTiling) / sizeof(uint32_t); i++, ptr++) {
        *ptr = *(tiling32 + i);
    }
    return;
}

// 简化内核类
class KernelWelfordCoop {
public:
    __aicore__ inline KernelWelfordCoop() {}

    __aicore__ inline void Init(
        __gm__ uint8_t* srcGm, __gm__ uint8_t* inMeanGm, __gm__ uint8_t* inVarGm, __gm__ uint8_t* outMeanGm,
        __gm__ uint8_t* outVarGm, __gm__ uint8_t* finalMeanGm, __gm__ uint8_t* finalVarGm, WelfordCoopTiling tilingData,
        AscendC::TPipe* pipeIn)
    {
        pipe = pipeIn;
        this->tilingData = tilingData;

        bshLength = tilingData.nLength * tilingData.rLength;

        // 输入使用float类型
        inputX_global.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(srcGm), bshLength);
        inputMean_global.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(inMeanGm), bshLength);
        inputVar_global.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(inVarGm), bshLength);

        // 输出使用float类型
        outputMean_global.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(outMeanGm), bshLength);
        outputVar_global.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(outVarGm), bshLength);
        finalMean_global.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(finalMeanGm), 8);
        finalVar_global.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(finalVarGm), 8);

        // 初始化队列缓冲区
        pipe->InitBuffer(inQueueX, 1, sizeof(float) * bshLength);
        pipe->InitBuffer(inQueueMean, 1, sizeof(float) * bshLength);
        pipe->InitBuffer(inQueueVar, 1, sizeof(float) * bshLength);

        pipe->InitBuffer(outQueueMean, 1, sizeof(float) * bshLength);
        pipe->InitBuffer(outQueueVar, 1, sizeof(float) * bshLength);
        pipe->InitBuffer(outQueueFinalMean, 1, 8 * sizeof(float));
        pipe->InitBuffer(outQueueFinalVar, 1, 8 * sizeof(float));

        // 临时缓冲区
        if (tilingData.tmpLocalSize > 0) {
            tmpLocalBytes = tilingData.tmpLocalSize;
            if (tmpLocalBytes % LOCAL_BYTES != 0) {
                tmpLocalBytes = (tmpLocalBytes + LOCAL_BYTES - 1) / LOCAL_BYTES * LOCAL_BYTES;
            }
            pipe->InitBuffer(tmpLocalBuf, tmpLocalBytes);
        }
    }

    __aicore__ inline void Process()
    {
        CopyIn();
        Compute();
        CopyOut();
    }

private:
    __aicore__ inline void CopyIn()
    {
        AscendC::LocalTensor<float> inputXLocal = inQueueX.AllocTensor<float>();
        AscendC::LocalTensor<float> inMeanLocal = inQueueMean.AllocTensor<float>();
        AscendC::LocalTensor<float> inVarLocal = inQueueVar.AllocTensor<float>();

        AscendC::DataCopy(inputXLocal, inputX_global, bshLength);
        AscendC::DataCopy(inMeanLocal, inputMean_global, bshLength);
        AscendC::DataCopy(inVarLocal, inputVar_global, bshLength);

        inQueueX.EnQue(inputXLocal);
        inQueueMean.EnQue(inMeanLocal);
        inQueueVar.EnQue(inVarLocal);
    }

    __aicore__ inline void Compute()
    {
        // 出队输入
        AscendC::LocalTensor<float> inputXLocal = inQueueX.DeQue<float>();
        AscendC::LocalTensor<float> inMeanLocal = inQueueMean.DeQue<float>();
        AscendC::LocalTensor<float> inVarLocal = inQueueVar.DeQue<float>();

        // 分配输出
        AscendC::LocalTensor<float> outMeanLocal = outQueueMean.AllocTensor<float>();
        AscendC::LocalTensor<float> outVarLocal = outQueueVar.AllocTensor<float>();
        AscendC::LocalTensor<float> finalMeanLocal = outQueueFinalMean.AllocTensor<float>();
        AscendC::LocalTensor<float> finalVarLocal = outQueueFinalVar.AllocTensor<float>();

        // 初始化finalize输出
        AscendC::Duplicate(finalMeanLocal, 0.0f, 8);
        AscendC::Duplicate(finalVarLocal, 0.0f, 8);

        // ==================== WelfordUpdate计算 ====================
        static constexpr AscendC::WelfordUpdateConfig WELFORD_UPDATE_ENABLE_INPLACE_CFG = {true};
        static constexpr AscendC::WelfordUpdateConfig WELFORD_UPDATE_UNENABLE_INPLACE_CFG = {false};

        struct AscendC::WelfordUpdateParam updatePara = {
            tilingData.nLength, tilingData.rLength, tilingData.abComputeLength, tilingData.nRec};

        if (tmpLocalBytes > 0) {
            AscendC::LocalTensor<uint8_t> tmpLocalTensor = tmpLocalBuf.Get<uint8_t>();
            if (tilingData.inplace) {
                AscendC::WelfordUpdate<float, float, false, WELFORD_UPDATE_ENABLE_INPLACE_CFG>(
                    outMeanLocal, outVarLocal, inMeanLocal, inVarLocal, inputXLocal, tmpLocalTensor, updatePara);
            } else {
                AscendC::WelfordUpdate<float, float, false, WELFORD_UPDATE_UNENABLE_INPLACE_CFG>(
                    outMeanLocal, outVarLocal, inMeanLocal, inVarLocal, inputXLocal, tmpLocalTensor, updatePara);
            }
        } else {
            if (tilingData.inplace) {
                AscendC::WelfordUpdate<float, float, false, WELFORD_UPDATE_ENABLE_INPLACE_CFG>(
                    outMeanLocal, outVarLocal, inMeanLocal, inVarLocal, inputXLocal, updatePara);
            } else {
                AscendC::WelfordUpdate<float, float, false, WELFORD_UPDATE_UNENABLE_INPLACE_CFG>(
                    outMeanLocal, outVarLocal, inMeanLocal, inVarLocal, inputXLocal, updatePara);
            }
        }

        // ==================== WelfordFinalize汇总 ====================
        AscendC::TBuf<AscendC::QuePosition::VECCALC> countsBuf;
        pipe->InitBuffer(countsBuf, tilingData.abLength * sizeof(int32_t));
        AscendC::LocalTensor<int32_t> counts = countsBuf.Get<int32_t>();
        AscendC::Duplicate(counts, 0, tilingData.abLength);
        counts.SetValue(0, 1);

        AscendC::TBuf<AscendC::QuePosition::VECCALC> meanBuf;
        AscendC::TBuf<AscendC::QuePosition::VECCALC> varBuf;
        pipe->InitBuffer(meanBuf, tilingData.abLength * sizeof(float));
        pipe->InitBuffer(varBuf, tilingData.abLength * sizeof(float));

        AscendC::LocalTensor<float> meanForFinalize = meanBuf.Get<float>();
        AscendC::LocalTensor<float> varForFinalize = varBuf.Get<float>();

        AscendC::Duplicate(meanForFinalize, 0.0f, tilingData.abLength);
        AscendC::Duplicate(varForFinalize, 0.0f, tilingData.abLength);
        meanForFinalize.SetValue(0, outMeanLocal.GetValue(0));
        varForFinalize.SetValue(0, outVarLocal.GetValue(0));

        // 初始化 WelfordFinalizePara abLength=8（32字节对齐）
#if defined(__NPU_ARCH__) && (__NPU_ARCH__ == 3510)
        struct AscendC::WelfordFinalizePara finalizePara = {
            tilingData.rnLength, tilingData.abLength, 1, tilingData.abLength, 0, 0, tilingData.abRec, 1.0f, 1.0f};
#else
        // dav-2201: tailCount==0 时 tailCountLength 必须为 0
        struct AscendC::WelfordFinalizePara finalizePara = {
            tilingData.rnLength, tilingData.abLength, 1, tilingData.abLength, 0, 0, tilingData.abRec, 1.0f};
#endif

        AscendC::TBuf<AscendC::QuePosition::VECCALC> finalizeTmpBuf;
        pipe->InitBuffer(finalizeTmpBuf, 1024);
        AscendC::LocalTensor<uint8_t> finalizeTmpTensor = finalizeTmpBuf.Get<uint8_t>();

        // 3510需要传入WelfordFinalizeConfig，根据架构调用WelfordFinalize
#if defined(__NPU_ARCH__) && (__NPU_ARCH__ == 3510)
        static constexpr AscendC::WelfordFinalizeConfig WELFORD_FINALIZE_CFG = {true};
        AscendC::WelfordFinalize<false, WELFORD_FINALIZE_CFG>(
            finalMeanLocal, finalVarLocal, meanForFinalize, varForFinalize, counts, finalizeTmpTensor, finalizePara);
#else
        AscendC::WelfordFinalize<false>(
            finalMeanLocal, finalVarLocal, meanForFinalize, varForFinalize, counts, finalizeTmpTensor, finalizePara);
#endif
        // 释放输入张量
        inQueueX.FreeTensor(inputXLocal);
        inQueueMean.FreeTensor(inMeanLocal);
        inQueueVar.FreeTensor(inVarLocal);

        // 入队输出
        outQueueMean.EnQue<float>(outMeanLocal);
        outQueueVar.EnQue<float>(outVarLocal);
        outQueueFinalMean.EnQue<float>(finalMeanLocal);
        outQueueFinalVar.EnQue<float>(finalVarLocal);
    }

    __aicore__ inline void CopyOut()
    {
        AscendC::LocalTensor<float> outMeanLocal = outQueueMean.DeQue<float>();
        AscendC::LocalTensor<float> outVarLocal = outQueueVar.DeQue<float>();
        AscendC::LocalTensor<float> finalMeanLocal = outQueueFinalMean.DeQue<float>();
        AscendC::LocalTensor<float> finalVarLocal = outQueueFinalVar.DeQue<float>();

        AscendC::DataCopy(outputMean_global, outMeanLocal, bshLength);
        AscendC::DataCopy(outputVar_global, outVarLocal, bshLength);
        AscendC::DataCopy(finalMean_global, finalMeanLocal, 8);
        AscendC::DataCopy(finalVar_global, finalVarLocal, 8);

        outQueueMean.FreeTensor(outMeanLocal);
        outQueueVar.FreeTensor(outVarLocal);
        outQueueFinalMean.FreeTensor(finalMeanLocal);
        outQueueFinalVar.FreeTensor(finalVarLocal);
    }

private:
    AscendC::TPipe* pipe;
    AscendC::TQue<AscendC::QuePosition::VECIN, 1> inQueueX;
    AscendC::TQue<AscendC::QuePosition::VECIN, 1> inQueueMean;
    AscendC::TQue<AscendC::QuePosition::VECIN, 1> inQueueVar;
    AscendC::TQue<AscendC::QuePosition::VECOUT, 1> outQueueMean;
    AscendC::TQue<AscendC::QuePosition::VECOUT, 1> outQueueVar;
    AscendC::TQue<AscendC::QuePosition::VECOUT, 1> outQueueFinalMean;
    AscendC::TQue<AscendC::QuePosition::VECOUT, 1> outQueueFinalVar;

    AscendC::TBuf<AscendC::QuePosition::VECCALC> tmpLocalBuf;

    AscendC::GlobalTensor<float> inputX_global;
    AscendC::GlobalTensor<float> inputMean_global;
    AscendC::GlobalTensor<float> inputVar_global;
    AscendC::GlobalTensor<float> outputMean_global;
    AscendC::GlobalTensor<float> outputVar_global;
    AscendC::GlobalTensor<float> finalMean_global;
    AscendC::GlobalTensor<float> finalVar_global;

    uint32_t tmpLocalBytes = 0;
    uint32_t bshLength = 0;

    WelfordCoopTiling tilingData;
};

extern "C" __global__ __vector__ void welford_coop_custom(
    __gm__ uint8_t* srcGm, __gm__ uint8_t* inMeanGm, __gm__ uint8_t* inVarGm, __gm__ uint8_t* outMeanGm,
    __gm__ uint8_t* outVarGm, __gm__ uint8_t* finalMeanGm, __gm__ uint8_t* finalVarGm, __gm__ uint8_t* workspace,
    __gm__ uint8_t* tiling)
{
    AscendC::TPipe pipe;
    KernelWelfordCoop op;
    WelfordCoopTiling tilingData;
    CopyTilingData(&tilingData, tiling);
    op.Init(srcGm, inMeanGm, inVarGm, outMeanGm, outVarGm, finalMeanGm, finalVarGm, tilingData, &pipe);
    op.Process();
}

// 精度比较函数
static bool CompareResult(const void* outputData, int64_t outSize, const char* goldenName, float eps = 1e-3f)
{
    void* goldenData = nullptr;
    aclrtMallocHost((void**)(&goldenData), outSize);
    if (!goldenData) {
        printf("Error: Failed to allocate host memory for golden data\n");
        return false;
    }

    std::string goldenPath = std::string("./output/golden_") + goldenName + ".bin";
    size_t goldenSize = outSize;
    bool ret = ReadFile(goldenPath.c_str(), goldenSize, goldenData, goldenSize);
    if (!ret) {
        printf("Error: Failed to read golden file: %s\n", goldenPath.c_str());
        aclrtFreeHost(goldenData);
        return false;
    }

    printf("ReadFile %s success!\n", goldenPath.c_str());

    int64_t wrongNum = 0;
    int64_t totalNum = outSize / sizeof(float);
    const float* outputPtr = reinterpret_cast<const float*>(outputData);
    const float* goldenPtr = reinterpret_cast<const float*>(goldenData);

    for (int i = 0; i < totalNum; i++) {
        float a = outputPtr[i];
        float b = goldenPtr[i];
        float ae = std::abs(a - b);

        if (ae > eps) {
            if (wrongNum < 3) {
                printf(
                    "CompareResult %s failed at [%d]: output=%.8f, golden=%.8f, abs_err=%.8f\n", goldenName, i, a, b,
                    ae);
            }
            wrongNum++;
        }
    }

    aclrtFreeHost(goldenData);

    if (wrongNum > 0) {
        printf("CompareResult %s failed: wrongNum=%ld, totalNum=%ld\n", goldenName, wrongNum, totalNum);
        return false;
    } else {
        printf("CompareResult %s success! (total=%ld)\n", goldenName, totalNum);
        return true;
    }
}

int32_t main(int32_t argc, char* argv[])
{
    uint32_t numBlocks = NUM_BLOCKS;
    uint32_t totalElements = RN_SIZE * AB_SIZE;

    // 计算各缓冲区大小
    size_t workspaceSize = WORKSPACE_SIZE;
    size_t srcSize = totalElements * sizeof(float);
    size_t inMeanSize = totalElements * sizeof(float);
    size_t inVarSize = totalElements * sizeof(float);
    size_t outMeanSize = totalElements * sizeof(float);
    size_t outVarSize = totalElements * sizeof(float);
    size_t finalMeanSize = 8 * sizeof(float);
    size_t finalVarSize = 8 * sizeof(float);
    size_t tilingFileSize = sizeof(WelfordCoopTiling);

    // 生成Tiling数据
    printf("Generating tiling data...\n");
    uint8_t* tilingBuf = GenerateWelfordCoopTiling();
    if (!tilingBuf) {
        printf("Error: Failed to generate tiling data\n");
        return -1;
    }

    // 初始化ACL
    aclInit(nullptr);
    aclrtContext context;
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtCreateContext(&context, deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t *srcHost, *inMeanHost, *inVarHost, *outMeanHost, *outVarHost;
    uint8_t *finalMeanHost, *finalVarHost, *workspaceHost, *tilingHost;

    aclrtMallocHost((void**)(&srcHost), srcSize);
    aclrtMallocHost((void**)(&inMeanHost), inMeanSize);
    aclrtMallocHost((void**)(&inVarHost), inVarSize);
    aclrtMallocHost((void**)(&outMeanHost), outMeanSize);
    aclrtMallocHost((void**)(&outVarHost), outVarSize);
    aclrtMallocHost((void**)(&finalMeanHost), finalMeanSize);
    aclrtMallocHost((void**)(&finalVarHost), finalVarSize);
    aclrtMallocHost((void**)(&workspaceHost), workspaceSize);
    aclrtMallocHost((void**)(&tilingHost), tilingFileSize);

    // 读取输入文件
    bool readSuccess = true;
    readSuccess &= ReadFile("./input/coop_src.bin", srcSize, srcHost, srcSize);
    readSuccess &= ReadFile("./input/coop_inMean.bin", inMeanSize, inMeanHost, inMeanSize);
    readSuccess &= ReadFile("./input/coop_inVar.bin", inVarSize, inVarHost, inVarSize);

    if (!readSuccess) {
        printf("Error: Failed to read input files\n");
        return -1;
    }

    // 复制Tiling数据
    memcpy_s(tilingHost, tilingFileSize, tilingBuf, tilingFileSize);

    // 设备端内存分配
    uint8_t *srcDevice, *inMeanDevice, *inVarDevice, *outMeanDevice, *outVarDevice;
    uint8_t *finalMeanDevice, *finalVarDevice, *workspaceDevice, *tilingDevice;

    aclrtMalloc((void**)&srcDevice, srcSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&inMeanDevice, inMeanSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&inVarDevice, inVarSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&outMeanDevice, outMeanSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&outVarDevice, outVarSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&finalMeanDevice, finalMeanSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&finalVarDevice, finalVarSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&workspaceDevice, workspaceSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&tilingDevice, tilingFileSize, ACL_MEM_MALLOC_HUGE_FIRST);

    // 数据传输到设备
    aclrtMemcpy(srcDevice, srcSize, srcHost, srcSize, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(inMeanDevice, inMeanSize, inMeanHost, inMeanSize, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(inVarDevice, inVarSize, inVarHost, inVarSize, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(workspaceDevice, workspaceSize, workspaceHost, workspaceSize, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(tilingDevice, tilingFileSize, tilingHost, tilingFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    // 启动核函数
    welford_coop_custom<<<numBlocks, nullptr, stream>>>(
        srcDevice, inMeanDevice, inVarDevice, outMeanDevice, outVarDevice, finalMeanDevice, finalVarDevice,
        workspaceDevice, tilingDevice);

    aclrtSynchronizeStream(stream);

    // 数据传输回主机
    aclrtMemcpy(outMeanHost, outMeanSize, outMeanDevice, outMeanSize, ACL_MEMCPY_DEVICE_TO_HOST);
    aclrtMemcpy(outVarHost, outVarSize, outVarDevice, outVarSize, ACL_MEMCPY_DEVICE_TO_HOST);
    aclrtMemcpy(finalMeanHost, finalMeanSize, finalMeanDevice, finalMeanSize, ACL_MEMCPY_DEVICE_TO_HOST);
    aclrtMemcpy(finalVarHost, finalVarSize, finalVarDevice, finalVarSize, ACL_MEMCPY_DEVICE_TO_HOST);

    // 写入输出文件
    WriteFile("./output/output_coop_outMean.bin", outMeanHost, outMeanSize);
    WriteFile("./output/output_coop_outVar.bin", outVarHost, outVarSize);
    WriteFile("./output/output_coop_finalMean.bin", finalMeanHost, finalMeanSize);
    WriteFile("./output/output_coop_finalVar.bin", finalVarHost, finalVarSize);

    // 验证结果
    printf("\nValidating results...\n");

    bool goldenResult = true;

    // 验证WelfordUpdate输出
    goldenResult &= CompareResult(outMeanHost, outMeanSize, "outMeanGm", 1e-3f);
    goldenResult &= CompareResult(outVarHost, outVarSize, "outVarGm", 1e-3f);

    // 验证WelfordFinalize输出
    goldenResult &= CompareResult(finalMeanHost, finalMeanSize, "coop_finalMean", 1e-3f);
    goldenResult &= CompareResult(finalVarHost, finalVarSize, "coop_finalVar", 1e-3f);

    // 清理资源
    aclrtFree(srcDevice);
    aclrtFree(inMeanDevice);
    aclrtFree(inVarDevice);
    aclrtFree(outMeanDevice);
    aclrtFree(outVarDevice);
    aclrtFree(finalMeanDevice);
    aclrtFree(finalVarDevice);
    aclrtFree(workspaceDevice);
    aclrtFree(tilingDevice);

    aclrtFreeHost(srcHost);
    aclrtFreeHost(inMeanHost);
    aclrtFreeHost(inVarHost);
    aclrtFreeHost(outMeanHost);
    aclrtFreeHost(outVarHost);
    aclrtFreeHost(finalMeanHost);
    aclrtFreeHost(finalVarHost);
    aclrtFreeHost(workspaceHost);
    aclrtFreeHost(tilingHost);

    aclrtDestroyStream(stream);
    aclrtDestroyContext(context);
    aclrtResetDevice(deviceId);
    aclFinalize();
    free(tilingBuf);

    if (goldenResult) {
        printf("test pass!\n");
        return 0;
    } else {
        printf("test failed!\n");
        return -1;
    }
}
