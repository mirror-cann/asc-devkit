/* !
 * \file dropout.asc
 * \brief 基于DropOut高阶API实现dropout功能，对输入数据根据mask进行随机丢弃处理
 */

#include "acl/acl.h"
#include "data_utils.h"
#include "kernel_operator.h"
#include "tiling/tiling_api.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

namespace optiling {
BEGIN_TILING_DATA_DEF(DropoutCustomTilingData)
TILING_DATA_FIELD_DEF(uint32_t, firstAxis);                // 输入数据的第一维长度
TILING_DATA_FIELD_DEF(uint32_t, srcLastAxis);              // 输入src数据的最后一维长度
TILING_DATA_FIELD_DEF(uint32_t, maskLastAxis);             // 输入mask数据的最后一维长度
TILING_DATA_FIELD_DEF(uint32_t, sharedTmpBufferSize);     // 共享临时空间大小
END_TILING_DATA_DEF;

REGISTER_TILING_DATA_CLASS(DropoutCustom, DropoutCustomTilingData)
} // namespace optiling

void ComputeTiling(const uint32_t firstAxis, const uint32_t srcLastAxis, const uint32_t maskLastAxis,
                  optiling::DropoutCustomTilingData& tiling)
{
    std::vector<int64_t> srcShapeVec = {static_cast<int64_t>(firstAxis), static_cast<int64_t>(srcLastAxis), static_cast<int64_t>(maskLastAxis)};
    ge::Shape srcShape(srcShapeVec);
    uint32_t maxTmpSize;
    uint32_t minTmpSize;

    // srcShape: 输入数据的shape信息
    // 4: 数据类型大小（float为4字节）
    // false: 是否使用大临时空间，false表示使用最小临时空间
    // maxTmpSize: 输出参数，返回所需最大临时空间大小
    // minTmpSize: 输出参数，返回所需最小临时空间大小
    AscendC::GetDropOutMaxMinTmpSize(srcShape, 4, false, maxTmpSize, minTmpSize);

    uint32_t localWorkspaceSize = minTmpSize;
    tiling.set_firstAxis(firstAxis);
    tiling.set_srcLastAxis(srcLastAxis);
    tiling.set_maskLastAxis(maskLastAxis);
    tiling.set_sharedTmpBufferSize(localWorkspaceSize);
}

uint8_t* GetTilingBuf(optiling::DropoutCustomTilingData* tilingData)
{
    uint32_t tilingSize = sizeof(optiling::DropoutCustomTilingData);
    uint8_t* buf = (uint8_t*)malloc(tilingSize);
    if (buf == nullptr) {
        return nullptr;
    }
    tilingData->SaveToBuffer(buf, tilingSize);
    return buf;
}

uint8_t* GenerateTiling(uint32_t firstAxis, uint32_t srcLastAxis, uint32_t maskLastAxis)
{
    optiling::DropoutCustomTilingData tiling;
    ComputeTiling(firstAxis, srcLastAxis, maskLastAxis, tiling);
    return GetTilingBuf(&tiling);
}

/**
 * @brief Dropout核函数类，实现基于DropOut API的随机丢弃功能
 */
template <typename T>
class KernelDropout {
public:
    __aicore__ inline KernelDropout() {}
    __aicore__ inline void Init(__gm__ uint8_t* src_gm, __gm__ uint8_t* mask_gm, __gm__ uint8_t* dst_gm, __gm__ uint8_t* workspace, __gm__ uint8_t* tiling_gm,
                                uint32_t firstAxis, uint32_t srcLastAxis, uint32_t maskLastAxis, uint32_t sharedTmpBufferSizeIn,
                                AscendC::TPipe* pipeIn)
    {
        pipe = pipeIn;
        srcSize = firstAxis * srcLastAxis;
        maskSize = firstAxis * maskLastAxis;
        sharedTmpBufferSize = sharedTmpBufferSizeIn;

        info.firstAxis = firstAxis;
        info.srcLastAxis = srcLastAxis;
        info.maskLastAxis = maskLastAxis;

        src_global.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(src_gm), srcSize);
        mask_global.SetGlobalBuffer(reinterpret_cast<__gm__ uint8_t*>(mask_gm), maskSize);
        tiling_global.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(tiling_gm), 1);
        dst_global.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(dst_gm), srcSize);

        probValue = tiling_global.GetValue(0);
        int32_t eventID = static_cast<int32_t>(GetTPipePtr()->FetchEventID(AscendC::HardEvent::S_MTE3));
        AscendC::SetFlag<AscendC::HardEvent::S_MTE3>(eventID);
        AscendC::WaitFlag<AscendC::HardEvent::S_MTE3>(eventID);

        pipe->InitBuffer(inQueueX, 1, srcSize * sizeof(T) + 256);
        pipe->InitBuffer(inQueueY, 1, maskSize * sizeof(uint8_t));
        pipe->InitBuffer(outQueue, 1, srcSize * sizeof(T) + 256);
        pipe->InitBuffer(tmpQueue, 1, sharedTmpBufferSize);
    }
    __aicore__ inline void Process()
    {
        CopyIn();
        Compute();
        CopyOut();
    }

private:
    __aicore__ inline void CopyIn()
    {
        AscendC::LocalTensor<T> srcLocal = inQueueX.AllocTensor<T>();
        AscendC::LocalTensor<uint8_t> maskLocal = inQueueY.AllocTensor<uint8_t>();

        AscendC::DataCopy(srcLocal, src_global, srcSize);
        AscendC::DataCopy(maskLocal, mask_global, maskSize);

        inQueueX.EnQue(srcLocal);
        inQueueY.EnQue(maskLocal);
    }
    __aicore__ inline void Compute()
    {
        AscendC::LocalTensor<T> dstLocal = outQueue.AllocTensor<T>();

        AscendC::LocalTensor<T> srcLocal = inQueueX.DeQue<T>();
        AscendC::LocalTensor<uint8_t> maskLocal = inQueueY.DeQue<uint8_t>();
        AscendC::LocalTensor<uint8_t> tmpBuffer = tmpQueue.AllocTensor<uint8_t>();
        // dstLocal: 输出Tensor，存储dropout后的结果
        // srcLocal: 输入Tensor，待处理的源数据
        // maskLocal: mask Tensor，用于指示哪些元素需要保留
        // tmpBuffer: 临时Buffer，用于存储中间计算结果
        // probValue: 保留概率，具体值来自input_tiling.bin（由脚本生成），表示元素的保留比例
        // info: DropOutShapeInfo结构体，包含输入输出的shape信息
        AscendC::DropOut(dstLocal, srcLocal, maskLocal, tmpBuffer, probValue, info);

        outQueue.EnQue<T>(dstLocal);
        inQueueX.FreeTensor(srcLocal);
        inQueueY.FreeTensor(maskLocal);
        tmpQueue.FreeTensor(tmpBuffer);
    }
    __aicore__ inline void CopyOut()
    {
        AscendC::LocalTensor<T> dstLocal = outQueue.DeQue<T>();
        AscendC::DataCopy(dst_global, dstLocal, srcSize);
        outQueue.FreeTensor(dstLocal);
    }

private:
    AscendC::GlobalTensor<T> src_global;
    AscendC::GlobalTensor<uint8_t> mask_global;
    AscendC::GlobalTensor<float> tiling_global;
    AscendC::GlobalTensor<T> dst_global;

    AscendC::TPipe* pipe;
    AscendC::TQue<AscendC::QuePosition::VECIN, 1> inQueueX;
    AscendC::TQue<AscendC::QuePosition::VECIN, 1> inQueueY;
    AscendC::TQue<AscendC::QuePosition::VECOUT, 1> tmpQueue;
    AscendC::TQue<AscendC::QuePosition::VECOUT, 1> outQueue;

    uint32_t srcSize = 0;
    uint32_t maskSize = 0;
    uint32_t sharedTmpBufferSize = 0;
    float probValue = 0.75;
    AscendC::DropOutShapeInfo info;
};

namespace MyCustomKernel {
struct VecTiling {
    uint32_t firstAxis;
    uint32_t srcLastAxis;
    uint32_t maskLastAxis;
    uint32_t sharedTmpBufferSize;
};
} // namespace MyCustomKernel

__aicore__ inline void CopyTiling(MyCustomKernel::VecTiling* tiling, __gm__ uint8_t* tilingGM)
{
    uint32_t* ptr = reinterpret_cast<uint32_t*>(tiling);
    auto tiling32 = reinterpret_cast<__gm__ uint32_t*>(tilingGM);

    for (uint32_t i = 0; i < sizeof(MyCustomKernel::VecTiling) / sizeof(uint32_t); i++, ptr++) {
        *ptr = *(tiling32 + i);
    }
    return;
}

extern "C" __global__ __vector__ void dropout_custom(__gm__ uint8_t* src_gm, __gm__ uint8_t* mask_gm, __gm__ uint8_t* dst_gm, __gm__ uint8_t* workspace,
                                                      __gm__ uint8_t* tiling_gm, __gm__ uint8_t* tilingData_gm)
{
    AscendC::TPipe pipe;
    KernelDropout<float> op;
    MyCustomKernel::VecTiling tilingData;
    CopyTiling(&tilingData, tilingData_gm);
    op.Init(src_gm, mask_gm, dst_gm, workspace, tiling_gm, tilingData.firstAxis, tilingData.srcLastAxis,
            tilingData.maskLastAxis, tilingData.sharedTmpBufferSize, &pipe);
    op.Process();
}

static bool CompareResult(const void* outputData, uint32_t outSize)
{
    void* goldenData;
    aclrtMallocHost((void**)(&goldenData), outSize);
    size_t goldenSize = outSize;
    bool ret = ReadFile("./output/golden.bin", goldenSize, goldenData, goldenSize);
    if (ret) {
        printf("ReadFile golden.bin success!\n");
    } else {
        printf("test failed!\n");
        return false;
    }
    constexpr float EPS = 1e-4;
    int64_t wrongNum = 0;

    for (size_t i = 0; i < outSize / sizeof(float); i++) {
        float a = (reinterpret_cast<const float*>(outputData))[i];
        float b = (reinterpret_cast<const float*>(goldenData))[i];
        float ae = std::abs(a - b);
        float re = ae / std::abs(b);
        if (ae > EPS && re > EPS) {
            printf("CompareResult golden.bin failed output is %lf, golden is %lf\n", a, b);
            wrongNum++;
        }
    }
    aclrtFreeHost(goldenData);
    if (wrongNum != 0) {
        printf("wrongNum: %ld\n", wrongNum);
        return false;
    } else {
        printf("CompareResult golden.bin success!\n");
        return true;
    }
}

constexpr uint32_t NUM_BLOCKS = 1;
constexpr uint32_t FIRST_AXIS = 4;
constexpr uint32_t SRC_LAST_AXIS = 256;
constexpr uint32_t MASK_LAST_AXIS = 32;
constexpr uint32_t TILINGDATA_SIZE = 4;
constexpr uint32_t WORKSPACE_SIZE = 16 * 1024 * 1024;

int32_t main(int32_t argc, char* argv[])
{
    uint32_t numBlocks = NUM_BLOCKS;
    uint32_t firstAxis = FIRST_AXIS;
    uint32_t srcLastAxis = SRC_LAST_AXIS;
    uint32_t maskLastAxis = MASK_LAST_AXIS;
    size_t param1FileSize = firstAxis * srcLastAxis * sizeof(float);
    size_t param2FileSize = firstAxis * maskLastAxis * sizeof(uint8_t);
    size_t param3FileSize = firstAxis * srcLastAxis * sizeof(float);
    size_t param4FileSize = 1 * sizeof(float);
    size_t tilingFileSize = TILINGDATA_SIZE * sizeof(uint32_t);
    size_t workspaceSize = WORKSPACE_SIZE;
    uint8_t* tilingBuf = GenerateTiling(firstAxis, srcLastAxis, maskLastAxis);

    aclInit(nullptr);
    aclrtContext context;
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtCreateContext(&context, deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t *param1Host, *param2Host, *param3Host, *param4Host, *workspaceHost, *tilingHost;
    uint8_t *param1Device, *param2Device, *param3Device, *param4Device, *workspaceDevice, *tilingDevice;

    aclrtMallocHost((void**)(&param1Host), param1FileSize);
    aclrtMallocHost((void**)(&param2Host), param2FileSize);
    aclrtMallocHost((void**)(&param3Host), param3FileSize);
    aclrtMallocHost((void**)(&param4Host), param4FileSize);
    aclrtMallocHost((void**)(&workspaceHost), workspaceSize);
    aclrtMallocHost((void**)(&tilingHost), tilingFileSize);
    aclrtMalloc((void**)&param1Device, param1FileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&param2Device, param2FileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&param3Device, param3FileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&param4Device, param4FileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&workspaceDevice, workspaceSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&tilingDevice, tilingFileSize, ACL_MEM_MALLOC_HUGE_FIRST);

    ReadFile("./input/input_src.bin", param1FileSize, param1Host, param1FileSize);
    ReadFile("./input/input_mask.bin", param2FileSize, param2Host, param2FileSize);
    ReadFile("./input/input_tiling.bin", param4FileSize, param4Host, param4FileSize);

    aclrtMemcpy(tilingDevice, tilingFileSize, tilingBuf, tilingFileSize, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(param1Device, param1FileSize, param1Host, param1FileSize, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(param2Device, param2FileSize, param2Host, param2FileSize, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(param4Device, param4FileSize, param4Host, param4FileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    dropout_custom<<<numBlocks, nullptr, stream>>>(param1Device, param2Device, param3Device, workspaceDevice, param4Device, tilingDevice);
    aclrtSynchronizeStream(stream);
    aclrtMemcpy(param3Host, param3FileSize, param3Device, param3FileSize, ACL_MEMCPY_DEVICE_TO_HOST);

    WriteFile("./output/output.bin", param3Host, param3FileSize);

    bool goldenResult = CompareResult(param3Host, param3FileSize);
    if (goldenResult) {
        printf("test pass!\n");
    } else {
        printf("test failed!\n");
    }

    aclrtFree(param1Device);
    aclrtFree(param2Device);
    aclrtFree(param3Device);
    aclrtFree(param4Device);
    aclrtFree(tilingDevice);
    aclrtFree(workspaceDevice);
    aclrtFreeHost(param1Host);
    aclrtFreeHost(param2Host);
    aclrtFreeHost(param3Host);
    aclrtFreeHost(param4Host);
    aclrtFreeHost(tilingHost);
    aclrtFreeHost(workspaceHost);

    aclrtDestroyStream(stream);
    aclrtDestroyContext(context);
    aclrtResetDevice(deviceId);
    aclFinalize();
    free(tilingBuf);

    return 0;
}
