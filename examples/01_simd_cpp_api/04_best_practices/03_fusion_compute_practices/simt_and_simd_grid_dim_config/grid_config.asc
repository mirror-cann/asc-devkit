/* !
 * \file grid_config.asc
 * \brief SIMT vf programming sample demonstrating grid/block configuration and vf call optimization
 */

#include <iostream>
#include <iterator>
#include <vector>
#include <cstdlib>
#include <ctime>
#include "acl/acl.h"
#include "simt_api/asc_simt.h"

#ifndef SCENARIO_NUM
#define SCENARIO_NUM 1
#endif

#if SCENARIO_NUM < 1 || SCENARIO_NUM > 16
#error "SCENARIO_NUM must be between 1 and 16."
#endif

namespace {
constexpr uint32_t THREAD_NUM = 2048;
constexpr uint32_t INDEX_WIDTH = 2048;

struct ScenarioConfig {
    uint32_t num_blocks;
    uint32_t thread_num;
    uint32_t vf_call_times;
    bool use_gather;
    uint32_t input_total_length;
    uint32_t index_rows;
    const char* name;
};

ScenarioConfig get_scenario_config(uint32_t scenario, uint32_t physical_core_num)
{
    switch (scenario) {
        case 1:
            return {1, THREAD_NUM, 1, false, 2200000, 1024, "Case0: 1 core, 1 vf (empty)"};
        case 2:
            return {32, THREAD_NUM, 1, false, 2200000, 1024, "Case0: 32 cores, 1 vf (empty)"};
        case 3:
            return {physical_core_num, THREAD_NUM, 1, false, 2200000, 1024, "Case0: physical cores, 1 vf (empty)"};
        case 4:
            return {128, THREAD_NUM, 1, false, 2200000, 1024, "Case0: 128 cores, 1 vf (empty)"};
        case 5:
            return {1024, THREAD_NUM, 1, false, 2200000, 1024, "Case0: 1024 cores, 1 vf (empty)"};
        case 6:
            return {32, THREAD_NUM, 2, false, 2200000, 1024, "Case1: 32 cores, 2 vf (empty)"};
        case 7:
            return {physical_core_num, THREAD_NUM, 2, false, 2200000, 1024, "Case1: physical cores, 2 vf (empty)"};
        case 8:
            return {1024, THREAD_NUM, 2, false, 2200000, 1024, "Case1: 1024 cores, 2 vf (empty)"};
        case 9:
            return {1024, THREAD_NUM, 1, true, 2200000, 1024, "Case2: 1024 cores, 1 data/thread"};
        case 10:
            return {64, THREAD_NUM, 16, true, 2200000, 1024, "Case2: 64 cores, 16 data/thread"};
        case 11:
            return {32, THREAD_NUM, 32, true, 2200000, 1024, "Case2: 32 cores, 32 data/thread"};
        case 12:
            return {4, THREAD_NUM, 2, true, 20000, 8, "Case3: 4 cores, 2 data/thread"};
        case 13:
            return {8, THREAD_NUM, 1, true, 20000, 8, "Case3: 8 cores, 1 data/thread"};
        case 14:
            return {16, 1024, 1, true, 20000, 8, "Case3: 16 cores, 1024 threads"};
        case 15:
            return {32, 512, 1, true, 20000, 8, "Case3: 32 cores, 512 threads"};
        case 16:
            return {physical_core_num, 256, 1, true, 20000, 8, "Case3: physical cores, 256 threads"};
        default:
            return {1, THREAD_NUM, 1, false, 2200000, 1024, "unknown"};
    }
}
} // namespace

__simt_vf__ __launch_bounds__(THREAD_NUM) inline void simt_empty(__gm__ float* input, __gm__ uint32_t* index) {}

__global__ __vector__ void empty_kernel(
    __gm__ float* input, __gm__ uint32_t* index, __gm__ float* output, uint32_t input_total_length,
    uint32_t index_total_length, uint32_t vf_call_times)
{
    for (uint32_t vf_idx = 0; vf_idx < vf_call_times; vf_idx++) {
        asc_vf_call<simt_empty>(dim3(THREAD_NUM), input, index);
    }
}

__simt_vf__ __launch_bounds__(THREAD_NUM) inline void simt_gather(
    __gm__ float* output, __gm__ float* input, __gm__ uint32_t* index, uint32_t input_total_length,
    uint32_t index_start, uint32_t vf_loop_times)
{
    for (uint32_t vf_idx = 0; vf_idx < vf_loop_times; vf_idx++) {
        uint32_t idx = threadIdx.x + index_start + vf_idx * blockDim.x;
        uint32_t gather_idx = index[idx];

        if (gather_idx >= input_total_length) {
            gather_idx = 0;
        }

        output[idx] = input[gather_idx];
    }
}

__global__ __vector__ void gather_kernel(
    __gm__ float* input, __gm__ uint32_t* index, __gm__ float* output, uint32_t input_total_length,
    uint32_t index_total_length, uint32_t vf_loop_times, uint32_t thread_num)
{
    uint32_t rows_per_block = index_total_length / gridDim.x;
    uint32_t index_start = blockIdx.x * rows_per_block;

    asc_vf_call<simt_gather>(
        dim3(thread_num), output, input, index, input_total_length, index_start,
        vf_loop_times);
}

std::vector<float> run_kernel(
    std::vector<float>& input, std::vector<uint32_t>& index, uint32_t num_blocks, uint32_t vf_call_times,
    bool use_gather, uint32_t thread_num)
{
    uint32_t input_total_length = input.size();
    size_t input_total_byte_size = input_total_length * sizeof(float);

    uint32_t index_total_length = index.size();
    size_t index_total_byte_size = index_total_length * sizeof(uint32_t);

    uint32_t output_total_length = index.size();
    size_t output_total_byte_size = output_total_length * sizeof(float);

    aclrtStream stream = nullptr;

    uint8_t* input_host = reinterpret_cast<uint8_t*>(input.data());
    uint8_t* index_host = reinterpret_cast<uint8_t*>(index.data());
    uint8_t* output_host = nullptr;
    float* input_device = nullptr;
    uint32_t* index_device = nullptr;
    float* output_device = nullptr;

    aclrtCreateStream(&stream);

    aclrtMallocHost((void**)(&output_host), output_total_byte_size);
    aclrtMalloc((void**)&input_device, input_total_byte_size, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&index_device, index_total_byte_size, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&output_device, output_total_byte_size, ACL_MEM_MALLOC_HUGE_FIRST);

    aclrtMemcpy(input_device, input_total_byte_size, input_host, input_total_byte_size, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(index_device, index_total_byte_size, index_host, index_total_byte_size, ACL_MEMCPY_HOST_TO_DEVICE);

    if (use_gather) {
        gather_kernel<<<num_blocks, 0, stream>>>(
            input_device, index_device, output_device, input_total_length, index_total_length, vf_call_times,
            thread_num);
    } else {
        aclrtMemcpy(
            output_device, output_total_byte_size, input_device, output_total_byte_size, ACL_MEMCPY_DEVICE_TO_DEVICE);
        empty_kernel<<<num_blocks, 0, stream>>>(
            input_device, index_device, output_device, input_total_length, index_total_length, vf_call_times);
    }

    aclrtSynchronizeStream(stream);

    aclrtMemcpy(output_host, output_total_byte_size, output_device, output_total_byte_size, ACL_MEMCPY_DEVICE_TO_HOST);
    std::vector<float> output((float*)output_host, (float*)(output_host + output_total_byte_size));

    aclrtFree(input_device);
    aclrtFree(index_device);
    aclrtFree(output_device);
    aclrtFreeHost(output_host);

    const char* err = aclGetRecentErrMsg();
    if (err != nullptr) {
        fprintf(stderr, "%s\n", err);
    }

    aclrtDestroyStream(stream);
    return output;
}

uint32_t verify_result(std::vector<float>& output, std::vector<float>& golden)
{
    auto print_tensor = [](std::vector<float>& tensor, const char* name) {
        constexpr size_t max_print_size = 20;
        std::cout << name << ": ";
        std::copy(
            tensor.begin(), tensor.begin() + std::min(tensor.size(), max_print_size),
            std::ostream_iterator<float>(std::cout, " "));
        if (tensor.size() > max_print_size) {
            std::cout << "...";
        }
        std::cout << std::endl;
    };
    print_tensor(output, "Output");
    print_tensor(golden, "Golden");

    if (std::equal(golden.begin(), golden.end(), output.begin())) {
        std::cout << "[Success] Case accuracy is verification passed." << std::endl;
        return 0;
    } else {
        std::cout << "[Failed] Case accuracy is verification failed!" << std::endl;
        return 1;
    }
}

int32_t main(int32_t argc, char* argv[])
{
    srand(static_cast<uint32_t>(time(nullptr)));

    const uint32_t scenario = static_cast<uint32_t>(SCENARIO_NUM);

    aclInit(nullptr);
    int32_t device_id = 0;
    aclrtSetDevice(device_id);

    int64_t physical_aiv_core_num = 0;
    aclError ret = aclrtGetDeviceInfo(
        static_cast<uint32_t>(device_id),
        ACL_DEV_ATTR_VECTOR_CORE_NUM,
        &physical_aiv_core_num);
    if (ret == ACL_SUCCESS) {
        printf("Physical AIV (Vector Core) num: %ld\n", physical_aiv_core_num);
    }

    uint32_t core_num = static_cast<uint32_t>(physical_aiv_core_num);
    ScenarioConfig config = get_scenario_config(scenario, core_num);

    printf("Scenario %u: %s\n", scenario, config.name);

    uint32_t input_total_length = config.input_total_length;
    uint32_t index_rows = config.index_rows;
    uint32_t index_total_length = index_rows * INDEX_WIDTH;

    std::vector<float> input(input_total_length);
    for (uint32_t i = 0; i < input_total_length; i++) {
        input[i] = i * 1.2f;
    }

    std::vector<uint32_t> index(index_total_length);
    for (uint32_t i = 0; i < index_rows; i++) {
        for (uint32_t j = 0; j < INDEX_WIDTH; j++) {
            index[i * INDEX_WIDTH + j] = rand() % input_total_length;
        }
    }

    std::vector<float> golden(index_total_length);
    if (config.use_gather) {
        for (uint32_t i = 0; i < index_rows; i++) {
            for (uint32_t j = 0; j < INDEX_WIDTH; j++) {
                uint32_t input_idx = index[i * INDEX_WIDTH + j];
                uint32_t output_idx = i * INDEX_WIDTH + j;
                golden[output_idx] = input[input_idx];
            }
        }
    } else {
        for (uint32_t i = 0; i < index_total_length; i++) {
            golden[i] = input[i];
        }
    }

    std::vector<float> output =
        run_kernel(input, index, config.num_blocks, config.vf_call_times, config.use_gather, config.thread_num);

    aclrtResetDevice(device_id);
    aclFinalize();
    if (output.empty()) {
        return 1;
    }
    return verify_result(output, golden);
}
