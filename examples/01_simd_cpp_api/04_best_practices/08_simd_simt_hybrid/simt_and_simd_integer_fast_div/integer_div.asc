/*!
 * \file integer_div.asc
 * \brief uint32_t integer division with implementation modes selected by SCENARIO_NUM:
 *        SCENARIO_NUM=0: normal division in SIMT
 *        SCENARIO_NUM=1: fast division with precomputed magic and shift
 */

#include <algorithm>
#include <climits>
#include <cstdint>
#include <iostream>
#include <iterator>
#include <random>
#include <vector>
#include "acl/acl.h"
#include "kernel_operator.h"
#include "simt_api/asc_simt.h"
#include "c_api/asc_simd.h"

#ifndef SCENARIO_NUM
#define SCENARIO_NUM 0
#endif

#if SCENARIO_NUM < 0 || SCENARIO_NUM > 1
#error "SCENARIO_NUM must be one of 0, 1."
#endif

namespace {
constexpr uint32_t THREAD_COUNT = 2048;
constexpr uint32_t THREAD_LIMIT = 2048;
constexpr uint32_t MAX_UB_ELEMENTS = 32768;
constexpr uint32_t BIT_64_LEN = 64;
constexpr uint8_t BIT_32_LEN = 32;

constexpr uint32_t DATA_SIZE = 8388608;  // number of input elements
constexpr uint32_t DIVISOR = 7;          // fixed divisor
}

__aicore__ inline int64_t CountLeadingZero(uint64_t x)
{
    return clz(x);
}

__aicore__ inline int64_t GetBitCount1(uint64_t x)
{
    return bcnt1(x);
}

__aicore__ inline void calc_magic_shift(uint32_t& magic_out, uint32_t& shift_out, uint32_t divisor)
{
    if (divisor == 0) {
        magic_out = 0;
        shift_out = 0;
        return;
    }

    int64_t pos = BIT_64_LEN - CountLeadingZero(divisor);
    int64_t cnt1 = GetBitCount1(divisor);
    uint32_t shift = (cnt1 == 1) ? (pos - 1) : pos;
    uint32_t magic = (1l << BIT_32_LEN) * ((1l << shift) - divisor) / divisor + 1;

    magic_out = magic;
    shift_out = shift;
}

__simt_vf__ __launch_bounds__(THREAD_LIMIT) inline void simt_normal_div(
    __ubuf__ uint32_t* input,
    __ubuf__ uint32_t* output,
    uint32_t divisor,
    uint32_t total_length)
{
    uint32_t local_idx = threadIdx.x;
    uint32_t idx = blockIdx.x * blockDim.x + local_idx;

    if (idx >= total_length) {
        return;
    }

    uint32_t value = input[local_idx];
    uint32_t result = value / divisor;
    output[local_idx] = result;
}

__simt_vf__ __launch_bounds__(THREAD_LIMIT) inline void simt_fast_div(
    __ubuf__ uint32_t* input,
    __ubuf__ uint32_t* output,
    uint32_t magic,
    uint32_t shift,
    uint32_t total_length)
{
    uint32_t local_idx = threadIdx.x;
    uint32_t idx = blockIdx.x * blockDim.x + local_idx;

    if (idx >= total_length) {
        return;
    }

    uint32_t value = input[local_idx];
    uint32_t q = __umulhi(value, magic);
    uint32_t result = (value + q) >> shift;
    output[local_idx] = result;
}

template <int scenario>
__global__ __vector__ void integer_div_kernel(
    __gm__ uint32_t* input,
    __gm__ uint32_t* output,
    uint32_t divisor,
    uint32_t total_length)
{
    uint32_t magic = 0;
    uint32_t shift = 0;
    if constexpr (scenario == 1) {
        calc_magic_shift(magic, shift, divisor);
    }

    uint32_t block_idx = AscendC::GetBlockIdx();
    uint32_t block_offset = block_idx * THREAD_COUNT;

    __ubuf__ uint32_t input_buf[THREAD_COUNT];
    __ubuf__ uint32_t output_buf[THREAD_COUNT];
    uint32_t blk_length = THREAD_COUNT * sizeof(uint32_t);
    asc_copy_gm2ub_align(input_buf, input + block_offset, 1, blk_length, 0, 0, false, 0, 0, 0);

    if ASC_IS_AIV {
        asc_sync_notify(PIPE_MTE2, PIPE_V, EVENT_ID0);
        asc_sync_wait(PIPE_MTE2, PIPE_V, EVENT_ID0);
    }

    if constexpr (scenario == 0) {
        asc_vf_call<simt_normal_div>(dim3(THREAD_COUNT), input_buf, output_buf, divisor, total_length);
    } else {
        asc_vf_call<simt_fast_div>(dim3(THREAD_COUNT), input_buf, output_buf, magic, shift, total_length);
    }

    if ASC_IS_AIV {
        asc_sync_notify(PIPE_V, PIPE_MTE3, EVENT_ID0);
        asc_sync_wait(PIPE_V, PIPE_MTE3, EVENT_ID0);
    }

    asc_copy_ub2gm_align(output + block_offset, output_buf, 1, blk_length, 0, 0, 0);
}

std::vector<uint32_t> integer_div_compute(std::vector<uint32_t>& input, uint32_t divisor)
{
    uint32_t total_length = input.size();

    if (THREAD_COUNT > MAX_UB_ELEMENTS) {
        std::cout << "[ERROR] THREAD_COUNT " << THREAD_COUNT << " exceeds MAX_UB_ELEMENTS "
                  << MAX_UB_ELEMENTS << std::endl;
        return {};
    }

    uint32_t num_blocks = (total_length + THREAD_COUNT - 1) / THREAD_COUNT;
    size_t total_byte_size = total_length * sizeof(uint32_t);

    int32_t device_id = 0;
    aclrtStream stream = nullptr;

    uint8_t* input_host = reinterpret_cast<uint8_t*>(input.data());
    uint8_t* output_host = nullptr;
    uint32_t* input_device = nullptr;
    uint32_t* output_device = nullptr;

    aclInit(nullptr);
    aclrtSetDevice(device_id);
    aclrtCreateStream(&stream);

    aclrtMallocHost((void**)(&output_host), total_byte_size);
    aclrtMalloc((void**)&input_device, total_byte_size, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&output_device, total_byte_size, ACL_MEM_MALLOC_HUGE_FIRST);

    aclrtMemcpy(input_device, total_byte_size, input_host, total_byte_size, ACL_MEMCPY_HOST_TO_DEVICE);

    uint32_t dyn_ubuf_size = 0;  // No need to alloc dynamic memory.

    integer_div_kernel<SCENARIO_NUM><<<num_blocks, dyn_ubuf_size, stream>>>(
        input_device, output_device, divisor, total_length);
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(output_host, total_byte_size, output_device, total_byte_size, ACL_MEMCPY_DEVICE_TO_HOST);

    std::vector<uint32_t> output((uint32_t*)output_host, (uint32_t*)(output_host + total_byte_size));

    aclrtFree(input_device);
    aclrtFree(output_device);
    aclrtFreeHost(output_host);

    aclrtDestroyStream(stream);
    aclrtResetDevice(device_id);
    aclFinalize();

    return output;
}

uint32_t verify_result(std::vector<uint32_t>& output, std::vector<uint32_t>& golden)
{
    auto print_tensor = [](std::vector<uint32_t>& tensor, const char* name) {
        constexpr size_t max_print_size = 20;
        std::cout << name << ": ";
        std::copy(tensor.begin(), tensor.begin() + std::min(tensor.size(), max_print_size),
            std::ostream_iterator<uint32_t>(std::cout, " "));
        if (tensor.size() > max_print_size) {
            std::cout << "...";
        }
        std::cout << std::endl;
    };
    print_tensor(output, "Output");
    print_tensor(golden, "Golden");
    if (std::equal(output.begin(), output.end(), golden.begin())) {
        std::cout << "[Success] Case accuracy is verification passed." << std::endl;
        return 0;
    } else {
        std::cout << "[Failed] Case accuracy is verification failed!" << std::endl;
        return 1;
    }
}

uint32_t random_uint32(uint32_t min, uint32_t max)
{
    static std::mt19937 engine(12345);
    std::uniform_int_distribution<uint32_t> dist(min, max);
    return dist(engine);
}

int32_t main()
{
    uint32_t total_length = DATA_SIZE;
    uint32_t divisor = DIVISOR;

    std::vector<uint32_t> input(total_length);
    for (uint32_t i = 0; i < total_length; i++) {
        input[i] = random_uint32(0, INT32_MAX);
    }

    std::vector<uint32_t> golden(total_length);
    for (uint32_t i = 0; i < total_length; i++) {
        golden[i] = input[i] / divisor;
    }

    std::vector<uint32_t> output = integer_div_compute(input, divisor);

    if (output.empty()) {
        return 1;
    }

    return verify_result(output, golden);
}
