/* !
 * \file bank_conflict_nd2nz.asc
 * \brief bank conflict nd2nz operator performance tuning sample
 */

#include "acl/acl.h"
#include "kernel_operator.h"
#include "data_utils.h"

#ifndef SCENARIO
#define SCENARIO 1
#endif

#if defined(__NPU_ARCH__) && (__NPU_ARCH__ == 3510)
#include "bank_conflict_nd2nz_3510.h"
#endif

namespace {
// 1 个 DataBlock/C0 固定为 32B，即 16 个 half 元素
constexpr uint32_t C0_ELEMS = 16;
} // namespace

template <
    uint32_t totalM, uint32_t totalN, uint32_t tileH, uint32_t tileW, uint32_t vecLenHalf, uint32_t rowSplits,
    uint32_t colSplits>
class KernelNd2Nz {
    static_assert(tileW % C0_ELEMS == 0, "tileW must be aligned to C0");
    static_assert(tileW % vecLenHalf == 0, "tileW must be divisible by vecLenHalf");

    static constexpr uint32_t tileC0Cols = tileW / C0_ELEMS;
    static constexpr uint32_t totalRowTiles = (totalM + tileH - 1) / tileH;
    static constexpr uint32_t totalColTiles = totalN / tileW;
    static_assert(totalN % tileW == 0, "totalN must be divisible by tileW");
    static_assert(totalColTiles % colSplits == 0, "total column tiles must be divisible by colSplits");
    static constexpr uint32_t tileColsPerSplit = totalColTiles / colSplits;
    static constexpr uint32_t totalBlocks = rowSplits * colSplits;
    static constexpr uint32_t dstNzC0Stride = (SCENARIO == 1) ? tileH : (tileH + 1);
    static constexpr uint32_t ndBufElems = tileH * tileW;
    static constexpr uint32_t vecLenDbs = vecLenHalf / C0_ELEMS;

    // UB 内 NZ tile 在 S2 会在相邻 C0 列之间多偏移 1 个 DataBlock，写回 GM 时由 MTE3 跳过。
    // S2 额外在末尾多预留 1 个 DataBlock 作为 padding，不写回 GM。
    static constexpr uint32_t nzTileDataDbs = (tileH - 1) + (tileC0Cols - 1) * dstNzC0Stride + 1;
    static constexpr uint32_t nzBufPaddingDbs = (SCENARIO == 2) ? 1 : 0;
    static constexpr uint32_t nzBufElems = (nzTileDataDbs + nzBufPaddingDbs) * C0_ELEMS;
    static constexpr uint32_t ndBufBytes = ndBufElems * sizeof(half);
    static constexpr uint32_t nzBufBytes = nzBufElems * sizeof(half);
    // Ascend 950PR/Ascend 950DT 上 S2 让 nzBuf 从 bank 8 起步，使 V_LOAD（bank 0~7）与
    // V_STORE（bank 8~15）落到不相交的物理 bank，规避同拍读写冲突；S1 保留紧凑布局
    // （bank 0 起步），便于对比基线下的同 bank 冲突开销。
    // 同时在 nzPing 与 nzPong 之间再补 8 个 datablock 的 padding，让 nzPong 也从 bank 8
    // 起步（nzBuf 单块 1160 datablock，不是 16 的整数倍，需要手动补齐）。
    // 16-bank 低位交织下，每跨 1 个 datablock 切换一个 bank，跨 8 个 datablock = 跨 8 个 bank。
    static constexpr uint32_t kBank8ShiftBytes = 8 * C0_ELEMS * sizeof(half);
#if defined(__NPU_ARCH__) && (__NPU_ARCH__ == 3510) && (SCENARIO == 2)
    static constexpr uint32_t nzBufBaseOffset     = 2 * ndBufBytes + kBank8ShiftBytes;
    static constexpr uint32_t nzPongExtraPadBytes = kBank8ShiftBytes;
#else
    static constexpr uint32_t nzBufBaseOffset     = 2 * ndBufBytes;
    static constexpr uint32_t nzPongExtraPadBytes = 0;
#endif

public:
    __aicore__ inline KernelNd2Nz() {}

    __aicore__ inline void Init(__gm__ uint8_t* x, __gm__ uint8_t* z)
    {
        xGm.SetGlobalBuffer((__gm__ half*)x, totalM * totalN);
        zGm.SetGlobalBuffer((__gm__ half*)z, totalM * totalN);
    }

    __aicore__ inline void Process()
    {
        // VECIN 和 VECOUT 在硬件上都映射到 UB
        AscendC::LocalTensor<half> ndPing(AscendC::TPosition::VECIN, 0, ndBufElems);
        AscendC::LocalTensor<half> ndPong(AscendC::TPosition::VECIN, ndBufBytes, ndBufElems);
        AscendC::LocalTensor<half> nzPing(AscendC::TPosition::VECOUT, nzBufBaseOffset, nzBufElems);
        AscendC::LocalTensor<half> nzPong(AscendC::TPosition::VECOUT,
                                          nzBufBaseOffset + nzBufBytes + nzPongExtraPadBytes,
                                          nzBufElems);

        const uint32_t blockIdx = AscendC::GetBlockIdx();
        if (blockIdx >= totalBlocks) {
            return;
        }

        const uint32_t rowSplit = blockIdx / colSplits;
        const uint32_t colSplit = blockIdx % colSplits;
        const uint32_t baseRowTiles = totalRowTiles / rowSplits;
        const uint32_t extraRowTiles = totalRowTiles % rowSplits;
        const uint32_t rowTileBegin = rowSplit * baseRowTiles + ((rowSplit < extraRowTiles) ? rowSplit : extraRowTiles);
        const uint32_t rowTileCount = baseRowTiles + ((rowSplit < extraRowTiles) ? 1 : 0);
        const uint32_t colTileBegin = colSplit * tileColsPerSplit;
        const uint32_t tilesPerBlock = rowTileCount * tileColsPerSplit;

        AscendC::SetFlag<AscendC::HardEvent::V_MTE2>(EVENT_ID0);
        AscendC::SetFlag<AscendC::HardEvent::V_MTE2>(EVENT_ID1);
        AscendC::SetFlag<AscendC::HardEvent::MTE3_V>(EVENT_ID0);
        AscendC::SetFlag<AscendC::HardEvent::MTE3_V>(EVENT_ID1);

        for (uint32_t i = 0; i < tilesPerBlock; ++i) {
            const int32_t eventID = ((i & 1) == 0) ? EVENT_ID0 : EVENT_ID1;
            AscendC::LocalTensor<half>& ndBuf = ((i & 1) == 0) ? ndPing : ndPong;
            AscendC::LocalTensor<half>& nzBuf = ((i & 1) == 0) ? nzPing : nzPong;
            const uint32_t tileRow = rowTileBegin + i / tileColsPerSplit;
            const uint32_t tileCol = colTileBegin + i % tileColsPerSplit;
            const uint32_t tileRowStart = tileRow * tileH;
            const uint32_t tileColStart = tileCol * tileW;
            const uint32_t remainRows = totalM - tileRowStart;
            const uint32_t actualTileH = (remainRows < tileH) ? remainRows : tileH;
            const uint32_t srcOffset = tileRowStart * totalN + tileColStart;
            const uint32_t dstBlockOffset = tileRowStart + (tileColStart / C0_ELEMS) * totalM;

            AscendC::WaitFlag<AscendC::HardEvent::V_MTE2>(eventID);

            AscendC::DataCopyParams ndParams;
            ndParams.blockCount = actualTileH;
            ndParams.blockLen = tileW / C0_ELEMS;
            ndParams.srcStride = (totalN - tileW) / C0_ELEMS;
            ndParams.dstStride = 0;
            AscendC::DataCopy(ndBuf, xGm[srcOffset], ndParams);

            AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(eventID);
            AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(eventID);
            AscendC::WaitFlag<AscendC::HardEvent::MTE3_V>(eventID);

#if defined(__NPU_ARCH__) && (__NPU_ARCH__ == 2201)
            ComputeTileNd2nzWithCopy(ndBuf, nzBuf, actualTileH);
#elif defined(__NPU_ARCH__) && (__NPU_ARCH__ == 3510)
            Nd2Nz3510::ComputeTileWithRegVF<tileH, tileW, vecLenHalf>(ndBuf, nzBuf, actualTileH);
#endif

            AscendC::SetFlag<AscendC::HardEvent::V_MTE2>(eventID);
            AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(eventID);
            AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(eventID);

            AscendC::DataCopyParams outParams;
            outParams.blockCount = tileC0Cols;
            outParams.blockLen = actualTileH;
            outParams.srcStride = dstNzC0Stride - actualTileH;
            outParams.dstStride = totalM - actualTileH;
            AscendC::DataCopy(zGm[dstBlockOffset * C0_ELEMS], nzBuf, outParams);

            AscendC::SetFlag<AscendC::HardEvent::MTE3_V>(eventID);
        }

        AscendC::WaitFlag<AscendC::HardEvent::V_MTE2>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::V_MTE2>(EVENT_ID1);
        AscendC::WaitFlag<AscendC::HardEvent::MTE3_V>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE3_V>(EVENT_ID1);
    }

private:
#if defined(__NPU_ARCH__) && (__NPU_ARCH__ == 2201)
    __aicore__ inline void ComputeTileNd2nzWithCopy(
        AscendC::LocalTensor<half>& ndBuf, AscendC::LocalTensor<half>& nzBuf, uint32_t actualTileH)
    {
        AscendC::CopyRepeatParams copyParams;
        copyParams.dstStride = dstNzC0Stride;
        copyParams.srcStride = 1;
        copyParams.dstRepeatSize = 1;
        copyParams.srcRepeatSize = tileW / C0_ELEMS;

        for (uint32_t k = 0; k < tileW / vecLenHalf; ++k) {
            AscendC::Copy(
                nzBuf[k * vecLenDbs * dstNzC0Stride * C0_ELEMS], ndBuf[k * vecLenHalf],
                static_cast<uint64_t>(vecLenHalf), static_cast<uint8_t>(actualTileH), copyParams);
        }
    }
#endif

private:
    AscendC::GlobalTensor<half> xGm;
    AscendC::GlobalTensor<half> zGm;
};

template <
    uint32_t totalM, uint32_t totalN, uint32_t tileH, uint32_t tileW, uint32_t vecLenHalf, uint32_t rowSplits,
    uint32_t colSplits>
__global__ __vector__ void bank_conflict_nd2nz(__gm__ uint8_t* x, __gm__ uint8_t* z)
{
    AscendC::InitSocState();
    KernelNd2Nz<totalM, totalN, tileH, tileW, vecLenHalf, rowSplits, colSplits> op;
    op.Init(x, z);
    op.Process();
    AscendC::PipeBarrier<PIPE_ALL>();
}

int32_t main(int32_t argc, char* argv[])
{
    (void)argc;
    (void)argv;

    constexpr uint32_t totalM = 8192;
    constexpr uint32_t totalN = 8192;
    // 分区内部再用 144x128 小 tile 流水处理，平衡 vcopy repeat 与 MTE 搬运压力。
    constexpr uint32_t tileH = 144;
    constexpr uint32_t tileW = 128;
    // tiling 参数：单条 vcopy 正确处理 8 个 DataBlock，即 128 个 half 元素。
    constexpr uint32_t vecLenHalf = 128;

#if NPU_ARCH == 2201
    // 2201 有 48 个 Vector 核：8 列切分 * 6 行切分。
    constexpr uint32_t colSplits = 8;
    constexpr uint32_t rowSplits = 6;
#elif NPU_ARCH == 3510
    // 3510 有 64 个 Vector 核：8 列切分 * 8 行切分。
    constexpr uint32_t colSplits = 8;
    constexpr uint32_t rowSplits = 8;
#endif
    constexpr uint32_t totalBlocks = rowSplits * colSplits;

    constexpr size_t inputByteSize = static_cast<size_t>(totalM) * totalN * sizeof(half);
    constexpr size_t outputByteSize = static_cast<size_t>(totalM) * totalN * sizeof(half);

    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t* xHost = nullptr;
    uint8_t* zHost = nullptr;
    uint8_t* xDevice = nullptr;
    uint8_t* zDevice = nullptr;

    aclrtMallocHost((void**)(&xHost), inputByteSize);
    aclrtMallocHost((void**)(&zHost), outputByteSize);
    aclrtMalloc((void**)&xDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&zDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);

    size_t inputFileSize = 0;
    if (!ReadFile("./input/input.bin", inputFileSize, xHost, inputByteSize)) {
        return 1;
    }

    aclrtMemcpy(xDevice, inputByteSize, xHost, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
    bank_conflict_nd2nz<totalM, totalN, tileH, tileW, vecLenHalf, rowSplits, colSplits>
        <<<totalBlocks, nullptr, stream>>>(xDevice, zDevice);
    aclrtSynchronizeStream(stream);
    aclrtMemcpy(zHost, outputByteSize, zDevice, outputByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", zHost, outputByteSize);

    aclrtFree(xDevice);
    aclrtFree(zDevice);
    aclrtFreeHost(xHost);
    aclrtFreeHost(zHost);
    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();
    return 0;
}
