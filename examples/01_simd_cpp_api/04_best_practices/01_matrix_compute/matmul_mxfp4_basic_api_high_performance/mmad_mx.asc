/* !
 * \file mmad_mx.asc
 * \brief matmul_mxfp4_basic_api_high_performance
 */

#include "acl/acl.h"
#include "kernel_operator.h"
#include "data_utils.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

constexpr uint32_t CUBE_BLOCK = 16;
constexpr uint32_t L0_PINGPONG_BYTES = 32 * 1024;
constexpr uint32_t L1_PINGPONG_BYTES = 256 * 1024;
constexpr bool IS_B_TRANSPOSE = true;
constexpr bool IS_BS_TRANSPOSE = true;
constexpr uint32_t SCALE_CEIL_NUMBER = 32;
constexpr uint32_t SCALE_ALIGN_NUMBER = 2;

template <
    uint32_t M, uint32_t K, uint32_t N, uint32_t baseM, uint32_t baseK, uint32_t baseN, uint32_t singleCoreM,
    uint32_t singleCoreK, uint32_t singleCoreN, uint32_t stepKa, uint32_t stepKb, uint32_t scaleFactorKa,
    uint32_t scaleFactorKb>
class KernelMmadmx {
    // 编译期常量：避免重复计算公式和单位混淆
    static constexpr uint32_t PACKED_K =
        AscendC::DivCeil(K, 2); // fp4x2每行元素数，2个fp4打包为1个uint8（仅在gm2l1的Nd2Nz参数中使用）
    static constexpr uint32_t SCALE_K = AscendC::AlignUp(AscendC::DivCeil(K, SCALE_CEIL_NUMBER), SCALE_ALIGN_NUMBER);

public:
    __aicore__ inline KernelMmadmx() {}
    __aicore__ inline void Init(__gm__ uint8_t* a, __gm__ uint8_t* b, __gm__ uint8_t* as, __gm__ uint8_t* bs, __gm__ uint8_t* c)
    {
        aGMOri.SetGlobalBuffer((__gm__ fp4x2_e1m2_t*)a);
        bGMOri.SetGlobalBuffer((__gm__ fp4x2_e1m2_t*)b);
        asGMOri.SetGlobalBuffer((__gm__ fp8_e8m0_t*)as);
        bsGMOri.SetGlobalBuffer((__gm__ fp8_e8m0_t*)bs);
        cGMOri.SetGlobalBuffer((__gm__ bfloat16_t*)c);
    }

    __aicore__ inline void Process()
    {
        InitComputeParams();

        // ============================================================
        // 1. Buffer 分配：L1 / L0 双缓冲 Ping-Pong 布局
        // ============================================================
        // L1: A1 + AS1 Ping/Pong (0~256KB), B1 + BS1 Ping/Pong (256~512KB)
        // L0: A2/B2 Ping/Pong (0~32KB / 32KB~64KB)
        // L0AMX L0BMX 无需考虑地址（占4KB）
        // A/B in L1 are fp4x2 packed tensors, so K-span uses packed width.
        constexpr uint32_t a1BufSize = baseM * AscendC::DivCeil(baseK * stepKa, 2);
        constexpr uint32_t b1BufSize = baseN * AscendC::DivCeil(baseK * stepKb, 2);
        constexpr uint32_t as1BufSize = baseM * AscendC::DivCeil(baseK * stepKa, SCALE_CEIL_NUMBER) * scaleFactorKa;
        constexpr uint32_t bs1BufSize = baseN * AscendC::DivCeil(baseK * stepKb, SCALE_CEIL_NUMBER) * scaleFactorKb;
        static_assert(2 * a1BufSize + 2 * as1BufSize <= L1_PINGPONG_BYTES, "A/As ping-pong L1 footprint exceeds 256KB");
        static_assert(2 * b1BufSize + 2 * bs1BufSize <= L1_PINGPONG_BYTES, "B/Bs ping-pong L1 footprint exceeds 256KB");
        uint32_t a2PingpongSize = baseM * baseK;
        uint32_t b2PingpongSize = baseK * baseN;

        // A1: L1 Ping/Pong
        AscendC::LocalTensor<fp4x2_e1m2_t> a1LocalPing(AscendC::TPosition::A1, 0, a1BufSize);
        AscendC::LocalTensor<fp4x2_e1m2_t> a1LocalPong(AscendC::TPosition::A1, a1BufSize, a1BufSize);
        AscendC::LocalTensor<fp8_e8m0_t> as1LocalPing(AscendC::TPosition::A1, 2 * a1BufSize, as1BufSize);
        AscendC::LocalTensor<fp8_e8m0_t> as1LocalPong(AscendC::TPosition::A1, 2 * a1BufSize + as1BufSize, as1BufSize);

        // B1: L1 Ping/Pong
        AscendC::LocalTensor<fp4x2_e1m2_t> b1LocalPing(AscendC::TPosition::B1, L1_PINGPONG_BYTES, b1BufSize);
        AscendC::LocalTensor<fp4x2_e1m2_t> b1LocalPong(
            AscendC::TPosition::B1, L1_PINGPONG_BYTES + b1BufSize, b1BufSize);
        AscendC::LocalTensor<fp8_e8m0_t> bs1LocalPing(
            AscendC::TPosition::B1, L1_PINGPONG_BYTES + 2 * b1BufSize, bs1BufSize);
        AscendC::LocalTensor<fp8_e8m0_t> bs1LocalPong(
            AscendC::TPosition::B1, L1_PINGPONG_BYTES + 2 * b1BufSize + bs1BufSize, bs1BufSize);

        // A2: L0 Ping/Pong  32KB
        AscendC::LocalTensor<fp4x2_e1m2_t> a2LocalPing(AscendC::TPosition::A2, 0, a2PingpongSize);
        AscendC::LocalTensor<fp4x2_e1m2_t> a2LocalPong(AscendC::TPosition::A2, L0_PINGPONG_BYTES, a2PingpongSize);
        // B2: L0 Ping/Pong  32KB
        AscendC::LocalTensor<fp4x2_e1m2_t> b2LocalPing(AscendC::TPosition::B2, 0, b2PingpongSize);
        AscendC::LocalTensor<fp4x2_e1m2_t> b2LocalPong(AscendC::TPosition::B2, L0_PINGPONG_BYTES, b2PingpongSize);

        // CO1: L0C
        AscendC::LocalTensor<float> cLocal(AscendC::TPosition::CO1, 0, baseM * baseN);

        ProcessLoop(
            a1LocalPing, a1LocalPong, as1LocalPing, as1LocalPong, a2LocalPing, a2LocalPong, b1LocalPing, b1LocalPong,
            bs1LocalPing, bs1LocalPong, b2LocalPing, b2LocalPong, cLocal);
    }

private:
    __aicore__ inline int32_t GetDataEventId(uint32_t pingPongIdx) const
    {
        return (pingPongIdx == 0) ? EVENT_ID0 : EVENT_ID1;
    }

    __aicore__ inline int32_t GetScaleEventId(uint32_t pingPongIdx) const
    {
        return (pingPongIdx == 0) ? EVENT_ID2 : EVENT_ID3;
    }

    __aicore__ inline int32_t GetL0EventId(uint32_t pingPongIdx) const
    {
        return (pingPongIdx == 0) ? EVENT_ID0 : EVENT_ID1;
    }

    // N/M/K 主循环：执行当前核的完整计算
    __aicore__ inline void ProcessLoop(
        AscendC::LocalTensor<fp4x2_e1m2_t>& a1LocalPing, AscendC::LocalTensor<fp4x2_e1m2_t>& a1LocalPong,
        AscendC::LocalTensor<fp8_e8m0_t>& as1LocalPing, AscendC::LocalTensor<fp8_e8m0_t>& as1LocalPong,
        AscendC::LocalTensor<fp4x2_e1m2_t>& a2LocalPing, AscendC::LocalTensor<fp4x2_e1m2_t>& a2LocalPong,
        AscendC::LocalTensor<fp4x2_e1m2_t>& b1LocalPing, AscendC::LocalTensor<fp4x2_e1m2_t>& b1LocalPong,
        AscendC::LocalTensor<fp8_e8m0_t>& bs1LocalPing, AscendC::LocalTensor<fp8_e8m0_t>& bs1LocalPong,
        AscendC::LocalTensor<fp4x2_e1m2_t>& b2LocalPing, AscendC::LocalTensor<fp4x2_e1m2_t>& b2LocalPong,
        AscendC::LocalTensor<float>& cLocal)
    {
        // ============================================================
        // 1. DataCopyIn 进度跟踪变量
        // ============================================================
        constexpr uint32_t asChunkStep = stepKa * scaleFactorKa;
        constexpr uint32_t bsChunkStep = stepKb * scaleFactorKb;
        static_assert(stepKa == stepKb, "stepKa and stepKb must match when A/B share data events");
        static_assert(asChunkStep == bsChunkStep, "As/Bs scale chunk steps must match when scale events are shared");
        constexpr uint32_t dataChunkStep = stepKa;
        constexpr uint32_t scaleChunkStep = asChunkStep;
        uint32_t dataNextKChunkIdx = 0;  // A/B 下一次 DataCopyIn 要搬的 K 方向大包索引
        uint32_t scaleNextKChunkIdx = 0; // As/Bs 下一次 DataCopyIn 要搬的 K 方向大包索引
        uint8_t dataCopyInIdx = 0;       // A/B 下一次 DataCopyIn 写入的 L1 buffer 索引 (0=Ping, 1=Pong)
        uint8_t scaleCopyInIdx = 0;      // As/Bs 下一次 DataCopyIn 写入的 L1 buffer 索引 (0=Ping, 1=Pong)

        // ============================================================
        // 2. 同步标志初始化：反向同步需预置，防止首次 WaitFlag 死锁
        // ============================================================
        // MTE1_MTE2 (反向): DataCopyIn 可覆盖通知
        //   EVENT_ID0: A/B Ping 可写 | EVENT_ID1: A/B Pong 可写
        //   EVENT_ID2: As/Bs Ping 可写 | EVENT_ID3: As/Bs Pong 可写
        AscendC::SetFlag<AscendC::HardEvent::MTE1_MTE2>(EVENT_ID0);
        AscendC::SetFlag<AscendC::HardEvent::MTE1_MTE2>(EVENT_ID1);
        AscendC::SetFlag<AscendC::HardEvent::MTE1_MTE2>(EVENT_ID2);
        AscendC::SetFlag<AscendC::HardEvent::MTE1_MTE2>(EVENT_ID3);
        // M_MTE1 (反向): L0 双缓冲，DataLoad 可覆盖通知
        AscendC::SetFlag<AscendC::HardEvent::M_MTE1>(EVENT_ID0);
        AscendC::SetFlag<AscendC::HardEvent::M_MTE1>(EVENT_ID1);

        // ============================================================
        // 3. N/M 外层循环 + K 主循环
        // ============================================================
        for (uint32_t nBlockIdx = 0; nBlockIdx < nLoopCount; nBlockIdx++) {
            for (uint32_t mBlockIdx = 0; mBlockIdx < mLoopCount; mBlockIdx++) {
                // 每个 (mBlockIdx, nBlockIdx) 子块重置 DataCopyIn 进度
                dataNextKChunkIdx = 0;
                scaleNextKChunkIdx = 0;
                dataCopyInIdx = 0;
                scaleCopyInIdx = 0;

                // ---- 搬入 A/B 以及 As/Bs 的首个大包 ----
                int32_t dataWriteEvent = GetDataEventId(dataCopyInIdx);
                AscendC::WaitFlag<AscendC::HardEvent::MTE1_MTE2>(dataWriteEvent); // A/B Ping 可写
                DataCopyInA(a1LocalPing, dataNextKChunkIdx, mBlockIdx);
                DataCopyInB(b1LocalPing, dataNextKChunkIdx, nBlockIdx);
                AscendC::SetFlag<AscendC::HardEvent::MTE2_MTE1>(dataWriteEvent); // A/B Ping 数据就绪
                dataNextKChunkIdx += dataChunkStep;
                dataCopyInIdx ^= 1; // 下次写 Pong

                int32_t scaleWriteEvent = GetScaleEventId(scaleCopyInIdx);
                AscendC::WaitFlag<AscendC::HardEvent::MTE1_MTE2>(scaleWriteEvent); // As/Bs Ping 可写
                DataCopyInAScale(as1LocalPing, scaleNextKChunkIdx, mBlockIdx);
                DataCopyInBScale(bs1LocalPing, scaleNextKChunkIdx, nBlockIdx);
                AscendC::SetFlag<AscendC::HardEvent::MTE2_MTE1>(scaleWriteEvent); // As/Bs Ping 数据就绪
                scaleNextKChunkIdx += scaleChunkStep;
                scaleCopyInIdx ^= 1;

                // ---- K 方向主循环 ----
                for (uint32_t kBlockIdx = 0; kBlockIdx < kLoopCount; kBlockIdx++) {
                    // 确定当前 kBlockIdx 对应的 L1 读取缓冲区（Ping/Pong）
                    uint32_t dataReadIdx = (kBlockIdx / dataChunkStep) % 2;
                    uint32_t scaleReadIdx = (kBlockIdx / scaleChunkStep) % 2;
                    uint32_t kOffsetInDataChunk = kBlockIdx % dataChunkStep;
                    uint32_t kOffsetInScaleChunk = kBlockIdx % scaleChunkStep;

                    AscendC::LocalTensor<fp4x2_e1m2_t> a1ReadBuf = (dataReadIdx == 0) ? a1LocalPing : a1LocalPong;
                    AscendC::LocalTensor<fp4x2_e1m2_t> b1ReadBuf = (dataReadIdx == 0) ? b1LocalPing : b1LocalPong;
                    AscendC::LocalTensor<fp8_e8m0_t> as1ReadBuf = (scaleReadIdx == 0) ? as1LocalPing : as1LocalPong;
                    AscendC::LocalTensor<fp8_e8m0_t> bs1ReadBuf = (scaleReadIdx == 0) ? bs1LocalPing : bs1LocalPong;

                    // L0 双缓冲选择
                    AscendC::LocalTensor<fp4x2_e1m2_t> a2Local = (mte1DBFlag == 0) ? a2LocalPing : a2LocalPong;
                    AscendC::LocalTensor<fp4x2_e1m2_t> b2Local = (mte1DBFlag == 0) ? b2LocalPing : b2LocalPong;

                    // ---- 反向同步：等待上一轮 Compute 释放 L0 缓冲区 ----
                    AscendC::WaitFlag<AscendC::HardEvent::M_MTE1>(GetL0EventId(mte1DBFlag));

                    // ---- 正向同步：等待 L1 大包数据就绪（仅大包中首元素需等待） ----
                    if (kOffsetInDataChunk == 0) {
                        AscendC::WaitFlag<AscendC::HardEvent::MTE2_MTE1>(GetDataEventId(dataReadIdx));
                    }
                    if (kOffsetInScaleChunk == 0) {
                        AscendC::WaitFlag<AscendC::HardEvent::MTE2_MTE1>(GetScaleEventId(scaleReadIdx));
                    }

                    // ---- DataLoad: L1 → L0 ----
                    DataLoadA(a1ReadBuf, as1ReadBuf, a2Local, mBlockIdx, kOffsetInDataChunk, kOffsetInScaleChunk);
                    DataLoadB(b1ReadBuf, bs1ReadBuf, b2Local, nBlockIdx, kOffsetInDataChunk, kOffsetInScaleChunk);

                    // ---- 反向同步：当前 L1 大包消费完毕，通知 DataCopyIn 可覆盖 ----
                    if (((kOffsetInDataChunk + 1) == dataChunkStep) || (kBlockIdx + 1 == kLoopCount)) {
                        AscendC::SetFlag<AscendC::HardEvent::MTE1_MTE2>(GetDataEventId(dataReadIdx));
                    }
                    if (((kOffsetInScaleChunk + 1) == scaleChunkStep) || (kBlockIdx + 1 == kLoopCount)) {
                        AscendC::SetFlag<AscendC::HardEvent::MTE1_MTE2>(GetScaleEventId(scaleReadIdx));
                    }

                    // ---- Compute: Mmad 矩阵乘累加 ----
                    Compute(cLocal, a2Local, b2Local, kBlockIdx, mBlockIdx, nBlockIdx);

                    // ---- 搬入下一个 L1 大包，使 DataCopyIn 与 Compute 流水重叠 ----
                    // 触发条件：
                    //   (1) kBlockIdx == 0：首个 K 块计算时，A1/B1 Pong 尚未使用，可直接搬入
                    //   (2) 当前 L1 大包最后一个 baseK 被消费完，该缓冲区可被覆盖
                    if (((kBlockIdx == 0) || ((kOffsetInDataChunk + 1) == dataChunkStep)) &&
                        dataNextKChunkIdx < kLoopCount) {
                        AscendC::LocalTensor<fp4x2_e1m2_t> a1WriteBuf =
                            (dataCopyInIdx == 0) ? a1LocalPing : a1LocalPong;
                        AscendC::LocalTensor<fp4x2_e1m2_t> b1WriteBuf =
                            (dataCopyInIdx == 0) ? b1LocalPing : b1LocalPong;
                        int32_t dataWriteEvent = GetDataEventId(dataCopyInIdx);
                        AscendC::WaitFlag<AscendC::HardEvent::MTE1_MTE2>(dataWriteEvent);
                        DataCopyInA(a1WriteBuf, dataNextKChunkIdx, mBlockIdx);
                        DataCopyInB(b1WriteBuf, dataNextKChunkIdx, nBlockIdx);
                        AscendC::SetFlag<AscendC::HardEvent::MTE2_MTE1>(dataWriteEvent);
                        dataNextKChunkIdx += dataChunkStep;
                        dataCopyInIdx ^= 1;
                    }
                    if (((kBlockIdx == 0) || ((kOffsetInScaleChunk + 1) == scaleChunkStep)) &&
                        scaleNextKChunkIdx < kLoopCount) {
                        AscendC::LocalTensor<fp8_e8m0_t> as1WriteBuf =
                            (scaleCopyInIdx == 0) ? as1LocalPing : as1LocalPong;
                        AscendC::LocalTensor<fp8_e8m0_t> bs1WriteBuf =
                            (scaleCopyInIdx == 0) ? bs1LocalPing : bs1LocalPong;
                        int32_t scaleWriteEvent = GetScaleEventId(scaleCopyInIdx);
                        AscendC::WaitFlag<AscendC::HardEvent::MTE1_MTE2>(scaleWriteEvent);
                        DataCopyInAScale(as1WriteBuf, scaleNextKChunkIdx, mBlockIdx);
                        DataCopyInBScale(bs1WriteBuf, scaleNextKChunkIdx, nBlockIdx);
                        AscendC::SetFlag<AscendC::HardEvent::MTE2_MTE1>(scaleWriteEvent);
                        scaleNextKChunkIdx += scaleChunkStep;
                        scaleCopyInIdx ^= 1;
                    }
                }
                // ---- CopyOut: CO1 → GM ----
                CopyOut(cLocal, mBlockIdx, nBlockIdx);
            }
        }

        // ============================================================
        // 4. 等待所有同步完成
        // ============================================================
        AscendC::WaitFlag<AscendC::HardEvent::M_MTE1>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::M_MTE1>(EVENT_ID1);
        AscendC::WaitFlag<AscendC::HardEvent::MTE1_MTE2>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE1_MTE2>(EVENT_ID1);
        AscendC::WaitFlag<AscendC::HardEvent::MTE1_MTE2>(EVENT_ID2);
        AscendC::WaitFlag<AscendC::HardEvent::MTE1_MTE2>(EVENT_ID3);
    }

    __aicore__ inline void InitComputeParams()
    {
        // ---- 1. 计算当前核在 M/N 方向的迭代索引，确定 GM 起始偏移 ----
        constexpr uint32_t mIter = AscendC::DivCeil(M, singleCoreM);
        uint32_t mIterIdx = AscendC::GetBlockIdx() % mIter;
        uint32_t nIterIdx = AscendC::GetBlockIdx() / mIter;

        uint64_t gmOffsetA = mIterIdx * singleCoreM * K;
        uint64_t gmOffsetB = IS_B_TRANSPOSE ? nIterIdx * K * singleCoreN : nIterIdx * singleCoreN;
        uint64_t gmOffsetC = mIterIdx * singleCoreM * N + nIterIdx * singleCoreN;
        uint64_t gmOffsetAs = mIterIdx * singleCoreM * SCALE_K;
        uint64_t gmOffsetBs = IS_BS_TRANSPOSE ? nIterIdx * SCALE_K * singleCoreN : nIterIdx * singleCoreN;
        aGM = aGMOri[gmOffsetA];
        bGM = bGMOri[gmOffsetB];
        asGM = asGMOri[gmOffsetAs];
        bsGM = bsGMOri[gmOffsetBs];
        cGM = cGMOri[gmOffsetC];

        // ---- 2. 计算当前核实际的 M/N 维度大小（最后一块可能不满 singleCore） ----
        actualSingleCoreM = M - mIterIdx * singleCoreM;
        actualSingleCoreM = actualSingleCoreM < singleCoreM ? actualSingleCoreM : singleCoreM;
        actualSingleCoreN = N - nIterIdx * singleCoreN;
        actualSingleCoreN = actualSingleCoreN < singleCoreN ? actualSingleCoreN : singleCoreN;

        // ---- 3. 计算 K/M/N 三个维度的循环次数 ----
        kLoopCount = AscendC::DivCeil(singleCoreK, baseK);
        mLoopCount = AscendC::DivCeil(actualSingleCoreM, baseM);
        nLoopCount = AscendC::DivCeil(actualSingleCoreN, baseN);

        // ---- 4. 计算 N 方向分块参数：完整 baseN 块数 + 尾块大小及对齐 ----
        baseNCount = actualSingleCoreN / baseN;
        tailN = actualSingleCoreN % baseN;
        tailNAlign = AscendC::DivCeil(tailN, CUBE_BLOCK) * CUBE_BLOCK;

        // ---- 5. 计算 M 方向分块参数：完整 baseM 块数 + 尾块大小及对齐 ----
        baseMCount = actualSingleCoreM / baseM;
        tailM = actualSingleCoreM % baseM;
        tailMAlign = AscendC::DivCeil(tailM, CUBE_BLOCK) * CUBE_BLOCK;
    }

    // GM → A1: 将 A 矩阵的一个大包 (stepKa 个 baseK) 搬入 L1，同时搬入对应的 scale 数据
    // kChunkIdx: K 方向大包索引，用于计算 GM 读取偏移
    // mBlockIdx: M 方向 baseM 块索引，用于计算 GM 读取偏移及判断尾块
    __aicore__ inline void DataCopyInA(
        AscendC::LocalTensor<fp4x2_e1m2_t> a1Local, uint32_t kChunkIdx, uint32_t mBlockIdx)
    {
        // NOTE:
        // aGM/a1Local 的元素类型是 fp4x2_e1m2_t（1 个元素打包 2 个 fp4）。
        // 因此 DataCopy 的宽度/步长/偏移都要按“打包后元素个数”计算：
        // packedK = ceil(K / 2)，而不是按原始 fp4 元素个数 K。
        // 尾块使用 tailM，否则使用 baseM
        uint32_t curM = (mBlockIdx != baseMCount) ? baseM : tailM;
        constexpr uint32_t packedStepK = AscendC::DivCeil(baseK * stepKa, 2);
        AscendC::Nd2NzParams nd2nzA1Params;
        nd2nzA1Params.ndNum = 1;
        nd2nzA1Params.nValue = curM;
        nd2nzA1Params.dValue = packedStepK;
        nd2nzA1Params.srcNdMatrixStride = 0; // 源操作数相邻ND矩阵间的起始地址偏移
        nd2nzA1Params.srcDValue = PACKED_K; // 源操作数同一ND矩阵内相邻行的起始地址偏移（打包后的K）
        nd2nzA1Params.dstNzC0Stride = baseM; // ND转NZ后，同一行数据切分后各段的起始地址间隔，单位32B
        nd2nzA1Params.dstNzNStride = 1;      // ND矩阵第x行与第x+1行转NZ后在dst中的偏移
        nd2nzA1Params.dstNzMatrixStride = 0;
        AscendC::DataCopy(a1Local, aGM[kChunkIdx * baseK + mBlockIdx * K * baseM], nd2nzA1Params);
    }

    __aicore__ inline void DataCopyInAScale(
        AscendC::LocalTensor<fp8_e8m0_t> as1Local, uint32_t kChunkIdx, uint32_t mBlockIdx)
    {
        // 尾块使用tailM，否则使用baseM
        uint32_t curM = (mBlockIdx != baseMCount) ? baseM : tailM;
        constexpr uint32_t stepScaleK = AscendC::DivCeil(baseK * stepKa * scaleFactorKa, SCALE_CEIL_NUMBER);
        static_assert(stepScaleK % 2 == 0, "stepScaleK需2B对齐以使用Dn2Nz.b16");
        static_assert(baseK % 64 == 0, "baseK需64对齐以计算b16 scale搬运偏移");
        uint32_t scaleOffset = (kChunkIdx * baseK) / SCALE_CEIL_NUMBER;
        // Scale为fp8(1B)，硬件在MX路径下要求K方向按2B连续搬运
        // 因此将2个fp8视作1个b16，使用Dn2Nz完成[M, stepScaleK] -> K-major/NZ布局转换
        AscendC::Dn2NzParams dn2nzParams;
        dn2nzParams.dnNum = 1;
        dn2nzParams.dValue = curM;
        dn2nzParams.nValue = stepScaleK / 2;
        dn2nzParams.srcDnMatrixStride = 0;
        dn2nzParams.srcDValue = SCALE_K / 2;
        dn2nzParams.dstNzC0Stride = stepScaleK / 2;
        dn2nzParams.dstNzNStride = 1;
        dn2nzParams.dstNzMatrixStride = 0;

        AscendC::GlobalTensor<half> asGMB16;
        asGMB16.SetGlobalBuffer(
            ((__gm__ half*)(asGM.GetPhyAddr())) + (mBlockIdx * baseM * SCALE_K + scaleOffset) / 2,
            curM * (SCALE_K / 2));
        auto asLocalB16 = as1Local.ReinterpretCast<half>();
        AscendC::DataCopy(asLocalB16, asGMB16, dn2nzParams);
    }

    // GM → B1: 将 B 矩阵的一个大包 (stepKb 个 baseK) 搬入 L1，同时搬入对应的 scale 数据
    // kChunkIdx: K 方向大包索引，用于计算 GM 读取偏移
    // nBlockIdx: N 方向 baseN 块索引，用于计算 GM 读取偏移及判断尾块
    __aicore__ inline void DataCopyInB(
        AscendC::LocalTensor<fp4x2_e1m2_t> b1Local, uint32_t kChunkIdx, uint32_t nBlockIdx)
    {
        // NOTE:
        // bGM/b1Local 同样是 fp4x2_e1m2_t，地址与 stride 也都按 packedK=ceil(K/2) 计。
        // 只有 Mmad 参数里的 k 才是逻辑 fp4 元素个数 K。
        // 尾块使用tailN，否则使用baseN
        uint32_t curN = (nBlockIdx != baseNCount) ? baseN : tailN;
        constexpr uint32_t packedStepK = AscendC::DivCeil(baseK * stepKb, 2);
        AscendC::Nd2NzParams nd2nzB1Params;
        if constexpr (!IS_B_TRANSPOSE) {
            nd2nzB1Params.ndNum = 1;
            nd2nzB1Params.nValue = packedStepK;
            nd2nzB1Params.dValue = curN;
            nd2nzB1Params.srcNdMatrixStride = 0;
            nd2nzB1Params.srcDValue = N;
            nd2nzB1Params.dstNzC0Stride = packedStepK;
            nd2nzB1Params.dstNzNStride = 1;
            nd2nzB1Params.dstNzMatrixStride = 0;
            AscendC::DataCopy(b1Local, bGM[kChunkIdx * baseK * N + nBlockIdx * baseN], nd2nzB1Params);
        } else {
            nd2nzB1Params.ndNum = 1;
            nd2nzB1Params.nValue = curN;
            nd2nzB1Params.dValue = packedStepK;
            nd2nzB1Params.srcNdMatrixStride = 0;
            nd2nzB1Params.srcDValue = PACKED_K;
            nd2nzB1Params.dstNzC0Stride = baseN;
            nd2nzB1Params.dstNzNStride = 1;
            nd2nzB1Params.dstNzMatrixStride = 0;
            AscendC::DataCopy(b1Local, bGM[kChunkIdx * baseK + nBlockIdx * baseN * K], nd2nzB1Params);
        }
    }

    __aicore__ inline void DataCopyInBScale(
        AscendC::LocalTensor<fp8_e8m0_t> bs1Local, uint32_t kChunkIdx, uint32_t nBlockIdx)
    {
        uint32_t curN = (nBlockIdx != baseNCount) ? baseN : tailN;
        constexpr uint32_t stepScaleK = AscendC::DivCeil(baseK * stepKb * scaleFactorKb, SCALE_CEIL_NUMBER);
        static_assert(stepScaleK % 2 == 0, "stepScaleK需2B对齐以使用Dn2Nz.b16");
        static_assert(baseK % 64 == 0, "baseK需64对齐以计算b16 scale搬运偏移");
        uint32_t scaleOffset = (kChunkIdx * baseK) / SCALE_CEIL_NUMBER;
        // 与A scale同理：按b16视图做Dn2Nz，保证后续LOAD_MX_2D读到的scale排布正确
        AscendC::Dn2NzParams dn2nzParams;
        dn2nzParams.dnNum = 1;
        dn2nzParams.dValue = curN;
        dn2nzParams.nValue = stepScaleK / 2;
        dn2nzParams.srcDnMatrixStride = 0;
        dn2nzParams.srcDValue = SCALE_K / 2;
        dn2nzParams.dstNzC0Stride = stepScaleK / 2;
        dn2nzParams.dstNzNStride = 1;
        dn2nzParams.dstNzMatrixStride = 0;

        AscendC::GlobalTensor<half> bsGMB16;
        bsGMB16.SetGlobalBuffer(
            ((__gm__ half*)(bsGM.GetPhyAddr())) + (nBlockIdx * baseN * SCALE_K + scaleOffset) / 2,
            curN * (SCALE_K / 2));
        auto bsLocalB16 = bs1Local.ReinterpretCast<half>();
        AscendC::DataCopy(bsLocalB16, bsGMB16, dn2nzParams);
    }

    // A1 → A2: 将 L1 中的一个 baseM * baseK 切片搬入 L0 (MX 格式含 scale)
    // mBlockIdx: M 方向 baseM 块索引，用于判断尾块对齐
    // kOffsetInChunkA: 当前 base块 在大包内的偏移序号 (0 ~ stepKa-1)
    __aicore__ inline void DataLoadA(
        AscendC::LocalTensor<fp4x2_e1m2_t> a1Local, AscendC::LocalTensor<fp8_e8m0_t> as1Local,
        AscendC::LocalTensor<fp4x2_e1m2_t> a2Local, uint32_t mBlockIdx, uint32_t kOffsetInChunkA,
        uint32_t kOffsetInScaleChunkA)
    {
        // fp4x2 LocalTensor在LoadData路径的索引应使用逻辑fp4 K跨度，避免半步地址计算
        uint32_t srcAddr = kOffsetInChunkA * baseK * baseM;
        uint32_t scaleSrcAddr = (kOffsetInScaleChunkA * baseK / SCALE_CEIL_NUMBER) * CUBE_BLOCK;
        // 尾块使用对齐后的 tailMAlign，保证 LoadData 地址对齐
        uint32_t curMAlign = (mBlockIdx != baseMCount) ? baseM : tailMAlign;

        AscendC::LoadData2DParamsV2 loadDataParams;
        loadDataParams.mStartPosition = 0;
        loadDataParams.kStartPosition = 0;
        loadDataParams.mStep = AscendC::DivCeil(curMAlign, CUBE_BLOCK); // M轴搬运长度，单位16元素（1个分形）
        loadDataParams.kStep = AscendC::DivCeil(baseK, 64);             // K轴搬运长度，单位32B
        loadDataParams.srcStride = AscendC::DivCeil(baseM, CUBE_BLOCK); // 源K方向相邻分形起始地址间隔，单位512B
        loadDataParams.dstStride = AscendC::DivCeil(curMAlign, CUBE_BLOCK); // 目标K方向相邻分形起始地址间隔，单位512B
        loadDataParams.sid = 0;
        loadDataParams.ifTranspose = false;
        AscendC::LoadData2DMxParams loadMxDataParams;
        loadMxDataParams.xStartPosition = 0;
        loadMxDataParams.yStartPosition = 0;
        loadMxDataParams.xStep = AscendC::DivCeil(curMAlign, CUBE_BLOCK); // M维度搬运长度，单位1个分形
        loadMxDataParams.yStep = AscendC::DivCeil(baseK, 64);             // K维度搬运长度，单位32B
        loadMxDataParams.srcStride =
            AscendC::DivCeil(baseK * stepKa * scaleFactorKa, 64); // 源scale K方向相邻分形间隔，单位32B
        loadMxDataParams.dstStride = AscendC::DivCeil(baseK, 64);
        AscendC::LoadData(a2Local, a1Local[srcAddr], as1Local[scaleSrcAddr], loadDataParams, loadMxDataParams);
    }

    // B1 → B2: 将 L1 中的一个 baseK * baseN 切片搬入 L0 (MX 格式含 scale)
    // nBlockIdx: N 方向 baseN 块索引，用于判断尾块对齐
    // kOffsetInChunkB: 当前 base块 在大包内的偏移序号 (0 ~ stepKb-1)
    __aicore__ inline void DataLoadB(
        AscendC::LocalTensor<fp4x2_e1m2_t> b1Local, AscendC::LocalTensor<fp8_e8m0_t> bs1Local,
        AscendC::LocalTensor<fp4x2_e1m2_t> b2Local, uint32_t nBlockIdx, uint32_t kOffsetInChunkB,
        uint32_t kOffsetInScaleChunkB)
    {
        uint32_t srcAddr = kOffsetInChunkB * baseK * (IS_B_TRANSPOSE ? baseN : CUBE_BLOCK);
        uint32_t scaleSrcAddr = (kOffsetInScaleChunkB * baseK / SCALE_CEIL_NUMBER) * CUBE_BLOCK;
        // 尾块使用对齐后的 tailNAlign，保证 LoadData 地址对齐
        uint32_t curNAlign = (nBlockIdx != baseNCount) ? baseN : tailNAlign;

        AscendC::LoadData2DParamsV2 loadDataParamsB;
        loadDataParamsB.mStartPosition = 0;
        loadDataParamsB.kStartPosition = 0;
        loadDataParamsB.mStep = AscendC::DivCeil(curNAlign, CUBE_BLOCK); // N轴搬运长度，单位16元素（1个分形）
        loadDataParamsB.kStep = AscendC::DivCeil(baseK, 64);             // K轴搬运长度，单位32B
        loadDataParamsB.srcStride = AscendC::DivCeil(baseN, CUBE_BLOCK); // 源K方向相邻分形起始地址间隔，单位512B
        loadDataParamsB.dstStride = AscendC::DivCeil(curNAlign, CUBE_BLOCK); // 目标K方向相邻分形起始地址间隔，单位512B
        loadDataParamsB.ifTranspose = false;
        AscendC::LoadData2DMxParams loadMxDataParams;
        loadMxDataParams.xStartPosition = 0;
        loadMxDataParams.yStartPosition = 0;
        loadMxDataParams.xStep = AscendC::DivCeil(curNAlign, CUBE_BLOCK); // N维度搬运长度，单位1个分形
        loadMxDataParams.yStep = AscendC::DivCeil(baseK, 64);             // K维度搬运长度，单位32B
        loadMxDataParams.srcStride =
            AscendC::DivCeil(baseK * stepKb * scaleFactorKb, 64); // 源scale K方向相邻分形间隔，单位32B
        loadMxDataParams.dstStride = AscendC::DivCeil(baseK, 64);
        AscendC::LoadData(b2Local, b1Local[srcAddr], bs1Local[scaleSrcAddr], loadDataParamsB, loadMxDataParams);
    }

    // A2 * B2 → CO1: 执行一次 Mmad 矩阵乘累加，A矩阵大小 baseM * baseK，B矩阵 baseK * baseN
    // kBlockIdx: K 方向 baseK 块索引，用于判断是否首次累加
    // mBlockIdx/nBlockIdx: M/N 方向块索引，用于判断尾块实际尺寸
    __aicore__ inline void Compute(
        AscendC::LocalTensor<float> cLocal, AscendC::LocalTensor<fp4x2_e1m2_t> a2Local,
        AscendC::LocalTensor<fp4x2_e1m2_t> b2Local, uint32_t kBlockIdx, uint32_t mBlockIdx, uint32_t nBlockIdx)
    {
        // MTE1_M 正向同步：等待 MTE1 完成 L1 → L0 搬运
        int32_t l0Event = GetL0EventId(mte1DBFlag);
        AscendC::SetFlag<AscendC::HardEvent::MTE1_M>(l0Event);
        AscendC::WaitFlag<AscendC::HardEvent::MTE1_M>(l0Event);
        // 尾块使用 tailM/tailN，否则使用 baseM/baseN
        uint32_t curM = (mBlockIdx != baseMCount) ? baseM : tailM;
        uint32_t curN = (nBlockIdx != baseNCount) ? baseN : tailN;
        AscendC::MmadParams mmadParams;
        mmadParams.m = curM;
        mmadParams.n = curN;
        mmadParams.k = baseK;
        mmadParams.cmatrixInitVal = (kBlockIdx == 0);
        AscendC::MmadMx(cLocal, a2Local, b2Local, mmadParams);
        // M_MTE1 反向同步：通知下一轮 DataLoad 可以覆盖 L0 缓冲区
        AscendC::SetFlag<AscendC::HardEvent::M_MTE1>(l0Event);
        mte1DBFlag ^= 1;
    }

    // CO1 → GM: 将计算结果从 L0C 写回 Global Memory
    // mBlockIdx/nBlockIdx: M/N 方向块索引，用于计算 GM 写入偏移及判断尾块尺寸
    __aicore__ inline void CopyOut(AscendC::LocalTensor<float> cLocal, uint32_t mBlockIdx, uint32_t nBlockIdx)
    {
        AscendC::SetFlag<AscendC::HardEvent::M_FIX>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::M_FIX>(EVENT_ID0);
        // 尾块使用对齐后的 tailMAlign 作为 srcStride，使用 tailM/tailN 作为实际行列数
        uint32_t curMAlign = (mBlockIdx != baseMCount) ? baseM : tailMAlign;
        uint32_t curM = (mBlockIdx != baseMCount) ? baseM : tailM;
        uint32_t curN = (nBlockIdx != baseNCount) ? baseN : tailN;
        AscendC::FixpipeParamsArch3510<AscendC::CO2Layout::ROW_MAJOR> fixpipeParams;
        fixpipeParams.nSize = curN;
        fixpipeParams.mSize = curM;
        fixpipeParams.srcStride = curMAlign;
        fixpipeParams.dstStride = N;
        fixpipeParams.quantPre = QuantMode_t::F322BF16;
        AscendC::Fixpipe(cGM[mBlockIdx * baseM * N + nBlockIdx * baseN], cLocal, fixpipeParams);
        AscendC::SetFlag<AscendC::HardEvent::FIX_M>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::FIX_M>(EVENT_ID0);
    }

private:
    AscendC::GlobalTensor<fp4x2_e1m2_t> aGM;
    AscendC::GlobalTensor<fp4x2_e1m2_t> bGM;
    AscendC::GlobalTensor<fp8_e8m0_t> asGM;
    AscendC::GlobalTensor<fp8_e8m0_t> bsGM;
    AscendC::GlobalTensor<bfloat16_t> cGM;
    AscendC::GlobalTensor<fp4x2_e1m2_t> aGMOri;
    AscendC::GlobalTensor<fp4x2_e1m2_t> bGMOri;
    AscendC::GlobalTensor<fp8_e8m0_t> asGMOri;
    AscendC::GlobalTensor<fp8_e8m0_t> bsGMOri;
    AscendC::GlobalTensor<bfloat16_t> cGMOri;
    uint32_t actualSingleCoreM, actualSingleCoreN;
    uint32_t mLoopCount, nLoopCount, kLoopCount;
    uint32_t baseMCount, baseNCount;
    uint32_t tailM, tailN;
    uint32_t tailMAlign, tailNAlign;
    uint8_t mte1DBFlag = 0;
};

template <
    uint32_t M, uint32_t K, uint32_t N, uint32_t baseM, uint32_t baseK, uint32_t baseN, uint32_t singleCoreM,
    uint32_t singleCoreK, uint32_t singleCoreN, uint32_t stepKa, uint32_t stepKb, uint32_t scaleFactorKa,
    uint32_t scaleFactorKb>
__global__ __cube__ void mmadmx_custom(__gm__ uint8_t* a, __gm__ uint8_t* b, __gm__ uint8_t* as, __gm__ uint8_t* bs, __gm__ uint8_t* c)
{
    AscendC::InitSocState();
    KernelMmadmx<
        M, K, N, baseM, baseK, baseN, singleCoreM, singleCoreK, singleCoreN, stepKa, stepKb, scaleFactorKa,
        scaleFactorKb>
        op;
    op.Init(a, b, as, bs, c);
    op.Process();
    AscendC::PipeBarrier<PIPE_ALL>();
}

int32_t main(int32_t argc, char* argv[])
{
    constexpr uint32_t M = 8192;
    constexpr uint32_t K = 8192;
    constexpr uint32_t N = 8192;
    constexpr uint32_t baseM = 256;
    constexpr uint32_t baseK = 256;
    constexpr uint32_t baseN = 256;
    constexpr uint32_t singleCoreM = 2048;
    constexpr uint32_t singleCoreK = 8192;
    constexpr uint32_t singleCoreN = 1024;

    constexpr uint32_t stepKa = 2;
    constexpr uint32_t stepKb = 2;
    constexpr uint32_t scaleFactorKa = 4;
    constexpr uint32_t scaleFactorKb = 4;

    constexpr uint32_t numBlocks = 32;

    constexpr uint32_t scaleKUnaligned = (K + SCALE_CEIL_NUMBER - 1) / SCALE_CEIL_NUMBER;
    constexpr uint32_t sK = ((scaleKUnaligned + SCALE_ALIGN_NUMBER - 1) / SCALE_ALIGN_NUMBER) * SCALE_ALIGN_NUMBER;

    size_t aFileSize = static_cast<size_t>(M * K) * sizeof(uint8_t) / 2;
    size_t bFileSize = static_cast<size_t>(N * K) * sizeof(uint8_t) / 2;
    size_t asFileSize = static_cast<size_t>(M * sK) * sizeof(uint8_t);
    size_t bsFileSize = static_cast<size_t>(N * sK) * sizeof(uint8_t);
    size_t cFileSize = M * N * sizeof(uint16_t);

    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t* aHost;
    uint8_t* aDevice;
    aclrtMallocHost((void**)(&aHost), aFileSize);
    aclrtMalloc((void**)&aDevice, aFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/x1_gm.bin", aFileSize, aHost, aFileSize);
    aclrtMemcpy(aDevice, aFileSize, aHost, aFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t* bHost;
    uint8_t* bDevice;
    aclrtMallocHost((void**)(&bHost), bFileSize);
    aclrtMalloc((void**)&bDevice, bFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/x2_gm.bin", bFileSize, bHost, bFileSize);
    aclrtMemcpy(bDevice, bFileSize, bHost, bFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t* asHost;
    uint8_t* asDevice;
    aclrtMallocHost((void**)(&asHost), asFileSize);
    aclrtMalloc((void**)&asDevice, asFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/x1_scale_gm.bin", asFileSize, asHost, asFileSize);
    aclrtMemcpy(asDevice, asFileSize, asHost, asFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t* bsHost;
    uint8_t* bsDevice;
    aclrtMallocHost((void**)(&bsHost), bsFileSize);
    aclrtMalloc((void**)&bsDevice, bsFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/x2_scale_gm.bin", bsFileSize, bsHost, bsFileSize);
    aclrtMemcpy(bsDevice, bsFileSize, bsHost, bsFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t* cHost;
    uint8_t* cDevice;
    aclrtMallocHost((void**)(&cHost), cFileSize);
    aclrtMalloc((void**)&cDevice, cFileSize, ACL_MEM_MALLOC_HUGE_FIRST);

    mmadmx_custom<
        M, K, N, baseM, baseK, baseN, singleCoreM, singleCoreK, singleCoreN, stepKa, stepKb, scaleFactorKa,
        scaleFactorKb><<<numBlocks, nullptr, stream>>>(aDevice, bDevice, asDevice, bsDevice, cDevice);
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(cHost, cFileSize, cDevice, cFileSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", cHost, cFileSize);

    aclrtFree(aDevice);
    aclrtFreeHost(aHost);
    aclrtFree(bDevice);
    aclrtFreeHost(bHost);
    aclrtFree(asDevice);
    aclrtFreeHost(asHost);
    aclrtFree(bsDevice);
    aclrtFreeHost(bsHost);
    aclrtFree(cDevice);
    aclrtFreeHost(cHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();
    return 0;
}
