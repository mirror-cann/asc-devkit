/* !
 * \file vector_tiling_strategy.asc
 * \brief
 * 以两个一维Tensor相加为例，演示如何根据数据总量与核数的关系计算Tiling参数。
 * 样例覆盖四种典型场景：仅主块、主块+尾块、主块+尾核、尾块+尾核。
 */

#include <cstdint>
#include <cstdio>

#include "acl/acl.h"
#include "data_utils.h"
#include "kernel_operator.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

constexpr uint32_t scenarioNum = SCENARIO_NUM;
constexpr uint32_t NUM_BLOCKS = 8;
constexpr uint32_t BLOCK_SIZE = 32;
constexpr uint32_t HALF_SIZE = 2;
constexpr uint32_t ALIGN_NUM = BLOCK_SIZE / HALF_SIZE;
constexpr uint32_t MAIN_TILE_LENGTH = 3200; // 主块数据量

struct MainTileOnlyTiling {
    uint32_t blockLength; // 每个核处理的数据量
    uint32_t tileNum;     // 主块数量
};

struct MainTileWithTailBlockTiling {
    uint32_t blockLength;    // 每个核处理的数据量
    uint32_t tileNum;        // 主块数量
    uint32_t lastTileLength; // 尾块数据量
};

struct MainTileWithTailCoreTiling {
    uint32_t formerNum;            // 整核数量
    uint32_t formerLength;         // 整核处理的数据量
    uint32_t formerTileNum;        // 整核中主块的数量
    uint32_t formerLastTileLength; // 整核中尾块的数据量
    uint32_t tailLength;           // 尾核处理的数据量
    uint32_t tailTileNum;          // 尾核中主块的数量
};

struct TailBlockAndTailCoreTiling {
    uint32_t formerNum;            // 整核数量
    uint32_t formerLength;         // 整核处理的数据量
    uint32_t formerTileNum;        // 整核中主块的数量
    uint32_t formerLastTileLength; // 整核中尾块的数据量
    uint32_t tailLength;           // 尾核处理的数据量
    uint32_t tailTileNum;          // 尾核中主块的数量
    uint32_t tailLastTileLength;   // 尾核中尾块的数据量
};

struct TileInfo {
    uint32_t tileNum;
    uint32_t lastTileLength;
};

uint32_t AlignUp(uint32_t value, uint32_t align) { return ((value + align - 1U) / align) * align; }

TileInfo CalcTileInfo(uint32_t length)
{
    TileInfo info;
    info.tileNum = length / MAIN_TILE_LENGTH;
    info.lastTileLength = length - info.tileNum * MAIN_TILE_LENGTH;
    return info;
}

class KernelAdd {
public:
    __aicore__ inline KernelAdd() = default;

    __aicore__ inline void Init(__gm__ uint8_t* x, __gm__ uint8_t* y, __gm__ uint8_t* z, MainTileOnlyTiling tiling)
    {
        uint32_t offset = AscendC::GetBlockIdx() * tiling.blockLength;
        InitGm(x, y, z, offset, tiling.blockLength);
        this->tileNum = tiling.tileNum;
        this->lastTileLength = 0U;
    }

    __aicore__ inline void Init(
        __gm__ uint8_t* x, __gm__ uint8_t* y, __gm__ uint8_t* z, MainTileWithTailBlockTiling tiling)
    {
        uint32_t offset = AscendC::GetBlockIdx() * tiling.blockLength;
        InitGm(x, y, z, offset, tiling.blockLength);
        this->tileNum = tiling.tileNum;
        this->lastTileLength = tiling.lastTileLength;
    }

    __aicore__ inline void Init(
        __gm__ uint8_t* x, __gm__ uint8_t* y, __gm__ uint8_t* z, MainTileWithTailCoreTiling tiling)
    {
        uint32_t blockIdx = AscendC::GetBlockIdx();
        if (blockIdx < tiling.formerNum) {
            uint32_t offset = tiling.formerLength * blockIdx;
            InitGm(x, y, z, offset, tiling.formerLength);
            this->tileNum = tiling.formerTileNum;
            this->lastTileLength = tiling.formerLastTileLength;
        } else {
            uint32_t offset =
                tiling.formerLength * tiling.formerNum + tiling.tailLength * (blockIdx - tiling.formerNum);
            InitGm(x, y, z, offset, tiling.tailLength);
            this->tileNum = tiling.tailTileNum;
            this->lastTileLength = 0U;
        }
    }

    __aicore__ inline void Init(
        __gm__ uint8_t* x, __gm__ uint8_t* y, __gm__ uint8_t* z, TailBlockAndTailCoreTiling tiling)
    {
        uint32_t blockIdx = AscendC::GetBlockIdx();
        if (blockIdx < tiling.formerNum) {
            uint32_t offset = tiling.formerLength * blockIdx;
            InitGm(x, y, z, offset, tiling.formerLength);
            this->tileNum = tiling.formerTileNum;
            this->lastTileLength = tiling.formerLastTileLength;
        } else {
            uint32_t offset =
                tiling.formerLength * tiling.formerNum + tiling.tailLength * (blockIdx - tiling.formerNum);
            InitGm(x, y, z, offset, tiling.tailLength);
            this->tileNum = tiling.tailTileNum;
            this->lastTileLength = tiling.tailLastTileLength;
        }
    }

    __aicore__ inline void Process()
    {
        AscendC::LocalTensor<half> xLocal(AscendC::TPosition::VECCALC, xAddr, MAIN_TILE_LENGTH);
        AscendC::LocalTensor<half> yLocal(AscendC::TPosition::VECCALC, yAddr, MAIN_TILE_LENGTH);
        AscendC::LocalTensor<half> zLocal(AscendC::TPosition::VECCALC, zAddr, MAIN_TILE_LENGTH);

        uint32_t totalLoop = this->tileNum + (this->lastTileLength > 0U ? 1U : 0U);
        for (uint32_t loopIdx = 0; loopIdx < totalLoop; loopIdx++) {
            uint32_t curLen = (loopIdx < this->tileNum) ? MAIN_TILE_LENGTH : this->lastTileLength;
            uint32_t startElement = loopIdx * MAIN_TILE_LENGTH;

            if (loopIdx != 0U) {
                AscendC::WaitFlag<AscendC::HardEvent::V_MTE2>(EVENT_ID0);
            }

            AscendC::DataCopy(xLocal, xGm[startElement], curLen);
            AscendC::DataCopy(yLocal, yGm[startElement], curLen);

            AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
            AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);

            if (loopIdx != 0U) {
                AscendC::WaitFlag<AscendC::HardEvent::MTE3_V>(EVENT_ID0);
            }

            AscendC::Add(zLocal, xLocal, yLocal, curLen);

            if (loopIdx != totalLoop - 1U) {
                AscendC::SetFlag<AscendC::HardEvent::V_MTE2>(EVENT_ID0);
            }
            AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
            AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);

            AscendC::DataCopy(zGm[startElement], zLocal, curLen);

            if (loopIdx != totalLoop - 1U) {
                AscendC::SetFlag<AscendC::HardEvent::MTE3_V>(EVENT_ID0);
            }
        }
    }

private:
    __aicore__ inline void InitGm(
        __gm__ uint8_t* x, __gm__ uint8_t* y, __gm__ uint8_t* z, uint32_t offset, uint32_t length)
    {
        xGm.SetGlobalBuffer((__gm__ half*)x + offset, length);
        yGm.SetGlobalBuffer((__gm__ half*)y + offset, length);
        zGm.SetGlobalBuffer((__gm__ half*)z + offset, length);
    }

private:
    static constexpr uint32_t xAddr = 0;
    static constexpr uint32_t yAddr = MAIN_TILE_LENGTH * HALF_SIZE;
    static constexpr uint32_t zAddr = yAddr + MAIN_TILE_LENGTH * HALF_SIZE;

    AscendC::GlobalTensor<half> xGm;
    AscendC::GlobalTensor<half> yGm;
    AscendC::GlobalTensor<half> zGm;
    uint32_t tileNum;
    uint32_t lastTileLength;
};

template <typename TilingData>
__vector__ __global__ void add_custom(__gm__ uint8_t* x, __gm__ uint8_t* y, __gm__ uint8_t* z, TilingData tiling)
{
    AscendC::InitSocState();
    KernelAdd op;
    op.Init(x, y, z, tiling);
    op.Process();
    AscendC::PipeBarrier<PIPE_ALL>();
}

void LaunchAddByTiling(uint8_t* xDevice, uint8_t* yDevice, uint8_t* zDevice, uint32_t totalLength, aclrtStream stream)
{
    // Host侧Tiling逐级计算主块数量、尾块数量、尾核数量。
    // 第零步，将数据量按32字节对齐
    uint32_t totalLengthAligned = AlignUp(totalLength, ALIGN_NUM);

    // 第一步，所有核均分相同数量的主块。
    uint32_t mainTileNum = totalLengthAligned / (NUM_BLOCKS * MAIN_TILE_LENGTH);
    uint32_t mainTileRemainder = totalLengthAligned % (NUM_BLOCKS * MAIN_TILE_LENGTH);

    // 第二步，mainTileRemainder按DataBlock给每个核补齐等长尾块。
    uint32_t tailBlockNumEachCore = mainTileRemainder / (NUM_BLOCKS * ALIGN_NUM);
    uint32_t formerCoreRemainder = mainTileRemainder % (NUM_BLOCKS * ALIGN_NUM);
    uint32_t baseLength = mainTileNum * MAIN_TILE_LENGTH + tailBlockNumEachCore * ALIGN_NUM;
    TileInfo baseInfo = CalcTileInfo(baseLength);

    // 如果没有剩余DataBlock，所有核都处理baseLength，只需要区分是否存在尾块。
    if (formerCoreRemainder == 0U) {
        if (baseInfo.lastTileLength == 0U) {
            MainTileOnlyTiling tiling{baseLength, baseInfo.tileNum};
            printf("Tiling mode: main_tile_only\n");
            add_custom<MainTileOnlyTiling><<<NUM_BLOCKS, 0, stream>>>(xDevice, yDevice, zDevice, tiling);
        } else {
            MainTileWithTailBlockTiling tiling{baseLength, baseInfo.tileNum, baseInfo.lastTileLength};
            printf("Tiling mode: main_tile_with_tail_block\n");
            add_custom<MainTileWithTailBlockTiling><<<NUM_BLOCKS, 0, stream>>>(xDevice, yDevice, zDevice, tiling);
        }
        return;
    }

    // 第三步，最后剩余的DataBlock分给前formerNum个整核。
    uint32_t formerNum = formerCoreRemainder / ALIGN_NUM;
    uint32_t formerLength = baseLength + ALIGN_NUM; // 前formerNum个核都多处理一个DataBlock的数据
    uint32_t tailLength = baseLength;
    TileInfo formerInfo = CalcTileInfo(formerLength);
    TileInfo tailInfo = baseInfo;
    bool formerOnlyOneDataBlockTail = (formerInfo.lastTileLength == ALIGN_NUM);
    bool tailHasNoTailTile = (tailInfo.lastTileLength == 0U);
    if (formerOnlyOneDataBlockTail && tailHasNoTailTile) {
        MainTileWithTailCoreTiling tiling{formerNum,  formerLength,    formerInfo.tileNum, formerInfo.lastTileLength,
                                          tailLength, tailInfo.tileNum};
        printf("Tiling mode: main_tile_with_tail_core\n");
        add_custom<MainTileWithTailCoreTiling><<<NUM_BLOCKS, 0, stream>>>(xDevice, yDevice, zDevice, tiling);
    } else {
        TailBlockAndTailCoreTiling tiling{
            formerNum,  formerLength,     formerInfo.tileNum,     formerInfo.lastTileLength,
            tailLength, tailInfo.tileNum, tailInfo.lastTileLength};
        printf("Tiling mode: tail_block_and_tail_core\n");
        add_custom<TailBlockAndTailCoreTiling><<<NUM_BLOCKS, 0, stream>>>(xDevice, yDevice, zDevice, tiling);
    }
}

int32_t main(int32_t argc, char* argv[])
{
    constexpr uint32_t dataLen = (scenarioNum == 0) ? 256000 :
                                 (scenarioNum == 1) ? 260096 :
                                 (scenarioNum == 2) ? 256064 :
                                                      258112;
    size_t dataByteSize = static_cast<size_t>(dataLen) * HALF_SIZE;

    printf("Usage: %s (compile-time SCENARIO_NUM=%u)\n", argv[0], scenarioNum);
    printf("Running scenario %u, totalLength=%u\n", scenarioNum, dataLen);

    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t* inputXHost = nullptr;
    uint8_t* inputYHost = nullptr;
    uint8_t* outputHost = nullptr;
    uint8_t* inputXDevice = nullptr;
    uint8_t* inputYDevice = nullptr;
    uint8_t* outputDevice = nullptr;

    aclrtMallocHost((void**)(&inputXHost), dataByteSize);
    aclrtMallocHost((void**)(&inputYHost), dataByteSize);
    aclrtMallocHost((void**)(&outputHost), dataByteSize);
    aclrtMalloc((void**)(&inputXDevice), dataByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)(&inputYDevice), dataByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)(&outputDevice), dataByteSize, ACL_MEM_MALLOC_HUGE_FIRST);

    ReadFile("./input/input_x.bin", dataByteSize, inputXHost, dataByteSize);
    ReadFile("./input/input_y.bin", dataByteSize, inputYHost, dataByteSize);

    aclrtMemcpy(inputXDevice, dataByteSize, inputXHost, dataByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(inputYDevice, dataByteSize, inputYHost, dataByteSize, ACL_MEMCPY_HOST_TO_DEVICE);

    LaunchAddByTiling(inputXDevice, inputYDevice, outputDevice, dataLen, stream);
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(outputHost, dataByteSize, outputDevice, dataByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", outputHost, dataByteSize);

    aclrtFree(inputXDevice);
    aclrtFree(inputYDevice);
    aclrtFree(outputDevice);
    aclrtFreeHost(inputXHost);
    aclrtFreeHost(inputYHost);
    aclrtFreeHost(outputHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();

    printf("Scenario %u completed.\n", scenarioNum);
    return 0;
}
