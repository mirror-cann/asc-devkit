/* !
 * \file add.asc
 * \brief Add operator ACL graph sample.
 */

#include <algorithm>
#include <cstdint>
#include <cstdlib>
#include <iostream>
#include <iterator>
#include <vector>

#include "acl/acl.h"
#include "kernel_operator.h"

enum class CaptureMode : int32_t {
    SINGLE_STREAM = 1,
    DOUBLE_STREAM = 2,
};

template <uint32_t blockLength>
__vector__ __global__ void add_custom(__gm__ float* x, __gm__ float* y, __gm__ float* z)
{
    AscendC::InitSocState();

    AscendC::GlobalTensor<float> xGm, yGm, zGm;
    xGm.SetGlobalBuffer(x + block_idx * blockLength, blockLength);
    yGm.SetGlobalBuffer(y + block_idx * blockLength, blockLength);
    zGm.SetGlobalBuffer(z + block_idx * blockLength, blockLength);

    AscendC::LocalMemAllocator<AscendC::Hardware::UB> ubAllocator;
    AscendC::LocalTensor<float> xLocal = ubAllocator.Alloc<float, blockLength>();
    AscendC::LocalTensor<float> yLocal = ubAllocator.Alloc<float, blockLength>();
    AscendC::LocalTensor<float> zLocal = ubAllocator.Alloc<float, blockLength>();

    AscendC::DataCopy(xLocal, xGm, blockLength);
    AscendC::DataCopy(yLocal, yGm, blockLength);
    AscendC::PipeBarrier<PIPE_ALL>();

    AscendC::Add(zLocal, xLocal, yLocal, blockLength);
    AscendC::PipeBarrier<PIPE_ALL>();

    AscendC::DataCopy(zGm, zLocal, blockLength);
    AscendC::PipeBarrier<PIPE_ALL>();
}

void PrintUsage(const char* programName)
{
    std::cerr << "Usage: " << programName << " [mode]" << std::endl;
    std::cerr << "  mode 1: single stream capture" << std::endl;
    std::cerr << "  mode 2: double stream capture" << std::endl;
}

bool ParseCaptureMode(int32_t argc, char* argv[], CaptureMode& mode)
{
    mode = CaptureMode::SINGLE_STREAM;
    if (argc == 1) {
        return true;
    }
    if (argc != 2) {
        return false;
    }

    char* end = nullptr;
    long modeValue = std::strtol(argv[1], &end, 10);
    if (*argv[1] == '\0' || *end != '\0') {
        return false;
    }
    if (modeValue == static_cast<long>(CaptureMode::SINGLE_STREAM)) {
        mode = CaptureMode::SINGLE_STREAM;
        return true;
    }
    if (modeValue == static_cast<long>(CaptureMode::DOUBLE_STREAM)) {
        mode = CaptureMode::DOUBLE_STREAM;
        return true;
    }
    return false;
}

void ExecuteModelRI(aclmdlRI modelRI, aclrtStream mainStream)
{
    for (int i = 0; i < 5; ++i) {
        aclmdlRIExecuteAsync(modelRI, mainStream);
        aclrtSynchronizeStream(mainStream);
    }
}

template <uint32_t numBlocks, uint32_t blockLength>
void RunSingleStreamCapture(
    float* xDevice, float* yDevice, float* zDevice, uint8_t* xHost, uint8_t* yHost, uint8_t* zHost,
    size_t totalByteSize, aclrtStream mainStream)
{
    aclmdlRI modelRI = nullptr;

    aclmdlRICaptureBegin(mainStream, ACL_MODEL_RI_CAPTURE_MODE_GLOBAL);
    aclrtMemcpyAsync(xDevice, totalByteSize, xHost, totalByteSize, ACL_MEMCPY_HOST_TO_DEVICE, mainStream);
    aclrtMemcpyAsync(yDevice, totalByteSize, yHost, totalByteSize, ACL_MEMCPY_HOST_TO_DEVICE, mainStream);
    add_custom<blockLength><<<numBlocks, 0, mainStream>>>(xDevice, yDevice, zDevice);
    aclrtMemcpyAsync(zHost, totalByteSize, zDevice, totalByteSize, ACL_MEMCPY_DEVICE_TO_HOST, mainStream);
    aclmdlRICaptureEnd(mainStream, &modelRI);
    aclmdlRIDebugJsonPrint(modelRI, "./modelRI_single_stream.json", 0);

    ExecuteModelRI(modelRI, mainStream);
    aclmdlRIDestroy(modelRI);
}

template <uint32_t numBlocks, uint32_t blockLength>
void RunDoubleStreamCapture(
    float* xDevice, float* yDevice, float* zDevice, uint8_t* xHost, uint8_t* yHost, uint8_t* zHost,
    size_t totalByteSize, aclrtStream mainStream)
{
    aclmdlRI modelRI = nullptr;
    aclrtStream computeStream = nullptr;
    aclrtEvent xReadyEvent = nullptr;
    aclrtEvent computeDoneEvent = nullptr;
    aclrtCreateStream(&computeStream);
    aclrtCreateEventExWithFlag(&xReadyEvent, ACL_EVENT_SYNC);
    aclrtCreateEventExWithFlag(&computeDoneEvent, ACL_EVENT_SYNC);

    aclmdlRICaptureBegin(mainStream, ACL_MODEL_RI_CAPTURE_MODE_GLOBAL);
    aclrtMemcpyAsync(xDevice, totalByteSize, xHost, totalByteSize, ACL_MEMCPY_HOST_TO_DEVICE, mainStream);
    aclrtRecordEvent(xReadyEvent, mainStream);

    aclrtStreamWaitEvent(computeStream, xReadyEvent);
    aclrtMemcpyAsync(yDevice, totalByteSize, yHost, totalByteSize, ACL_MEMCPY_HOST_TO_DEVICE, computeStream);
    add_custom<blockLength><<<numBlocks, 0, computeStream>>>(xDevice, yDevice, zDevice);
    aclrtRecordEvent(computeDoneEvent, computeStream);

    aclrtStreamWaitEvent(mainStream, computeDoneEvent);
    aclrtMemcpyAsync(zHost, totalByteSize, zDevice, totalByteSize, ACL_MEMCPY_DEVICE_TO_HOST, mainStream);
    aclmdlRICaptureEnd(mainStream, &modelRI);
    aclmdlRIDebugJsonPrint(modelRI, "./modelRI_double_stream.json", 0);

    ExecuteModelRI(modelRI, mainStream);
    aclmdlRIDestroy(modelRI);
    aclrtDestroyEvent(xReadyEvent);
    aclrtDestroyEvent(computeDoneEvent);
    aclrtDestroyStream(computeStream);
}

std::vector<float> kernel_add(std::vector<float>& x, std::vector<float>& y, CaptureMode mode)
{
    constexpr uint32_t numBlocks = 8;
    constexpr uint32_t blockLength = 2048;
    uint32_t totalLength = x.size();
    size_t totalByteSize = totalLength * sizeof(float);
    int32_t deviceId = 0;
    float* xDevice = nullptr;
    float* yDevice = nullptr;
    float* zDevice = nullptr;
    uint8_t* xHost = nullptr;
    uint8_t* yHost = nullptr;
    uint8_t* zHost = nullptr;

    aclInit(nullptr);
    aclrtSetDevice(deviceId);

    aclrtStream mainStream = nullptr;
    aclrtCreateStream(&mainStream);

    aclrtMallocHost((void**)&xHost, totalByteSize);
    aclrtMallocHost((void**)&yHost, totalByteSize);
    aclrtMallocHost((void**)&zHost, totalByteSize);
    for (uint32_t i = 0; i < totalLength; ++i) {
        *((float*)xHost + i) = x[i];
        *((float*)yHost + i) = y[i];
    }

    aclrtMalloc((void**)&xDevice, totalByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&yDevice, totalByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&zDevice, totalByteSize, ACL_MEM_MALLOC_HUGE_FIRST);

    if (mode == CaptureMode::SINGLE_STREAM) {
        RunSingleStreamCapture<numBlocks, blockLength>(
            xDevice, yDevice, zDevice, xHost, yHost, zHost, totalByteSize, mainStream);
    } else {
        RunDoubleStreamCapture<numBlocks, blockLength>(
            xDevice, yDevice, zDevice, xHost, yHost, zHost, totalByteSize, mainStream);
    }

    std::vector<float> z(totalLength);
    z.assign((float*)zHost, (float*)(zHost + totalByteSize));

    aclrtDestroyStream(mainStream);

    aclrtFree(xDevice);
    aclrtFree(yDevice);
    aclrtFree(zDevice);
    aclrtFreeHost(xHost);
    aclrtFreeHost(yHost);
    aclrtFreeHost(zHost);

    aclrtResetDevice(deviceId);
    aclFinalize();

    return z;
}

uint32_t VerifyResult(std::vector<float>& output, std::vector<float>& golden)
{
    auto printTensor = [](std::vector<float>& tensor, const char* name) {
        constexpr size_t maxPrintSize = 20;
        std::cout << name << ": ";
        std::copy(
            tensor.begin(), tensor.begin() + std::min(tensor.size(), maxPrintSize),
            std::ostream_iterator<float>(std::cout, " "));
        if (tensor.size() > maxPrintSize) {
            std::cout << "...";
        }
        std::cout << std::endl;
    };
    printTensor(output, "Output");
    printTensor(golden, "Golden");
    if (std::equal(golden.begin(), golden.end(), output.begin())) {
        std::cout << "test pass!" << std::endl;
        return 0;
    } else {
        std::cout << "test failed!" << std::endl;
        return 1;
    }
}

int32_t main(int32_t argc, char* argv[])
{
    CaptureMode mode;
    if (!ParseCaptureMode(argc, argv, mode)) {
        PrintUsage(argv[0]);
        return 1;
    }

    constexpr uint32_t totalLength = 8 * 2048;
    std::vector<float> x(totalLength);
    std::vector<float> y(totalLength);

    for (uint32_t i = 0; i < totalLength; ++i) {
        x[i] = i * 0.1f;
        y[i] = i * 0.2f;
    }

    std::vector<float> output = kernel_add(x, y, mode);

    std::vector<float> golden(totalLength);
    for (uint32_t i = 0; i < totalLength; ++i) {
        golden[i] = x[i] + y[i];
    }

    return VerifyResult(output, golden);
}
