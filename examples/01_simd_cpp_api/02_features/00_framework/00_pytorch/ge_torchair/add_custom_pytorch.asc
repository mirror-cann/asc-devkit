/* !
 * \file add_custom_pytorch.asc
 * \brief PyTorch侧自定义算子的schema和Meta注册
 */

#include <torch/extension.h>

namespace {
constexpr int64_t ROW_NUM = 8;
constexpr int64_t COL_NUM = 2048;

// Meta实现用于torch.compile图捕获阶段推导输出shape和dtype，不执行真实NPU计算
at::Tensor AscendcAddMeta(const at::Tensor& x, const at::Tensor& y)
{
    TORCH_CHECK(x.sizes() == y.sizes(), "x and y must have the same shape.");
    TORCH_CHECK(
        x.dim() == 2 && x.size(0) == ROW_NUM && x.size(1) == COL_NUM,
        "ascendc_add only supports shape [8, 2048] in this sample.");
    TORCH_CHECK(
        x.scalar_type() == at::ScalarType::Float && y.scalar_type() == at::ScalarType::Float,
        "ascendc_add only supports float tensors in this sample.");
    return at::empty_like(x);
}
} // namespace

// 注册PyTorch自定义算子schema，使Python侧可以通过torch.ops.ascendc_ops.ascendc_add引用该算子
TORCH_LIBRARY_FRAGMENT(ascendc_ops, m) { m.def("ascendc_add(Tensor x, Tensor y) -> Tensor"); }

// 注册Meta实现，使torch.compile能够在图捕获阶段获得输出Tensor描述
TORCH_LIBRARY_IMPL(ascendc_ops, Meta, m) { m.impl("ascendc_add", TORCH_FN(AscendcAddMeta)); }
