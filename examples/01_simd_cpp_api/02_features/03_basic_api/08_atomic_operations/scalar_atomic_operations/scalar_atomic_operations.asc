/* !
 * \file scalar_atomic_operations.asc
 * \brief 本样例基于 AtomicAdd/AtomicCas 接口，介绍在 GM 地址上进行标量原子加和原子比较交换的实现流程
 */

#include "acl/acl.h"
#include "data_utils.h"
#include "kernel_operator.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

constexpr uint32_t scenarioNum = SCENARIO_NUM;

class KernelScalarAtomic {
public:
    __aicore__ inline KernelScalarAtomic() {}
    __aicore__ inline void Init(__gm__ uint8_t* y)
    {
        dstGm = y;
    }
    __aicore__ inline void Process()
    {
        if constexpr (scenarioNum == 1) {
            // AtomicAdd：三个核分别对GM首个元素原子加1
            int32_t valueToAdd = 1;
            int32_t oldValue = AscendC::AtomicAdd(reinterpret_cast<__gm__ int32_t*>(dstGm), valueToAdd);

            // 原子操作后插入同步
            AscendC::SetFlag<AscendC::HardEvent::S_MTE2>(EVENT_ID0);
            AscendC::WaitFlag<AscendC::HardEvent::S_MTE2>(EVENT_ID0);
        } else {
            // AtomicCas：三个核分别对GM首个元素原子比较交换
            uint32_t expected = 1;
            uint32_t newValue = 2;
            uint32_t oldValue = AscendC::AtomicCas(reinterpret_cast<__gm__ uint32_t*>(dstGm), expected, newValue);

            // 原子操作后插入同步
            AscendC::SetFlag<AscendC::HardEvent::S_MTE2>(EVENT_ID0);
            AscendC::WaitFlag<AscendC::HardEvent::S_MTE2>(EVENT_ID0);
        }
    }

private:
    __gm__ uint8_t* dstGm;
};

template <uint32_t DATA_SIZE>
__global__ __vector__ void scalar_atomic_operations_custom(__gm__ uint8_t* x, __gm__ uint8_t* y)
{
    KernelScalarAtomic op;
    op.Init(y);
    op.Process();
}

int32_t main(int32_t argc, char* argv[])
{
    constexpr uint32_t NUM_BLOCKS = 3;
    constexpr uint32_t DATA_SIZE = 256;
    size_t inputByteSize = DATA_SIZE * sizeof(int32_t);
    size_t outputByteSize = DATA_SIZE * sizeof(int32_t);

    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t *xHost, *outHost;
    uint8_t *xDevice, *outDevice;

    aclrtMallocHost((void**)(&xHost), inputByteSize);
    aclrtMallocHost((void**)(&outHost), inputByteSize);
    aclrtMalloc((void**)&xDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&outDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);

    ReadFile("./input/input_x.bin", inputByteSize, xHost, inputByteSize);
    ReadFile("./input/input_y.bin", inputByteSize, outHost, inputByteSize);

    aclrtMemcpy(xDevice, inputByteSize, xHost, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(outDevice, inputByteSize, outHost, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);

    scalar_atomic_operations_custom<DATA_SIZE><<<NUM_BLOCKS, nullptr, stream>>>(xDevice, outDevice);
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(outHost, outputByteSize, outDevice, outputByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", outHost, outputByteSize);

    aclrtFree(xDevice);
    aclrtFree(outDevice);
    aclrtFreeHost(xHost);
    aclrtFreeHost(outHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();

    return 0;
}