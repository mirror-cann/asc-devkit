/* !
 * \file data_copy_l0c2gm.asc
 * \brief DataCopy量化激活搬运样例，支持随路NZ2ND、随路量化、relu激活能力组合
 */

#include "acl/acl.h"
#include "kernel_operator.h"
#include "data_utils.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

constexpr uint32_t scenarioNum = SCENARIO_NUM;

constexpr uint32_t CUBE_BLOCK = 16;
constexpr uint32_t C0_SIZE = 32;

constexpr uint32_t M = 128;
constexpr uint32_t K = 128;
constexpr uint32_t N = 256;
constexpr uint32_t K_ROUND = 2;

constexpr static uint16_t LIMIT_MNSIZE = 10;
constexpr static uint16_t ALIGN_NUM = 16;

template <class inputType, class outputType, class l0cType, uint32_t cubeBlockSize, uint32_t cubeBlockNum>
class KernelDataCopyL0c2Gm {
public:
    __aicore__ inline KernelDataCopyL0c2Gm()
    {
        aSingleSize = m * k;
        bSingleSize = k * n;
        cSingleSize = m * n;

        // A 不转置
        aSizeAlignL1 = CeilAlign(m, CUBE_BLOCK) * CeilAlign(k, C0_SIZE);
        aSizeAlignL0 = CeilAlign(m, CUBE_BLOCK) * CeilAlign(k, C0_SIZE);
        // B 不转置
        bSizeAlignL1 = CeilAlign(k, C0_SIZE) * CeilAlign(n, C0_SIZE);
        bSizeAlignL0 = CeilAlign(k, C0_SIZE) * CeilAlign(n, C0_SIZE);
        // C矩阵无视数据类型和a、b是否转置，m,n都向16对齐
        cSizeAlignL0 = CeilAlign(m, CUBE_BLOCK) * CeilAlign(n, CUBE_BLOCK);
    }

    __aicore__ inline void Init(__gm__ uint8_t* a, __gm__ uint8_t* b, __gm__ uint8_t* c, __gm__ uint8_t* quantAlpha)
    {
        aGM.SetGlobalBuffer((__gm__ inputType*)a);
        bGM.SetGlobalBuffer((__gm__ inputType*)b);
        cGM.SetGlobalBuffer((__gm__ outputType*)c);
        quantAlphaGM.SetGlobalBuffer((__gm__ uint64_t*)quantAlpha);
    }

    __aicore__ inline void Process()
    {
        AscendC::LocalTensor<inputType> a1Local(AscendC::TPosition::A1, a1Addr, aSizeAlignL1);
        AscendC::LocalTensor<inputType> a2Local(AscendC::TPosition::A2, a2Addr, aSizeAlignL0);
        AscendC::LocalTensor<inputType> b1Local(AscendC::TPosition::B1, b1Addr, bSizeAlignL1);
        AscendC::LocalTensor<inputType> b2Local(AscendC::TPosition::B2, b2Addr, bSizeAlignL0);
        AscendC::LocalTensor<l0cType> cLocal(AscendC::TPosition::CO1, cAddr, cSizeAlignL0);

        uint32_t chunkSize = K_ROUND;
        for (uint32_t kIndex = 0; kIndex < chunkSize; kIndex++) {
            CopyIn(a1Local, b1Local, kIndex);
            AscendC::SetFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID0);
            AscendC::WaitFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID0);
            SplitA(a1Local, a2Local);
            SplitB(b1Local, b2Local);
            AscendC::SetFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID0);
            AscendC::WaitFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID0);
            AscendC::SetFlag<AscendC::HardEvent::MTE1_MTE2>(EVENT_ID0);
            AscendC::WaitFlag<AscendC::HardEvent::MTE1_MTE2>(EVENT_ID0);
            Compute(cLocal, a2Local, b2Local, kIndex);
            AscendC::SetFlag<AscendC::HardEvent::M_MTE1>(EVENT_ID0);
            AscendC::WaitFlag<AscendC::HardEvent::M_MTE1>(EVENT_ID0);
        }

        AscendC::LocalTensor<uint64_t> quantAlphaTensor(AscendC::TPosition::C1, c1Addr, N);
        // vector quant mode
        if constexpr (scenarioNum == 2 || scenarioNum == 4 || scenarioNum == 6) {
            CopyQuantAlphaGmToL1(quantAlphaTensor);
        }

        AscendC::SetFlag<AscendC::HardEvent::M_FIX>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::M_FIX>(EVENT_ID0);
        CopyOut(cLocal, quantAlphaTensor);
    }

private:
    __aicore__ inline uint16_t CeilDivision(uint16_t numerator, uint16_t denominator)
    {
        return (numerator + denominator - 1) / denominator;
    }

    __aicore__ inline uint16_t CeilAlign(uint16_t numerator, uint16_t denominator)
    {
        return (numerator + denominator - 1) / denominator * denominator;
    }

    __aicore__ inline void CopyQuantAlphaGmToL1(AscendC::LocalTensor<uint64_t>& quantAlphaTensor)
    {
        AscendC::SetFlag<AscendC::HardEvent::FIX_MTE2>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::FIX_MTE2>(EVENT_ID0);
        uint16_t burstLen = CeilAlign(n * sizeof(uint64_t), 128) / 32;
        AscendC::DataCopyParams intriParams{1, burstLen, 0, 0};
        AscendC::DataCopy(quantAlphaTensor, quantAlphaGM, intriParams);
        AscendC::SetFlag<AscendC::HardEvent::MTE2_FIX>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_FIX>(EVENT_ID0);
    }

    __aicore__ inline void CopyIn(
        AscendC::LocalTensor<inputType>& a1Local, AscendC::LocalTensor<inputType>& b1Local, uint32_t kIndex)
    {
        AscendC::Nd2NzParams nd2nzA1Params;
        nd2nzA1Params.ndNum = 1;
        nd2nzA1Params.nValue = m;
        nd2nzA1Params.dValue = k;
        nd2nzA1Params.srcNdMatrixStride = 0;
        nd2nzA1Params.srcDValue = k;
        nd2nzA1Params.dstNzC0Stride = CeilAlign(m, C0_SIZE / sizeof(inputType));
        nd2nzA1Params.dstNzNStride = 1;
        nd2nzA1Params.dstNzMatrixStride = 0;
        AscendC::DataCopy(a1Local, aGM[kIndex * aSingleSize], nd2nzA1Params);

        AscendC::Nd2NzParams nd2nzB1Params;
        nd2nzB1Params.ndNum = 1;
        nd2nzB1Params.nValue = k;
        nd2nzB1Params.dValue = n;
        nd2nzB1Params.srcNdMatrixStride = 0;
        nd2nzB1Params.srcDValue = n;
        nd2nzB1Params.dstNzC0Stride = CeilAlign(k, C0_SIZE / sizeof(inputType));
        nd2nzB1Params.dstNzNStride = 1;
        nd2nzB1Params.dstNzMatrixStride = 0;
        AscendC::DataCopy(b1Local, bGM[kIndex * bSingleSize], nd2nzB1Params);
    }

    __aicore__ inline void SplitA(AscendC::LocalTensor<inputType>& a1Local, AscendC::LocalTensor<inputType>& a2Local)
    {
#if defined(__NPU_ARCH__) && (__NPU_ARCH__ == 2201)
        uint32_t dstOffset = CeilDivision(k, C0_SIZE / sizeof(inputType)) * cubeBlockSize;
        uint32_t srcOffset = cubeBlockSize;
        // Nz -> Zz
        AscendC::LoadData2DParams loadDataParams;
        loadDataParams.repeatTimes = CeilDivision(k, C0_SIZE / sizeof(inputType));
        loadDataParams.srcStride = CeilDivision(m, CUBE_BLOCK);
        loadDataParams.dstGap = 0;
        loadDataParams.ifTranspose = false;
        for (int i = 0; i < CeilDivision(m, CUBE_BLOCK); ++i) {
            AscendC::LoadData(a2Local[i * dstOffset], a1Local[i * srcOffset], loadDataParams);
        }
#elif defined(__NPU_ARCH__) && (__NPU_ARCH__ == 3510)
        AscendC::LoadData2DParamsV2 loadDataParams;
        loadDataParams.mStep = CeilDivision(m, CUBE_BLOCK);
        loadDataParams.kStep = CeilDivision(k, C0_SIZE / sizeof(inputType));
        loadDataParams.srcStride = CeilDivision(m, CUBE_BLOCK);
        loadDataParams.dstStride = CeilDivision(m, CUBE_BLOCK);
        AscendC::LoadData(a2Local, a1Local, loadDataParams);
#endif
    }

    __aicore__ inline void SplitB(AscendC::LocalTensor<inputType>& b1Local, AscendC::LocalTensor<inputType>& b2Local)
    {
        // int8_t: 32*32*1B per repeat; half: 16*16*2B per repeat
        uint32_t dstOffset = CeilDivision(n, C0_SIZE / sizeof(inputType)) * cubeBlockSize * cubeBlockNum;
        uint32_t srcOffset = cubeBlockSize * cubeBlockNum;
        // Nz -> Zn
        AscendC::LoadData2dTransposeParams loadDataParams;
        loadDataParams.startIndex = 0;
        loadDataParams.repeatTimes = CeilDivision(n, C0_SIZE / sizeof(inputType));
        loadDataParams.srcStride = CeilDivision(k, C0_SIZE / sizeof(inputType));
        if constexpr (scenarioNum == 1 || scenarioNum == 2 || scenarioNum == 5 || scenarioNum == 6) {
            loadDataParams.dstGap = 1;
        } else {
            loadDataParams.dstGap = 0;
        }
        loadDataParams.dstFracGap = 0;
        for (int i = 0; i < CeilDivision(k, C0_SIZE / sizeof(inputType)); ++i) {
            AscendC::LoadDataWithTranspose(b2Local[i * dstOffset], b1Local[i * srcOffset], loadDataParams);
        }
    }

    __aicore__ inline void Compute(
        AscendC::LocalTensor<l0cType>& cLocal, AscendC::LocalTensor<inputType>& a2Local,
        AscendC::LocalTensor<inputType>& b2Local, uint32_t kIndex)
    {
        AscendC::MmadParams mmadParams;
        mmadParams.m = m;
        // mmad默认n轴向16对齐，但是由于b转置过程n轴向2 * 16对齐，填充了一个全部由无效数据的32 * 16的分形，
        // 如果仍然设置mmadParams.n = n，cube单元会多读入无效数据的分形同时有效数据的分形也未被读入。
        // 此时可以通过设置n向32对齐，让此分形参与计算，搬出时跳过无效分形参与计算的得到的分形即可
        mmadParams.n = CeilAlign(n, C0_SIZE);
        mmadParams.k = k;
        if (kIndex == 0) {
            mmadParams.cmatrixInitVal = true;
        } else {
            mmadParams.cmatrixInitVal = false;
        }
        AscendC::Mmad(cLocal, a2Local, b2Local, mmadParams);
        if ((m / ALIGN_NUM) * (n / ALIGN_NUM) < LIMIT_MNSIZE) {
            AscendC::PipeBarrier<PIPE_M>();
        }
    }

    __aicore__ inline void CopyOut(
        AscendC::LocalTensor<l0cType>& cLocal, AscendC::LocalTensor<uint64_t>& quantAlphaTensor)
    {
        AscendC::DataCopyCO12DstParams intriParams;
        intriParams.nSize = CeilAlign(n, CUBE_BLOCK);
        intriParams.mSize = m;
        intriParams.srcStride = CeilAlign(m, CUBE_BLOCK);
        intriParams.dstStride = m * C0_SIZE / AscendC::ONE_BLK_SIZE;

        if constexpr (scenarioNum == 1 || scenarioNum == 3 || scenarioNum == 5) { // scalar quant mode
            if constexpr (scenarioNum == 1) {
                intriParams.quantPre = QuantMode_t::DEQF16;
            } else if constexpr (scenarioNum == 3) {
                intriParams.quantPre = QuantMode_t::QF322B8_PRE;
            } else {
                intriParams.quantPre = QuantMode_t::REQ8;
            }
            uint64_t deqScalar = static_cast<uint64_t>(*reinterpret_cast<int32_t*>(&quantScalar));
            constexpr bool sign = (AscendC::IsSameType<outputType, int8_t>::value) ? true : false;
            deqScalar = (deqScalar & ~(static_cast<uint64_t>(1) << 46)) | (static_cast<uint64_t>(sign) << 46);
            AscendC::SetFixpipePreQuantFlag(deqScalar);
        } else { // vector quant mode
            if constexpr (scenarioNum == 2) {
                intriParams.quantPre = QuantMode_t::VDEQF16;
            } else if constexpr (scenarioNum == 4) {
                intriParams.quantPre = QuantMode_t::VQF322B8_PRE;
            } else {
                intriParams.quantPre = QuantMode_t::VREQ8;
            }
            AscendC::LocalTensor<uint64_t> fbTensor(AscendC::TPosition::C2PIPE2GM, fbAddr, N);
            uint16_t burstLen = CeilAlign(n * sizeof(uint64_t), 128) / 128;
            AscendC::DataCopyParams dataCopyParams(1, burstLen, 0, 0);
            AscendC::DataCopy(fbTensor, quantAlphaTensor, dataCopyParams);
            AscendC::SetFixPipeConfig(fbTensor);
        }

        if constexpr (scenarioNum == 1 || scenarioNum == 4 || scenarioNum == 6) {
            intriParams.reluPre = 1;
        }

        // 随路NZ2ND
        if constexpr (scenarioNum == 1 || scenarioNum == 4 || scenarioNum == 5) {
            intriParams.nz2ndEn = true;
            // Orignal nSize
            intriParams.nSize = n;
            intriParams.dstStride = n;
            uint16_t ndNum = 1;
            uint16_t srcNdStride = 0;
            uint16_t dstNdStride = 0;
            AscendC::SetFixpipeNz2ndFlag(ndNum, srcNdStride, dstNdStride);
        }
        // L0C -> GM
        AscendC::DataCopy(cGM, cLocal, intriParams);
    }

private:
    uint64_t a1Addr = 0;
    uint64_t a2Addr = 0;
    uint64_t b1Addr = 256 * 1024;
    uint64_t b2Addr = 0;
    uint64_t cAddr = 0;
    uint64_t c1Addr = 0;
    uint64_t fbAddr = 0;

    AscendC::GlobalTensor<inputType> aGM;
    AscendC::GlobalTensor<inputType> bGM;
    AscendC::GlobalTensor<outputType> cGM;
    AscendC::GlobalTensor<uint64_t> quantAlphaGM;

    float quantScalar = 2.0;
    // 注意沿着K轴切分
    uint16_t m = M, k = K / K_ROUND, n = N;
    uint16_t aSingleSize, bSingleSize, cSingleSize;
    uint16_t aSizeAlignL1, bSizeAlignL1;
    uint16_t aSizeAlignL0, bSizeAlignL0, cSizeAlignL0;
};

extern "C" __cube__ __global__ void data_copy_l0c2gm(__gm__ uint8_t* a, __gm__ uint8_t* b, __gm__ uint8_t* c, __gm__ uint8_t* quantAlpha)
{
    AscendC::InitSocState();
    if constexpr (scenarioNum == 1 || scenarioNum == 2) {
        KernelDataCopyL0c2Gm<int8_t, half, int32_t, 512, 2> op;
        op.Init(a, b, c, quantAlpha);
        op.Process();
    } else if constexpr (scenarioNum == 3 || scenarioNum == 4) {
        KernelDataCopyL0c2Gm<half, int8_t, float, 256, 1> op;
        op.Init(a, b, c, quantAlpha);
        op.Process();
    } else if constexpr (scenarioNum == 5 || scenarioNum == 6) {
        KernelDataCopyL0c2Gm<int8_t, int8_t, int32_t, 512, 2> op;
        op.Init(a, b, c, quantAlpha);
        op.Process();
    } else {
        AscendC::printf("current input scenario not support!");
    }
    AscendC::PipeBarrier<PIPE_ALL>();
}

int32_t main(int32_t argc, char* argv[])
{
    size_t inputDtypeSize = 1;
    size_t outputDtypeSize = 1;
    if constexpr (scenarioNum == 1 || scenarioNum == 2) {
        inputDtypeSize = sizeof(int8_t);
        outputDtypeSize = sizeof(half);
    } else if constexpr (scenarioNum == 3 || scenarioNum == 4) {
        inputDtypeSize = sizeof(half);
        outputDtypeSize = sizeof(int8_t);
    } else {
        inputDtypeSize = sizeof(int8_t);
        outputDtypeSize = sizeof(int8_t);
    }
    size_t aFileSize = M * K * inputDtypeSize;
    size_t bFileSize = K * N * inputDtypeSize;
    size_t cFileSize = M * N * outputDtypeSize;
    size_t quantAlphaSize = 1 * N * sizeof(uint64_t);
    uint32_t numBlocks = 1;

    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t* aHost;
    uint8_t* aDevice;
    aclrtMallocHost((void**)(&aHost), aFileSize);
    aclrtMalloc((void**)&aDevice, aFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/x1_gm.bin", aFileSize, aHost, aFileSize);
    aclrtMemcpy(aDevice, aFileSize, aHost, aFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t* bHost;
    uint8_t* bDevice;
    aclrtMallocHost((void**)(&bHost), bFileSize);
    aclrtMalloc((void**)&bDevice, bFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/x2_gm.bin", bFileSize, bHost, bFileSize);
    aclrtMemcpy(bDevice, bFileSize, bHost, bFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t* cHost;
    uint8_t* cDevice;
    aclrtMallocHost((void**)(&cHost), cFileSize);
    aclrtMalloc((void**)&cDevice, cFileSize, ACL_MEM_MALLOC_HUGE_FIRST);

    uint8_t* quantAlphaHost;
    uint8_t* quantAlphaDevice;
    aclrtMallocHost((void**)(&quantAlphaHost), quantAlphaSize);
    aclrtMalloc((void**)&quantAlphaDevice, quantAlphaSize, ACL_MEM_MALLOC_HUGE_FIRST);
    // vector quant mode
    if constexpr (scenarioNum == 2 || scenarioNum == 4 || scenarioNum == 6) {
        ReadFile("./input/quant_pre.bin", quantAlphaSize, quantAlphaHost, quantAlphaSize);
    }
    aclrtMemcpy(quantAlphaDevice, quantAlphaSize, quantAlphaHost, quantAlphaSize, ACL_MEMCPY_HOST_TO_DEVICE);

    data_copy_l0c2gm<<<numBlocks, nullptr, stream>>>(aDevice, bDevice, cDevice, quantAlphaDevice);
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(cHost, cFileSize, cDevice, cFileSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", cHost, cFileSize);

    aclrtFree(aDevice);
    aclrtFreeHost(aHost);
    aclrtFree(bDevice);
    aclrtFreeHost(bHost);
    aclrtFree(cDevice);
    aclrtFreeHost(cHost);
    aclrtFree(quantAlphaDevice);
    aclrtFreeHost(quantAlphaHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();
    return 0;
}
