#include "acl/acl.h"
#include "kernel_operator.h"
#include "data_utils.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

constexpr uint32_t scenarioNum = SCENARIO_NUM;

template <typename T>
__simd_vf__ inline void CopyWithOffsetVF(__ubuf__ T* zAddr, __ubuf__ T* xAddr, __ubuf__ T* yAddr,
    uint16_t oneRepeatSize, uint32_t repeatTimes, uint32_t calculateLength)
{
    AscendC::Reg::RegTensor<T> xReg;
    AscendC::Reg::RegTensor<T> yReg;
    AscendC::Reg::RegTensor<T> zReg;
    AscendC::Reg::MaskReg mask;
    for (uint16_t i = 0; i < repeatTimes; ++i) {
        mask = AscendC::Reg::UpdateMask<T>(calculateLength);
        AscendC::Reg::LoadAlign(xReg, xAddr + i * oneRepeatSize);
        AscendC::Reg::LoadAlign(yReg, yAddr + i * oneRepeatSize);
        AscendC::Reg::Add(zReg, xReg, yReg, mask);
        AscendC::Reg::StoreAlign(zAddr + i * oneRepeatSize, zReg, mask);
    }
}

template <typename T>
__simd_vf__ inline void CopyWithPostUpdateVF(__ubuf__ T* zAddr, __ubuf__ T* xAddr, __ubuf__ T* yAddr,
    uint16_t oneRepeatSize, uint32_t repeatTimes, uint32_t outputLength)
{
    AscendC::Reg::RegTensor<T> xReg;
    AscendC::Reg::RegTensor<T> yReg;
    AscendC::Reg::RegTensor<T> zReg;
    AscendC::Reg::MaskReg mask;
    for (uint16_t i = 0; i < repeatTimes; ++i) {
        mask = AscendC::Reg::UpdateMask<T>(outputLength);
        AscendC::Reg::LoadAlign<T, AscendC::Reg::PostLiteral::POST_MODE_UPDATE>(xReg, xAddr, oneRepeatSize);
        AscendC::Reg::LoadAlign<T, AscendC::Reg::PostLiteral::POST_MODE_UPDATE>(yReg, yAddr, oneRepeatSize);
        AscendC::Reg::Add(zReg, xReg, yReg, mask);
        AscendC::Reg::StoreAlign<T, AscendC::Reg::PostLiteral::POST_MODE_UPDATE>(zAddr, zReg, oneRepeatSize, mask);
    }
}

template <typename T>
__simd_vf__ inline void CopyWithAddrRegVF(__ubuf__ T* zAddr, __ubuf__ T* xAddr, __ubuf__ T* yAddr,
    uint16_t oneRepeatSize, uint32_t repeatTimes, uint32_t outputLength)
{
    AscendC::Reg::RegTensor<T> xReg;
    AscendC::Reg::RegTensor<T> yReg;
    AscendC::Reg::RegTensor<T> zReg;
    AscendC::Reg::MaskReg mask;
    AscendC::Reg::AddrReg areg;
    for (uint16_t i = 0; i < repeatTimes; ++i) {
        areg = AscendC::Reg::CreateAddrReg<T>(i, oneRepeatSize);
        mask = AscendC::Reg::UpdateMask<T>(outputLength);
        AscendC::Reg::LoadAlign(xReg, xAddr, areg);
        AscendC::Reg::LoadAlign(yReg, yAddr, areg);
        AscendC::Reg::Add(zReg, xReg, yReg, mask);
        AscendC::Reg::StoreAlign(zAddr, zReg, areg, mask);
    }
}

template <typename T>
__simd_vf__ inline void CopyDataBlock(__ubuf__ T* zAddr, __ubuf__ T* xAddr, __ubuf__ T* yAddr,
    uint16_t oneRepeatSize, uint32_t repeatTimes, uint32_t outputLength, uint32_t srcBlockStride)
{
    AscendC::Reg::RegTensor<T> xReg;
    AscendC::Reg::RegTensor<T> yReg;
    AscendC::Reg::RegTensor<T> zReg;
    AscendC::Reg::MaskReg mask;
    // VL=256B，DataBlock=32B，单次迭代处理的DataBlock数为256/32=8
    constexpr uint32_t oneRepeatDataBlock = 8;
    // 仅演示用DataBlock搬运实现连续搬出，不作为最优性能接口
    constexpr uint32_t dstBlockStride = 1;
    for (uint16_t i = 0; i < repeatTimes; ++i) {
        mask = AscendC::Reg::UpdateMask<T>(outputLength);
        AscendC::Reg::LoadAlign<T, AscendC::Reg::DataCopyMode::DATA_BLOCK_COPY, AscendC::Reg::PostLiteral::POST_MODE_UPDATE>(
            xReg, xAddr, srcBlockStride, srcBlockStride * oneRepeatDataBlock, mask);
        AscendC::Reg::LoadAlign<T, AscendC::Reg::DataCopyMode::DATA_BLOCK_COPY, AscendC::Reg::PostLiteral::POST_MODE_UPDATE>(
            yReg, yAddr, srcBlockStride, srcBlockStride * oneRepeatDataBlock, mask);
        AscendC::Reg::Add(zReg, xReg, yReg, mask);
        AscendC::Reg::StoreAlign<T, AscendC::Reg::DataCopyMode::DATA_BLOCK_COPY, AscendC::Reg::PostLiteral::POST_MODE_UPDATE>(
            zAddr, zReg, dstBlockStride, dstBlockStride * oneRepeatDataBlock, mask);
    }
}

template <typename T>
__simd_vf__ inline void CopyInBroadcastVF(__ubuf__ T* zAddr, __ubuf__ T* xAddr, __ubuf__ T* yAddr,
    uint16_t oneRepeatSize, uint32_t repeatTimes)
{
    AscendC::Reg::RegTensor<T> xReg;
    AscendC::Reg::RegTensor<T> yReg;
    AscendC::Reg::RegTensor<T> zReg;
    AscendC::Reg::MaskReg mask = AscendC::Reg::CreateMask<T>();
    for (uint16_t i = 0; i < repeatTimes; ++i) {
        AscendC::Reg::LoadAlign<T, AscendC::Reg::LoadDist::DIST_BRC_B16>(xReg, xAddr + i * oneRepeatSize);
        AscendC::Reg::LoadAlign<T, AscendC::Reg::LoadDist::DIST_BRC_B16>(yReg, yAddr + i * oneRepeatSize);
        AscendC::Reg::Add(zReg, xReg, yReg, mask);
        AscendC::Reg::StoreAlign(zAddr + i * oneRepeatSize, zReg, mask);
    }
}

template <typename T>
__simd_vf__ inline void CopyInUpsampleVF(__ubuf__ T* zAddr, __ubuf__ T* xAddr, __ubuf__ T* yAddr,
    uint16_t oneRepeatSize, uint32_t repeatTimes)
{
    AscendC::Reg::RegTensor<T> xReg;
    AscendC::Reg::RegTensor<T> yReg;
    AscendC::Reg::RegTensor<T> zReg;
    AscendC::Reg::MaskReg mask = AscendC::Reg::CreateMask<T>();
    for (uint16_t i = 0; i < repeatTimes; ++i) {
        AscendC::Reg::LoadAlign<T, AscendC::Reg::LoadDist::DIST_US_B16>(xReg, xAddr + i * oneRepeatSize / 2);
        AscendC::Reg::LoadAlign<T, AscendC::Reg::LoadDist::DIST_US_B16>(yReg, yAddr + i * oneRepeatSize / 2);
        AscendC::Reg::Add(zReg, xReg, yReg, mask);
        AscendC::Reg::StoreAlign(zAddr + i * oneRepeatSize, zReg, mask);
    }
}

template <typename T>
class Kernel {
public:
    __aicore__ inline void Init(__gm__ uint8_t* x, __gm__ uint8_t* y, __gm__ uint8_t* z, uint32_t inputLength, uint32_t outputLength)
    {
        this->inputLength = inputLength;
        this->outputLength = outputLength;
        this->xGm.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(x));
        this->yGm.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(y));
        this->zGm.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(z));
    }

    __aicore__ inline void Process()
    {
        // 使用 LocalMemAllocator 分配 UB 内存
        AscendC::LocalMemAllocator<AscendC::Hardware::UB> ubAllocator;
        AscendC::LocalTensor<T> xLocal = ubAllocator.Alloc<T>(inputLength);
        AscendC::LocalTensor<T> yLocal = ubAllocator.Alloc<T>(inputLength);
        AscendC::LocalTensor<T> zLocal = ubAllocator.Alloc<T>(outputLength);

        // CopyIn: GM -> UB (x and y)
        AscendC::DataCopy(xLocal, xGm, inputLength);
        AscendC::DataCopy(yLocal, yGm, inputLength);

        // 同步：等待 MTE2 完成
        AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);

        // Compute: VF函数内部实现z = x + y
        __ubuf__ T* xAddr = reinterpret_cast<__ubuf__ T*>(xLocal.GetPhyAddr());
        __ubuf__ T* yAddr = reinterpret_cast<__ubuf__ T*>(yLocal.GetPhyAddr());
        __ubuf__ T* zAddr = reinterpret_cast<__ubuf__ T*>(zLocal.GetPhyAddr());
        constexpr uint32_t oneRepeatSize = AscendC::GetVecLen() / sizeof(T);
        uint16_t repeatTimes = AscendC::CeilDivision(inputLength, oneRepeatSize);
        if constexpr (scenarioNum == 1) {
            // 介绍数据非对齐场景，处理1021个数据
            asc_vf_call<CopyWithOffsetVF<T>>(zAddr, xAddr, yAddr, oneRepeatSize, repeatTimes, outputLength - 3);
        } else if constexpr (scenarioNum == 2) {
            asc_vf_call<CopyWithPostUpdateVF<T>>(zAddr, xAddr, yAddr, oneRepeatSize, repeatTimes, outputLength);
        } else if constexpr (scenarioNum == 3) {
            asc_vf_call<CopyWithAddrRegVF<T>>(zAddr, xAddr, yAddr, oneRepeatSize, repeatTimes, outputLength);
        } else if constexpr (scenarioNum == 4) {
            // 输入时两个有效datablock头和头之间，间隔2个datablock的长度，输入仅一半元素有效，repeat次数减半
            asc_vf_call<CopyDataBlock<T>>(zAddr, xAddr, yAddr, oneRepeatSize, repeatTimes / 2, outputLength, 2);
        } else if constexpr (scenarioNum == 5) {
            asc_vf_call<CopyInBroadcastVF<T>>(zAddr, xAddr, yAddr, oneRepeatSize, repeatTimes);
        } else if constexpr (scenarioNum == 6) {
            // 每次搬入VL/2，repeat次数加倍
            asc_vf_call<CopyInUpsampleVF<T>>(zAddr, xAddr, yAddr, oneRepeatSize, repeatTimes * 2);
        }

        // 同步：等待 V 完成
        AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);

        // CopyOut: UB -> GM
        AscendC::DataCopy(zGm, zLocal, outputLength);
    }

private:
    uint32_t inputLength;
    uint32_t outputLength;
    AscendC::GlobalTensor<T> xGm;
    AscendC::GlobalTensor<T> yGm;
    AscendC::GlobalTensor<T> zGm;
};

__global__ __vector__ void ld_st_reg_align_kernel(__gm__ uint8_t* x, __gm__ uint8_t* y, __gm__ uint8_t* z)
{
    AscendC::InitSocState();
    uint32_t inputLength = 1024;
    uint32_t outputLength = 1024;
    if constexpr (scenarioNum == 4) {
        outputLength = 512;
    } else if constexpr (scenarioNum == 6) {
        outputLength = 2048;
    }
    Kernel<half> kernel;
    kernel.Init(x, y, z, inputLength, outputLength);
    kernel.Process();
    AscendC::PipeBarrier<PIPE_ALL>();
}

static bool CompareResult(const void* outputData, uint32_t outSize)
{
    void* goldenData;
    aclrtMallocHost((void**)(&goldenData), outSize);
    size_t goldenSize = outSize;
    bool ret = ReadFile("./output/golden.bin", goldenSize, goldenData, goldenSize);
    if (ret) {
        printf("ReadFile golden.bin success!\n");
    } else {
        printf("test failed!\n");
        aclrtFreeHost(goldenData);
        return false;
    }
    constexpr float EPS = 1e-3;
    int64_t wrongNum = 0;

    for (size_t i = 0; i < outSize / sizeof(half); i++) {
        half a = (reinterpret_cast<const half*>(outputData))[i];
        half b = (reinterpret_cast<const half*>(goldenData))[i];
        float aFloat = static_cast<float>(a);
        float bFloat = static_cast<float>(b);
        float ae = std::abs(aFloat - bFloat);
        float re = ae / std::abs(bFloat);
        if (ae > EPS && re > EPS) {
            printf("CompareResult golden.bin failed output is %f, golden is %f\n", aFloat, bFloat);
            wrongNum++;
        }
    }
    aclrtFreeHost(goldenData);
    if (wrongNum != 0) {
        return false;
    } else {
        printf("CompareResult golden.bin success!\n");
        return true;
    }
}

int32_t main(int32_t argc, char* argv[])
{
    uint32_t numBlocks = 1;
    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);
    uint32_t inputLength = 1024;
    uint32_t outputLength = 1024;
    if constexpr (scenarioNum == 4) {
        outputLength = 512;
    } else if constexpr (scenarioNum == 6) {
        outputLength = 2048;
    }
    size_t inputByteSize = static_cast<size_t>(1) * inputLength * sizeof(half);
    size_t outputByteSize = static_cast<size_t>(1) * outputLength * sizeof(half);
    uint8_t *xHost, *yHost, *zHost;
    uint8_t *xDevice, *yDevice, *zDevice;
    aclrtMallocHost((void**)(&xHost), inputByteSize);
    aclrtMallocHost((void**)(&yHost), inputByteSize);
    aclrtMallocHost((void**)(&zHost), outputByteSize);
    aclrtMalloc((void**)&xDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&yDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&zDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/input_x.bin", inputByteSize, xHost, inputByteSize);
    ReadFile("./input/input_y.bin", inputByteSize, yHost, inputByteSize);
    aclrtMemcpy(xDevice, inputByteSize, xHost, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(yDevice, inputByteSize, yHost, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
    ld_st_reg_align_kernel<<<numBlocks, nullptr, stream>>>(xDevice, yDevice, zDevice);
    aclrtSynchronizeStream(stream);
    aclrtMemcpy(zHost, outputByteSize, zDevice, outputByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", zHost, outputByteSize);
    bool goldenResult = true;
    goldenResult = CompareResult(zHost, outputByteSize);
    if (goldenResult) {
        printf("test pass!\n");
    } else {
        printf("test failed!\n");
    }
    aclrtFree(xDevice);
    aclrtFree(yDevice);
    aclrtFree(zDevice);
    aclrtFreeHost(xHost);
    aclrtFreeHost(yHost);
    aclrtFreeHost(zHost);
    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();
    return 0;
}
