/* !
 * \file mmad_tensor_api.asc
 * \brief
 */
#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

#include "acl/acl.h"
#include "tensor_api/tensor.h"
#include "kernel_operator.h"
#include "data_utils.h"

template <typename A_TYPE, typename B_TYPE, typename L0C_TYPE, typename C_TYPE,
        int32_t baseM, int32_t baseN, int32_t baseK, int32_t stepM, int32_t stepN, int32_t stepK, bool ENABLE_UNITFLAG>
__cube__ __global__ void mmad_quant_custom(__gm__ A_TYPE* x, __gm__ B_TYPE* y, __gm__ C_TYPE* z, __gm__ uint64_t* quant,
                    int32_t m, int32_t n, int32_t k, int32_t singleCoreM, int32_t singleCoreN, int32_t singleCoreK)
{
    using namespace AscendC::Te;
    // Copy tiling info from GM to local
    uint32_t mIter = (m + singleCoreM - 1) / singleCoreM;
    uint32_t mIterIdx = AscendC::GetBlockIdx() % mIter;
    uint32_t nIterIdx = AscendC::GetBlockIdx() / mIter;
    int32_t actualSingleCoreM = m - mIterIdx * singleCoreM;
    int32_t actualSingleCoreN = n - nIterIdx * singleCoreN;
    actualSingleCoreM = actualSingleCoreM < singleCoreM ? actualSingleCoreM : singleCoreM;
    actualSingleCoreN = actualSingleCoreN < singleCoreN ? actualSingleCoreN : singleCoreN;

    auto gmATensor = MakeTensor(MakeMemPtr(x), MakeFrameLayout<NDExtLayoutPtn>(m, k));
    auto gmBTensor = MakeTensor(MakeMemPtr(y), MakeFrameLayout<DNExtLayoutPtn>(k, n));
    auto gmCTensor = MakeTensor(MakeMemPtr(z), MakeFrameLayout<NDExtLayoutPtn>(m, n));
    auto gmQuantTensor = MakeTensor(MakeMemPtr(quant), MakeFrameLayout<NDExtLayoutPtn>(1, n));

    auto gmASingleTensor = gmATensor.Slice(
        MakeCoord(mIterIdx * singleCoreM, 0), 
        MakeShape(actualSingleCoreM, singleCoreK)
    );
    auto gmBSingleTensor = gmBTensor.Slice(
        MakeCoord(0, nIterIdx * singleCoreN), 
        MakeShape(singleCoreK, actualSingleCoreN)
    );
    auto gmCSingleTensor = gmCTensor.Slice(
        MakeCoord(mIterIdx * singleCoreM, nIterIdx * singleCoreN), 
        MakeShape(actualSingleCoreM, actualSingleCoreN)
    );
    auto gmQuantSingleTensor = gmQuantTensor.Slice(
        MakeCoord(0, nIterIdx * singleCoreN), 
        MakeShape(1, actualSingleCoreN)
    );

    __cbuf__ A_TYPE l1ABuf[baseM * stepM * baseK * stepK];
    __cbuf__ B_TYPE l1BBuf[baseK * stepK * baseN * stepN];
    __cbuf__ uint64_t l1QuantBuf[baseN * stepN];
    __ca__ A_TYPE l0ABuf[baseM * baseK];
    __cb__ B_TYPE l0BBuf[baseK * baseN];
    __cc__ L0C_TYPE l0CBuf[baseM * baseN];

    auto l1QuantPtr = MakeMemPtr(l1QuantBuf);
    auto l0APtr = MakeMemPtr(l0ABuf);
    auto l0BPtr = MakeMemPtr(l0BBuf);
    auto l0CPtr = MakeMemPtr(l0CBuf);

    auto copyGM2L1Atom = MakeCopy(CopyGM2L1{}, CopyGM2L1TraitDefault{});
    auto copyL12L0AAtom = MakeCopy(CopyL12L0A{}, CopyL12L0ATraitDefault{});
    auto copyL12L0BAtom = MakeCopy(CopyL12L0B{}, CopyL12L0BTraitDefault{});
    auto copyL0C2GMAtom = MakeCopy(CopyL0C2GM{}, CopyL0C2GMTraitDefault{});
    auto mmadAtom = MakeMmad(MmadOperation{}, MmadTraitDefault{});
    
    auto l1ATensor = MakeTensor(
        MakeMemPtr(l1ABuf), 
        MakeFrameLayout<NZLayoutPtn, A_TYPE>(baseM * stepM, baseK * stepK)
    );
    auto l1BTensor = MakeTensor(
        MakeMemPtr(l1BBuf), 
        MakeFrameLayout<ZNLayoutPtn, B_TYPE>(baseK * stepK, baseN * stepN)
    );

    uint32_t mLoop = (actualSingleCoreM + baseM - 1) / baseM;
    uint32_t nLoop = (actualSingleCoreN + baseN - 1) / baseN;
    uint32_t kLoop = (singleCoreK + baseK - 1) / baseK;

    static constexpr uint32_t L1_EVENT_ID = 0;
    static constexpr uint32_t L0_EVENT_ID = 1;
    static constexpr uint32_t L0C_EVENT_ID = 2;
    static constexpr uint32_t QUANT_EVENT_ID = 3;
    AscendC::SetFlag<AscendC::HardEvent::MTE1_MTE2>(L1_EVENT_ID);
    AscendC::SetFlag<AscendC::HardEvent::M_MTE1>(L0_EVENT_ID);
    AscendC::SetFlag<AscendC::HardEvent::FIX_M>(L0C_EVENT_ID);
    AscendC::SetFlag<AscendC::HardEvent::FIX_MTE2>(QUANT_EVENT_ID);
    uint16_t tileM =  (actualSingleCoreM % baseM != 0) ? actualSingleCoreM % baseM : baseM;            
    uint16_t tileN =  (actualSingleCoreN % baseN != 0) ? actualSingleCoreN % baseN : baseN; 
    uint16_t tileK =  (singleCoreK % baseK != 0) ? singleCoreK % baseK : baseK; 
               
    for (uint32_t i = 0; i < mLoop; i++) {
        uint16_t curM = (i + 1 == mLoop) ? tileM : baseM;
        for (uint32_t j = 0; j < nLoop; j++) {
            uint16_t curN = (j + 1 == nLoop) ? tileN : baseN;
            auto l0CTensor = MakeTensor(l0CPtr, MakeFrameLayout<NZLayoutPtn>(curM, curN));
            for (uint32_t kIter = 0; kIter < kLoop; kIter++) {
                uint16_t curK = (kIter + 1 == kLoop) ? tileK : baseK;
                auto l0ATensor = MakeTensor(l0APtr, MakeFrameLayout<NZLayoutPtn, A_TYPE>(curM, curK));
                auto l0BTensor = MakeTensor(l0BPtr, MakeFrameLayout<ZNLayoutPtn, B_TYPE>(curK, curN));
                if (kIter % stepK == 0) {
                    AscendC::WaitFlag<AscendC::HardEvent::MTE1_MTE2>(L1_EVENT_ID);
                    // GM -> L1A
                    Copy(copyGM2L1Atom, l1ATensor, 
                        gmASingleTensor.Slice(MakeCoord(i * baseM, kIter * baseK * stepK), MakeShape(baseM, baseK * stepK))
                    );
                    // GM -> L1B
                    Copy(copyGM2L1Atom, l1BTensor, 
                        gmBSingleTensor.Slice(MakeCoord(kIter * baseK * stepK, j * baseN), MakeShape(baseK * stepK, baseN))
                    );
                    AscendC::SetFlag<AscendC::HardEvent::MTE2_MTE1>(L1_EVENT_ID);
                    AscendC::WaitFlag<AscendC::HardEvent::MTE2_MTE1>(L1_EVENT_ID);
                }
                AscendC::WaitFlag<AscendC::HardEvent::M_MTE1>(L0_EVENT_ID);
                // L1A -> L0A
                Copy(copyL12L0AAtom, l0ATensor,
                    l1ATensor.Slice(MakeCoord(0, kIter % stepK * baseK), MakeShape(curM, curK))
                );
                // L1B -> L0B
                Copy(copyL12L0BAtom, l0BTensor, 
                    l1BTensor.Slice(MakeCoord(kIter % stepK * baseK, 0), MakeShape(curK, curN))
                );
                if ((kIter + 1) % stepK == 0) {
                    AscendC::SetFlag<AscendC::HardEvent::MTE1_MTE2>(L1_EVENT_ID);
                }
                AscendC::SetFlag<AscendC::HardEvent::MTE1_M>(L0_EVENT_ID);
                AscendC::WaitFlag<AscendC::HardEvent::MTE1_M>(L0_EVENT_ID);

                // mmad
                if (kIter == 0) {
                    AscendC::WaitFlag<AscendC::HardEvent::FIX_M>(L0C_EVENT_ID);
                }

                MmadParams para;
                para.m = curM;
                para.n = curN;
                para.k = curK;
                para.cmatrixInitVal = (kIter == 0) ? true : false;
                if constexpr (ENABLE_UNITFLAG){
                    para.unitFlag = (kIter == kLoop - 1) ? 3 : 2;
                }
                Mmad(mmadAtom.with(para), l0CTensor, l0ATensor, l0BTensor);
                if (kIter == kLoop - 1) {
                    AscendC::SetFlag<AscendC::HardEvent::M_FIX>(L0C_EVENT_ID);
                }

                AscendC::SetFlag<AscendC::HardEvent::M_MTE1>(L0_EVENT_ID);
            }
            // L0C -> GM
            AscendC::WaitFlag<AscendC::HardEvent::FIX_MTE2>(QUANT_EVENT_ID);
            auto gmCSilce = gmCSingleTensor.Slice(
                MakeCoord(i * baseM, j * baseN), 
                MakeShape(curM, curN)
            );
            auto l1QuantTensor = MakeTensor(
                l1QuantPtr,
                MakeFrameLayout<NDExtLayoutPtn>(1, curN)
            );
            Copy(copyGM2L1Atom, l1QuantTensor, gmQuantSingleTensor.Slice(MakeCoord(0, j * baseN), MakeShape(1, curN)));
            AscendC::SetFlag<AscendC::HardEvent::MTE2_FIX>(QUANT_EVENT_ID);
            AscendC::WaitFlag<AscendC::HardEvent::MTE2_FIX>(QUANT_EVENT_ID);

            AscendC::WaitFlag<AscendC::HardEvent::M_FIX>(L0C_EVENT_ID);
            if constexpr(ENABLE_UNITFLAG){
                FixpipeParams params;
                params.unitFlag = 3;
                Copy(copyL0C2GMAtom.with(params), gmCSilce, l0CTensor, l1QuantTensor);
            }else{
                Copy(copyL0C2GMAtom, gmCSilce, l0CTensor, l1QuantTensor);
            }   
            AscendC::SetFlag<AscendC::HardEvent::FIX_M>(L0C_EVENT_ID);
            AscendC::SetFlag<AscendC::HardEvent::FIX_MTE2>(QUANT_EVENT_ID);
        }
    }

    AscendC::WaitFlag<AscendC::HardEvent::M_MTE1>(L0_EVENT_ID);
    AscendC::WaitFlag<AscendC::HardEvent::FIX_M>(L0C_EVENT_ID);
    AscendC::WaitFlag<AscendC::HardEvent::MTE1_MTE2>(L1_EVENT_ID);
    AscendC::WaitFlag<AscendC::HardEvent::FIX_MTE2>(QUANT_EVENT_ID);
}

int32_t main(int32_t argc, char* argv[])
{
    using A_TYPE = int8_t;
    using B_TYPE = int8_t;
    using L0C_TYPE = int32_t;
    using C_TYPE = half;

    int32_t m = 1024;
    int32_t n = 1024;
    int32_t k = 256;
    int32_t singleCoreM = 256;
    int32_t singleCoreN = 128;
    int32_t singleCoreK = 256;

    constexpr int32_t BASE_M = 256;
    constexpr int32_t BASE_N = 256;
    constexpr int32_t BASE_K = 64;
    constexpr int32_t STEP_M = 1;
    constexpr int32_t STEP_N = 1;
    constexpr int32_t STEP_K = 4;
    
    constexpr bool ENABLE_UNITFLAG = true;
    constexpr uint32_t NUM_BLOCKS = 32;

    size_t param1FileSize = m * k * sizeof(A_TYPE);
    size_t param2FileSize = n * k * sizeof(B_TYPE);
    size_t param3FileSize = m * n * sizeof(C_TYPE);
    size_t param4FileSize = n * sizeof(uint64_t);

    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t *xHost, *yHost, *zHost, *quantHost;
    A_TYPE *xDevice;
    B_TYPE *yDevice;
    C_TYPE* zDevice;
    uint64_t* quantDevice;

    aclrtMallocHost((void**)(&xHost), param1FileSize);
    aclrtMallocHost((void**)(&yHost), param2FileSize);
    aclrtMallocHost((void**)(&zHost), param3FileSize);
    aclrtMallocHost((void**)(&quantHost), param4FileSize);
    aclrtMalloc((void**)&xDevice, param1FileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&yDevice, param2FileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&zDevice, param3FileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&quantDevice, param4FileSize, ACL_MEM_MALLOC_HUGE_FIRST);

    ReadFile("./input/input_x.bin", param1FileSize, xHost, param1FileSize);
    ReadFile("./input/input_y.bin", param2FileSize, yHost, param2FileSize);
    ReadFile("./input/quant.bin", param4FileSize, quantHost, param4FileSize);

    aclrtMemcpy(xDevice, param1FileSize, xHost, param1FileSize, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(yDevice, param2FileSize, yHost, param2FileSize, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(quantDevice, param4FileSize, quantHost, param4FileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    mmad_quant_custom<A_TYPE, B_TYPE, L0C_TYPE, C_TYPE, BASE_M, BASE_N, BASE_K, STEP_M, STEP_N, STEP_K, ENABLE_UNITFLAG>
        <<<NUM_BLOCKS, stream>>>(
            xDevice, yDevice, zDevice, quantDevice,
            m, n, k, singleCoreM, singleCoreN, singleCoreK
        );
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(zHost, param3FileSize, zDevice, param3FileSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", zHost, param3FileSize);

    aclrtFree(xDevice);
    aclrtFree(yDevice);
    aclrtFree(zDevice);
    aclrtFree(quantDevice);
    aclrtFreeHost(xHost);
    aclrtFreeHost(yHost);
    aclrtFreeHost(zHost);
    aclrtFreeHost(quantHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();

    return 0;
}
