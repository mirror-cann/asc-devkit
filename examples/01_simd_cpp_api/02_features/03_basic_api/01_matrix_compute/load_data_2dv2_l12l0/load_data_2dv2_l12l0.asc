/* !
 * \file load_data_2dv2_l12l0.asc
 * \brief 本样例适用于Ascend 950PR/Ascend 950DT，介绍了在矩阵乘法场景下，使用Load2dV2接口将矩阵数据从L1搬运到L0A/L0B的方法。
 *        Ascend 950PR/Ascend 950DT的L0A数据排布格式为Nz（与Atlas A2/A3系列的Zz不同）。
 *        支持int8_t/half/float三种数据类型，共7种转置场景组合：
 *        - A不转置B转置：scenarioNum = 1,4,6 (int8_t, half, float);
 *        - A转置B不转置，A/B矩阵从L1->L0调用一次Load2dV2进行搬运：scenarioNum = 2,4,6 (int8_t, half, float);
 *        - A转置B不转置，A矩阵从L1->L0A调用for循环+Load2dV2进行搬运，B矩阵从L1->L0B调用一次Load2dV2进行搬运：scenarioNum = 7 (int8_t)。
 */

#include "acl/acl.h"
#include "kernel_operator.h"
#include "data_utils.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

constexpr uint32_t scenarioNum = SCENARIO_NUM;
constexpr uint32_t INT8_M_STEP_ALIGN = 2;

/*
    1. L1数据排布格式为Nz
    2. L0A数据排布格式为Nz
    3. L0B数据排布格式为Zn
    
    isAtranspose为false，表示GM上输入A矩阵不转置，即输入为[m, k]，L1-->L0A时矩阵A不需要转置，loadDataParams.ifTranspose = false
    isAtranspose为true，表示GM上输入A矩阵转置，即输入为[k, m]，L1-->L0A时矩阵A需要转置，loadDataParams.ifTranspose = true
    
    isBtranspose为false，表示GM上输入B矩阵不转置，即输入为[k, n]，L1-->L0B时矩阵B需要转置，loadDataParams.ifTranspose = true
    isBtranspose为true，表示GM上输入B矩阵转置，即输入为[n, k]，L1-->L0B时矩阵B不需要转置，loadDataParams.ifTranspose = false
*/

template <class T, class U, uint32_t m, uint32_t n, uint32_t k, bool isAtranspose, bool isBtranspose>
class KernelMmad {
public:
    __aicore__ inline KernelMmad()
    {
        fractalShape[0] = 16;
        fractalShape[1] = 32 / sizeof(T);
        
        if constexpr (sizeof(T) == 1) {
            fractalNum = 2;
        } else if constexpr (sizeof(T) == 2) {
            fractalNum = 1;
        } else {
            fractalNum = 2;
        }
        if constexpr (AscendC::IsSameType<T, int8_t>::value || AscendC::IsSameType<T, half>::value) {
            if constexpr (!isAtranspose) {
                // GM上A矩阵的shape为[m,k], L1上的shape为[mAlignL1, kaAlignL1], L0上的shape为[mAlignL0, kaAlignL0]
                // L1->L0A 调用Load2dV2 L1/L0上row和col分别向fractalShape[0], fractalShape[1]对齐
                // L1上排布格式为Nz，A矩阵的对齐
                mAlignL1 = CeilAlign(m, fractalShape[0]);
                kaAlignL1 = CeilAlign(k, fractalShape[1]);
                aSizeAlignL1 = mAlignL1 * kaAlignL1;
                // L0上排布格式为Nz，A矩阵的对齐
                mAlignL0 = CeilAlign(m, fractalShape[0]);
                kaAlignL0 = CeilAlign(k, fractalShape[1]);
                aSizeAlignL0 = mAlignL0 * kaAlignL0;
            } else {
                // GM上A矩阵的shape为[k,m], L1上的shape为[kaAlignL1, mAlignL1], L0上的shape为[mAlignL0, kaAlignL0]
                // L1->L0A 调用Load2dV2 L1和L0上row和col分别向fractalShape[0] * fractalNum, fractalShape[1]对齐
                // L1上排布格式为Nz，A矩阵的对齐
                kaAlignL1 = CeilAlign(k, fractalShape[0] * fractalNum);
                mAlignL1 = CeilAlign(m, fractalShape[1]);
                aSizeAlignL1 = kaAlignL1 * mAlignL1;
                // L0上排布格式为Nz，A矩阵的对齐
                mAlignL0 = CeilAlign(m, fractalShape[0] * fractalNum);
                kaAlignL0 = CeilAlign(k, fractalShape[1]);
                aSizeAlignL0 = mAlignL0 * kaAlignL0;
            }

            if constexpr (!isBtranspose) {
                // GM上B矩阵的shape为[k,n], L1上的shape为[kbAlignL1, nAlignL1], L0上的shape为[kbAlignL0, nAlignL0]
                // L1->L0B 调用Load2dV2 L1上row和col分别向fractalShape[0] * fractalNum, fractalShape[1]对齐; L0上row向fractalShape[1]对齐, col向fractalShape[0] * fractalNum对齐
                // L1上排布格式为Nz，B矩阵的对齐
                kbAlignL1 = CeilAlign(k, fractalShape[0] * fractalNum);
                nAlignL1 = CeilAlign(n, fractalShape[1]);
                bSizeAlignL1 = kbAlignL1 * nAlignL1;
                // L0上排布格式为Zn，B矩阵的对齐
                kbAlignL0 = CeilAlign(k, fractalShape[1]);
                nAlignL0 = CeilAlign(n, fractalShape[0] * fractalNum);
                bSizeAlignL0 = kbAlignL0 * nAlignL0;
            } else {
                // GM上B矩阵的shape为[n,k], L1上的shape为[nAlignL1, kbAlignL1], L0上的shape为[kbAlignL0, nAlignL0]
                // L1->L0B 调用Load2dV2 L1/L0上row和col分别向fractalShape[0], fractalShape[1]对齐
                // L1上排布格式为Nz，B矩阵的对齐
                nAlignL1 = CeilAlign(n, fractalShape[0]);
                kbAlignL1 = CeilAlign(k, fractalShape[1]);
                bSizeAlignL1 = nAlignL1 * kbAlignL1;
                kbAlignL0 = CeilAlign(k, fractalShape[1]);
                nAlignL0 = CeilAlign(n, fractalShape[0]);
                bSizeAlignL0 = kbAlignL0 * nAlignL0;
            }
        } else if constexpr (AscendC::IsSameType<T, float>::value) {
            if constexpr (!isAtranspose) {
                // GM上A矩阵的shape为[m,k], L1上的shape为[mAlignL1, kaAlignL1], L0上的shape为[mAlignL0, kaAlignL0]
                // L1->L0A 调用Load2dV2 L1/L0上row和col分别向fractalShape[0], fractalShape[1]对齐
                // L1上排布格式为Nz，A矩阵的对齐
                mAlignL1 = CeilAlign(m, fractalShape[0]);
                kaAlignL1 = CeilAlign(k, fractalShape[1]);
                aSizeAlignL1 = mAlignL1 * kaAlignL1;
                // L0上排布格式为Nz，A矩阵的对齐
                mAlignL0 = CeilAlign(m, fractalShape[0]);
                kaAlignL0 = CeilAlign(k, fractalShape[1]);
                aSizeAlignL0 = mAlignL0 * kaAlignL0;
            } else {
                // GM上A矩阵的shape为[k,m], L1上的shape为[kaAlignL1, mAlignL1], L0上的shape为[mAlignL0, kaAlignL0]
                // L1->L0A 调用Load2dV2 L1/L0上row和col分别向fractalShape[0], fractalShape[1] * fractalNum对齐
                // L1上排布格式为Nz，A矩阵的对齐
                kaAlignL1 = CeilAlign(k, fractalShape[0]);
                mAlignL1 = CeilAlign(m, fractalShape[1] * fractalNum);
                aSizeAlignL1 = kaAlignL1 * mAlignL1;
                // L0上排布格式为Nz，A矩阵的对齐
                mAlignL0 = CeilAlign(m, fractalShape[0]);
                kaAlignL0 = CeilAlign(k, fractalShape[1] * fractalNum);
                aSizeAlignL0 = mAlignL0 * kaAlignL0;
            }
            if constexpr (!isBtranspose) {
                // GM上B矩阵的shape为[k,n], L1上的shape为[kbAlignL1, nAlignL1], L0上的shape为[kbAlignL0, nAlignL0]
                // L1->L0B 调用Load2dV2 L1上row和col分别向fractalShape[0], fractalShape[1] * fractalNum对齐; L0上row向fractalShape[1] * fractalNum对齐, col向fractalShape[0]对齐
                // L1上排布格式为Nz，B矩阵的对齐
                kbAlignL1 = CeilAlign(k, fractalShape[0]);
                nAlignL1 = CeilAlign(n, fractalShape[1] * fractalNum);
                bSizeAlignL1 = kbAlignL1 * nAlignL1;
                // L0上排布格式为Zn，B矩阵的对齐
                kbAlignL0 = CeilAlign(k, fractalShape[1] * fractalNum);
                nAlignL0 = CeilAlign(n, fractalShape[0]);
                bSizeAlignL0 = kbAlignL0 * nAlignL0;
            } else {
                // GM上B矩阵的shape为[n,k], L1上的shape为[nAlignL1, kbAlignL1], L0上的shape为[kbAlignL0, nAlignL0]
                // L1->L0B 调用Load2dV2 L1/L0上row和col分别向fractalShape[0], fractalShape[1]对齐
                // L1上排布格式为Nz, B矩阵的对齐
                nAlignL1 = CeilAlign(n, fractalShape[0]); // row
                kbAlignL1 = CeilAlign(k, fractalShape[1]); // col
                bSizeAlignL1 = nAlignL1 * kbAlignL1;
                // L0上排布格式为Zn，B矩阵的对齐
                kbAlignL0 = CeilAlign(k, fractalShape[1]); // row
                nAlignL0 = CeilAlign(n, fractalShape[0]); // col
                bSizeAlignL0 = kbAlignL0 * nAlignL0;
            }
        }

        if constexpr (scenarioNum == 7) {
            // 输入为int8类型，A矩阵[k,m]转置输入，L1->L0A需要转置，for循环调用Load2DV2，按照方型搬运，每次for循环在L0A上跳过m方向尾脏数据分形，m方向多搬运数据不超过1个分形；
            // B矩阵[k, n]不转置输入，L1->L0B需要转置，调用一次Load2DV2，n方向多搬运数据不超过1个分形；
            // 矩阵计算Mmad计算量为CeilAlign(m, fractalShape[0]) * CeilAlign(n, fractalShape[0] * fractalNum)。
            mAlignL0 = CeilAlign(m, fractalShape[0]);
            kaAlignL0 = CeilAlign(k, fractalShape[1]);
            aSizeAlignL0 = mAlignL0 * kaAlignL0;
            // C
            cSizeAlignL0 = mAlignL0 * nAlignL0;
        } else if constexpr (scenarioNum == 2) {
            // 输入为int8类型，A矩阵[k,m]转置输入，L1->L0A需要转置，调用一次Load2DV2，按照方型搬运，m方向多搬运数据超过1个分形；
            // B矩阵[k, n]不转置输入，L1->L0B需要转置，调用一次Load2DV2，n方向多搬运数据不超过1个分形；
            // 矩阵计算Mmad计算量为CeilAlign(m, fractalShape[0] * fractalNum) * CeilAlign(n, fractalShape[0] * fractalNum)。
            cSizeAlignL0 = mAlignL0 * nAlignL0;
        } else {
            cSizeAlignL0 = CeilAlign(m, 16) * CeilAlign(n, 16);
        }
    }

    __aicore__ inline void Init(GM_ADDR a, GM_ADDR b, GM_ADDR c)
    {
        aGM.SetGlobalBuffer((__gm__ T *)a);
        bGM.SetGlobalBuffer((__gm__ T *)b);
        cGM.SetGlobalBuffer((__gm__ U *)c);
    }

    __aicore__ inline void Process()
    {

        AscendC::LocalTensor<T> a1Local(AscendC::TPosition::A1, a1Addr, aSizeAlignL1);
        AscendC::LocalTensor<T> a2Local(AscendC::TPosition::A2, a2Addr, aSizeAlignL0);
        AscendC::LocalTensor<T> b1Local(AscendC::TPosition::B1, b1Addr, bSizeAlignL1);
        AscendC::LocalTensor<T> b2Local(AscendC::TPosition::B2, b2Addr, bSizeAlignL0);
        AscendC::LocalTensor<U> c1Local(AscendC::TPosition::CO1, co1Addr, cSizeAlignL0);
        // 1.GM -> L1 
        CopyInA1(a1Local);
        CopyInB1(b1Local);
        AscendC::SetFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID0);
        // 2.L1 -> L0 
        SplitA(a1Local, a2Local);
        SplitB(b1Local, b2Local);
        AscendC::SetFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID0);
        // 3.Mmad
        AscendC::MmadParams mmadParams;
        if constexpr (scenarioNum == 2) {
            // mmad默认m轴向16对齐，但是由于A转置过程m轴向2 * 16对齐，填充了一个全部由无效数据的16 * 32的分形，
            // 如果仍然设置mmadParams.m = m，cube单元会多读入无效数据的分形同时有效数据的分形也未被读入，
            // 此时可以通过设置m向32对齐，让此分形参与计算，搬出时跳过无效分形参与计算的得到的分形即可。
            mmadParams.m = CeilAlign(m, fractalShape[0] * fractalNum);
        } else {
            mmadParams.m = m;
        }
        mmadParams.n = n;
        mmadParams.k = k;
        AscendC::Mmad(c1Local, a2Local, b2Local, mmadParams);
        AscendC::SetFlag<AscendC::HardEvent::M_FIX>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::M_FIX>(EVENT_ID0);
        // 4. L0C -> GM
        AscendC::FixpipeParamsArch3510<AscendC::CO2Layout::ROW_MAJOR> fixpipeParams;
        // 输出矩阵在n方向上的大小
        fixpipeParams.nSize = n;
        // 输出矩阵在m方向上的大小
        fixpipeParams.mSize = m;
        if constexpr (scenarioNum == 2) {
            fixpipeParams.srcStride = CeilAlign(m, fractalShape[0] * fractalNum);
        } else {
            fixpipeParams.srcStride = CeilAlign(m, fractalShape[0]);
        }
        fixpipeParams.dstStride = n;
        AscendC::Fixpipe<U, U, AscendC::CFG_ROW_MAJOR>(cGM, c1Local, fixpipeParams);
    }

private:
    __aicore__ inline uint16_t CeilDivision(uint16_t numerator, uint16_t denominator)
    {
        return (numerator + denominator - 1) / denominator;
    }

    __aicore__ inline uint16_t CeilAlign(uint16_t numerator, uint16_t denominator)
    {
        return (numerator + denominator - 1) / denominator * denominator;
    }

    __aicore__ inline void CopyInA1(AscendC::LocalTensor<T> a1Local)
    {
        AscendC::Nd2NzParams nd2nzA1Params;
        if constexpr (!isAtranspose) {
            nd2nzA1Params.ndNum = 1;
            nd2nzA1Params.nValue = m;
            nd2nzA1Params.dValue = k;
            nd2nzA1Params.srcNdMatrixStride = 0;
            nd2nzA1Params.srcDValue = k;
            nd2nzA1Params.dstNzC0Stride = mAlignL1;
            nd2nzA1Params.dstNzNStride = 1;
            nd2nzA1Params.dstNzMatrixStride = 0;
        } else {
            nd2nzA1Params.ndNum = 1;
            nd2nzA1Params.nValue = k;
            nd2nzA1Params.dValue = m;
            nd2nzA1Params.srcNdMatrixStride = 0;
            nd2nzA1Params.srcDValue = m;
            nd2nzA1Params.dstNzC0Stride = kaAlignL1;
            nd2nzA1Params.dstNzNStride = 1;
            nd2nzA1Params.dstNzMatrixStride = 0;
        }
        AscendC::DataCopy(a1Local, aGM, nd2nzA1Params);
    }

    __aicore__ inline void CopyInB1(AscendC::LocalTensor<T> b1Local)
    {
        AscendC::Nd2NzParams nd2nzB1Params;
        if constexpr (!isBtranspose) {
            nd2nzB1Params.ndNum = 1;
            nd2nzB1Params.nValue = k;
            nd2nzB1Params.dValue = n;
            nd2nzB1Params.srcNdMatrixStride = 0;
            nd2nzB1Params.srcDValue = n;
            nd2nzB1Params.dstNzC0Stride = kbAlignL1;
            nd2nzB1Params.dstNzNStride = 1;
            nd2nzB1Params.dstNzMatrixStride = 0;
        } else {
            nd2nzB1Params.ndNum = 1;
            nd2nzB1Params.nValue = n;
            nd2nzB1Params.dValue = k;
            nd2nzB1Params.srcNdMatrixStride = 0;
            nd2nzB1Params.srcDValue = k;
            nd2nzB1Params.dstNzC0Stride = nAlignL1;
            nd2nzB1Params.dstNzNStride = 1;
            nd2nzB1Params.dstNzMatrixStride = 0;
        }
        AscendC::DataCopy(b1Local, bGM, nd2nzB1Params);
    }

    __aicore__ inline void SplitA(AscendC::LocalTensor<T> a1Local, AscendC::LocalTensor<T> a2Local)
    {
        AscendC::LoadData2DParamsV2 loadDataParams;
        loadDataParams.sid = 0;
        loadDataParams.mStartPosition = 0;
        loadDataParams.kStartPosition = 0;
        if constexpr (scenarioNum == 7) {
            // 输入为int8类型，A矩阵[k,m]转置输入，L1->L0A需要转置
            // for循环调用Load2DV2，以m轴方向做for循环，每次循环在L1的m方向搬运2个分形，在L0A上跳过m方向尾脏数据分形，m方向多搬运数据不超过1个分形
            uint16_t L0ALoopNum = CeilDivision(kaAlignL0, fractalShape[0] * fractalNum);
            loadDataParams.mStep = INT8_M_STEP_ALIGN;
            loadDataParams.kStep = CeilDivision(mAlignL0, fractalShape[1]);
            loadDataParams.srcStride = CeilDivision(kaAlignL1, fractalShape[0]);
            loadDataParams.dstStride = CeilDivision(mAlignL0, fractalShape[0]);
            loadDataParams.ifTranspose = true;
            uint32_t dstOffset = 0;
            for (uint16_t loopIdx = 0; loopIdx < L0ALoopNum; ++loopIdx) {
                loadDataParams.mStartPosition = INT8_M_STEP_ALIGN * loopIdx;
                AscendC::LoadData(a2Local[dstOffset], a1Local, loadDataParams);
                dstOffset += CeilAlign(mAlignL0, fractalShape[0]) * fractalShape[1];
            }
        } else {
            // 调用一次Load2DV2完成L1->L0A的搬运
            if constexpr (!isAtranspose){
                loadDataParams.mStep = CeilDivision(mAlignL1, fractalShape[0]);
                loadDataParams.kStep = CeilDivision(kaAlignL1, fractalShape[1]);
                loadDataParams.srcStride = CeilDivision(mAlignL1, fractalShape[0]);
                loadDataParams.dstStride = CeilDivision(mAlignL0, fractalShape[0]);
                loadDataParams.ifTranspose = false;
            } else {
                loadDataParams.mStep = CeilDivision(kaAlignL1, fractalShape[0]);
                loadDataParams.kStep = CeilDivision(mAlignL1, fractalShape[1]);
                loadDataParams.srcStride = CeilDivision(kaAlignL1, fractalShape[0]);
                loadDataParams.dstStride = CeilDivision(mAlignL0, fractalShape[0]);
                loadDataParams.ifTranspose = true;
            }
            AscendC::LoadData(a2Local, a1Local, loadDataParams);
        }
    }

    __aicore__ inline void SplitB(AscendC::LocalTensor<T> b1Local, AscendC::LocalTensor<T> b2Local)
    {
        AscendC::LoadData2DParamsV2 loadDataParams;
        loadDataParams.mStartPosition = 0;
        loadDataParams.kStartPosition = 0;
        loadDataParams.sid = 0;
        // 调用一次Load2DV2完成L1->L0B的搬运
        if constexpr (isBtranspose) {
            loadDataParams.mStep = CeilDivision(nAlignL1, fractalShape[0]);
            loadDataParams.kStep = CeilDivision(kbAlignL1, fractalShape[1]);
            loadDataParams.srcStride = CeilDivision(nAlignL1, fractalShape[0]);
            loadDataParams.dstStride = CeilDivision(nAlignL0, fractalShape[0]);
            loadDataParams.ifTranspose = false;
        } else {
            loadDataParams.mStep = CeilDivision(kbAlignL1, fractalShape[0]);
            loadDataParams.kStep = CeilDivision(nAlignL1, fractalShape[1]);
            loadDataParams.srcStride = CeilDivision(kbAlignL1, fractalShape[0]);
            loadDataParams.dstStride = CeilDivision(nAlignL0, fractalShape[0]);
            loadDataParams.ifTranspose = true;
        }

        AscendC::LoadData(b2Local, b1Local, loadDataParams);
    }

private:
    AscendC::GlobalTensor<T> aGM;
    AscendC::GlobalTensor<T> bGM;
    AscendC::GlobalTensor<U> cGM;

    static constexpr uint32_t a1Addr = 0;
    static constexpr uint32_t a2Addr = 0;
    static constexpr uint32_t b1Addr = 128 * 1024;
    static constexpr uint32_t b2Addr = 0;
    static constexpr uint32_t co1Addr = 0;

    uint32_t mAlignL1 = m, kaAlignL1 = k, kbAlignL1 = k, nAlignL1 = n;
    uint32_t mAlignL0 = m, kaAlignL0 = k, kbAlignL0 = k, nAlignL0 = n;

    uint32_t aSizeAlignL1, bSizeAlignL1;
    uint32_t aSizeAlignL0, bSizeAlignL0, cSizeAlignL0;
    uint32_t fractalShape[2] = {0, 0};
    uint32_t fractalNum = 0;
};

template<typename KernelType>
__aicore__ inline void RunKernel(GM_ADDR a, GM_ADDR b, GM_ADDR c)
{
    AscendC::InitSocState();
    KernelType op;
    op.Init(a, b, c);
    op.Process();
    AscendC::PipeBarrier<PIPE_ALL>();
}

template <uint32_t m, uint32_t n, uint32_t k>
__global__ __cube__ void KernelLoadDataL12L0Load2Dv2(GM_ADDR a, GM_ADDR b, GM_ADDR c)
{
    if constexpr (scenarioNum == 1) {
        RunKernel<KernelMmad<int8_t, int32_t, m, n, k, false, true>>(a, b, c);
    } else if constexpr (scenarioNum == 2 || scenarioNum == 7) {
        RunKernel<KernelMmad<int8_t, int32_t, m, n, k, true, false>>(a, b, c);
    } else if constexpr (scenarioNum == 3) {
        RunKernel<KernelMmad<half, float, m, n, k, false, true>>(a, b, c);
    } else if constexpr (scenarioNum == 4) {
        RunKernel<KernelMmad<half, float, m, n, k, true, false>>(a, b, c);
    } else if constexpr (scenarioNum == 5) {
        RunKernel<KernelMmad<float, float, m, n, k, false, true>>(a, b, c);
    } else if constexpr (scenarioNum == 6) {
        RunKernel<KernelMmad<float, float, m, n, k, true, false>>(a, b, c);
    }
}

int32_t main(int32_t argc, char *argv[])
{
    constexpr uint32_t m = 40;
    constexpr uint32_t n = 50;
    constexpr uint32_t k = 70;

    size_t aFileSize = 0;
    size_t bFileSize = 0;
    size_t cFileSize = 0;

    if constexpr (scenarioNum <= 2 || scenarioNum == 7) {
        aFileSize = m * k * sizeof(int8_t);
        bFileSize = n * k * sizeof(int8_t);
        cFileSize = m * n * sizeof(int32_t);
    } else if constexpr (scenarioNum <= 4) {
        aFileSize = m * k * sizeof(half);
        bFileSize = n * k * sizeof(half);
        cFileSize = m * n * sizeof(float);
    } else {
        aFileSize = m * k * sizeof(float);
        bFileSize = n * k * sizeof(float);
        cFileSize = m * n * sizeof(float);
    }
    uint32_t numBlocks = 1;

    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t *aHost;
    uint8_t *aDevice;
    aclrtMallocHost((void **)(&aHost), aFileSize);
    aclrtMalloc((void **)&aDevice, aFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/x1_gm.bin", aFileSize, aHost, aFileSize);
    aclrtMemcpy(aDevice, aFileSize, aHost, aFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t *bHost;
    uint8_t *bDevice;
    aclrtMallocHost((void **)(&bHost), bFileSize);
    aclrtMalloc((void **)&bDevice, bFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/x2_gm.bin", bFileSize, bHost, bFileSize);
    aclrtMemcpy(bDevice, bFileSize, bHost, bFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t *cHost;
    uint8_t *cDevice;
    aclrtMallocHost((void **)(&cHost), cFileSize);
    aclrtMalloc((void **)&cDevice, cFileSize, ACL_MEM_MALLOC_HUGE_FIRST);

    KernelLoadDataL12L0Load2Dv2<m, n, k><<<numBlocks, nullptr, stream>>>(aDevice, bDevice, cDevice);
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(cHost, cFileSize, cDevice, cFileSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", cHost, cFileSize);

    aclrtFree(aDevice);
    aclrtFreeHost(aHost);
    aclrtFree(bDevice);
    aclrtFreeHost(bHost);
    aclrtFree(cDevice);
    aclrtFreeHost(cHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();
    return 0;
}