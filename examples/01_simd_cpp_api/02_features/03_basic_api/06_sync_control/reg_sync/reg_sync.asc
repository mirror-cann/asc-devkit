#include "acl/acl.h"
#include "kernel_operator.h"
#include "data_utils.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

constexpr uint32_t scenarioNum = SCENARIO_NUM;

#if SCENARIO_NUM == 1

template <typename T>
__simd_vf__ inline void RegSyncVf(__ubuf__ T* dataAddr,
                                    uint16_t oneRepeatSize, uint32_t repeatTimes, uint32_t count)
{
    AscendC::Reg::RegTensor<T> reg0;
    AscendC::Reg::MaskReg mask;
    for (uint16_t i = 0; i < repeatTimes; i++) {
        mask = AscendC::Reg::UpdateMask<T>(count);
        AscendC::Reg::LoadAlign(reg0, dataAddr + i * oneRepeatSize);
        AscendC::Reg::Exp(reg0, reg0, mask);
        AscendC::Reg::StoreAlign(dataAddr + i * oneRepeatSize, reg0, mask);
    }
}

template <typename T>
class Kernel {
public:
    __aicore__ inline void Init(__gm__ uint8_t* x, __gm__ uint8_t* z, uint32_t count)
    {
        this->count = count;
        this->xGm.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(x));
        this->zGm.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(z));
    }
    __aicore__ inline void Process()
    {
        AscendC::LocalMemAllocator<AscendC::Hardware::UB> ubAllocator;
        AscendC::LocalTensor<T> xLocal = ubAllocator.Alloc<T>(count);
        AscendC::LocalTensor<T> zLocal = ubAllocator.Alloc<T>(count);

        AscendC::DataCopy(xLocal, xGm, count);
        AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);

        __ubuf__ T* dataAddr = reinterpret_cast<__ubuf__ T*>(xLocal.GetPhyAddr());
        __ubuf__ T* dstAddr = reinterpret_cast<__ubuf__ T*>(zLocal.GetPhyAddr());
        constexpr uint32_t oneRepeatSize = AscendC::GetVecLen() / sizeof(T);
        uint16_t repeatTimes = AscendC::CeilDivision(count, oneRepeatSize);

        asc_vf_call<RegSyncVf<T>>(dataAddr, oneRepeatSize, repeatTimes, count);

        AscendC::DataCopy(zLocal, xLocal, count);
        AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        AscendC::DataCopy(zGm, zLocal, count);
    }

private:
    uint32_t count;
    AscendC::GlobalTensor<T> xGm, zGm;
};

__global__ __vector__ void reg_sync(__gm__ uint8_t* x, __gm__ uint8_t* z)
{
    AscendC::InitSocState();
    Kernel<float> kernel;
    kernel.Init(x, z, 1024);
    kernel.Process();
    AscendC::PipeBarrier<PIPE_ALL>();
}

#elif SCENARIO_NUM == 2

template <typename T>
__simd_vf__ inline void UbSyncVf(__ubuf__ T* xAddr, __ubuf__ T* tmpBuf,
                                   __ubuf__ T* sumAddr, uint32_t count)
{
    AscendC::Reg::RegTensor<T> reg0, reg1, reg2, sumReg;
    AscendC::Reg::MaskReg mask = AscendC::Reg::UpdateMask<T>(count);
    AscendC::Reg::MaskReg maskOne = AscendC::Reg::CreateMask<uint32_t, AscendC::Reg::MaskPattern::VL1>();

    AscendC::Reg::LoadAlign(reg0, xAddr);
    AscendC::Reg::Abs(reg1, reg0, mask);
    AscendC::Reg::StoreAlign(tmpBuf, reg1, mask);
    AscendC::Reg::LocalMemBar<AscendC::Reg::MemType::VEC_STORE,
                               AscendC::Reg::MemType::VEC_LOAD>();
    AscendC::Reg::LoadAlign(reg2, tmpBuf);
    AscendC::Reg::Duplicate(sumReg, (T)0);
    AscendC::Reg::Add(sumReg, sumReg, reg2, mask);
    AscendC::Reg::ReduceSum(sumReg, sumReg, mask);
    AscendC::Reg::StoreAlign<T, AscendC::Reg::StoreDist::DIST_FIRST_ELEMENT_B32>(sumAddr, sumReg, maskOne);
}

template <typename T>
class Kernel {
public:
    __aicore__ inline void Init(__gm__ uint8_t* x, __gm__ uint8_t* sum, uint32_t count)
    {
        this->count = count;
        this->xGm.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(x));
        this->sumGm.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(sum));
    }
    __aicore__ inline void Process()
    {
        AscendC::LocalMemAllocator<AscendC::Hardware::UB> ubAllocator;
        AscendC::LocalTensor<T> xLocal = ubAllocator.Alloc<T>(count);
        AscendC::LocalTensor<T> tmpBufLocal = ubAllocator.Alloc<T>(count);
        AscendC::LocalTensor<T> sumLocal = ubAllocator.Alloc<T, 8>();

        AscendC::DataCopy(xLocal, xGm, count);
        AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);

        __ubuf__ T* xAddr = reinterpret_cast<__ubuf__ T*>(xLocal.GetPhyAddr());
        __ubuf__ T* tmpBufAddr = reinterpret_cast<__ubuf__ T*>(tmpBufLocal.GetPhyAddr());
        __ubuf__ T* sumAddr = reinterpret_cast<__ubuf__ T*>(sumLocal.GetPhyAddr());

        asc_vf_call<UbSyncVf<T>>(xAddr, tmpBufAddr, sumAddr, count);

        AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        AscendC::DataCopy(sumGm, sumLocal, 8);
    }

private:
    uint32_t count;
    AscendC::GlobalTensor<T> xGm, sumGm;
};

__global__ __vector__ void reg_sync(__gm__ uint8_t* x, __gm__ uint8_t* sum)
{
    AscendC::InitSocState();
    Kernel<float> kernel;
    kernel.Init(x, sum, 8);
    kernel.Process();
    AscendC::PipeBarrier<PIPE_ALL>();
}

#endif

static bool CompareResult(const void* outputData, uint32_t outSize)
{
    void* goldenData;
    aclrtMallocHost((void**)(&goldenData), outSize);
    size_t goldenSize = outSize;

    bool ret = ReadFile("./output/golden.bin", goldenSize, goldenData, goldenSize);
    if (ret) {
        printf("ReadFile golden.bin success!\n");
    } else {
        printf("test failed!\n");
        aclrtFreeHost(goldenData);
        return false;
    }

    constexpr float EPS = 1e-4;
    int64_t wrongNum = 0;

    for (size_t i = 0; i < outSize / sizeof(float); i++) {
        float a = (reinterpret_cast<const float*>(outputData))[i];
        float b = (reinterpret_cast<const float*>(goldenData))[i];
        float ae = std::abs(a - b);
        float re = ae / std::abs(b + EPS);
        if (ae > EPS && re > EPS) {
            printf("CompareResult golden.bin failed output is %lf, golden is %lf\n", a, b);
            wrongNum++;
        }
    }

    aclrtFreeHost(goldenData);
    if (wrongNum != 0) {
        return false;
    } else {
        printf("CompareResult golden.bin success!\n");
        return true;
    }
}

int32_t main(int32_t argc, char* argv[])
{
    uint32_t numBlocks = 1;
    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);
    uint32_t count = 1024;
#if SCENARIO_NUM == 2
    count = 8;
#endif
#if SCENARIO_NUM == 1
    size_t inputByteSize = static_cast<size_t>(1) * count * sizeof(float);
    size_t outputByteSize = static_cast<size_t>(1) * count * sizeof(float);
    uint8_t *xHost, *zHost;
    uint8_t *xDevice, *zDevice;
    aclrtMallocHost((void**)(&xHost), inputByteSize);
    aclrtMallocHost((void**)(&zHost), outputByteSize);
    aclrtMalloc((void**)&xDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&zDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/input_x.bin", inputByteSize, xHost, inputByteSize);
    aclrtMemcpy(xDevice, inputByteSize, xHost, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
    reg_sync<<<numBlocks, nullptr, stream>>>(xDevice, zDevice);
    aclrtSynchronizeStream(stream);
    aclrtMemcpy(zHost, outputByteSize, zDevice, outputByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", zHost, outputByteSize);
    bool goldenResult = CompareResult(zHost, outputByteSize);
    if (goldenResult) {
        printf("test pass!\n");
    } else {
        printf("test failed!\n");
    }
    aclrtFree(xDevice);
    aclrtFree(zDevice);
    aclrtFreeHost(xHost);
    aclrtFreeHost(zHost);
#elif SCENARIO_NUM == 2
    size_t inputByteSize = static_cast<size_t>(count) * sizeof(float);
    size_t outputByteSize = static_cast<size_t>(8) * sizeof(float);
    uint8_t *xHost, *sumHost;
    uint8_t *xDevice, *sumDevice;
    aclrtMallocHost((void**)(&xHost), inputByteSize);
    aclrtMallocHost((void**)(&sumHost), outputByteSize);
    aclrtMalloc((void**)&xDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&sumDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/input_x.bin", inputByteSize, xHost, inputByteSize);
    aclrtMemcpy(xDevice, inputByteSize, xHost, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
    reg_sync<<<numBlocks, nullptr, stream>>>(xDevice, sumDevice);
    aclrtSynchronizeStream(stream);
    aclrtMemcpy(sumHost, outputByteSize, sumDevice, outputByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", sumHost, outputByteSize);
    bool goldenResult = CompareResult(sumHost, outputByteSize);
    if (goldenResult) {
        printf("test pass!\n");
    } else {
        printf("test failed!\n");
    }
    aclrtFree(xDevice);
    aclrtFree(sumDevice);
    aclrtFreeHost(xHost);
    aclrtFreeHost(sumHost);
#endif
    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();
    return 0;
}
