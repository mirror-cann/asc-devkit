/* !
 * \file element_wise_logic.asc
 * \brief 基于And、Ors、ShiftLeft、ShiftRight实现按位逻辑运算
 */

#include "acl/acl.h"
#include "data_utils.h"
#include "kernel_operator.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

constexpr size_t COUNT = 512;
constexpr uint16_t SHIFT_BITS = 2;

class KernelLogic {
public:
    __aicore__ inline KernelLogic() {}
    __aicore__ inline void Init(__gm__ uint8_t* src0, __gm__ uint8_t* src1, __gm__ uint8_t* dst)
    {
        src0Global.SetGlobalBuffer(reinterpret_cast<__gm__ uint16_t*>(src0));
        src1Global.SetGlobalBuffer(reinterpret_cast<__gm__ uint16_t*>(src1));
        dstGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ uint16_t*>(dst));
    }
    __aicore__ inline void Process()
    {
        // 使用静态Tensor分配UB内存
        AscendC::LocalMemAllocator<AscendC::Hardware::UB> ubAllocator;
        AscendC::LocalTensor<uint16_t> src0Local = ubAllocator.Alloc<uint16_t, COUNT>();
        AscendC::LocalTensor<uint16_t> src1Local = ubAllocator.Alloc<uint16_t, COUNT>();
        AscendC::LocalTensor<uint16_t> dstLocal = ubAllocator.Alloc<uint16_t, COUNT>();
        
        AscendC::DataCopy(src0Local, src0Global, COUNT);
        AscendC::DataCopy(src1Local, src1Global, COUNT);

        // MTE2->V同步：确保GM数据搬运到UB后，才能开始计算
        AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
        
        Compute(src0Local, src1Local, dstLocal);
        // V->MTE3同步：确保计算完成后，才能将数据搬运到GM
        AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        
        AscendC::DataCopy(dstGlobal, dstLocal, COUNT);
    }

private:
    __aicore__ inline void Compute(AscendC::LocalTensor<uint16_t>& src0Local, AscendC::LocalTensor<uint16_t>& src1Local, AscendC::LocalTensor<uint16_t>& dstLocal)
    {
        if constexpr (SCENARIO_NUM == 1) {
            // 场景1：两个源操作数进行按位与运算
            AscendC::And(dstLocal, src0Local, src1Local, COUNT);
        }
#if defined(__NPU_ARCH__) && (__NPU_ARCH__ == 3510)
        else if constexpr (SCENARIO_NUM == 2) {
            // 场景2：矢量内每个元素和标量间做或操作（仅支持Ascend 950PR/Ascend 950DT）
            static constexpr AscendC::BinaryConfig config = { 0 };
            AscendC::Ors<AscendC::BinaryDefaultType, true, config>(dstLocal, src0Local[0], src1Local, COUNT);
        } else if constexpr (SCENARIO_NUM == 3) {
            // 场景3：tensor形式左移操作（仅支持Ascend 950PR/Ascend 950DT）
            AscendC::LocalTensor<int16_t> src1S16 = src1Local.ReinterpretCast<int16_t>();
            AscendC::ShiftLeft(dstLocal, src0Local, src1S16, COUNT);
        }
#endif
        else if constexpr (SCENARIO_NUM == 4) {
            // 场景4：scalar形式右移操作
            AscendC::ShiftRight(dstLocal, src0Local, SHIFT_BITS, COUNT);
        }
    }
private:
    AscendC::GlobalTensor<uint16_t> src0Global, src1Global, dstGlobal;
};

__global__ __vector__ void logic_custom(__gm__ uint8_t* src0, __gm__ uint8_t* src1, __gm__ uint8_t* dst)
{
    AscendC::InitSocState();
    KernelLogic op;
    op.Init(src0, src1, dst);
    op.Process();
    // kernel结束前必须调用PipeBarrier
    AscendC::PipeBarrier<PIPE_ALL>();
}

int32_t main(int32_t argc, char* argv[])
{
    constexpr size_t numBlocks = 1;
    size_t inputByteSize = COUNT * sizeof(uint16_t);
    size_t outputByteSize = COUNT * sizeof(uint16_t);

    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t *src0Host, *src1Host, *dstHost;
    uint8_t *src0Device, *src1Device, *dstDevice;

    aclrtMallocHost((void**)(&src0Host), inputByteSize);
    aclrtMallocHost((void**)(&src1Host), inputByteSize);
    aclrtMallocHost((void**)(&dstHost), outputByteSize);
    aclrtMalloc((void**)&src0Device, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&src1Device, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&dstDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);

    ReadFile("./input/input_src0.bin", inputByteSize, src0Host, inputByteSize);
    ReadFile("./input/input_src1.bin", inputByteSize, src1Host, inputByteSize);

    aclrtMemcpy(src0Device, inputByteSize, src0Host, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(src1Device, inputByteSize, src1Host, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);

    logic_custom<<<numBlocks, nullptr, stream>>>(src0Device, src1Device, dstDevice);
    
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(dstHost, outputByteSize, dstDevice, outputByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", dstHost, outputByteSize);

    aclrtFree(src0Device);
    aclrtFree(src1Device);
    aclrtFree(dstDevice);
    aclrtFreeHost(src0Host);
    aclrtFreeHost(src1Host);
    aclrtFreeHost(dstHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();

    return 0;
}
