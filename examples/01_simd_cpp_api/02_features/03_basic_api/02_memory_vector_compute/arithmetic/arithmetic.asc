/* !
 * \file arithmetic.asc
 * \brief Arithmetic类样例实现，演示基础算术类接口LeakyRelu的使用方法
 */

#include "acl/acl.h"
#include "data_utils.h"
#include "kernel_operator.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

template <uint32_t count, uint32_t mask>
class KernelLeakyRelu {
public:
    __aicore__ inline KernelLeakyRelu() {}
    __aicore__ inline void Init(__gm__ uint8_t* src, __gm__ uint8_t* dstGm)
    {
        srcGlobal.SetGlobalBuffer((__gm__ half*)src);
        dstGlobal.SetGlobalBuffer((__gm__ half*)dstGm);
    }
    __aicore__ inline void Process()
    {
        AscendC::LocalMemAllocator<AscendC::Hardware::UB> ubAllocator;
        AscendC::LocalTensor<half> srcLocal = ubAllocator.Alloc<half, count>();
        AscendC::LocalTensor<half> dstLocal = ubAllocator.Alloc<half, count>();

        AscendC::DataCopy(srcLocal, srcGlobal, count);
        AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);

        half scalar = 0.01;
        AscendC::LeakyRelu(dstLocal, srcLocal, scalar, mask, 4, {1, 1, 8, 8});

        AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        AscendC::DataCopy(dstGlobal, dstLocal, count);
    }

private:
    AscendC::GlobalTensor<half> srcGlobal, dstGlobal;
};

template <uint32_t count, uint32_t mask>
__global__ __vector__ void arithmetic_kernel(__gm__ uint8_t* src, __gm__ uint8_t* dstGm)
{
    AscendC::InitSocState();
    KernelLeakyRelu<count, mask> op;
    op.Init(src, dstGm);
    op.Process();
    AscendC::PipeBarrier<PIPE_ALL>();
}

int32_t main(int32_t argc, char* argv[])
{
    constexpr uint32_t count = 512;
    constexpr uint32_t mask = 128;

    uint32_t numBlocks = 1;
    size_t inputByteSize = 4 * 128 * sizeof(uint16_t);
    size_t outputByteSize = 4 * 128 * sizeof(uint16_t);

    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t *xHost, *outHost;
    uint8_t *xDevice, *outDevice;

    aclrtMallocHost((void**)(&xHost), inputByteSize);
    aclrtMallocHost((void**)(&outHost), outputByteSize);
    aclrtMalloc((void**)&xDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&outDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);

    ReadFile("./input/input_x.bin", inputByteSize, xHost, inputByteSize);

    aclrtMemcpy(xDevice, inputByteSize, xHost, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);

    arithmetic_kernel<count, mask><<<numBlocks, nullptr, stream>>>(xDevice, outDevice);
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(outHost, outputByteSize, outDevice, outputByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", outHost, outputByteSize);

    aclrtFree(xDevice);
    aclrtFree(outDevice);
    aclrtFreeHost(xHost);
    aclrtFreeHost(outHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();

    return 0;
}