/* !
 * \file cast.asc
 * \brief Cast样例实现，支持half到int32_t和half到int4b_t两种数据类型转换场景
 */

#include "acl/acl.h"
#include "data_utils.h"
#include "kernel_operator.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

constexpr uint32_t scenarioNum = SCENARIO_NUM;

template <typename T, typename U, int32_t blockLength, int32_t tileLength, uint64_t mask>
class KernelCast {
public:
    __aicore__ inline KernelCast() {}

    __aicore__ inline void Init(__gm__ uint8_t* x, __gm__ uint8_t* y)
    {
        xGm.SetGlobalBuffer((__gm__ T*)x + blockLength * AscendC::GetBlockIdx(), blockLength);

        if constexpr (AscendC::IsSameType<U, AscendC::int4b_t>::value) {
            yGm.SetGlobalBuffer((__gm__ int8_t*)y + blockLength * AscendC::GetBlockIdx() / 2, blockLength / 2);
        } else {
            yGm.SetGlobalBuffer((__gm__ U*)y + blockLength * AscendC::GetBlockIdx(), blockLength);
        }
    }

    __aicore__ inline void Process()
    {
        AscendC::LocalMemAllocator<AscendC::Hardware::UB> ubAllocator;
        AscendC::LocalTensor<T> xLocal = ubAllocator.Alloc<T, tileLength>();

        if constexpr (AscendC::IsSameType<U, AscendC::int4b_t>::value) {
            AscendC::LocalTensor<int8_t> yLocal = ubAllocator.Alloc<int8_t, tileLength / 2>();

            AscendC::DataCopy(xLocal, xGm, tileLength);
            AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
            AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);

            AscendC::LocalTensor<AscendC::int4b_t> yLocalTmp = yLocal.template ReinterpretCast<AscendC::int4b_t>();
            AscendC::Cast<AscendC::int4b_t, T>(yLocalTmp, xLocal, AscendC::RoundMode::CAST_CEIL, mask, 4, {1, 1, 2, 8});
            AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
            AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);

            AscendC::DataCopy(yGm, yLocal, tileLength / 2);
        } else {
            AscendC::LocalTensor<U> yLocal = ubAllocator.Alloc<U, tileLength>();

            AscendC::DataCopy(xLocal, xGm, tileLength);
            AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
            AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);

            AscendC::Cast(yLocal, xLocal, AscendC::RoundMode::CAST_CEIL, tileLength);
            AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
            AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);

            AscendC::DataCopy(yGm, yLocal, tileLength);
        }
    }

private:
    AscendC::GlobalTensor<T> xGm;
    AscendC::GlobalTensor<
        typename AscendC::Conditional<AscendC::IsSameType<U, AscendC::int4b_t>::value, int8_t, U>::type>
        yGm;
};

template <int32_t blockLength, int32_t tileLength, uint64_t mask>
__global__ __vector__ void cast_custom(__gm__ uint8_t* x, __gm__ uint8_t* y)
{
    AscendC::InitSocState();

    if constexpr (scenarioNum == 0) {
        // 场景0：half转int4b_t
        KernelCast<half, AscendC::int4b_t, blockLength, tileLength, mask> op;
        op.Init(x, y);
        op.Process();
    } else if constexpr (scenarioNum == 1) {
        // 场景1：half转int32_t
        KernelCast<half, int32_t, blockLength, tileLength, mask> op;
        op.Init(x, y);
        op.Process();
    } else {
        AscendC::printf("scenarioNum %d is not supported!\n", scenarioNum);
    }

    AscendC::PipeBarrier<PIPE_ALL>();
}

int32_t main(int32_t argc, char* argv[])
{
    constexpr int32_t totalLength = 512;
    constexpr int32_t blockLength = totalLength;
    constexpr int32_t tileLength = blockLength;
    constexpr uint64_t mask = 128;

    uint32_t numBlocks = 1;
    size_t inputByteSize = totalLength * sizeof(half);
    size_t outputByteSize = 0;
    if constexpr (scenarioNum == 0) {
        outputByteSize = totalLength * sizeof(int8_t) / 2;
    } else if constexpr (scenarioNum == 1) {
        outputByteSize = totalLength * sizeof(int32_t);
    }

    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t *xHost, *yHost;
    uint8_t *xDevice, *yDevice;

    aclrtMallocHost((void**)(&xHost), inputByteSize);
    aclrtMallocHost((void**)(&yHost), outputByteSize);
    aclrtMalloc((void**)&xDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&yDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);

    ReadFile("./input/input_x.bin", inputByteSize, xHost, inputByteSize);
    aclrtMemcpy(xDevice, inputByteSize, xHost, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
    cast_custom<blockLength, tileLength, mask><<<numBlocks, nullptr, stream>>>(xDevice, yDevice);
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(yHost, outputByteSize, yDevice, outputByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", yHost, outputByteSize);

    aclrtFree(xDevice);
    aclrtFree(yDevice);
    aclrtFreeHost(xHost);
    aclrtFreeHost(yHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();

    return 0;
}