/* !
 * \file create_vec_index.asc
 * \brief 演示使用CreateVecIndex API创建指定起始值的向量索引，生成连续的整数序列
 */

#include "acl/acl.h"
#include "data_utils.h"
#include "kernel_operator.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

template <typename T, uint32_t count>
__global__ __vector__ void testCreateVecIndex(__gm__ uint8_t* dstGm)
{
    AscendC::InitSocState();
    AscendC::TPipe pipe;
    AscendC::GlobalTensor<T> dstGlobal;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> queOut;
    dstGlobal.SetGlobalBuffer((__gm__ T*)dstGm);
    pipe.InitBuffer(queOut, 1, count * sizeof(T));

    AscendC::LocalTensor<T> dstLocal = queOut.AllocTensor<T>();
    AscendC::Duplicate(dstLocal, (T)0, count);
    AscendC::PipeBarrier<PIPE_V>();
    AscendC::CreateVecIndex(dstLocal, (T)0, count);
    queOut.EnQue(dstLocal);

    AscendC::LocalTensor<T> dstLocalOut = queOut.DeQue<T>();
    AscendC::DataCopy(dstGlobal, dstLocalOut, count);
    queOut.FreeTensor(dstLocalOut);
    AscendC::PipeBarrier<PIPE_ALL>();
}

int32_t main(int32_t argc, char* argv[])
{
    constexpr uint32_t count = 128;
    uint32_t numBlocks = 8;
    size_t outputByteSize = count * sizeof(uint16_t);

    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t* outHost;
    uint8_t* outDevice;

    aclrtMallocHost((void**)(&outHost), outputByteSize);
    aclrtMalloc((void**)&outDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);

    testCreateVecIndex<int16_t, count><<<numBlocks, nullptr, stream>>>(outDevice);
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(outHost, outputByteSize, outDevice, outputByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", outHost, outputByteSize);

    aclrtFree(outDevice);
    aclrtFreeHost(outHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();

    return 0;
}
