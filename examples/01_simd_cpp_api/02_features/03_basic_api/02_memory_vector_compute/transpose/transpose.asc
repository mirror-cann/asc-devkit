/* !
 * \file transpose.asc
 * \brief 数据转置样例，支持普通转置、增强转置和5HD格式转换三种场景
 */

#include "acl/acl.h"
#include "data_utils.h"
#include "kernel_operator.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

constexpr uint32_t C0_SIZE = 16;

template <typename T, uint32_t INPUT_SIZE, uint32_t N, uint32_t C, uint32_t H, uint32_t W>
class KernelTranspose {
public:
    __aicore__ inline KernelTranspose() {}
    __aicore__ inline void Init(__gm__ uint8_t* src, __gm__ uint8_t* dstGm, AscendC::TPipe* pipeIn)
    {
        pipe = pipeIn;
        srcGlobal.SetGlobalBuffer((__gm__ T*)src);
        dstGlobal.SetGlobalBuffer((__gm__ T*)dstGm);
        pipe->InitBuffer(inQueueSrc, 1, INPUT_SIZE * sizeof(T));
        pipe->InitBuffer(outQueueDst, 1, INPUT_SIZE * sizeof(T));
        if constexpr (SCENARIO_NUM == 2) {
            // 场景2：增强转置，[N,C,H,W]转置为[N,H,W,C]
            // auto h0 = 16; // 当数据类型的位宽为8时，h0 = 32；其他情况下，h0 = 16
            // auto w0 = 32 / sizeof(type);  // type代表数据类型
            // auto tmpBufferSize = (cSize  * 2 + 1)  * h0 * w0 * sizeof(type);
            uint32_t tmpBufferSize = 1280;
            transposeType = AscendC::TransposeType::TRANSPOSE_NCHW2NHWC;
            pipe->InitBuffer(tmpQueue, 1, tmpBufferSize * sizeof(T));
        }
    }
    __aicore__ inline void Process()
    {
        AscendC::LocalTensor<T> srcLocal = inQueueSrc.AllocTensor<T>();
        AscendC::DataCopy(srcLocal, srcGlobal, INPUT_SIZE);
        inQueueSrc.EnQue(srcLocal);
        Compute();
        AscendC::LocalTensor<T> dstLocal = outQueueDst.DeQue<T>();
        AscendC::DataCopy(dstGlobal, dstLocal, INPUT_SIZE);
        outQueueDst.FreeTensor(dstLocal);
    }

private:
    __aicore__ inline void Compute()
    {
        AscendC::LocalTensor<T> srcLocal = inQueueSrc.DeQue<T>();
        AscendC::LocalTensor<T> dstLocal = outQueueDst.AllocTensor<T>();
        if constexpr (SCENARIO_NUM == 1) {
            // 场景1：普通转置，[16,16]二维矩阵转置
            AscendC::Transpose<T>(dstLocal, srcLocal);
        } else if constexpr (SCENARIO_NUM == 2) {
            // 场景2：增强转置，[N,C,H,W]转置为[N,H,W,C]
            AscendC::LocalTensor<uint8_t> stackBuffer = tmpQueue.AllocTensor<uint8_t>();
            AscendC::TransposeParamsExt transposeParams;
            transposeParams.nSize = N;
            transposeParams.cSize = C;
            transposeParams.hSize = H;
            transposeParams.wSize = W;
            transposeParams.transposeType = transposeType;
            AscendC::Transpose(dstLocal, srcLocal, stackBuffer, transposeParams);
            tmpQueue.FreeTensor(stackBuffer);
        } else if constexpr (SCENARIO_NUM == 3) {
            // 场景3：5HD格式转换，NCHW转换为NC1HWC0
            AscendC::TransDataTo5HDParams transDataParams;
            transDataParams.dstHighHalf = false;
            transDataParams.srcHighHalf = false;
            transDataParams.repeatTimes = 16; // 重复迭代次数，每次repeat处理16个DataBlock
            // repeatStride是指相邻迭代间相同datablock的地址步长
            transDataParams.dstRepStride = 16;
            transDataParams.srcRepStride = 1;
            for (int j = 0; j < 4; j++) {
                uint64_t dstLocalList[16];
                uint64_t srcLocalList[16];
                for (int i = 0; i < 16; i++) {
                    dstLocalList[i] = (uint64_t)(dstLocal[j * C0_SIZE * H * W + W * i].GetPhyAddr());
                    srcLocalList[i] = (uint64_t)(srcLocal[j * C0_SIZE * H * W + H * W * i].GetPhyAddr());
                }
                AscendC::TransDataTo5HD<T>(dstLocalList, srcLocalList, transDataParams);
            }
        }
        outQueueDst.EnQue<T>(dstLocal);
        inQueueSrc.FreeTensor(srcLocal);
    }

private:
    AscendC::TPipe* pipe;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> inQueueSrc;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> outQueueDst;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> tmpQueue;
    AscendC::GlobalTensor<T> srcGlobal, dstGlobal;
    AscendC::TransposeType transposeType;
};

template <uint32_t INPUT_SIZE, uint32_t N, uint32_t C, uint32_t H, uint32_t W>
__global__ __vector__ void transpose_custom(__gm__ uint8_t* x, __gm__ uint8_t* z)
{
    AscendC::TPipe pipe;
    KernelTranspose<half, INPUT_SIZE, N, C, H, W> op;
    op.Init(x, z, &pipe);
    op.Process();
}

int32_t main(int32_t argc, char* argv[])
{
    constexpr uint32_t NUM_BLOCKS = 1;

    size_t inputByteSize;
    if constexpr (SCENARIO_NUM == 1) {
        inputByteSize = 256 * sizeof(half);
    } else if constexpr (SCENARIO_NUM == 2) {
        inputByteSize = 144 * sizeof(uint16_t);
    } else if constexpr (SCENARIO_NUM == 3) {
        inputByteSize = 16384 * sizeof(uint16_t);
    }
    size_t outputByteSize = inputByteSize;

    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t *xHost, *zHost;
    uint8_t *xDevice, *zDevice;

    aclrtMallocHost((void**)(&xHost), inputByteSize);
    aclrtMallocHost((void**)(&zHost), outputByteSize);
    aclrtMalloc((void**)&xDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&zDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);

    ReadFile("./input/input_x.bin", inputByteSize, xHost, inputByteSize);

    aclrtMemcpy(xDevice, inputByteSize, xHost, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);

    if constexpr (SCENARIO_NUM == 1) {
        transpose_custom<256, 1, 1, 16, 16><<<NUM_BLOCKS, nullptr, stream>>>(xDevice, zDevice);
    } else if constexpr (SCENARIO_NUM == 2) {
        transpose_custom<144, 3, 3, 2, 8><<<NUM_BLOCKS, nullptr, stream>>>(xDevice, zDevice);
    } else if constexpr (SCENARIO_NUM == 3) {
        transpose_custom<16384, 2, 32, 16, 16><<<NUM_BLOCKS, nullptr, stream>>>(xDevice, zDevice);
    }

    aclrtSynchronizeStream(stream);

    aclrtMemcpy(zHost, outputByteSize, zDevice, outputByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", zHost, outputByteSize);

    aclrtFree(xDevice);
    aclrtFree(zDevice);
    aclrtFreeHost(xHost);
    aclrtFreeHost(zHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();

    return 0;
}
