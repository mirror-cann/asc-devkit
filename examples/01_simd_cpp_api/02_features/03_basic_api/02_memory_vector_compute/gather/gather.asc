/* !
 * \file gather.asc
 * \brief 基于GatherMask、Gather、Gatherb实现从源操作数中选取元素写入目的操作数，支持多种场景
 */

#include "acl/acl.h"
#include "data_utils.h"
#include "kernel_operator.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

template <typename T, size_t INPUT_SIZE, size_t INPUT_Y_SIZE, size_t OUTPUT_SIZE>
__global__ __vector__ void gather_custom(__gm__ uint8_t* x, __gm__ uint8_t* y, __gm__ uint8_t* z)
{
    AscendC::InitSocState();
    AscendC::GlobalTensor<T> src0Global;
    AscendC::GlobalTensor<T> dstGlobal;
    src0Global.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(x));
    dstGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(z));

    // 使用静态Tensor分配UB内存
    AscendC::LocalMemAllocator<AscendC::Hardware::UB> ubAllocator;
    AscendC::LocalTensor<T> src0Local = ubAllocator.Alloc<T, INPUT_SIZE>();

    AscendC::DataCopy(src0Local, src0Global, INPUT_SIZE);

    if constexpr (SCENARIO_NUM == 1) {
        AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);

        // 场景1：内置固定模式，dst与src0共用同一块UB
        uint64_t rsvdCnt = 0; // 用于保存筛选后保留下来的元素个数
        uint32_t mask = 0;       // normal模式下mask建议设置为0
        uint8_t src1Pattern = 2; // 内置固定模式，取值范围为[1,7]
        // reduceMode = false;   使用normal模式
        // src0BlockStride = 1;  单次迭代内数据间隔1个Block，即数据连续读取和写入
        // repeatTimes = 4;      重复迭代4次
        // src0RepeatStride = 8; 源操作数迭代间数据间隔8个datablock
        // src1RepeatStride = 0;
        AscendC::GatherMask(src0Local, src0Local, src1Pattern, false, mask, {1, 4, 8, 0}, rsvdCnt);

        AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        AscendC::DataCopy(dstGlobal, src0Local, OUTPUT_SIZE);
    } else {
        AscendC::GlobalTensor<uint32_t> src1Global;
        src1Global.SetGlobalBuffer(reinterpret_cast<__gm__ uint32_t*>(y));
        AscendC::LocalTensor<uint32_t> src1Local = ubAllocator.Alloc<uint32_t, INPUT_Y_SIZE>();
        AscendC::LocalTensor<T> dstLocal = ubAllocator.Alloc<T, OUTPUT_SIZE>();

        AscendC::DataCopy(src1Local, src1Global, INPUT_Y_SIZE);
        AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);

        uint64_t rsvdCnt = 0; // 用于保存筛选后保留下来的元素个数
        if constexpr (SCENARIO_NUM == 2) {
            // 场景2：用户自定义模式
            // 先将dstLocal置0，避免Counter模式未写入位置出现脏数据
            AscendC::Duplicate(dstLocal, static_cast<T>(0), OUTPUT_SIZE);
            uint32_t mask = 70;
            // reduceMode = true;    使用Counter模式
            // src0BlockStride = 1;  单次迭代内数据间隔1个datablock，即数据连续读取和写入
            // repeatTimes = 2;      Counter模式时，仅在部分产品型号下会生效
            // src0RepeatStride = 4; 源操作数迭代间数据间隔4个datablock
            // src1RepeatStride = 0; src1迭代间数据间隔0个datablock，即原位置读取
            AscendC::GatherMask(
                dstLocal, src0Local, src1Local.template ReinterpretCast<T>(), true, mask, {1, 2, 4, 0}, rsvdCnt);
        } else if constexpr (SCENARIO_NUM == 3) {
            // 场景3：张量偏移模式（按元素地址偏移）
            src0Local.SetSize(INPUT_Y_SIZE);
            AscendC::Gather(dstLocal, src0Local, src1Local, static_cast<uint32_t>(0), INPUT_Y_SIZE);
        } else if constexpr (SCENARIO_NUM == 4) {
            // 场景4：DataBlock偏移模式
            AscendC::GatherRepeatParams params{1, 8};
            uint8_t repeatTime = INPUT_SIZE * sizeof(T) / 256; // 重复迭代次数
            AscendC::Gatherb<T>(dstLocal, src0Local, src1Local, repeatTime, params);
        }

        AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        AscendC::DataCopy(dstGlobal, dstLocal, OUTPUT_SIZE);
    }
    AscendC::PipeBarrier<PIPE_ALL>();
}

int32_t main(int32_t argc, char* argv[])
{
    constexpr uint32_t NUM_BLOCKS = 1;

    size_t inputByteSize, inputYByteSize, outputByteSize;
    if constexpr (SCENARIO_NUM == 1 || SCENARIO_NUM == 2) {
        inputByteSize = 256 * sizeof(uint32_t);
        inputYByteSize = 32 * sizeof(uint32_t);
        outputByteSize = 256 * sizeof(uint32_t);
    } else if constexpr (SCENARIO_NUM == 3) {
        inputByteSize = 128 * sizeof(uint16_t);
        inputYByteSize = 128 * sizeof(uint32_t);
        outputByteSize = 128 * sizeof(uint16_t);
    } else if constexpr (SCENARIO_NUM == 4) {
        inputByteSize = 128 * sizeof(uint16_t);
        inputYByteSize = 8 * sizeof(uint32_t);
        outputByteSize = 128 * sizeof(uint16_t);
    }

    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t *xHost, *yHost, *zHost;
    uint8_t *xDevice, *yDevice, *zDevice;

    aclrtMallocHost((void**)(&xHost), inputByteSize);
    aclrtMallocHost((void**)(&zHost), outputByteSize);
    aclrtMalloc((void**)&xDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&zDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);

    ReadFile("./input/input_x.bin", inputByteSize, xHost, inputByteSize);

    aclrtMemcpy(xDevice, inputByteSize, xHost, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);

    if constexpr (SCENARIO_NUM == 1) {
        gather_custom<uint32_t, 256, 0, 256><<<NUM_BLOCKS, nullptr, stream>>>(xDevice, nullptr, zDevice);
    } else {
        aclrtMallocHost((void**)(&yHost), inputYByteSize);
        aclrtMalloc((void**)&yDevice, inputYByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
        ReadFile("./input/input_y.bin", inputYByteSize, yHost, inputYByteSize);
        aclrtMemcpy(yDevice, inputYByteSize, yHost, inputYByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
        if constexpr (SCENARIO_NUM == 2) {
            gather_custom<uint32_t, 256, 32, 256><<<NUM_BLOCKS, nullptr, stream>>>(xDevice, yDevice, zDevice);
        } else if constexpr (SCENARIO_NUM == 3) {
            gather_custom<uint16_t, 128, 128, 128><<<NUM_BLOCKS, nullptr, stream>>>(xDevice, yDevice, zDevice);
        } else if constexpr (SCENARIO_NUM == 4) {
            gather_custom<uint16_t, 128, 8, 128><<<NUM_BLOCKS, nullptr, stream>>>(xDevice, yDevice, zDevice);
        }
    }
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(zHost, outputByteSize, zDevice, outputByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", zHost, outputByteSize);

    aclrtFree(xDevice);
    aclrtFree(zDevice);
    aclrtFreeHost(xHost);
    aclrtFreeHost(zHost);

    if constexpr (SCENARIO_NUM == 2 || SCENARIO_NUM == 3 || SCENARIO_NUM == 4) {
        aclrtFree(yDevice);
        aclrtFreeHost(yHost);
    }

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();

    return 0;
}
