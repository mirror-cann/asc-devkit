/* !
 * \file select.asc
 * \brief 基于Select接口完成多种场景下的数据选择功能
 */

#include "acl/acl.h"
#include "data_utils.h"
#include "kernel_operator.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

template <typename T, typename U, uint32_t INPUT_SIZE, uint32_t INPUT_Y_SIZE, uint32_t INPUT_SEL_SIZE>
__global__ __vector__ void select_custom(__gm__ uint8_t* x, __gm__ uint8_t* y, __gm__ uint8_t* sel, __gm__ uint8_t* z)
{
    AscendC::InitSocState();
    AscendC::GlobalTensor<T> src0Global;
    AscendC::GlobalTensor<T> src1Global;
    AscendC::GlobalTensor<T> dstGlobal;
    AscendC::GlobalTensor<U> selMaskGlobal;
    src0Global.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(x));
    src1Global.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(y));
    selMaskGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ U*>(sel));
    dstGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(z));

    // 使用静态Tensor分配UB内存
    AscendC::LocalMemAllocator<AscendC::Hardware::UB> ubAllocator;
    AscendC::LocalTensor<T> src0Local = ubAllocator.Alloc<T, INPUT_SIZE>();
    AscendC::LocalTensor<T> src1Local = ubAllocator.Alloc<T, INPUT_Y_SIZE>();
    // 场景1的selMask仅有效8字节但DataCopyPad右补24字节，至少分配32字节避免越界
    constexpr uint32_t SEL_ALLOC_NUM = (SCENARIO_NUM == 1) ? 32 : INPUT_SEL_SIZE;
    AscendC::LocalTensor<U> selMaskLocal = ubAllocator.Alloc<U, SEL_ALLOC_NUM>();
    AscendC::LocalTensor<T> dstLocal = ubAllocator.Alloc<T, INPUT_SIZE>();

    AscendC::DataCopy(src0Local, src0Global, INPUT_SIZE);
    AscendC::DataCopy(src1Local, src1Global, INPUT_Y_SIZE);
    if constexpr (SCENARIO_NUM == 1) {
        AscendC::DataCopyExtParams copyParams{1, INPUT_SEL_SIZE * sizeof(U), 0, 0, 0};
        AscendC::DataCopyPadExtParams<U> padParams;
        padParams.isPad = false;
        padParams.leftPadding = 0;
        padParams.rightPadding = 24; // 右侧补充24字节
        AscendC::SetPadValue((uint8_t)0);
        AscendC::DataCopyPad(selMaskLocal, selMaskGlobal, copyParams, padParams); // 非对齐搬运
    } else {
        AscendC::DataCopy(selMaskLocal, selMaskGlobal, INPUT_SEL_SIZE);
    }
    AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
    AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);

    if constexpr (SCENARIO_NUM == 1 || SCENARIO_NUM == 3) {
        AscendC::SELMODE selMode =
            (SCENARIO_NUM == 1) ? AscendC::SELMODE::VSEL_CMPMASK_SPR : AscendC::SELMODE::VSEL_TENSOR_TENSOR_MODE;
        AscendC::Select(dstLocal, selMaskLocal, src0Local, src1Local, selMode, INPUT_SIZE);
    } else if constexpr (SCENARIO_NUM == 2) {
        // 场景2：tensor vs scalar，需要MTE2->S 与 S->V 同步
        AscendC::SetFlag<AscendC::HardEvent::MTE2_S>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_S>(EVENT_ID0);
        T src1Scalar = src1Local.GetValue(0);

        AscendC::SetFlag<AscendC::HardEvent::S_V>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::S_V>(EVENT_ID0);

        AscendC::Select(
            dstLocal, selMaskLocal, src0Local, src1Scalar, AscendC::SELMODE::VSEL_TENSOR_SCALAR_MODE, INPUT_SIZE);
    } else if constexpr (SCENARIO_NUM == 4) {
#if defined(__NPU_ARCH__) && (__NPU_ARCH__ == 3510)
        // 场景4：灵活标量位置，仅Ascend 950PR/Ascend 950DT产品支持
        static constexpr AscendC::BinaryConfig config = {1}; // 1表示标量在后，默认值；0表示标量在前
        AscendC::Select<AscendC::BinaryDefaultType, U, config>(
            dstLocal, selMaskLocal, src0Local, src1Local[0], AscendC::SELMODE::VSEL_TENSOR_SCALAR_MODE, INPUT_SIZE);
#endif
    }

    AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
    AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);

    AscendC::DataCopy(dstGlobal, dstLocal, INPUT_SIZE);
    AscendC::PipeBarrier<PIPE_ALL>();
}

int32_t main(int32_t argc, char* argv[])
{
    constexpr uint32_t NUM_BLOCKS = 1;

    size_t inputYByteSize, selByteSize;
    size_t inputByteSize = 256 * sizeof(float);
    size_t outputByteSize = inputByteSize;
    if constexpr (SCENARIO_NUM == 1) {
        inputYByteSize = 256 * sizeof(float);
        selByteSize = 8 * sizeof(uint8_t);
    } else if constexpr (SCENARIO_NUM == 2 || SCENARIO_NUM == 4) {
        inputYByteSize = 8 * sizeof(float);
        selByteSize = 32 * sizeof(uint8_t);
    } else if constexpr (SCENARIO_NUM == 3) {
        inputYByteSize = 256 * sizeof(float);
        selByteSize = 32 * sizeof(uint8_t);
    }

    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t *xHost, *yHost, *zHost, *selHost;
    uint8_t *xDevice, *yDevice, *zDevice, *selDevice;

    aclrtMallocHost((void**)(&xHost), inputByteSize);
    aclrtMallocHost((void**)(&yHost), inputYByteSize);
    aclrtMallocHost((void**)(&zHost), outputByteSize);
    aclrtMallocHost((void**)(&selHost), selByteSize);

    aclrtMalloc((void**)&xDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&yDevice, inputYByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&zDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&selDevice, selByteSize, ACL_MEM_MALLOC_HUGE_FIRST);

    ReadFile("./input/input_x.bin", inputByteSize, xHost, inputByteSize);
    ReadFile("./input/input_y.bin", inputYByteSize, yHost, inputYByteSize);
    ReadFile("./input/input_sel.bin", selByteSize, selHost, selByteSize);
    aclrtMemcpy(xDevice, inputByteSize, xHost, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(yDevice, inputYByteSize, yHost, inputYByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(selDevice, selByteSize, selHost, selByteSize, ACL_MEMCPY_HOST_TO_DEVICE);

    if constexpr (SCENARIO_NUM == 1) {
        select_custom<float, uint8_t, 256, 256, 8>
            <<<NUM_BLOCKS, nullptr, stream>>>(xDevice, yDevice, selDevice, zDevice);
    } else if constexpr (SCENARIO_NUM == 2 || SCENARIO_NUM == 4) {
        select_custom<float, uint8_t, 256, 8, 32>
            <<<NUM_BLOCKS, nullptr, stream>>>(xDevice, yDevice, selDevice, zDevice);
    } else if constexpr (SCENARIO_NUM == 3) {
        select_custom<float, uint8_t, 256, 256, 32>
            <<<NUM_BLOCKS, nullptr, stream>>>(xDevice, yDevice, selDevice, zDevice);
    }

    aclrtSynchronizeStream(stream);

    aclrtMemcpy(zHost, outputByteSize, zDevice, outputByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", zHost, outputByteSize);

    aclrtFree(xDevice);
    aclrtFree(yDevice);
    aclrtFree(zDevice);
    aclrtFree(selDevice);
    aclrtFreeHost(xHost);
    aclrtFreeHost(yHost);
    aclrtFreeHost(zHost);
    aclrtFreeHost(selHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();

    return 0;
}
