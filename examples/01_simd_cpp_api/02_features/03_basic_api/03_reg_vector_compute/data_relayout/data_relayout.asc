/* !
 * \file data_relayout.asc
 * \brief 演示使用Interleave和Pack接口实现数据重排功能
 *        - 场景1：使用Interleave接口（将两个向量交织）
 *        - 场景2：使用Pack接口（从uint32_t提取低16位到uint16_t）
 */

#include "acl/acl.h"
#include "kernel_operator.h"
#include "data_utils.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

constexpr uint32_t totalLength = 128;

#if SCENARIO_NUM == 1

template <typename T>
__simd_vf__ inline void InterleaveVF(__ubuf__ T* dst0Addr, __ubuf__ T* dst1Addr,
                                       __ubuf__ T* src0Addr, __ubuf__ T* src1Addr,
                                       uint32_t repeatTimes, uint32_t oneRepeatSize)
{
    AscendC::Reg::RegTensor<T> src0Reg, src1Reg, dst0Reg, dst1Reg;
    AscendC::Reg::MaskReg mask = AscendC::Reg::CreateMask<T, AscendC::Reg::MaskPattern::ALL>();

    for (uint16_t i = 0; i < repeatTimes; ++i) {
        AscendC::Reg::LoadAlign<T, AscendC::Reg::PostLiteral::POST_MODE_UPDATE>(src0Reg, src0Addr, oneRepeatSize);
        AscendC::Reg::LoadAlign<T, AscendC::Reg::PostLiteral::POST_MODE_UPDATE>(src1Reg, src1Addr, oneRepeatSize);
        AscendC::Reg::Interleave<T>(dst0Reg, dst1Reg, src0Reg, src1Reg);
        AscendC::Reg::StoreAlign<T, AscendC::Reg::PostLiteral::POST_MODE_UPDATE>(dst0Addr, dst0Reg, oneRepeatSize, mask);
        AscendC::Reg::StoreAlign<T, AscendC::Reg::PostLiteral::POST_MODE_UPDATE>(dst1Addr, dst1Reg, oneRepeatSize, mask);
    }
}

template <typename T, uint32_t singleCoreLength>
class KernelInterleave {
public:
    __aicore__ inline void Init(__gm__ uint8_t* x, __gm__ uint8_t* y, __gm__ uint8_t* dst0, __gm__ uint8_t* dst1)
    {
        xGm.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(x));
        yGm.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(y));
        dst0Gm.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(dst0));
        dst1Gm.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(dst1));
    }

    __aicore__ inline void Process()
    {
        AscendC::LocalMemAllocator<AscendC::Hardware::UB> ubAllocator;
        AscendC::LocalTensor<T> xLocal = ubAllocator.Alloc<T, singleCoreLength>();
        AscendC::LocalTensor<T> yLocal = ubAllocator.Alloc<T, singleCoreLength>();
        AscendC::LocalTensor<T> dst0Local = ubAllocator.Alloc<T, singleCoreLength>();
        AscendC::LocalTensor<T> dst1Local = ubAllocator.Alloc<T, singleCoreLength>();

        AscendC::DataCopy(xLocal, xGm, singleCoreLength);
        AscendC::DataCopy(yLocal, yGm, singleCoreLength);
        AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);

        __ubuf__ T* xAddr = reinterpret_cast<__ubuf__ T*>(xLocal.GetPhyAddr());
        __ubuf__ T* yAddr = reinterpret_cast<__ubuf__ T*>(yLocal.GetPhyAddr());
        __ubuf__ T* dst0Addr = reinterpret_cast<__ubuf__ T*>(dst0Local.GetPhyAddr());
        __ubuf__ T* dst1Addr = reinterpret_cast<__ubuf__ T*>(dst1Local.GetPhyAddr());
        constexpr uint32_t oneRepeatSize = AscendC::GetVecLen() / sizeof(T);
        uint16_t repeatTimes = AscendC::CeilDivision(singleCoreLength, oneRepeatSize);

        asc_vf_call<InterleaveVF<T>>(dst0Addr, dst1Addr, xAddr, yAddr, repeatTimes, oneRepeatSize);

        AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);

        AscendC::DataCopy(dst0Gm, dst0Local, singleCoreLength);
        AscendC::DataCopy(dst1Gm, dst1Local, singleCoreLength);
    }

private:
    AscendC::GlobalTensor<T> xGm;
    AscendC::GlobalTensor<T> yGm;
    AscendC::GlobalTensor<T> dst0Gm;
    AscendC::GlobalTensor<T> dst1Gm;
};

__global__ __vector__ void data_relayout(__gm__ uint8_t* x, __gm__ uint8_t* y, __gm__ uint8_t* dst0, __gm__ uint8_t* dst1)
{
    AscendC::InitSocState();
    constexpr uint32_t singleCoreLength = totalLength;
    KernelInterleave<uint16_t, singleCoreLength> kernel;
    kernel.Init(x, y, dst0, dst1);
    kernel.Process();
    AscendC::PipeBarrier<PIPE_ALL>();
}

#elif SCENARIO_NUM == 2

template <typename T32, typename T16>
__simd_vf__ inline void PackVF(__ubuf__ T16* dstAddr, __ubuf__ T32* srcAddr,
                                 uint32_t repeatTimes, uint32_t oneRepeatSize)
{
    AscendC::Reg::RegTensor<T32> srcReg;
    AscendC::Reg::RegTensor<T16> dstReg;
    AscendC::Reg::MaskReg mask16 = AscendC::Reg::CreateMask<T16, AscendC::Reg::MaskPattern::ALL>();

    for (uint16_t i = 0; i < repeatTimes; ++i) {
        AscendC::Reg::LoadAlign<T32, AscendC::Reg::PostLiteral::POST_MODE_UPDATE>(srcReg, srcAddr, oneRepeatSize);
        AscendC::Reg::Pack<T16, T32, AscendC::Reg::HighLowPart::LOWEST>(dstReg, srcReg);
        AscendC::Reg::StoreAlign<T16, AscendC::Reg::PostLiteral::POST_MODE_UPDATE>(dstAddr, dstReg, oneRepeatSize, mask16);
    }
}

template <typename T32, typename T16, uint32_t singleCoreLength>
class KernelPack {
public:
    __aicore__ inline void Init(__gm__ uint8_t* src, __gm__ uint8_t* dst)
    {
        srcGm.SetGlobalBuffer(reinterpret_cast<__gm__ T32*>(src));
        dstGm.SetGlobalBuffer(reinterpret_cast<__gm__ T16*>(dst));
    }

    __aicore__ inline void Process()
    {
        AscendC::LocalMemAllocator<AscendC::Hardware::UB> ubAllocator;
        AscendC::LocalTensor<T32> srcLocal = ubAllocator.Alloc<T32, singleCoreLength>();
        AscendC::LocalTensor<T16> dstLocal = ubAllocator.Alloc<T16, singleCoreLength>();

        AscendC::DataCopy(srcLocal, srcGm, singleCoreLength);
        AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);

        __ubuf__ T32* srcAddr = reinterpret_cast<__ubuf__ T32*>(srcLocal.GetPhyAddr());
        __ubuf__ T16* dstAddr = reinterpret_cast<__ubuf__ T16*>(dstLocal.GetPhyAddr());
        constexpr uint32_t oneRepeatSize = AscendC::GetVecLen() / sizeof(T32);
        uint16_t repeatTimes = AscendC::CeilDivision(singleCoreLength, oneRepeatSize);

        asc_vf_call<PackVF<T32, T16>>(dstAddr, srcAddr, repeatTimes, oneRepeatSize);

        AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);

        AscendC::DataCopy(dstGm, dstLocal, singleCoreLength);
    }

private:
    AscendC::GlobalTensor<T32> srcGm;
    AscendC::GlobalTensor<T16> dstGm;
};

__global__ __vector__ void data_relayout(__gm__ uint8_t* src, __gm__ uint8_t* y, __gm__ uint8_t* dst, __gm__ uint8_t* dst1)
{
    AscendC::InitSocState();
    constexpr uint32_t singleCoreLength = totalLength;
    KernelPack<uint32_t, uint16_t, singleCoreLength> kernel;
    kernel.Init(src, dst);
    kernel.Process();
    AscendC::PipeBarrier<PIPE_ALL>();
}

#endif

static bool CompareResult(const void* outputData, const void* goldenData, uint32_t outSize, uint32_t elementSize)
{
    int64_t wrongNum = 0;
    size_t count = outSize / elementSize;
    for (size_t i = 0; i < count; i++) {
        if (elementSize == 4) {
            uint32_t a = (reinterpret_cast<const uint32_t*>(outputData))[i];
            uint32_t b = (reinterpret_cast<const uint32_t*>(goldenData))[i];
            if (a != b) {
                printf("CompareResult failed at %zu: output=0x%08x, golden=0x%08x\n", i, a, b);
                wrongNum++;
            }
        } else {
            uint16_t a = (reinterpret_cast<const uint16_t*>(outputData))[i];
            uint16_t b = (reinterpret_cast<const uint16_t*>(goldenData))[i];
            if (a != b) {
                printf("CompareResult failed at %zu: output=0x%04x, golden=0x%04x\n", i, a, b);
                wrongNum++;
            }
        }
        if (wrongNum > 10) {
            printf("... (too many errors, truncated)\n");
            break;
        }
    }
    if (wrongNum != 0) {
        return false;
    } else {
        printf("CompareResult success!\n");
        return true;
    }
}

int32_t main(int32_t argc, char* argv[])
{
    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);
    uint32_t numBlocks = 1;

#if SCENARIO_NUM == 1
    size_t byteSize = totalLength * sizeof(uint16_t);
    uint8_t *xHost, *yHost, *dst0Host, *dst1Host;
    uint8_t *xDevice, *yDevice, *dst0Device, *dst1Device;
    aclrtMallocHost((void**)(&xHost), byteSize);
    aclrtMallocHost((void**)(&yHost), byteSize);
    aclrtMallocHost((void**)(&dst0Host), byteSize);
    aclrtMallocHost((void**)(&dst1Host), byteSize);
    aclrtMalloc((void**)&xDevice, byteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&yDevice, byteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&dst0Device, byteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&dst1Device, byteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    size_t fileSize = byteSize;
    ReadFile("./input/input_x.bin", fileSize, xHost, byteSize);
    ReadFile("./input/input_y.bin", fileSize, yHost, byteSize);
    aclrtMemcpy(xDevice, byteSize, xHost, byteSize, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(yDevice, byteSize, yHost, byteSize, ACL_MEMCPY_HOST_TO_DEVICE);
    data_relayout<<<numBlocks, nullptr, stream>>>(xDevice, yDevice, dst0Device, dst1Device);
    aclrtSynchronizeStream(stream);
    aclrtMemcpy(dst0Host, byteSize, dst0Device, byteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    aclrtMemcpy(dst1Host, byteSize, dst1Device, byteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output_dst0.bin", dst0Host, byteSize);
    WriteFile("./output/output_dst1.bin", dst1Host, byteSize);
    void* g0; aclrtMallocHost((void**)(&g0), byteSize);
    size_t gs0 = byteSize;
    ReadFile("./output/golden_dst0.bin", gs0, g0, byteSize);
    bool r0 = CompareResult(dst0Host, g0, byteSize, sizeof(uint16_t));
    aclrtFreeHost(g0);
    void* g1; aclrtMallocHost((void**)(&g1), byteSize);
    size_t gs1 = byteSize;
    ReadFile("./output/golden_dst1.bin", gs1, g1, byteSize);
    bool r1 = CompareResult(dst1Host, g1, byteSize, sizeof(uint16_t));
    aclrtFreeHost(g1);
    if (r0 && r1) { printf("test pass!\n"); } else { printf("test failed!\n"); }
    aclrtFree(xDevice); aclrtFree(yDevice); aclrtFree(dst0Device); aclrtFree(dst1Device);
    aclrtFreeHost(xHost); aclrtFreeHost(yHost); aclrtFreeHost(dst0Host); aclrtFreeHost(dst1Host);
#elif SCENARIO_NUM == 2
    size_t inputByteSize = totalLength * sizeof(uint32_t);
    size_t outputByteSize = totalLength * sizeof(uint16_t);
    uint8_t *srcHost, *dstHost;
    uint8_t *srcDevice, *dstDevice;
    aclrtMallocHost((void**)(&srcHost), inputByteSize);
    aclrtMallocHost((void**)(&dstHost), outputByteSize);
    aclrtMalloc((void**)&srcDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&dstDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    size_t fileSize = inputByteSize;
    ReadFile("./input/input_x.bin", fileSize, srcHost, inputByteSize);
    aclrtMemcpy(srcDevice, inputByteSize, srcHost, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
    data_relayout<<<numBlocks, nullptr, stream>>>(srcDevice, nullptr, dstDevice, nullptr);
    aclrtSynchronizeStream(stream);
    aclrtMemcpy(dstHost, outputByteSize, dstDevice, outputByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", dstHost, outputByteSize);
    void* golden; aclrtMallocHost((void**)(&golden), outputByteSize);
    size_t goldenSize = outputByteSize;
    ReadFile("./output/golden.bin", goldenSize, golden, outputByteSize);
    bool result = CompareResult(dstHost, golden, outputByteSize, sizeof(uint16_t));
    aclrtFreeHost(golden);
    if (result) { printf("test pass!\n"); } else { printf("test failed!\n"); }
    aclrtFree(srcDevice); aclrtFree(dstDevice);
    aclrtFreeHost(srcHost); aclrtFreeHost(dstHost);
#endif

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();
    return 0;
}