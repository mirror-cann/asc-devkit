/* !
 * \file duplicate.asc
 * \brief 演示使用Duplicate API实现数据填充功能，将一个标量值或立即数复制多次并填充到向量中
 */

#include "acl/acl.h"
#include "kernel_operator.h"
#include "data_utils.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

template <typename T>
__simd_vf__ inline void DuplicateScalarVF(__ubuf__ T* dstAddr, T scalarValue,
                                             uint32_t repeatTimes, uint32_t oneRepeatSize)
{
    AscendC::Reg::RegTensor<T> dstReg;
    AscendC::Reg::MaskReg mask = AscendC::Reg::CreateMask<T>();
    for (uint16_t i = 0; i < repeatTimes; ++i) {
        // Duplicate: 将标量值填充到dstReg的每个元素
        // dst[i] = scalarValue, for all i
        AscendC::Reg::Duplicate(dstReg, scalarValue, mask);
        AscendC::Reg::StoreAlign(dstAddr + i * oneRepeatSize, dstReg, mask);
    }
}

template <typename T>
class Kernel {
public:
    __aicore__ inline void Init(__gm__ uint8_t* y, uint32_t totalLength)
    {
        this->totalLength = totalLength;
        this->yGm.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(y));
    }
    __aicore__ inline void Process()
    {
        AscendC::LocalMemAllocator<AscendC::Hardware::UB> ubAllocator;
        AscendC::LocalTensor<T> yLocal = ubAllocator.Alloc<T, 256>();

        // Compute: RegBase DuplicateScalarVF
        __ubuf__ T* yAddr = reinterpret_cast<__ubuf__ T*>(yLocal.GetPhyAddr());
        // 一次repeat计算的数据个数
        constexpr uint32_t oneRepeatSize = AscendC::GetVecLen() / sizeof(T);
        // 总迭代次数
        uint16_t repeatTimes = AscendC::CeilDivision(totalLength, oneRepeatSize);
        // 填充的标量值
        T fillValue = static_cast<T>(3.14);
        asc_vf_call<DuplicateScalarVF<T>>(yAddr, fillValue, repeatTimes, oneRepeatSize);

        AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);

        // CopyOut: UB -> GM
        AscendC::DataCopy(yGm, yLocal, totalLength);
    }

private:
    uint32_t totalLength;
    AscendC::GlobalTensor<T> yGm;
};

__global__ __vector__ void duplicate(__gm__ uint8_t* y)
{
    AscendC::InitSocState();
    uint32_t totalLength = 256;
    Kernel<float> kernel;
    kernel.Init(y, totalLength);
    kernel.Process();
    AscendC::PipeBarrier<PIPE_ALL>();
}

static bool CompareResult(const void* outputData, uint32_t outSize)
{
    void* goldenData;
    aclrtMallocHost((void**)(&goldenData), outSize);
    size_t goldenSize = outSize;
    bool ret = ReadFile("./output/golden.bin", goldenSize, goldenData, goldenSize);
    if (ret) {
        printf("ReadFile golden.bin success!\n");
    } else {
        printf("test failed!\n");
        return false;
    }
    constexpr float EPS = 1e-4;
    int64_t wrongNum = 0;

    for (size_t i = 0; i < outSize / sizeof(float); i++) {
        float a = (reinterpret_cast<const float*>(outputData))[i];
        float b = (reinterpret_cast<const float*>(goldenData))[i];
        float ae = std::abs(a - b);
        float re = ae / std::abs(b);
        if (ae > EPS && re > EPS) {
            printf("CompareResult golden.bin failed at index %zu: output is %lf, golden is %lf\n", i, a, b);
            wrongNum++;
        }
    }
    aclrtFreeHost(goldenData);
    if (wrongNum != 0) {
        return false;
    } else {
        printf("CompareResult golden.bin success!\n");
        return true;
    }
}

int32_t main(int32_t argc, char* argv[])
{
    uint32_t numBlocks = 1;
    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);
    uint32_t totalLength = 256;
    size_t outputByteSize = static_cast<size_t>(1) * totalLength * sizeof(float);
    uint8_t *yHost;
    uint8_t *yDevice;
    aclrtMallocHost((void**)(&yHost), outputByteSize);
    aclrtMalloc((void**)&yDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    duplicate<<<numBlocks, nullptr, stream>>>(yDevice);
    aclrtSynchronizeStream(stream);
    aclrtMemcpy(yHost, outputByteSize, yDevice, outputByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", yHost, outputByteSize);
    bool goldenResult = true;
    goldenResult = CompareResult(yHost, outputByteSize);
    if (goldenResult) {
        printf("test pass!\n");
    } else {
        printf("test failed!\n");
    }
    aclrtFree(yDevice);
    aclrtFreeHost(yHost);
    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();
    return 0;
}
