/* !
 * \file mergemode.asc
 * \brief 演示 MaskMergeMode::MERGING 模式：未激活位保留 dstReg 原值
 */

#include "acl/acl.h"
#include "kernel_operator.h"
#include "data_utils.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

constexpr uint32_t totalLength = 200;
constexpr uint32_t paddedLength = 256;

template <typename T>
__simd_vf__ inline void MaxMergeModeVF(__ubuf__ T* dstAddr, __ubuf__ T* src0Addr, __ubuf__ T* src1Addr,
                                         uint32_t count, uint32_t oneRepeatSize)
{
    AscendC::Reg::RegTensor<T> src0Reg;
    AscendC::Reg::RegTensor<T> src1Reg;
    AscendC::Reg::RegTensor<T> dstReg;
    AscendC::Reg::MaskReg mask;
    AscendC::Reg::MaskReg allMask = AscendC::Reg::CreateMask<T, AscendC::Reg::MaskPattern::ALL>();
    uint16_t repeatTimes = AscendC::CeilDivision(count, oneRepeatSize);

    for (uint16_t i = 0; i < repeatTimes; ++i) {
        AscendC::Reg::Duplicate(dstReg, (T)2);
        mask = AscendC::Reg::UpdateMask<T>(count);
        AscendC::Reg::LoadAlign<T, AscendC::Reg::PostLiteral::POST_MODE_UPDATE>(src0Reg, src0Addr, oneRepeatSize);
        AscendC::Reg::LoadAlign<T, AscendC::Reg::PostLiteral::POST_MODE_UPDATE>(src1Reg, src1Addr, oneRepeatSize);
        AscendC::Reg::Max<T, AscendC::Reg::MaskMergeMode::MERGING>(dstReg, src0Reg, src1Reg, mask);
        AscendC::Reg::StoreAlign(dstAddr + i * oneRepeatSize, dstReg, allMask);
    }
}

template <typename T>
__simd_vf__ inline void ReduceMaxVF(__ubuf__ T* dstAddr, __ubuf__ T* srcAddr,
                                      uint32_t count, uint32_t oneRepeatSize)
{
    AscendC::Reg::MaskReg mask = AscendC::Reg::CreateMask<T, AscendC::Reg::MaskPattern::ALL>();
    AscendC::Reg::RegTensor<T> srcReg;
    AscendC::Reg::RegTensor<T> dstReg;
    AscendC::Reg::RegTensor<T> accReg;

    AscendC::Reg::LoadAlign(accReg, srcAddr);
    AscendC::Reg::Reduce<AscendC::Reg::ReduceType::MAX>(dstReg, accReg, mask);
    AscendC::Reg::Max(accReg, dstReg, dstReg, mask);

    uint16_t repeatTimes = AscendC::CeilDivision(count, oneRepeatSize);
    for (uint16_t i = 1; i < repeatTimes; ++i) {
        AscendC::Reg::LoadAlign(srcReg, srcAddr + i * oneRepeatSize);
        AscendC::Reg::Reduce<AscendC::Reg::ReduceType::MAX>(dstReg, srcReg, mask);
        AscendC::Reg::Max(accReg, accReg, dstReg, mask);
    }
    AscendC::Reg::StoreAlign(dstAddr, accReg, mask);
}

template <typename T>
class Kernel {
public:
    __aicore__ inline void Init(__gm__ uint8_t* x, __gm__ uint8_t* y)
    {
        this->xGm.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(x));
        this->yGm.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(y));
    }

    __aicore__ inline void Process()
    {
        AscendC::LocalMemAllocator<AscendC::Hardware::UB> ubAllocator;
        AscendC::LocalTensor<T> xLocal = ubAllocator.Alloc<T, paddedLength>();
        AscendC::LocalTensor<T> yLocal = ubAllocator.Alloc<T, paddedLength>();

        AscendC::Duplicate(yLocal, (T)2, paddedLength);

        AscendC::DataCopy(xLocal, xGm, totalLength);
        AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);

        __ubuf__ T* xAddr = reinterpret_cast<__ubuf__ T*>(xLocal.GetPhyAddr());
        __ubuf__ T* yAddr = reinterpret_cast<__ubuf__ T*>(yLocal.GetPhyAddr());
        constexpr uint32_t oneRepeatSize = AscendC::GetVecLen() / sizeof(T);

        asc_vf_call<MaxMergeModeVF<T>>(yAddr, xAddr, xAddr, totalLength, oneRepeatSize);
        asc_vf_call<ReduceMaxVF<T>>(yAddr, yAddr, paddedLength, oneRepeatSize);

        AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);

        constexpr uint32_t outAlignSize = 8;
        AscendC::DataCopy(yGm, yLocal, outAlignSize);
    }

private:
    AscendC::GlobalTensor<T> xGm;
    AscendC::GlobalTensor<T> yGm;
};

__global__ __vector__ void mergemode(__gm__ uint8_t* x, __gm__ uint8_t* y)
{
    AscendC::InitSocState();
    Kernel<float> kernel;
    kernel.Init(x, y);
    kernel.Process();
    AscendC::PipeBarrier<PIPE_ALL>();
}

static bool CompareResult(const void* outputData, const void* goldenData, uint32_t outSize)
{
    constexpr float EPS = 1e-4;
    int64_t wrongNum = 0;

    float a = (reinterpret_cast<const float*>(outputData))[0];
    float b = (reinterpret_cast<const float*>(goldenData))[0];
    float ae = std::abs(a - b);
    float re = ae / std::abs(b);
    if (ae > EPS && re > EPS) {
        printf("CompareResult failed: output=%f, golden=%f\n", a, b);
        wrongNum++;
    }

    if (wrongNum != 0) {
        return false;
    } else {
        printf("CompareResult success!\n");
        return true;
    }
}

int32_t main(int32_t argc, char* argv[])
{
    uint32_t numBlocks = 1;
    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    size_t inputByteSize = totalLength * sizeof(float);
    size_t outputByteSize = 8 * sizeof(float);

    uint8_t *xHost, *yHost;
    uint8_t *xDevice, *yDevice;
    aclrtMallocHost((void**)(&xHost), inputByteSize);
    aclrtMallocHost((void**)(&yHost), outputByteSize);
    aclrtMalloc((void**)&xDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&yDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);

    size_t inputFileSize = inputByteSize;
    ReadFile("./input/input_x.bin", inputFileSize, xHost, inputByteSize);
    aclrtMemcpy(xDevice, inputByteSize, xHost, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);

    mergemode<<<numBlocks, nullptr, stream>>>(xDevice, yDevice);
    aclrtSynchronizeStream(stream);
    aclrtMemcpy(yHost, outputByteSize, yDevice, outputByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", yHost, outputByteSize);

    void* goldenData;
    aclrtMallocHost((void**)(&goldenData), outputByteSize);
    size_t goldenFileSize = outputByteSize;
    ReadFile("./output/golden.bin", goldenFileSize, goldenData, outputByteSize);

    bool result = CompareResult(yHost, goldenData, outputByteSize);
    aclrtFreeHost(goldenData);

    if (result) {
        printf("test pass!\n");
    } else {
        printf("test failed!\n");
    }

    aclrtFree(xDevice);
    aclrtFree(yDevice);
    aclrtFreeHost(xHost);
    aclrtFreeHost(yHost);
    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();
    return 0;
}