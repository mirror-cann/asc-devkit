/* !
 * \file reduce_pair.asc
 * \brief 演示使用PairReduceSum API实现成对归约求和计算功能，对相邻元素成对求和并输出结果
 */

#include "acl/acl.h"
#include "kernel_operator.h"
#include "data_utils.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

template <typename T>
__simd_vf__ inline void PairReduceSumVF(__ubuf__ T* dstAddr, __ubuf__ T* srcAddr,
                                          uint32_t count, uint32_t repeatTimes,
                                          uint32_t oneRepeatSize)
{
    AscendC::Reg::RegTensor<T> srcReg;
    AscendC::Reg::RegTensor<T> dstReg;
    AscendC::Reg::MaskReg mask;

    for (uint16_t i = 0; i < repeatTimes; ++i) {
        AscendC::Reg::LoadAlign(srcReg, srcAddr + i * oneRepeatSize);
        mask = AscendC::Reg::UpdateMask<T>(count);
        // PairReduceElem: 相邻奇偶元素对求和
        // dst[0] = src[0] + src[1], dst[1] = src[2] + src[3], ...
        AscendC::Reg::PairReduceElem<AscendC::Reg::PairReduce::SUM>(dstReg, srcReg, mask);
        // 使用 StoreAlign，偏移使用 oneRepeatSize
        // PairReduceElem 输出在寄存器的前半部分
        AscendC::Reg::StoreAlign(dstAddr + i * oneRepeatSize, dstReg, mask);
    }
}

template <typename T>
class Kernel {
public:
    __aicore__ inline void Init(__gm__ uint8_t* x, __gm__ uint8_t* y, uint32_t totalLength)
    {
        this->totalLength = totalLength;
        this->xGm.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(x));
        this->yGm.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(y));
    }
    __aicore__ inline void Process()
    {
        AscendC::LocalMemAllocator<AscendC::Hardware::UB> ubAllocator;
        // 输入 256 个 float
        AscendC::LocalTensor<T> xLocal = ubAllocator.Alloc<T, 256>();
        // 输出需要 repeatTimes * oneRepeatSize = 4 * 64 = 256 个 float
        // 但 PairReduceElem 只产生有效数据在寄存器前半部分
        AscendC::LocalTensor<T> yLocal = ubAllocator.Alloc<T, 512>();

        // CopyIn: GM -> UB
        AscendC::DataCopy(xLocal, xGm, totalLength);
        AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);

        // Compute: RegBase PairReduceElem SUM
        __ubuf__ T* xAddr = reinterpret_cast<__ubuf__ T*>(xLocal.GetPhyAddr());
        __ubuf__ T* yAddr = reinterpret_cast<__ubuf__ T*>(yLocal.GetPhyAddr());
        // 一次repeat计算的数据个数
        constexpr uint32_t oneRepeatSize = AscendC::GetVecLen() / sizeof(T);
        // 总迭代次数
        uint16_t repeatTimes = AscendC::CeilDivision(totalLength, oneRepeatSize);
        asc_vf_call<PairReduceSumVF<T>>(yAddr, xAddr, totalLength, repeatTimes, oneRepeatSize);

        AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);

        // CopyOut: UB -> GM
        // PairReduceElem输出: 使用交错布局
        // 每次repeat存储oneRepeatSize个元素，其中前halfRepeatSize个有效
        // 总输出大小 = repeatTimes * oneRepeatSize
        uint32_t outputSize = repeatTimes * oneRepeatSize;
        AscendC::DataCopy(yGm, yLocal, outputSize);
    }

private:
    uint32_t totalLength;
    AscendC::GlobalTensor<T> xGm;
    AscendC::GlobalTensor<T> yGm;
};

__global__ __vector__ void reduce_pair(__gm__ uint8_t* x, __gm__ uint8_t* y)
{
    AscendC::InitSocState();
    uint32_t totalLength = 256;
    Kernel<float> kernel;
    kernel.Init(x, y, totalLength);
    kernel.Process();
    AscendC::PipeBarrier<PIPE_ALL>();
}

static bool CompareResult(const void* outputData, uint32_t outSize, uint32_t totalLength)
{
    void* goldenData;
    aclrtMallocHost((void**)(&goldenData), outSize);
    size_t goldenSize = outSize;
    bool ret = ReadFile("./output/golden.bin", goldenSize, goldenData, goldenSize);
    if (ret) {
        printf("ReadFile golden.bin success!\n");
    } else {
        printf("test failed!\n");
        return false;
    }
    constexpr float EPS = 1e-4;
    int64_t wrongNum = 0;

    // PairReduceElem: 结果数量为输入的一半
    // 使用交错布局：每64个元素中只有前32个有效
    constexpr uint32_t oneRepeatSize = 64;  // GetVecLen() / sizeof(float) = 64
    constexpr uint32_t halfRepeatSize = 32; // oneRepeatSize / 2
    uint32_t numResults = totalLength / 2;
    uint32_t numRepeats = (numResults + halfRepeatSize - 1) / halfRepeatSize;

    const float* output = reinterpret_cast<const float*>(outputData);
    const float* golden = reinterpret_cast<const float*>(goldenData);

    for (uint32_t i = 0; i < numResults; i++) {
        // 计算交错布局中的实际位置
        uint32_t repeatIdx = i / halfRepeatSize;
        uint32_t elemIdx = i % halfRepeatSize;
        uint32_t actualIdx = repeatIdx * oneRepeatSize + elemIdx;
        float a = output[actualIdx];
        float b = golden[i];
        float ae = std::abs(a - b);
        float re = ae / std::abs(b);
        if (ae > EPS && re > EPS) {
            printf("CompareResult golden.bin failed at index %zu: output is %lf, golden is %lf\n", i, a, b);
            wrongNum++;
        }
    }
    aclrtFreeHost(goldenData);
    if (wrongNum != 0) {
        return false;
    } else {
        printf("CompareResult golden.bin success!\n");
        return true;
    }
}

int32_t main(int32_t argc, char* argv[])
{
    uint32_t numBlocks = 1;
    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);
    uint32_t totalLength = 256;
    size_t inputByteSize = totalLength * sizeof(float);
    // 输出: PairReduceElem使用交错布局
    // 每次repeat存储oneRepeatSize个元素（其中前halfRepeatSize个有效）
    constexpr uint32_t oneRepeatSize = 64;
    uint32_t repeatTimes = (totalLength + oneRepeatSize - 1) / oneRepeatSize;
    size_t outputByteSize = repeatTimes * oneRepeatSize * sizeof(float);
    uint8_t *xHost, *zHost;
    uint8_t *xDevice, *zDevice;
    aclrtMallocHost((void**)(&xHost), inputByteSize);
    aclrtMallocHost((void**)(&zHost), outputByteSize);
    aclrtMalloc((void**)&xDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&zDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/input_x.bin", inputByteSize, xHost, inputByteSize);
    aclrtMemcpy(xDevice, inputByteSize, xHost, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
    reduce_pair<<<numBlocks, nullptr, stream>>>(xDevice, zDevice);
    aclrtSynchronizeStream(stream);
    aclrtMemcpy(zHost, outputByteSize, zDevice, outputByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", zHost, outputByteSize);
    bool goldenResult = true;
    goldenResult = CompareResult(zHost, outputByteSize, totalLength);
    if (goldenResult) {
        printf("test pass!\n");
    } else {
        printf("test failed!\n");
    }
    aclrtFree(xDevice);
    aclrtFree(zDevice);
    aclrtFreeHost(xHost);
    aclrtFreeHost(zHost);
    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();
    return 0;
}
