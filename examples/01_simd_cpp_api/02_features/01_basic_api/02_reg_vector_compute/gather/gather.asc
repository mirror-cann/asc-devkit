/* !
 * \file gather.asc
 * \brief 演示使用Gather接口（源操作数为寄存器）实现按索引收集元素功能
 */

#include "acl/acl.h"
#include "kernel_operator.h"
#include "data_utils.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

constexpr uint32_t totalLength = 128;

// ---- VF函数：Gather（源操作数为寄存器）----
// Gather：根据索引从源向量中收集元素，dstReg[i] = srcReg[indexReg[i]]
// 使用LoadAlign/StoreAlign的postUpdate模式加载数据
template <typename T, typename U>
__simd_vf__ inline void GatherVF(__ubuf__ T* dstAddr, __ubuf__ T* srcAddr,
                                   __ubuf__ U* indexAddr,
                                   uint32_t count, uint32_t oneRepeatSize)
{
    AscendC::Reg::RegTensor<T> srcReg, dstReg;
    AscendC::Reg::RegTensor<U> indexReg;
    AscendC::Reg::MaskReg mask = AscendC::Reg::CreateMask<T, AscendC::Reg::MaskPattern::ALL>();
    uint16_t repeatTimes = AscendC::CeilDivision(count, oneRepeatSize);

    for (uint16_t i = 0; i < repeatTimes; ++i) {
        AscendC::Reg::LoadAlign<T, AscendC::Reg::PostLiteral::POST_MODE_UPDATE>(srcReg, srcAddr, oneRepeatSize);
        AscendC::Reg::LoadAlign<U, AscendC::Reg::PostLiteral::POST_MODE_UPDATE>(indexReg, indexAddr, oneRepeatSize);
        AscendC::Reg::Gather<T, U>(dstReg, srcReg, indexReg);
        AscendC::Reg::StoreAlign<T, AscendC::Reg::PostLiteral::POST_MODE_UPDATE>(dstAddr, dstReg, oneRepeatSize, mask);
    }
}

// ---- Kernel：Gather ----
template <typename T, typename U, uint32_t singleCoreLength>
class KernelGather {
public:
    __aicore__ inline void Init(__gm__ uint8_t* src, __gm__ uint8_t* index, __gm__ uint8_t* dst)
    {
        srcGm.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(src));
        indexGm.SetGlobalBuffer(reinterpret_cast<__gm__ U*>(index));
        dstGm.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(dst));
    }

    __aicore__ inline void Process()
    {
        AscendC::LocalMemAllocator<AscendC::Hardware::UB> ubAllocator;
        AscendC::LocalTensor<T> srcLocal = ubAllocator.Alloc<T, singleCoreLength>();
        AscendC::LocalTensor<U> indexLocal = ubAllocator.Alloc<U, singleCoreLength>();
        AscendC::LocalTensor<T> dstLocal = ubAllocator.Alloc<T, singleCoreLength>();

        AscendC::DataCopy(srcLocal, srcGm, singleCoreLength);
        AscendC::DataCopy(indexLocal, indexGm, singleCoreLength);
        AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);

        __ubuf__ T* srcAddr = reinterpret_cast<__ubuf__ T*>(srcLocal.GetPhyAddr());
        __ubuf__ U* indexAddr = reinterpret_cast<__ubuf__ U*>(indexLocal.GetPhyAddr());
        __ubuf__ T* dstAddr = reinterpret_cast<__ubuf__ T*>(dstLocal.GetPhyAddr());
        constexpr uint32_t oneRepeatSize = AscendC::GetVecLen() / sizeof(T);

        asc_vf_call<GatherVF<T, U>>(dstAddr, srcAddr, indexAddr, singleCoreLength, oneRepeatSize);

        AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);

        AscendC::DataCopy(dstGm, dstLocal, singleCoreLength);
    }

private:
    AscendC::GlobalTensor<T> srcGm;
    AscendC::GlobalTensor<U> indexGm;
    AscendC::GlobalTensor<T> dstGm;
};

__global__ __vector__ void gather(__gm__ uint8_t* src, __gm__ uint8_t* index, __gm__ uint8_t* dst)
{
    AscendC::InitSocState();
    constexpr uint32_t singleCoreLength = totalLength;
    KernelGather<half, uint16_t, singleCoreLength> kernel;
    kernel.Init(src, index, dst);
    kernel.Process();
    AscendC::PipeBarrier<PIPE_ALL>();
}

static bool CompareResult(const void* outputData, const void* goldenData, uint32_t outSize, uint32_t elementSize)
{
    int64_t wrongNum = 0;
    size_t count = outSize / elementSize;
    for (size_t i = 0; i < count; i++) {
        if (elementSize == 4) {
            uint32_t a = (reinterpret_cast<const uint32_t*>(outputData))[i];
            uint32_t b = (reinterpret_cast<const uint32_t*>(goldenData))[i];
            if (a != b) {
                printf("CompareResult failed at %zu: output=0x%08x, golden=0x%08x\n", i, a, b);
                wrongNum++;
            }
        } else {
            uint16_t a = (reinterpret_cast<const uint16_t*>(outputData))[i];
            uint16_t b = (reinterpret_cast<const uint16_t*>(goldenData))[i];
            if (a != b) {
                printf("CompareResult failed at %zu: output=0x%04x, golden=0x%04x\n", i, a, b);
                wrongNum++;
            }
        }
        if (wrongNum > 10) {
            printf("... (too many errors, truncated)\n");
            break;
        }
    }
    if (wrongNum != 0) {
        return false;
    } else {
        printf("CompareResult success!\n");
        return true;
    }
}

int32_t main(int32_t argc, char* argv[])
{
    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);
    uint32_t numBlocks = 1;

    size_t byteSize = totalLength * sizeof(half);
    size_t indexByteSize = totalLength * sizeof(uint16_t);
    uint8_t *srcHost, *indexHost, *dstHost;
    uint8_t *srcDevice, *indexDevice, *dstDevice;
    aclrtMallocHost((void**)(&srcHost), byteSize);
    aclrtMallocHost((void**)(&indexHost), indexByteSize);
    aclrtMallocHost((void**)(&dstHost), byteSize);
    aclrtMalloc((void**)&srcDevice, byteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&indexDevice, indexByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&dstDevice, byteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    size_t srcFileSize = byteSize;
    size_t indexFileSize = indexByteSize;
    ReadFile("./input/input_x.bin", srcFileSize, srcHost, byteSize);
    ReadFile("./input/input_y.bin", indexFileSize, indexHost, indexByteSize);
    aclrtMemcpy(srcDevice, byteSize, srcHost, byteSize, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(indexDevice, indexByteSize, indexHost, indexByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
    gather<<<numBlocks, nullptr, stream>>>(srcDevice, indexDevice, dstDevice);
    aclrtSynchronizeStream(stream);
    aclrtMemcpy(dstHost, byteSize, dstDevice, byteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", dstHost, byteSize);
    void* golden; aclrtMallocHost((void**)(&golden), byteSize);
    size_t goldenSize = byteSize;
    ReadFile("./output/golden.bin", goldenSize, golden, byteSize);
    bool result = CompareResult(dstHost, golden, byteSize, sizeof(half));
    aclrtFreeHost(golden);
    if (result) { printf("test pass!\n"); } else { printf("test failed!\n"); }
    aclrtFree(srcDevice); aclrtFree(indexDevice); aclrtFree(dstDevice);
    aclrtFreeHost(srcHost); aclrtFreeHost(indexHost); aclrtFreeHost(dstHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();
    return 0;
}
