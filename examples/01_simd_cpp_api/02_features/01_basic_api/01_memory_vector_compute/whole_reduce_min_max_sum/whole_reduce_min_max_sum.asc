/* !
 * \file whole_reduce_min_max_sum.asc
 * \brief
 * 演示归约类接口在多场景下的使用方法，支持通过编译参数切换WholeReduceMax、WholeReduceMin、WholeReduceSum、RepeatReduceSum场景。
 * 配合GetReduceRepeatMaxMinSpr获取极值及索引，支持非对齐数据归约，场景3、场景4和场景6使用float类型输入
 */

#include "acl/acl.h"
#include "data_utils.h"
#include "kernel_operator.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

constexpr uint32_t scenarioNum = SCENARIO_NUM;
constexpr bool isFloat = (scenarioNum == 3 || scenarioNum == 4 || scenarioNum == 6);

// 场景1：WholeReduceMax，输入half类型[1, 1024]，输出[1, 8]，每个repeat内求最大值（不返回索引）
// 场景2：WholeReduceMin，输入half类型[1, 1024]，输出[1, 16]，每个repeat内求最小值及索引
// 场景3：WholeReduceSum，输入float类型[1, 2048]，输出[1, 32]，每个repeat内求和
// 场景4：RepeatReduceSum，输入float类型[1, 2048]，输出[1, 32]，每个repeat内求和（累加模式）
// 场景5：WholeReduceMin + GetReduceRepeatMaxMinSpr，输入half类型[1, 1024]，输出[1, 16]，求全局最小值及索引
// 场景6：WholeReduceSum非对齐场景，输入float类型[13, 57]，输出[1, 13]，对每行非对齐数据求和

template <uint32_t srcTotalLength, uint32_t srcRow, uint32_t srcCol, uint32_t dstTotalLength>
__global__ __vector__ void reduce_custom(__gm__ uint8_t* x, __gm__ uint8_t* z)
{
    AscendC::InitSocState();
    using T = typename AscendC::Conditional<isFloat, float, half>::type;
    constexpr uint32_t MASK = isFloat ? 64 : 128;
    constexpr uint32_t BYTE_ALIGN = 32;
    constexpr uint32_t COL_ALIGN_BYTES = ((srcCol * sizeof(T) + BYTE_ALIGN - 1) / BYTE_ALIGN) * BYTE_ALIGN;
    constexpr uint32_t SRC_BUFFER_LENGTH = srcRow * (COL_ALIGN_BYTES / sizeof(T));
    uint32_t repeat = srcTotalLength / MASK;

    AscendC::TPipe pipe;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> inQueueSrc;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> outQueueDst;
    AscendC::GlobalTensor<T> srcGlobal;
    AscendC::GlobalTensor<T> dstGlobal;
    srcGlobal.SetGlobalBuffer((__gm__ T*)x);
    dstGlobal.SetGlobalBuffer((__gm__ T*)z);
    pipe.InitBuffer(inQueueSrc, 1, SRC_BUFFER_LENGTH * sizeof(T));
    pipe.InitBuffer(outQueueDst, 1, dstTotalLength * sizeof(T));

    AscendC::LocalTensor<T> srcLocalIn = inQueueSrc.AllocTensor<T>();
    uint32_t colBytes = srcCol * sizeof(T);
    AscendC::DataCopyExtParams copyParamsIn = {(uint16_t)srcRow, colBytes, 0, 0, 0};
    uint8_t rpad = (COL_ALIGN_BYTES - colBytes) / sizeof(T);
    AscendC::DataCopyPadExtParams<T> padParams = {false, 0, rpad, 0};
    AscendC::DataCopyPad<T>(srcLocalIn, srcGlobal, copyParamsIn, padParams);
    inQueueSrc.EnQue(srcLocalIn);

    AscendC::LocalTensor<T> srcLocal = inQueueSrc.DeQue<T>();
    AscendC::LocalTensor<T> dstLocal = outQueueDst.AllocTensor<T>();

    if constexpr (scenarioNum == 1) {
        // 场景1：WholeReduceMax：对每个repeat内所有元素求最大值（不返回索引）
        // mask=128, repeat=srcDataSize/mask, order=ORDER_ONLY_VALUE
        // 输出只存储值：[max0, max1, max2, ...]
        AscendC::WholeReduceMax<T>(
            dstLocal, srcLocal, MASK, repeat, 1, 1, 8, AscendC::ReduceOrder::ORDER_ONLY_VALUE);
    } else if constexpr (scenarioNum == 2) {
        // 场景2：WholeReduceMin：对每个repeat内所有元素求最小值及其索引
        // mask=128, repeat=srcDataSize/mask, 使用默认order (ReduceOrder::ORDER_VALUE_INDEX)
        // 输出按值和索引交错存储：[min0, idx0, min1, idx1, ...]
        AscendC::WholeReduceMin<T>(dstLocal, srcLocal, MASK, repeat, 1, 1, 8);
    } else if constexpr (scenarioNum == 3) {
        // 场景3：WholeReduceSum：对每个repeat内所有元素求和，输入为float类型
        // mask=64(float类型32位), repeat=srcDataSize/mask, 每个repeat输出一个求和结果
        AscendC::WholeReduceSum<T>(dstLocal, srcLocal, MASK, repeat, 1, 1, 8);
    } else if constexpr (scenarioNum == 4) {
        // 场景4：RepeatReduceSum：对每个repeat内所有元素求和（累加模式），输入为float类型
        // 先将dstLocal初始化为0，再将所有repeat的结果累加
        // mask=64(float类型32位), repeat=srcDataSize/mask
        // dstBlkStride=0表示每个repeat的结果累加到同一个位置
        T zero(0);
        AscendC::Duplicate(dstLocal, zero, dstTotalLength);
        AscendC::PipeBarrier<PIPE_V>();
        AscendC::RepeatReduceSum<T>(dstLocal, srcLocal, repeat, MASK, 0, 1, 1, 8);
    } else if constexpr (scenarioNum == 5) {
        // 场景5：WholeReduceMin + GetReduceRepeatMaxMinSpr
        // 对1024个half元素求全局最小值及其索引
        // mask逐bit模式, repeat=8(1024/128), srcBlkStride=1, srcRepeatStride=8
        // 8个repeat各自归约得到局部最小值，再通过GetReduceRepeatMaxMinSpr获取全局最小值
        uint64_t mask[2] = {0xFFFFFFFFFFFFFFFF, 0xFFFFFFFFFFFFFFFF};
        AscendC::WholeReduceMin<T>(dstLocal, srcLocal, mask, repeat, 1, 1, 8);
        AscendC::PipeBarrier<PIPE_V>();
        T val = 0;
        T idx = 0;
        AscendC::GetReduceRepeatMaxMinSpr<T>(val, idx);
        AscendC::PipeBarrier<PIPE_V>();
        T zero{0};
        AscendC::Duplicate(dstLocal, zero, dstTotalLength);
        int32_t eventIdVToS = static_cast<int32_t>(GetTPipePtr()->FetchEventID(AscendC::HardEvent::V_S));
        AscendC::SetFlag<AscendC::HardEvent::V_S>(eventIdVToS);
        AscendC::WaitFlag<AscendC::HardEvent::V_S>(eventIdVToS);
        dstLocal.SetValue(0, val);
        dstLocal.SetValue(1, idx);
    } else if constexpr (scenarioNum == 6) {
        // 场景6：WholeReduceSum按行求和非对齐场景，输入为float类型
        // mask=srcCol(57)，每行57个元素求和
        // repeat=srcRow(13)，共13行
        // srcRepeatStride=对齐后的步长（COL_ALIGN_BYTES/BYTE_ALIGN个block），即每行在LocalTensor中对齐后占用的block数
        int32_t srcStride = COL_ALIGN_BYTES / BYTE_ALIGN;
        AscendC::WholeReduceSum<T>(dstLocal, srcLocal, srcCol, srcRow, 1, 1, srcStride);
    }

    outQueueDst.EnQue<T>(dstLocal);
    inQueueSrc.FreeTensor(srcLocal);

    AscendC::LocalTensor<T> dstLocalOut = outQueueDst.DeQue<T>();
    uint16_t outBytes = dstTotalLength * sizeof(T);
    AscendC::DataCopyExtParams copyParamsOut = {1, outBytes, 0, 0, 0};
    AscendC::DataCopyPad<T>(dstGlobal, dstLocalOut, copyParamsOut);
    outQueueDst.FreeTensor(dstLocalOut);
    AscendC::PipeBarrier<PIPE_ALL>();
}

int32_t main(int32_t argc, char* argv[])
{
    constexpr uint32_t MASK_HALF = 128;
    constexpr uint32_t MASK_FLOAT = 64;

    constexpr uint32_t SRC_TOTAL_LENGTH = (scenarioNum == 3 || scenarioNum == 4) ? 2048 :
                                          (scenarioNum == 6)                     ? 13 * 57 :
                                                                                   1024;

    constexpr uint32_t SRC_ROW = (scenarioNum == 6) ? 13 : 1;

    constexpr uint32_t SRC_COL = (scenarioNum == 6) ? 57 : SRC_TOTAL_LENGTH;

    constexpr uint32_t DST_TOTAL_LENGTH = (scenarioNum == 3 || scenarioNum == 4) ? (SRC_TOTAL_LENGTH / MASK_FLOAT) :
                                          (scenarioNum == 6)                     ? SRC_ROW :
                                          (scenarioNum == 1)                     ? 8 :
                                                                                   16;

    uint32_t numBlocks = 1;
    size_t inputByteSize = SRC_TOTAL_LENGTH * (isFloat ? sizeof(float) : sizeof(half));
    size_t outputByteSize = DST_TOTAL_LENGTH * (isFloat ? sizeof(float) : sizeof(half));

    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t *xHost, *zHost;
    uint8_t *xDevice, *zDevice;

    aclrtMallocHost((void**)(&xHost), inputByteSize);
    aclrtMallocHost((void**)(&zHost), outputByteSize);
    aclrtMalloc((void**)&xDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&zDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);

    ReadFile("./input/input_x.bin", inputByteSize, xHost, inputByteSize);

    aclrtMemcpy(xDevice, inputByteSize, xHost, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);

    reduce_custom<SRC_TOTAL_LENGTH, SRC_ROW, SRC_COL, DST_TOTAL_LENGTH>
        <<<numBlocks, nullptr, stream>>>(xDevice, zDevice);

    aclrtSynchronizeStream(stream);

    aclrtMemcpy(zHost, outputByteSize, zDevice, outputByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", zHost, outputByteSize);

    aclrtFree(xDevice);
    aclrtFree(zDevice);
    aclrtFreeHost(xHost);
    aclrtFreeHost(zHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();

    return 0;
}
