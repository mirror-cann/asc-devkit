/* !
 * \file mrg_sort.asc
 * \brief 演示Sort32与MrgSort的配合使用，先使用Sort32将数据按每32个元素一组进行降序排序形成有序队列，
 *        再使用MrgSort将多条有序队列合并为全局有序结果
 * 场景1：128个元素，4条队列合并为1条
 * 场景2：96个元素，3条队列合并为1条，validBit=0b0111演示非4对齐合并
 * 场景3：1024个元素，32条队列多轮合并为1条，实现多路归并排序
 */

#include "acl/acl.h"
#include "data_utils.h"
#include "kernel_operator.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

constexpr uint32_t scenarioNum = SCENARIO_NUM;
constexpr uint32_t SORT_SIZE = 32;

template <uint32_t srcDataSize, uint32_t workSize>
__global__ __vector__ void vec_mrgsort_kernel(__gm__ uint8_t* src0Gm, __gm__ uint8_t* src1Gm, __gm__ uint8_t* dstGm)
{
    AscendC::InitSocState();
    AscendC::GlobalTensor<float> srcGlobal0;
    AscendC::GlobalTensor<uint32_t> srcGlobal1;
    AscendC::GlobalTensor<float> dstGlobal;
    srcGlobal0.SetGlobalBuffer((__gm__ float*)src0Gm);
    srcGlobal1.SetGlobalBuffer((__gm__ uint32_t*)src1Gm);
    dstGlobal.SetGlobalBuffer((__gm__ float*)dstGm);
    constexpr uint32_t dstDataSize = srcDataSize * 2; // 输出结果包括值和索引
    constexpr uint32_t repeat = srcDataSize / SORT_SIZE;

    AscendC::LocalMemAllocator<AscendC::Hardware::UB> ubAllocator;
    AscendC::LocalTensor<float> srcLocal0 = ubAllocator.Alloc<float, srcDataSize>();
    AscendC::LocalTensor<uint32_t> srcLocal1 = ubAllocator.Alloc<uint32_t, srcDataSize>();
    AscendC::LocalTensor<float> workLocal = ubAllocator.Alloc<float, workSize>();
    AscendC::LocalTensor<float> dstLocal = ubAllocator.Alloc<float, srcDataSize * 2>();

    AscendC::DataCopy(srcLocal0, srcGlobal0, srcDataSize);
    AscendC::DataCopy(srcLocal1, srcGlobal1, srcDataSize);
    AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
    AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);

    AscendC::Sort32<float>(workLocal, srcLocal0, srcLocal1, repeat);

    AscendC::PipeBarrier<PIPE_V>();

    if constexpr (scenarioNum == 3) {
        // workLocal空间划分说明：
        // workLocal[0:2048]：Sort32后存储32条有序队列
        // workLocal[2048:4096]：第一轮归并结果存储区，以及第二轮归并的源数据起始地址
        // workLocal[4096:6144]：第二轮归并结果存储区，以及第三轮归并的源数据起始地址
        AscendC::LocalTensor<float> srcLocal = workLocal[0];
        AscendC::LocalTensor<float> tempLocal1 = workLocal[2048];
        AscendC::LocalTensor<float> tempLocal2 = workLocal[4096];

        // 第一轮归并：32条队列 -> 8条队列
        // workLocal：32条有序队列，每条32个元素
        // tempLocal1：输出8条有序队列，每条128个元素（占用256个float空间）
        AscendC::MrgSort4Info params;
        params.elementLengths[0] = SORT_SIZE;
        params.elementLengths[1] = SORT_SIZE;
        params.elementLengths[2] = SORT_SIZE;
        params.elementLengths[3] = SORT_SIZE;
        params.ifExhaustedSuspension = false;
        params.validBit = 0b1111;
        params.repeatTimes = 8;

        AscendC::MrgSortSrcList<float> srcList;
        srcList.src1 = srcLocal[0];
        srcList.src2 = srcLocal[SORT_SIZE * 1 * 2];
        srcList.src3 = srcLocal[SORT_SIZE * 2 * 2];
        srcList.src4 = srcLocal[SORT_SIZE * 3 * 2];

        AscendC::MrgSort<float>(tempLocal1, srcList, params);

        AscendC::PipeBarrier<PIPE_V>();

        // 第二轮归并：8条队列 -> 2条队列
        // tempLocal1：8条有序队列，每条128个元素
        // tempLocal2：输出2条有序队列，每条512个元素
        params.elementLengths[0] = 128;
        params.elementLengths[1] = 128;
        params.elementLengths[2] = 128;
        params.elementLengths[3] = 128;
        params.repeatTimes = 2;

        srcList.src1 = tempLocal1[0];
        srcList.src2 = tempLocal1[128 * 1 * 2];
        srcList.src3 = tempLocal1[128 * 2 * 2];
        srcList.src4 = tempLocal1[128 * 3 * 2];

        AscendC::MrgSort<float>(tempLocal2, srcList, params);

        AscendC::PipeBarrier<PIPE_V>();

        // 第三轮归并：2条队列 -> 1条全局有序队列
        // tempLocal2：2条有序队列，每条512个元素
        // dstLocal：输出1条全局有序队列，共1024个元素
        srcList.src1 = tempLocal2[0];
        srcList.src2 = tempLocal2[512 * 1 * 2];

        params.elementLengths[0] = 512;
        params.elementLengths[1] = 512;
        params.elementLengths[2] = 0;
        params.elementLengths[3] = 0;
        params.ifExhaustedSuspension = false;
        params.validBit = 0b11;
        params.repeatTimes = 1;

        AscendC::MrgSort<float>(dstLocal, srcList, params);
    } else {
        uint16_t validBit;
        uint16_t rptTimes;
        if constexpr (scenarioNum == 1) {
            validBit = 0b1111;
            rptTimes = 1;
        } else if constexpr (scenarioNum == 2) {
            // 场景2：3条队列有效，演示非4对齐情况下的合并
            validBit = 0b0111;
            rptTimes = 1;
        }

        // MrgSort合并多条已排序队列，params配置：
        // elementLengths：每条队列元素个数，无效队列设为0
        // ifExhaustedSuspension：false
        // validBit：0b1111表示4条队列均有效，0b0111表示前3条有效
        // repeatTimes：合并操作重复次数

        AscendC::MrgSort4Info params;
        params.elementLengths[0] = SORT_SIZE;
        params.elementLengths[1] = SORT_SIZE;
        params.elementLengths[2] = SORT_SIZE;
        params.elementLengths[3] = (validBit == 0b1111) ? SORT_SIZE : 0;
        params.ifExhaustedSuspension = false;
        params.validBit = validBit;
        params.repeatTimes = rptTimes;

        AscendC::MrgSortSrcList<float> srcList;
        srcList.src1 = workLocal[0];
        srcList.src2 = workLocal[SORT_SIZE * 1 * 2];
        srcList.src3 = workLocal[SORT_SIZE * 2 * 2];
        srcList.src4 = workLocal[SORT_SIZE * 3 * 2];

        AscendC::MrgSort<float>(dstLocal, srcList, params);
    }

    AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
    AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
    AscendC::DataCopy(dstGlobal, dstLocal, dstDataSize);
    AscendC::PipeBarrier<PIPE_ALL>();
}

int32_t main(int32_t argc, char* argv[])
{
    constexpr uint32_t SRC_DATA_SIZE = (scenarioNum == 1) ? 128 :
                                       (scenarioNum == 2) ? 96 :
                                       (scenarioNum == 3) ? 1024 :
                                                            128;

    constexpr uint32_t WORK_SIZE = (scenarioNum == 1) ? 4 * SORT_SIZE * 2 :
                                   (scenarioNum == 2) ? 4 * SORT_SIZE * 2 :
                                   (scenarioNum == 3) ? (SRC_DATA_SIZE / SORT_SIZE) * SORT_SIZE * 6 :
                                                        4 * SORT_SIZE * 2;

    uint32_t numBlocks = 1;
    size_t inputByteSize = SRC_DATA_SIZE * sizeof(uint32_t);
    size_t outputByteSize = SRC_DATA_SIZE * 2 * sizeof(uint32_t);

    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t *xHost, *yHost, *outHost;
    uint8_t *xDevice, *yDevice, *outDevice;

    aclrtMallocHost((void**)(&xHost), inputByteSize);
    aclrtMallocHost((void**)(&yHost), inputByteSize);
    aclrtMallocHost((void**)(&outHost), outputByteSize);
    aclrtMalloc((void**)&xDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&yDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&outDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);

    ReadFile("./input/input_x.bin", inputByteSize, xHost, inputByteSize);
    ReadFile("./input/input_y.bin", inputByteSize, yHost, inputByteSize);

    aclrtMemcpy(xDevice, inputByteSize, xHost, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(yDevice, inputByteSize, yHost, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);

    vec_mrgsort_kernel<SRC_DATA_SIZE, WORK_SIZE><<<numBlocks, nullptr, stream>>>(xDevice, yDevice, outDevice);
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(outHost, outputByteSize, outDevice, outputByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", outHost, outputByteSize);

    aclrtFree(xDevice);
    aclrtFree(yDevice);
    aclrtFree(outDevice);
    aclrtFreeHost(xHost);
    aclrtFreeHost(yHost);
    aclrtFreeHost(outHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();

    return 0;
}
