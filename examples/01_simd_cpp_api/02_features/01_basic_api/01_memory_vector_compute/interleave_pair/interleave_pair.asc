/* !
 * \file interleave_pair.asc
 * \brief 基于Interleave和DeInterleave实现元素交织和解交织功能
 */

#include "acl/acl.h"
#include "data_utils.h"
#include "kernel_operator.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

constexpr size_t COUNT = 512;

__global__ __vector__ void interleave_pair_custom(
    __gm__ uint8_t* src0, __gm__ uint8_t* src1, __gm__ uint8_t* dst0, __gm__ uint8_t* dst1)
{
    AscendC::InitSocState();
    AscendC::GlobalTensor<half> src0Global;
    AscendC::GlobalTensor<half> src1Global;
    AscendC::GlobalTensor<half> dst0Global;
    AscendC::GlobalTensor<half> dst1Global;
    src0Global.SetGlobalBuffer(reinterpret_cast<__gm__ half*>(src0));
    src1Global.SetGlobalBuffer(reinterpret_cast<__gm__ half*>(src1));
    dst0Global.SetGlobalBuffer(reinterpret_cast<__gm__ half*>(dst0));
    dst1Global.SetGlobalBuffer(reinterpret_cast<__gm__ half*>(dst1));

    // 使用静态Tensor分配UB内存
    AscendC::LocalMemAllocator<AscendC::Hardware::UB> ubAllocator;
    AscendC::LocalTensor<half> src0Local = ubAllocator.Alloc<half, COUNT>();
    AscendC::LocalTensor<half> src1Local = ubAllocator.Alloc<half, COUNT>();
    AscendC::LocalTensor<half> dst0Local = ubAllocator.Alloc<half, COUNT>();
    AscendC::LocalTensor<half> dst1Local = ubAllocator.Alloc<half, COUNT>();

    AscendC::DataCopy(src0Local, src0Global, COUNT);
    AscendC::DataCopy(src1Local, src1Global, COUNT);

    AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
    AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);

    // 初始化dst为0
    AscendC::Duplicate(dst0Local, (half)0, COUNT);
    AscendC::Duplicate(dst1Local, (half)0, COUNT);

    if constexpr (SCENARIO_NUM == 1) {
        // 场景1：将两个源操作数的元素交织存入两个结果操作数
        AscendC::Interleave(dst0Local, dst1Local, src0Local, src1Local, COUNT);
    } else if constexpr (SCENARIO_NUM == 2) {
        // 场景2：将两个源操作数的元素解交织存入两个结果操作数
        AscendC::DeInterleave(dst0Local, dst1Local, src0Local, src1Local, COUNT);
    }

    AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
    AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);

    AscendC::DataCopy(dst0Global, dst0Local, COUNT);
    AscendC::DataCopy(dst1Global, dst1Local, COUNT);
    AscendC::PipeBarrier<PIPE_ALL>();
}

int32_t main(int32_t argc, char* argv[])
{
    constexpr size_t numBlocks = 1;
    size_t inputByteSize = COUNT * sizeof(half);
    size_t outputByteSize = COUNT * sizeof(half);

    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t *src0Host, *src1Host, *dst0Host, *dst1Host;
    uint8_t *src0Device, *src1Device, *dst0Device, *dst1Device;

    aclrtMallocHost((void**)(&src0Host), inputByteSize);
    aclrtMallocHost((void**)(&src1Host), inputByteSize);
    aclrtMallocHost((void**)(&dst0Host), outputByteSize);
    aclrtMallocHost((void**)(&dst1Host), outputByteSize);
    aclrtMalloc((void**)&src0Device, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&src1Device, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&dst0Device, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&dst1Device, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);

    ReadFile("./input/input_src0.bin", inputByteSize, src0Host, inputByteSize);
    ReadFile("./input/input_src1.bin", inputByteSize, src1Host, inputByteSize);

    aclrtMemcpy(src0Device, inputByteSize, src0Host, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(src1Device, inputByteSize, src1Host, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);

    interleave_pair_custom<<<numBlocks, nullptr, stream>>>(src0Device, src1Device, dst0Device, dst1Device);

    aclrtSynchronizeStream(stream);

    aclrtMemcpy(dst0Host, outputByteSize, dst0Device, outputByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    aclrtMemcpy(dst1Host, outputByteSize, dst1Device, outputByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output_dst0.bin", dst0Host, outputByteSize);
    WriteFile("./output/output_dst1.bin", dst1Host, outputByteSize);

    aclrtFree(src0Device);
    aclrtFree(src1Device);
    aclrtFree(dst0Device);
    aclrtFree(dst1Device);
    aclrtFreeHost(src0Host);
    aclrtFreeHost(src1Host);
    aclrtFreeHost(dst0Host);
    aclrtFreeHost(dst1Host);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();

    return 0;
}
