/* !
 * \file sequential_block_sync.asc
 * \brief 基于InitDetermineComputeWorkspace、WaitPreBlock、NotifyNextBlock三个接口实现核间顺序同步，确保多核按blockIdx升序执行
 */

#include "acl/acl.h"
#include "data_utils.h"
#include "kernel_operator.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

constexpr int DATA_SIZE = 256;
constexpr int BLOCK_NUM = 8;
constexpr int GM_WORKSPACE_SIZE = BLOCK_NUM * 32;       // gmWorkspace申请的空间最少要求为：blockNum * 32Bytes
constexpr int UB_WORKSPACE_SIZE = BLOCK_NUM * 32 + 32;  // ubWorkspace申请的空间最少要求为：blockNum * 32 + 32Bytes
constexpr int TILE_NUM = 2;

/**
 * @brief 确定性计算样例核函数，使用三个接口组合确保核间顺序执行
 * 
 * 本样例展示InitDetermineComputeWorkspace、WaitPreBlock、NotifyNextBlock三个接口的配合使用：
 * 1. InitDetermineComputeWorkspace：初始化GM共享内存的同步状态
 * 2. WaitPreBlock：等待前序核（blockIdx-1）完成操作
 * 3. NotifyNextBlock：通知后序核（blockIdx+1）当前核已完成
 * 
 * 三个接口必须组合使用，确保多个AIV核严格按照blockIdx升序执行
 */
template <typename T>
__global__ __vector__ void kernel_sequential_block_sync(__gm__ uint8_t* x, __gm__ uint8_t* z, __gm__ uint8_t* workspace)
{
    AscendC::TPipe pipe;
    int64_t tileCount = DATA_SIZE / TILE_NUM;

    AscendC::GlobalTensor<T> srcGlobal;
    AscendC::GlobalTensor<T> dstGlobal;
    AscendC::GlobalTensor<int32_t> gmWorkspace;
    dstGlobal.SetGlobalBuffer((__gm__ T*)z);
    srcGlobal.SetGlobalBuffer((__gm__ T*)x);
    gmWorkspace.SetGlobalBuffer((__gm__ int32_t*)workspace);

    AscendC::TQue<AscendC::TPosition::VECIN, 1> queTmp;
    pipe.InitBuffer(queTmp, 1, UB_WORKSPACE_SIZE);
    AscendC::LocalTensor<int32_t> ubWorkspace = queTmp.AllocTensor<int32_t>();
    // 初始化GM共享内存的同步状态，必须在核函数开始时首先调用
    AscendC::InitDetermineComputeWorkspace(gmWorkspace, ubWorkspace);
    
    AscendC::TQue<AscendC::TPosition::VECIN, 1> que;
    pipe.InitBuffer(que, 1, DATA_SIZE * sizeof(T));
    for(int64_t i = 0; i < TILE_NUM; i++) {
        AscendC::LocalTensor<T> srcLocal = que.AllocTensor<T>();
        AscendC::DataCopy(srcLocal, srcGlobal[i * tileCount], tileCount);

        // 等待前序核（blockIdx-1）完成操作
        AscendC::WaitPreBlock(gmWorkspace, ubWorkspace);
        
        // 开启原子累加
        AscendC::SetAtomicAdd<T>();
        AscendC::DataCopy(dstGlobal[i * tileCount], srcLocal, tileCount);
        AscendC::DisableDmaAtomic();
        
        // 通知后序核（blockIdx+1）当前核已完成
        AscendC::NotifyNextBlock(gmWorkspace, ubWorkspace);
        que.FreeTensor(srcLocal);
    }
    queTmp.FreeTensor(ubWorkspace);
}

int32_t main(int32_t argc, char* argv[]) 
{
    size_t inputByteSize = DATA_SIZE * sizeof(float);
    size_t outputByteSize = DATA_SIZE * sizeof(float);
    size_t workByteSize = GM_WORKSPACE_SIZE;

    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t *xHost, *zHost, *workHost;
    uint8_t *xDevice, *zDevice, *workDevice;

    aclrtMallocHost((void **)(&xHost), inputByteSize);
    aclrtMallocHost((void **)(&zHost), outputByteSize);
    aclrtMallocHost((void **)(&workHost), workByteSize);
    aclrtMalloc((void **)&xDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void **)&zDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void **)&workDevice, workByteSize, ACL_MEM_MALLOC_HUGE_FIRST);

    ReadFile("./input/input_x.bin", inputByteSize, xHost, inputByteSize);
    ReadFile("./input/input_work.bin", workByteSize, workHost, workByteSize);

    aclrtMemcpy(xDevice, inputByteSize, xHost, inputByteSize,
                ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(workDevice, workByteSize, workHost, workByteSize,
  	               ACL_MEMCPY_HOST_TO_DEVICE);

    kernel_sequential_block_sync<float><<<BLOCK_NUM, nullptr, stream>>>(xDevice, zDevice, workDevice);
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(zHost, outputByteSize, zDevice, outputByteSize,
                ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", zHost, outputByteSize);

    aclrtFree(xDevice);
    aclrtFree(zDevice);
    aclrtFree(workDevice);
    aclrtFreeHost(xHost);
    aclrtFreeHost(zHost);
    aclrtFreeHost(workHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();

    return 0;
}
