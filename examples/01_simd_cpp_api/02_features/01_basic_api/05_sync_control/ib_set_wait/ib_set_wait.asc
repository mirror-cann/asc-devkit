/* !
 * \file ib_set_wait.asc
 * \brief 基于IBSet和IBWait实现核间同步，解决多核协同操作同一块全局内存时的数据依赖问题
 */

#include "acl/acl.h"
#include "data_utils.h"
#include "kernel_operator.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

constexpr int32_t TOTAL_LENGTH = 2 * 256;
constexpr int32_t USE_CORE_NUM = 2;
constexpr int32_t BLOCK_LENGTH = TOTAL_LENGTH / USE_CORE_NUM;

__global__ __vector__ void kernel_ib_set_wait(__gm__ uint8_t* x, __gm__ uint8_t* y, __gm__ uint8_t* sync, __gm__ uint8_t* z)
{
    AscendC::TPipe pipe;
    int32_t blockIdx = AscendC::GetBlockIdx();

    AscendC::GlobalTensor<half> xGm, yGm, zGm;
    AscendC::GlobalTensor<int32_t> sync_gm;
    // 设置全局内存地址，x和y为输入数据，z为输出数据，sync为同步信号缓冲区
    xGm.SetGlobalBuffer((__gm__ half*)x);
    yGm.SetGlobalBuffer((__gm__ half*)y);
    sync_gm.SetGlobalBuffer((__gm__ int32_t *)(sync), 256);
    zGm.SetGlobalBuffer((__gm__ half*)z);

    AscendC::TQue<AscendC::TPosition::VECIN, 1> inQueueX, inQueueY, vecIn;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> outQueueZ;
    pipe.InitBuffer(inQueueX, 1, BLOCK_LENGTH * sizeof(half));
    pipe.InitBuffer(inQueueY, 1, BLOCK_LENGTH * sizeof(half));
    pipe.InitBuffer(vecIn, 1, 8 * sizeof(int32_t));
    pipe.InitBuffer(outQueueZ, 1, BLOCK_LENGTH * sizeof(half));

    // 核1（blockIdx=1）需要等待核0完成z的写操作，避免读后写依赖问题
    if (blockIdx == 1) {
        auto sync_buf = vecIn.AllocTensor<int32_t>();
        // 等待核0的同步标志位0，确保核0已完成z的写操作
        AscendC::IBWait(sync_gm, sync_buf, 0, 0);
        vecIn.FreeTensor(sync_buf);
    }

    AscendC::LocalTensor<half> xLocal = inQueueX.AllocTensor<half>();
    AscendC::LocalTensor<half> yLocal = inQueueY.AllocTensor<half>();
    // 根据blockIdx从全局内存搬运不同的数据到本地内存
    // blockIdx=1：搬运z[0:256]和y[256:512]（z是核0的输出，y是共享输入）
    // blockIdx=0：搬运x[0:256]和y[0:256]（x和y都是输入）
    if (blockIdx == 1) {
        AscendC::DataCopy(xLocal, zGm[0 * BLOCK_LENGTH], BLOCK_LENGTH);
        AscendC::DataCopy(yLocal, yGm[1 * BLOCK_LENGTH], BLOCK_LENGTH);
    } else {
        AscendC::DataCopy(xLocal, xGm[0], BLOCK_LENGTH);
        AscendC::DataCopy(yLocal, yGm[0], BLOCK_LENGTH);
    }
    inQueueX.EnQue(xLocal);
    inQueueY.EnQue(yLocal);

    xLocal = inQueueX.DeQue<half>();
    yLocal = inQueueY.DeQue<half>();
    AscendC::LocalTensor<half> zLocal = outQueueZ.AllocTensor<half>();
    AscendC::Add(zLocal, xLocal, yLocal, BLOCK_LENGTH);
    outQueueZ.EnQue<half>(zLocal);
    inQueueX.FreeTensor(xLocal);
    inQueueY.FreeTensor(yLocal);

    zLocal = outQueueZ.DeQue<half>();
    AscendC::DataCopy(zGm[blockIdx * BLOCK_LENGTH], zLocal, BLOCK_LENGTH);
    outQueueZ.FreeTensor(zLocal);
    
    // 核0（blockIdx=0）完成计算后，设置同步标志位通知核1可以读取z
    if (blockIdx == 0) {
        auto sync_buf = vecIn.AllocTensor<int32_t>();
        // 设置同步标志位0，通知核1已完成z的写操作
        AscendC::IBSet(sync_gm, sync_buf, 0, 0);
        vecIn.FreeTensor(sync_buf);
    }
}

int32_t main(int32_t argc, char* argv[])
{
  uint32_t numBlocks = 2;
  size_t inputByteSize = 512 * sizeof(half);
  size_t outputByteSize = 512 * sizeof(half);

  int32_t deviceId = 0;
  aclrtSetDevice(deviceId);
  aclrtStream stream = nullptr;
  aclrtCreateStream(&stream);

  uint8_t *xHost, *yHost, *zHost, *syncHost;
  uint8_t *xDevice, *yDevice, *zDevice, *syncDevice;

  aclrtMallocHost((void **)(&xHost), inputByteSize);
  aclrtMallocHost((void **)(&yHost), inputByteSize);
  aclrtMallocHost((void **)(&syncHost), inputByteSize);
  aclrtMallocHost((void **)(&zHost), outputByteSize);
  aclrtMalloc((void **)&xDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
  aclrtMalloc((void **)&yDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
  aclrtMalloc((void **)&syncDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
  aclrtMalloc((void **)&zDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);

  ReadFile("./input/input_x.bin", inputByteSize, xHost, inputByteSize);
  ReadFile("./input/input_y.bin", inputByteSize, yHost, inputByteSize);
  ReadFile("./input/input_sync.bin", inputByteSize, syncHost, inputByteSize);
  aclrtMemcpy(xDevice, inputByteSize, xHost, inputByteSize,
              ACL_MEMCPY_HOST_TO_DEVICE);
  aclrtMemcpy(yDevice, inputByteSize, yHost, inputByteSize,
              ACL_MEMCPY_HOST_TO_DEVICE);
  aclrtMemcpy(syncDevice, inputByteSize, syncHost, inputByteSize,
              ACL_MEMCPY_HOST_TO_DEVICE);

  kernel_ib_set_wait<<<numBlocks, nullptr, stream>>>(xDevice, yDevice, syncDevice, zDevice);
  aclrtSynchronizeStream(stream);

  aclrtMemcpy(zHost, outputByteSize, zDevice, outputByteSize,
              ACL_MEMCPY_DEVICE_TO_HOST);
  WriteFile("./output/output.bin", zHost, outputByteSize);

  aclrtFree(xDevice);
  aclrtFree(yDevice);
  aclrtFree(syncDevice);
  aclrtFree(zDevice);
  aclrtFreeHost(xHost);
  aclrtFreeHost(yHost);
  aclrtFreeHost(syncHost);
  aclrtFreeHost(zHost);

  aclrtDestroyStream(stream);
  aclrtResetDevice(deviceId);
  aclFinalize();

  return 0;
}
