/* !
 * \file move_reg_scenario_1.asc
 * \brief 场景1：MaskGenWithRegTensor下采样场景
 */

#include "acl/acl.h"
#include "kernel_operator.h"
#include "data_utils.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

template <typename T>
__simd_vf__ inline void MaskGenVF(__ubuf__ T* condAddr, __ubuf__ uint8_t* maskOutAddr)
{
    AscendC::Reg::RegTensor<T> condReg;
    AscendC::Reg::MaskReg maskReg;

    AscendC::Reg::LoadAlign(condReg, condAddr);
    AscendC::Reg::MaskGenWithRegTensor<T, 0>(maskReg, condReg);
    AscendC::Reg::StoreAlign(maskOutAddr, maskReg);
}

template <typename T, uint32_t totalLength, uint32_t maskOutSize>
class KernelScenario1 {
public:
    __aicore__ inline void Init(__gm__ uint8_t* cond, __gm__ uint8_t* maskOut)
    {
        this->condGm.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(cond));
        this->maskOutGm.SetGlobalBuffer(reinterpret_cast<__gm__ uint8_t*>(maskOut));
    }

    __aicore__ inline void Process()
    {
        AscendC::LocalMemAllocator<AscendC::Hardware::UB> ubAllocator;
        AscendC::LocalTensor<T> condLocal = ubAllocator.Alloc<T, totalLength>();
        AscendC::LocalTensor<uint8_t> maskOutLocal = ubAllocator.Alloc<uint8_t, maskOutSize>();

        AscendC::DataCopy(condLocal, condGm, totalLength);

        AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);

        __ubuf__ T* condAddr = reinterpret_cast<__ubuf__ T*>(condLocal.GetPhyAddr());
        __ubuf__ uint8_t* maskOutAddr = reinterpret_cast<__ubuf__ uint8_t*>(maskOutLocal.GetPhyAddr());

        asc_vf_call<MaskGenVF<int32_t>>(condAddr, maskOutAddr);

        AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);

        AscendC::DataCopy(maskOutGm, maskOutLocal, maskOutSize);
    }

private:
    AscendC::GlobalTensor<T> condGm;
    AscendC::GlobalTensor<uint8_t> maskOutGm;
};

template<typename T, uint32_t totalLength, uint32_t maskOutSize>
__global__ __vector__ void move_reg_scenario_1(__gm__ uint8_t* cond, __gm__ uint8_t* maskOut)
{
    AscendC::InitSocState();
    KernelScenario1<T, totalLength, maskOutSize> kernel;
    kernel.Init(cond, maskOut);
    kernel.Process();
    AscendC::PipeBarrier<PIPE_ALL>();
}

static bool CompareMaskResult(const void* outputData, const void* goldenData, uint32_t outSize)
{
    int64_t wrongNum = 0;
    const uint8_t* output = reinterpret_cast<const uint8_t*>(outputData);
    const uint8_t* golden = reinterpret_cast<const uint8_t*>(goldenData);

    for (size_t i = 0; i < outSize; i++) {
        if (output[i] != golden[i]) {
            printf("CompareMaskResult failed at byte %zu: output=0x%02x, golden=0x%02x\n", i, output[i], golden[i]);
            wrongNum++;
        }
    }

    if (wrongNum != 0) {
        return false;
    } else {
        printf("CompareMaskResult success!\n");
        return true;
    }
}

int32_t main(int32_t argc, char* argv[])
{
    uint32_t numBlocks = 1;
    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    constexpr uint32_t totalLength = 64;
    constexpr uint32_t maskOutSize = 32;
    size_t inputByteSize = totalLength * sizeof(int32_t);
    size_t maskOutByteSize = maskOutSize;

    uint8_t *condHost, *maskOutHost;
    uint8_t *condDevice, *maskOutDevice;
    aclrtMallocHost((void**)(&condHost), inputByteSize);
    aclrtMallocHost((void**)(&maskOutHost), maskOutByteSize);
    aclrtMalloc((void**)&condDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&maskOutDevice, maskOutByteSize, ACL_MEM_MALLOC_HUGE_FIRST);

    ReadFile("./input/input_cond.bin", inputByteSize, condHost, inputByteSize);
    aclrtMemcpy(condDevice, inputByteSize, condHost, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);

    move_reg_scenario_1<int32_t, totalLength, maskOutSize>
        <<<numBlocks, nullptr, stream>>>(condDevice, maskOutDevice);
    aclrtSynchronizeStream(stream);
    aclrtMemcpy(maskOutHost, maskOutByteSize, maskOutDevice, maskOutByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", maskOutHost, maskOutByteSize);

    void* goldenData;
    aclrtMallocHost((void**)(&goldenData), maskOutByteSize);
    size_t goldenSize = maskOutByteSize;
    bool ret = ReadFile("./output/golden.bin", goldenSize, goldenData, goldenSize);
    if (ret) {
        printf("ReadFile golden.bin success!\n");
    } else {
        printf("test failed!\n");
        aclrtFreeHost(goldenData);
        aclrtFree(condDevice);
        aclrtFree(maskOutDevice);
        aclrtFreeHost(condHost);
        aclrtFreeHost(maskOutHost);
        aclrtDestroyStream(stream);
        aclrtResetDevice(deviceId);
        aclFinalize();
        return -1;
    }

    bool result = CompareMaskResult(maskOutHost, goldenData, maskOutByteSize);
    aclrtFreeHost(goldenData);

    if (result) {
        printf("test pass!\n");
    } else {
        printf("test failed!\n");
    }

    aclrtFree(condDevice);
    aclrtFree(maskOutDevice);
    aclrtFreeHost(condHost);
    aclrtFreeHost(maskOutHost);
    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();
    return 0;
}