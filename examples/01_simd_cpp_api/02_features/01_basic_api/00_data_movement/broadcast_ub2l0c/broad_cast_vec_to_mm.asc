/* !
 * \file broad_cast_vec_to_mm.asc
 * \brief 基于BroadCastVecToMM实现数据广播搬运样例，将shape为[16]的数据广播到[16, 16]
 */

#include "acl/acl.h"
#include "data_utils.h"
#include "kernel_operator.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

constexpr int32_t INPUT_LENGTH = 16;
constexpr int32_t OUTPUT_LENGTH = 16 * 16;

class KernelBroadCastVecToMM {
public:
    __aicore__ inline KernelBroadCastVecToMM() {}
    __aicore__ inline void Init(__gm__ uint8_t* srcGm, __gm__ uint8_t* dstGm)
    {
        srcGlobal.SetGlobalBuffer((__gm__ float*)srcGm);
        dstGlobal.SetGlobalBuffer((__gm__ float*)dstGm);
    }
    __aicore__ inline void Process()
    {
        AscendC::LocalTensor<float> srcLocal(AscendC::TPosition::VECIN, srcAddr, INPUT_LENGTH);
        AscendC::LocalTensor<float> brcLocal(AscendC::TPosition::CO1, brcAddr, OUTPUT_LENGTH);
        AscendC::LocalTensor<float> dstLocal(AscendC::TPosition::CO2, dstAddr, OUTPUT_LENGTH);

        AscendC::DataCopy(srcLocal, srcGlobal, INPUT_LENGTH);
        AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);

        // blockCount = 1, blockLen = 1, 256 elements total
        // srcGap = 0, dstGap = 1
        AscendC::BroadCastVecToMM(brcLocal, srcLocal, 1, 1, 0, 1);
        AscendC::PipeBarrier<PIPE_V>();

        AscendC::DataCopyParams dataCopyParams;
        dataCopyParams.blockCount = 1;
        dataCopyParams.blockLen = 1;
        AscendC::DataCopyEnhancedParams enhancedParams;
        enhancedParams.blockMode = AscendC::BlockMode::BLOCK_MODE_MATRIX;
        // L0C -> UB
        AscendC::DataCopy(dstLocal, brcLocal, dataCopyParams, enhancedParams);

        AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        AscendC::DataCopy(dstGlobal, dstLocal, OUTPUT_LENGTH);
    }

private:
    uint64_t srcAddr = 0;
    uint64_t brcAddr = 0;
    uint64_t dstAddr = 0;
    AscendC::GlobalTensor<float> srcGlobal, dstGlobal;
};

__global__ __vector__ void broad_cast_vec_to_mm_custom(__gm__ uint8_t* x, __gm__ uint8_t* z)
{
    AscendC::InitSocState();
    KernelBroadCastVecToMM op;
    op.Init(x, z);
    op.Process();
    AscendC::PipeBarrier<PIPE_ALL>();
}

int32_t main(int32_t argc, char* argv[])
{
    uint32_t numBlocks = 1;
    size_t inputByteSize = 16 * sizeof(uint32_t);
    size_t outputByteSize = 256 * sizeof(uint32_t);

    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t *xHost, *zHost;
    uint8_t *xDevice, *zDevice;

    aclrtMallocHost((void**)(&xHost), inputByteSize);
    aclrtMallocHost((void**)(&zHost), outputByteSize);
    aclrtMalloc((void**)&xDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&zDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);

    ReadFile("./input/input_x.bin", inputByteSize, xHost, inputByteSize);

    aclrtMemcpy(xDevice, inputByteSize, xHost, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);

    broad_cast_vec_to_mm_custom<<<numBlocks, nullptr, stream>>>(xDevice, zDevice);
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(zHost, outputByteSize, zDevice, outputByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", zHost, outputByteSize);

    aclrtFree(xDevice);
    aclrtFree(zDevice);
    aclrtFreeHost(xHost);
    aclrtFreeHost(zHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();

    return 0;
}
