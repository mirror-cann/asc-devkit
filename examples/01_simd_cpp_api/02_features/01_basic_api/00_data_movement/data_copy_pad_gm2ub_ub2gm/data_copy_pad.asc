/* !
 * \file data_copy_pad.asc
 * \brief 演示使用DataCopyPad实现非32字节对齐数据搬运及填充功能
 */

#include "acl/acl.h"
#include "data_utils.h"
#include "kernel_operator.h"

constexpr uint32_t scenarioNum = SCENARIO_NUM;

constexpr uint32_t CeilAlignConst(uint32_t value, uint32_t align) {
    return (value + align - 1) / align * align;
}

// 场景1：输入[1, 20]，输出[1, 32]，使用SetPadValue进行自定义填充
// 场景2：输入[32, 59]，输出[32, 64]，使用rightPadding进行默认
// 场景3：输入[3, 24]，输出[1, 80]，使用Compact模式，仅支持 Ascend 950PR/Ascend 950DT
// 场景4：输入[1, 320]，输出[1, 576]个int8元素，使用SetLoopModePara使能loop mode（Compact模式），实现GM→UB非连续stride搬运，仅支持 Ascend 950PR/Ascend 950DT
// 场景5：输入[1, 320]，输出[1, 576]个int8元素，使用SetLoopModePara使能loop mode（Normal模式），实现GM→UB非连续stride搬运，仅支持 Ascend 950PR/Ascend 950DT
// 场景6：输入[2, 4, 3, 128, 126]五维，搬运[2, 2, 2, 64, 126]，UB中连续存放为[512, 128]，尾轴每行补2个0，使用loop mode（Normal模式），仅支持 Ascend 950PR/Ascend 950DT

// 场景4/5参数
constexpr uint32_t BLOCK_LEN = 40;      // 每个数据块长度，单位Bytes
constexpr uint32_t BLOCK_COUNT = 2;     // 连续搬运的数据块数量
constexpr uint32_t LOOP1_SIZE = 2;      // 内层循环次数
constexpr uint32_t LOOP2_SIZE = 2;      // 外层循环次数
constexpr uint32_t TOTAL_DATA_SIZE = BLOCK_LEN * BLOCK_COUNT * LOOP1_SIZE * LOOP2_SIZE; // 320 Bytes

constexpr uint32_t LOOP1_SRC_STRIDE = 80;   // 内层循环源数据stride
constexpr uint32_t LOOP1_DST_STRIDE = 128;  // 内层循环目的数据stride（32B对齐）
constexpr uint32_t LOOP2_SRC_STRIDE = 160;  // 外层循环源数据stride
constexpr uint32_t LOOP2_DST_STRIDE = 288;  // 外层循环目的数据stride（32B对齐）


/**
 * @brief DataCopyPad样例的Kernel类，实现非32字节对齐数据搬运及填充功能
 */
template <typename T, uint32_t srcRows, uint32_t srcCols, uint32_t dstCols, uint32_t dstTotalLength>
class KernelDataCopyPad {
public:
    __aicore__ inline KernelDataCopyPad() {}
    __aicore__ inline void Init(__gm__ uint8_t* x, __gm__ uint8_t* z)
    {
        srcGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(x));
        dstGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(z));
    }
    __aicore__ inline void Process()
    {
        AscendC::LocalMemAllocator<AscendC::Hardware::UB> ubAllocator;
        AscendC::LocalTensor<T> srcLocal = ubAllocator.Alloc<T, dstTotalLength>();
        CopyIn(srcLocal);
        AscendC::SetFlag<AscendC::HardEvent::MTE2_MTE3>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_MTE3>(EVENT_ID0);
        AscendC::DataCopyExtParams copyParams{1, dstTotalLength * sizeof(T), 0, 0, 0};
        AscendC::DataCopyPad(dstGlobal, srcLocal, copyParams);
    }
private:
    __aicore__ inline void CopyIn(AscendC::LocalTensor<T>& srcLocal)
    {
        // 场景4/5/6：将srcLocal置0，确保间隔区域和padding区域初始值为0
        if constexpr (scenarioNum == 4 || scenarioNum == 5 || scenarioNum == 6) {
            AscendC::Duplicate<T>(srcLocal, (T)0, dstTotalLength);
            AscendC::SetFlag<AscendC::HardEvent::V_MTE2>(EVENT_ID0);
            AscendC::WaitFlag<AscendC::HardEvent::V_MTE2>(EVENT_ID0);
        }

        if constexpr (scenarioNum == 1) {
            // 场景1：使用SetPadValue进行自定义填充
            // DataCopyExtParams参数：blockCount=1, blockLen=20*sizeof(half), srcBlkStride=0, srcRepStride=0, reserved=0
            // DataCopyPadExtParams参数：isPad=false, leftPadding=0, rightPadding=12
            // SetPadValue设置填充值为1，配合isPad=false使用
            AscendC::DataCopyExtParams copyParams{1, srcCols * sizeof(T), 0, 0, 0};
            AscendC::DataCopyPadExtParams<T> padParams;
            padParams.isPad = false;
            padParams.leftPadding = 0;
            padParams.rightPadding = dstCols - srcCols;

            AscendC::SetPadValue((T)1);
            AscendC::DataCopyPad(srcLocal, srcGlobal, copyParams, padParams);
        } else if constexpr (scenarioNum == 2) {
            // 场景2：使用rightPadding进行默认填充
            // DataCopyExtParams参数：blockCount=32, blockLen=59*sizeof(float), srcBlkStride=0, srcRepStride=0, reserved=0
            // DataCopyPadExtParams参数：isPad=true, leftPadding=0, rightPadding=5
            // isPad=true时填充值为0，不使用SetPadValue
            AscendC::DataCopyExtParams copyParams{srcRows, srcCols * sizeof(float), 0, 0, 0};
            AscendC::DataCopyPadExtParams<T> padParams;
            padParams.isPad = true;
            padParams.leftPadding = 0;
            padParams.rightPadding = dstCols - srcCols;

            AscendC::DataCopyPad(srcLocal, srcGlobal, copyParams, padParams);
        }
#if defined(__NPU_ARCH__) && (__NPU_ARCH__ == 3510)
        else if constexpr (scenarioNum == 3) {
            // 场景3：使用Compact模式进行紧凑填充（仅支持 Ascend 950PR/Ascend 950DT）
            // DataCopyExtParams参数：blockCount=3, blockLen=24*sizeof(half), srcBlkStride=0, srcRepStride=0, reserved=0
            // DataCopyPadExtParams参数：isPad=true, leftPadding=0, rightPadding=16
            // PaddingMode::Compact：将多行数据紧凑排列到一行，填充区域紧凑放置在数据之后
            // 输入[3, 24]紧凑排列为[1, 80]，前72个元素为3行数据，后8个元素为填充区域
            AscendC::DataCopyExtParams copyParams{srcRows, srcCols * sizeof(T), 0, 0, 0};
            AscendC::DataCopyPadExtParams<T> padParams;
            padParams.isPad = true;
            padParams.leftPadding = 0;
            padParams.rightPadding = dstCols - srcCols * srcRows;

            AscendC::DataCopyPad<T, AscendC::PaddingMode::Compact>(srcLocal, srcGlobal, copyParams, padParams);
        } else if constexpr (scenarioNum == 4) {
            // 场景4：使用SetLoopModePara使能loop mode进行数据搬运（仅支持 Ascend 950PR/Ascend 950DT）
            // Compact模式：每次内层循环搬运80B后填充16B使其96B对齐
            // padding值设为-1
            AscendC::DataCopyExtParams copyParams{BLOCK_COUNT, BLOCK_LEN, 0, 0, 0};
            AscendC::DataCopyPadExtParams<T> padParams{true, 0, 0, -1};

            AscendC::LoopModeParams loopParam2Ub {LOOP1_SIZE, LOOP2_SIZE, LOOP1_SRC_STRIDE, LOOP1_DST_STRIDE, LOOP2_SRC_STRIDE, LOOP2_DST_STRIDE};
            AscendC::SetLoopModePara(loopParam2Ub, AscendC::DataCopyMVType::OUT_TO_UB);
            AscendC::DataCopyPad<int8_t, AscendC::PaddingMode::Compact>(srcLocal, srcGlobal, copyParams, padParams);
            AscendC::ResetLoopModePara(AscendC::DataCopyMVType::OUT_TO_UB);
        } else if constexpr (scenarioNum == 5) {
            // 场景5：使用SetLoopModePara使能loop mode进行数据搬运（仅支持 Ascend 950PR/Ascend 950DT）
            // Normal模式：每个block搬运40B后填充24B使其64B对齐
            // padding值设为-1
            AscendC::DataCopyExtParams copyParams{BLOCK_COUNT, BLOCK_LEN, 0, 0, 0};
            AscendC::DataCopyPadExtParams<T> padParams{true, 0, 0, -1};

            AscendC::LoopModeParams loopParam2Ub {LOOP1_SIZE, LOOP2_SIZE, LOOP1_SRC_STRIDE, LOOP1_DST_STRIDE, LOOP2_SRC_STRIDE, LOOP2_DST_STRIDE};
            AscendC::SetLoopModePara(loopParam2Ub, AscendC::DataCopyMVType::OUT_TO_UB);
            AscendC::DataCopyPad<int8_t>(srcLocal, srcGlobal, copyParams, padParams);
            AscendC::ResetLoopModePara(AscendC::DataCopyMVType::OUT_TO_UB);
        } else if constexpr (scenarioNum == 6) {
            // 场景6：五维数据搬运 GM[2, 4, 3, 128, 126]int8 -> UB[512, 128]int8
            // Normal模式，使用loop mode
            // 搬运规格：[2, 2, 2, 64, 126]，每个126字节补2字节padding到128字节
            // 最终UB连续存放为[512, 128]

            // Stride参数说明：
            // - loop1SrcStride=128*126：第2维stride，每次loop1源地址跳过128*126字节
            // - loop1DstStride=64*128：每次loop1目的地址跳过64*128字节（64行×128字节/行）
            // - loop2SrcStride=3*128*126：第1维stride，每次loop2源地址跳过3*128*126字节
            // - loop2DstStride=2*64*128：每次loop2目的地址跳过2*64*128字节

            AscendC::LoopModeParams loopParam2Ub {
                2,  // loop1Size=2（第2维搬运2次）
                2,  // loop2Size=2（第1维搬运2次）
                128 * 126,  // loop1SrcStride（第2维stride）
                64 * 128,   // loop1DstStride
                3 * 128 * 126,  // loop2SrcStride（第1维stride）
                2 * 64 * 128    // loop2DstStride
            };
            AscendC::SetLoopModePara(loopParam2Ub, AscendC::DataCopyMVType::OUT_TO_UB);

            AscendC::DataCopyExtParams copyParams{
                64,  // blockCount=64（第3维搬运64次）
                126,  // blockLen=126（第4维搬运126字节，padding到128）
                0, 0, 0  // srcStride/dstStride=0
            };
            AscendC::DataCopyPadExtParams<int8_t> padParams{true, 0, 0, 0};

            // 第0维for循环搬运2次
            for (uint32_t dim0 = 0; dim0 < 2; dim0++) {
                constexpr uint32_t dim0SrcStride = 4 * 3 * 128 * 126;  // 第0维源stride
                constexpr uint32_t dim0DstStride = 2 * 2 * 64 * 128;   // 第0维目的stride
                uint32_t srcOffset = dim0 * dim0SrcStride;
                uint32_t dstOffset = dim0 * dim0DstStride;

                AscendC::DataCopyPad<int8_t>(srcLocal[dstOffset], srcGlobal[srcOffset], copyParams, padParams);
            }

            AscendC::ResetLoopModePara(AscendC::DataCopyMVType::OUT_TO_UB);
        }
#endif
    }
private:
    AscendC::GlobalTensor<T> srcGlobal;
    AscendC::GlobalTensor<T> dstGlobal;
};

template <uint32_t srcRows, uint32_t srcCols, uint32_t dstCols, uint32_t dstTotalLength>
__global__ __vector__ void data_copy_pad_custom(__gm__ uint8_t* x, __gm__ uint8_t* z)
{
    AscendC::InitSocState();
    if constexpr (scenarioNum == 2) {
        KernelDataCopyPad<float, srcRows, srcCols, dstCols, dstTotalLength> op;
        op.Init(x, z);
        op.Process();
    } else if constexpr (scenarioNum == 4 || scenarioNum == 5 || scenarioNum == 6) {
        // 场景4/5/6使用int8_t类型，SetLoopModePara仅支持int8_t
        KernelDataCopyPad<int8_t, srcRows, srcCols, dstCols, dstTotalLength> op;
        op.Init(x, z);
        op.Process();
    } else {
        KernelDataCopyPad<half, srcRows, srcCols, dstCols, dstTotalLength> op;
        op.Init(x, z);
        op.Process();
    }
    AscendC::PipeBarrier<PIPE_ALL>();
}

int32_t main(int32_t argc, char* argv[])
{
    // 场景4/5：使用SetLoopModePara，数据类型int8，输入320个元素，输出576个元素
    // blockLen=40, blockCount=2，每次搬运40Bytes，连续搬运2块
    // loop1Size=2, loop2Size=2，内层循环2次，外层循环2次，总共搬运 40*2*2*2=320Bytes
    constexpr uint32_t SRC_ROWS =
        (scenarioNum == 2) ? 32 :
        (scenarioNum == 3) ? 3 :
        (scenarioNum == 6) ? 2 : 1;
    constexpr uint32_t SRC_COLS =
        (scenarioNum == 1) ? 20 :
        (scenarioNum == 2) ? 59 :
        (scenarioNum == 3) ? 24 :
        (scenarioNum == 4 || scenarioNum == 5) ? 320 :
        (scenarioNum == 6) ? 4 * 3 * 128 * 126 : 20; // 场景6: 2*4*3*128*126，但只搬运2*2*2*64*126
    constexpr uint32_t DST_COLS =
        (scenarioNum == 1) ? 32 :
        (scenarioNum == 2) ? 64 :
        (scenarioNum == 3) ? 80 :
        (scenarioNum == 4 || scenarioNum == 5) ? 576 :
        (scenarioNum == 6) ? 128 : 32;
    constexpr uint32_t DST_TOTAL_LENGTH =
        (scenarioNum >= 3 && scenarioNum != 6) ? DST_COLS :
        (scenarioNum == 6) ? 512* 128 : SRC_ROWS * DST_COLS;

    uint32_t numBlocks = 1;
    size_t elementSize = 0;

    if constexpr (scenarioNum == 2) {
        elementSize = sizeof(float);
    } else if constexpr (scenarioNum == 4 || scenarioNum == 5 || scenarioNum == 6) {
        elementSize = sizeof(int8_t);
    } else {
        elementSize = sizeof(half);
    }

    size_t inputByteSize = 0;
    if constexpr (scenarioNum == 6) {
        // 场景6：GM形状[2, 4, 3, 128, 126]int8
        inputByteSize = 2 * 4 * 3 * 128 * 126 * sizeof(int8_t);
    } else {
        inputByteSize = SRC_ROWS * SRC_COLS * elementSize;
    }

    size_t outputByteSize = DST_TOTAL_LENGTH * elementSize;

    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t *xHost, *zHost;
    uint8_t *xDevice, *zDevice;

    aclrtMallocHost((void **)(&xHost), inputByteSize);
    aclrtMallocHost((void **)(&zHost), outputByteSize);
    aclrtMalloc((void **)&xDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void **)&zDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);

    ReadFile("./input/input_x.bin", inputByteSize, xHost, inputByteSize);

    aclrtMemcpy(xDevice, inputByteSize, xHost, inputByteSize,
                ACL_MEMCPY_HOST_TO_DEVICE);

    data_copy_pad_custom<SRC_ROWS, SRC_COLS, DST_COLS, DST_TOTAL_LENGTH><<<numBlocks, nullptr, stream>>>(xDevice, zDevice);

    aclrtSynchronizeStream(stream);

    aclrtMemcpy(zHost, outputByteSize, zDevice, outputByteSize,
                ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", zHost, outputByteSize);

    aclrtFree(xDevice);
    aclrtFree(zDevice);
    aclrtFreeHost(xHost);
    aclrtFreeHost(zHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();

    return 0;
}
