/* !
 * \file fixpipe_l0c2gm.asc
 * \brief 本样例介绍如何使用Fixpipe将矩阵乘的结果从L0C Buffer搬出到GM（Global Memory）
 */

#include "acl/acl.h"
#include "kernel_operator.h"
#include "data_utils.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

// half type, cube block: [16, 16]
constexpr uint32_t CUBE_BLOCK = 16;
constexpr uint32_t C0_SIZE = 32;
constexpr uint32_t CUBE_BLOCK_SIZE = 16 * 16;

constexpr uint32_t K_ROUND = 2;

constexpr static uint16_t LIMIT_MNSIZE = 10;
constexpr static uint16_t ALIGN_NUM = 16;

template <class inputType, class outputType, class l0cType, uint32_t baseM, uint32_t baseK, uint32_t baseN>
class KernelFixpipe {
public:
    __aicore__ inline KernelFixpipe()
    {
        AscendC::InitSocState();
        aSingleSize = baseM * baseK;
        bSingleSize = baseK * baseN;
        cSingleSize = baseM * baseN;

        // A 不转置
        aSizeAlignL1 = CeilAlign(baseM, CUBE_BLOCK) * CeilAlign(baseK, C0_SIZE);
        aSizeAlignL0 = CeilAlign(baseM, CUBE_BLOCK) * CeilAlign(baseK, C0_SIZE);
        // B 不转置
        bSizeAlignL1 = CeilAlign(baseK, C0_SIZE) * CeilAlign(baseN, C0_SIZE);
        bSizeAlignL0 = CeilAlign(baseK, C0_SIZE) * CeilAlign(baseN, C0_SIZE);
        // C矩阵无视数据类型和a、b是否转置，m,n都向16对齐
        cSizeAlignL0 = CeilAlign(baseM, CUBE_BLOCK) * CeilAlign(baseN, CUBE_BLOCK);
    }

    __aicore__ inline void Init(__gm__ uint8_t* a, __gm__ uint8_t* b, __gm__ uint8_t* c, __gm__ uint8_t* quantAlpha)
    {
        aGM.SetGlobalBuffer((__gm__ inputType *)a);
        bGM.SetGlobalBuffer((__gm__ inputType *)b);
        cGM.SetGlobalBuffer((__gm__ outputType *)c);
        quantAlphaGM.SetGlobalBuffer((__gm__ uint64_t *)quantAlpha);

    }

    __aicore__ inline void Process()
    {
        uint32_t chunkSize = K_ROUND;
        AscendC::LocalTensor<inputType> a1Local(AscendC::TPosition::A1, a1Addr, aSizeAlignL1);
        AscendC::LocalTensor<inputType> a2Local(AscendC::TPosition::A2, a2Addr, aSizeAlignL0);
        AscendC::LocalTensor<inputType> b1Local(AscendC::TPosition::B1, b1Addr, bSizeAlignL1);
        AscendC::LocalTensor<inputType> b2Local(AscendC::TPosition::B2, b2Addr, bSizeAlignL0);
        AscendC::LocalTensor<l0cType> c(AscendC::TPosition::CO1, co1Addr, cSizeAlignL0);
        for (uint32_t kIndex = 0; kIndex < chunkSize; kIndex++) {
            CopyIn(kIndex, a1Local, b1Local);
            AscendC::SetFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID0);
            AscendC::WaitFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID0);
            SplitA(kIndex, a1Local, a2Local);
            SplitB(kIndex, b1Local, b2Local);
            AscendC::SetFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID0);
            AscendC::WaitFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID0);
            Compute(kIndex, c, a2Local, b2Local);
            AscendC::SetFlag<AscendC::HardEvent::M_MTE2>(EVENT_ID0);
            AscendC::WaitFlag<AscendC::HardEvent::M_MTE2>(EVENT_ID0);
        }

        AscendC::SetFlag<AscendC::HardEvent::M_FIX>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::M_FIX>(EVENT_ID0);
        CopyOut(c);
    }

private:
    __aicore__ inline uint16_t CeilDivision(uint16_t numerator, uint16_t denominator)
    {
        return (numerator + denominator - 1) / denominator;
    }

    __aicore__ inline uint16_t CeilAlign(uint16_t numerator, uint16_t denominator)
    {
        return (numerator + denominator - 1) / denominator * denominator;
    }

    __aicore__ inline void CopyQuantAlphaGmToL1(AscendC::LocalTensor<uint64_t> quantAlphaTensor)
    {
        AscendC::SetFlag<AscendC::HardEvent::FIX_MTE2>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::FIX_MTE2>(EVENT_ID0);
        uint16_t burstLen = CeilAlign(baseN * sizeof(uint64_t), 128) / 32;
        AscendC::DataCopyParams intriParams{ 1, burstLen, 0, 0 };
        AscendC::DataCopy(quantAlphaTensor, quantAlphaGM, intriParams);
        AscendC::SetFlag<AscendC::HardEvent::MTE2_FIX>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_FIX>(EVENT_ID0);
    }

    __aicore__ inline void CopyIn(uint32_t kIndex, AscendC::LocalTensor<inputType> a1Local, AscendC::LocalTensor<inputType> b1Local)
    {
        AscendC::Nd2NzParams nd2nzA1Params;
        // 传输ND矩阵的数目
        nd2nzA1Params.ndNum = 1;
        nd2nzA1Params.nValue = baseM;
        nd2nzA1Params.dValue = baseK;
        // 源操作数相邻ND矩阵起始地址间的偏移，单位为元素。
        nd2nzA1Params.srcNdMatrixStride = 0;
        nd2nzA1Params.srcDValue = baseK;
        // 目的NZ矩阵中，来自源操作数同一行的多行数据相邻行起始地址间的偏移，取值范围：dstNzC0Stride∈[1, 16384]，单位：C0_SIZE（32B）。
        nd2nzA1Params.dstNzC0Stride = CeilAlign(baseM, CUBE_BLOCK);
        // 目的NZ矩阵中，Z型矩阵相邻行起始地址之间的偏移。单位：C0_SIZE（32B）。
        nd2nzA1Params.dstNzNStride = 1;
        // 目的NZ矩阵中，相邻NZ矩阵起始地址间的偏移，单位为元素。
        nd2nzA1Params.dstNzMatrixStride = 0;
        AscendC::DataCopy(a1Local, aGM[kIndex * aSingleSize], nd2nzA1Params);

        AscendC::Nd2NzParams nd2nzB1Params;
        nd2nzB1Params.ndNum = 1;
        nd2nzB1Params.nValue = baseK;
        nd2nzB1Params.dValue = baseN;
        nd2nzB1Params.srcNdMatrixStride = 0;
        nd2nzB1Params.srcDValue = baseN;
        nd2nzB1Params.dstNzC0Stride = CeilAlign(baseK, CUBE_BLOCK);
        nd2nzB1Params.dstNzNStride = 1;
        nd2nzB1Params.dstNzMatrixStride = 0;
        AscendC::DataCopy(b1Local, bGM[kIndex * bSingleSize], nd2nzB1Params);
    }

    __aicore__ inline void SplitA(uint32_t kIndex, AscendC::LocalTensor<inputType> a1Local, AscendC::LocalTensor<inputType> a2Local)
    {
#if defined(__NPU_ARCH__) && (__NPU_ARCH__ == 2201)
        uint32_t dstOffset = CeilDivision(baseK, CUBE_BLOCK) * CUBE_BLOCK_SIZE;
        uint32_t srcOffset = CUBE_BLOCK_SIZE;
        // Nz -> Zz
        AscendC::LoadData2DParams loadDataParams;
        loadDataParams.repeatTimes = CeilDivision(baseK, CUBE_BLOCK);
        loadDataParams.srcStride = CeilDivision(baseM, CUBE_BLOCK);
        loadDataParams.dstGap = 0;
        loadDataParams.ifTranspose = false;
        for (int i = 0; i < CeilDivision(baseM, CUBE_BLOCK); ++i) {
            AscendC::LoadData(a2Local[i * dstOffset], a1Local[i * srcOffset], loadDataParams);
        }
#elif defined(__NPU_ARCH__) && (__NPU_ARCH__ == 3510)
        AscendC::LoadData2DParamsV2 loadDataParams;
        loadDataParams.mStep = CeilDivision(baseM, CUBE_BLOCK);
        loadDataParams.kStep = CeilDivision(baseK, C0_SIZE / sizeof(inputType));
        loadDataParams.srcStride = CeilDivision(baseM, CUBE_BLOCK);
        loadDataParams.dstStride = CeilDivision(baseM, CUBE_BLOCK);
        AscendC::LoadData(a2Local, a1Local, loadDataParams);
#endif
    }

    __aicore__ inline void SplitB(uint32_t kIndex, AscendC::LocalTensor<inputType> b1Local, AscendC::LocalTensor<inputType> b2Local)
    {
        uint32_t dstOffset = CeilDivision(baseN, CUBE_BLOCK) * CUBE_BLOCK_SIZE;
        uint32_t srcOffset = CUBE_BLOCK_SIZE;
        // Nz -> Zn
        AscendC::LoadData2DParams loadDataParams;
        loadDataParams.startIndex = 0;
        loadDataParams.repeatTimes = CeilDivision(baseN, CUBE_BLOCK);
        loadDataParams.srcStride = CeilDivision(baseK, CUBE_BLOCK);
        loadDataParams.dstGap = 0;
        loadDataParams.ifTranspose = true;
        for (int i = 0; i < CeilDivision(baseK, CUBE_BLOCK); ++i) {
            AscendC::LoadData(b2Local[i * dstOffset], b1Local[i * srcOffset], loadDataParams);
        }
    }

    __aicore__ inline void Compute(uint32_t kIndex, AscendC::LocalTensor<l0cType> c, AscendC::LocalTensor<inputType> a, AscendC::LocalTensor<inputType> b)
    {
        AscendC::MmadParams mmadParams;
        mmadParams.m = baseM;
        mmadParams.n = CeilAlign(baseN, C0_SIZE);
        mmadParams.k = baseK;
        if (kIndex == 0) {
            mmadParams.cmatrixInitVal = true;
        } else {
            mmadParams.cmatrixInitVal = false;
        }

        AscendC::Mmad(c, a, b, mmadParams);
        if ((baseM / ALIGN_NUM) * (baseN / ALIGN_NUM) < LIMIT_MNSIZE) {
            AscendC::PipeBarrier<PIPE_M>();
        }
    }

    __aicore__ inline void CopyOut(AscendC::LocalTensor<l0cType>& c)
    {
        // 不同场景用于展示Fixpipe的NZ输出、NZ2ND输出、relu、量化等能力，参数差异集中在这里配置。
        if constexpr (SCENARIO_NUM == 1) {
            // 场景1：输出格式NZ，输出数据类型float
            uint16_t c0Size = 16;
#if defined(__NPU_ARCH__) && (__NPU_ARCH__ == 2201)
            AscendC::FixpipeParamsV220 fixpipeParams;
            // NZ2NZ场景，FixpipeParamsV220的dstStride单位为datablock（32Bytes）
            fixpipeParams.dstStride = baseM * c0Size * sizeof(outputType) / AscendC::ONE_BLK_SIZE;
#elif defined(__NPU_ARCH__) && (__NPU_ARCH__ == 3510)
            AscendC::FixpipeParamsArch3510<AscendC::CO2Layout::NZ> fixpipeParams;
            // NZ2NZ场景，FixpipeParamsArch3510的dstStride单位为元素个数
            fixpipeParams.dstStride = baseM * c0Size;
#endif
            fixpipeParams.nSize = CeilAlign(baseN, c0Size);
            fixpipeParams.mSize = baseM;
            fixpipeParams.srcStride = CeilAlign(baseM, CUBE_BLOCK);
            AscendC::Fixpipe<outputType, l0cType, AscendC::CFG_NZ>(cGM, c, fixpipeParams);

        } else if constexpr (SCENARIO_NUM == 2) {
            // 场景2：输出格式ND，输出数据类型float
#if defined(__NPU_ARCH__) && (__NPU_ARCH__ == 2201)
            AscendC::FixpipeParamsV220 fixpipeParams;
            fixpipeParams.ndNum = 1;
            fixpipeParams.srcNdStride = 0;
            fixpipeParams.dstNdStride = 0;
#elif defined(__NPU_ARCH__) && (__NPU_ARCH__ == 3510)
            AscendC::FixpipeParamsArch3510<AscendC::CO2Layout::ROW_MAJOR> fixpipeParams;
#endif
            fixpipeParams.mSize = baseM;
            fixpipeParams.srcStride = CeilAlign(baseM, CUBE_BLOCK);
            // Orignal nSize
            fixpipeParams.nSize = baseN;
            fixpipeParams.dstStride = baseN;
            AscendC::Fixpipe<outputType, l0cType, AscendC::CFG_ROW_MAJOR>(cGM, c, fixpipeParams);

        } else if constexpr (SCENARIO_NUM == 3) {
            // 场景3：输出格式DN，输出数据类型float
#if defined(__NPU_ARCH__) && (__NPU_ARCH__ == 2201)
            assert(false && "Only dav-3510 support DN!");
#elif defined(__NPU_ARCH__) && (__NPU_ARCH__ == 3510)
            AscendC::FixpipeParamsArch3510<AscendC::CO2Layout::COLUMN_MAJOR> fixpipeParams;
            fixpipeParams.mSize = baseM;
            fixpipeParams.srcStride = CeilAlign(baseM, CUBE_BLOCK);
            // Orignal nSize
            fixpipeParams.nSize = baseN;
            fixpipeParams.dstStride = baseM;
            fixpipeParams.params = {1, 0, 0, 1};
            AscendC::Fixpipe<outputType, l0cType, AscendC::CFG_COLUMN_MAJOR>(cGM, c, fixpipeParams);
#endif

        } else if constexpr (SCENARIO_NUM == 4) {
            // 场景4：输出格式ND，输出数据类型int8_t，使能Scalar量化
#if defined(__NPU_ARCH__) && (__NPU_ARCH__ == 2201)
            AscendC::FixpipeParamsV220 fixpipeParams;
            fixpipeParams.ndNum = 1;
            fixpipeParams.srcNdStride = 0;
            fixpipeParams.dstNdStride = 0;
#elif defined(__NPU_ARCH__) && (__NPU_ARCH__ == 3510)
            AscendC::FixpipeParamsArch3510<AscendC::CO2Layout::ROW_MAJOR> fixpipeParams;
#endif
            fixpipeParams.mSize = baseM;
            fixpipeParams.srcStride = CeilAlign(baseM, CUBE_BLOCK);
            // Orignal nSize
            fixpipeParams.nSize = baseN;
            fixpipeParams.dstStride = baseN;
            // scalar quant
            fixpipeParams.quantPre = QuantMode_t::QF322B8_PRE;
            uint64_t deqScalar = static_cast<uint64_t>(*reinterpret_cast<int32_t *>(&quantScalar));
            constexpr bool sign = (AscendC::IsSameType<outputType, int8_t>::value) ? true : false;
            deqScalar = (deqScalar & ~(static_cast<uint64_t>(1) << 46)) | (static_cast<uint64_t>(sign) << 46);
            fixpipeParams.deqScalar = deqScalar;
            AscendC::Fixpipe<outputType, l0cType, AscendC::CFG_ROW_MAJOR>(cGM, c, fixpipeParams);
        
        } else if constexpr (SCENARIO_NUM == 5) {
            // 场景5：输出格式ND，输出数据类型int8_t，使能Vector量化
            AscendC::LocalTensor<uint64_t> quantAlphaTensor(AscendC::TPosition::C1, c1Addr, baseN);
            CopyQuantAlphaGmToL1(quantAlphaTensor);
#if defined(__NPU_ARCH__) && (__NPU_ARCH__ == 2201)
            AscendC::FixpipeParamsV220 fixpipeParams;
            fixpipeParams.ndNum = 1;
            fixpipeParams.srcNdStride = 0;
            fixpipeParams.dstNdStride = 0;
#elif defined(__NPU_ARCH__) && (__NPU_ARCH__ == 3510)
            AscendC::FixpipeParamsArch3510<AscendC::CO2Layout::ROW_MAJOR> fixpipeParams;
#endif
            fixpipeParams.mSize = baseM;
            fixpipeParams.srcStride = CeilAlign(baseM, CUBE_BLOCK);
            // Orignal nSize
            fixpipeParams.nSize = baseN;
            fixpipeParams.dstStride = baseN;
            // vector quant
            fixpipeParams.quantPre = QuantMode_t::VQF322B8_PRE;
            AscendC::Fixpipe<outputType, l0cType, AscendC::CFG_ROW_MAJOR>(cGM, c, quantAlphaTensor, fixpipeParams);
        
        } else if constexpr (SCENARIO_NUM == 6) {
            // 场景6：输出格式ND，输出数据类型float，使能relu
#if defined(__NPU_ARCH__) && (__NPU_ARCH__ == 2201)
            AscendC::FixpipeParamsV220 fixpipeParams;
            fixpipeParams.ndNum = 1;
            fixpipeParams.srcNdStride = 0;
            fixpipeParams.dstNdStride = 0;
#elif defined(__NPU_ARCH__) && (__NPU_ARCH__ == 3510)
            AscendC::FixpipeParamsArch3510<AscendC::CO2Layout::ROW_MAJOR> fixpipeParams;
#endif
            fixpipeParams.mSize = baseM;
            fixpipeParams.srcStride = CeilAlign(baseM, CUBE_BLOCK);
            // Orignal nSize
            fixpipeParams.nSize = baseN;
            fixpipeParams.dstStride = baseN;
            fixpipeParams.reluEn = true;
            AscendC::Fixpipe<outputType, l0cType, AscendC::CFG_ROW_MAJOR>(cGM, c, fixpipeParams);

        } else if constexpr (SCENARIO_NUM == 7) {
            // 场景7：输出格式NZ，输出数据类型float，使能ChannelSplit
            // fp32 cube block: [16, 8]
            uint16_t c0Size = 8;
#if defined(__NPU_ARCH__) && (__NPU_ARCH__ == 2201)
            AscendC::FixpipeParamsV220 fixpipeParams;
            // NZ2NZ场景，FixpipeParamsV220的dstStride单位为datablock（32Bytes）
            fixpipeParams.dstStride = baseM * c0Size * sizeof(outputType) / AscendC::ONE_BLK_SIZE;
#elif defined(__NPU_ARCH__) && (__NPU_ARCH__ == 3510)
            AscendC::FixpipeParamsArch3510<AscendC::CO2Layout::NZ> fixpipeParams;
            // NZ2NZ场景，FixpipeParamsArch3510的dstStride单位为元素个数
            fixpipeParams.dstStride = baseM * c0Size;
#endif
            fixpipeParams.nSize = CeilAlign(baseN, c0Size);
            // 使能ChannelSplit
            fixpipeParams.isChannelSplit = true;
            fixpipeParams.mSize = baseM;
            fixpipeParams.srcStride = CeilAlign(baseM, CUBE_BLOCK);
            AscendC::Fixpipe<outputType, l0cType, AscendC::CFG_NZ>(cGM, c, fixpipeParams);
        }
    }

private:
    static constexpr uint32_t a1Addr = 0;
    static constexpr uint32_t a2Addr = 0;
    static constexpr uint32_t b1Addr = 128 * 1024;
    static constexpr uint32_t b2Addr = 0;
    static constexpr uint32_t co1Addr = 0;
    // Vector quant参数 需要从GM拷贝到L1
    static constexpr uint32_t c1Addr = 0;

    AscendC::GlobalTensor<inputType> aGM;
    AscendC::GlobalTensor<inputType> bGM;
    AscendC::GlobalTensor<outputType> cGM;
    AscendC::GlobalTensor<uint64_t> quantAlphaGM;

    float quantScalar = 2.0;
    // 注意沿着K轴切分
    uint32_t aSingleSize, bSingleSize, cSingleSize;

    uint32_t aSizeAlignL1, bSizeAlignL1;
    uint32_t aSizeAlignL0, bSizeAlignL0, cSizeAlignL0;
};

template <uint32_t M, uint32_t K, uint32_t N>
__global__ __cube__ void fixpipe_l0c2gm(__gm__ uint8_t* a, __gm__ uint8_t* b, __gm__ uint8_t* c, __gm__ uint8_t* quantAlpha)
{
    if constexpr (SCENARIO_NUM == 4 || SCENARIO_NUM == 5) {
        KernelFixpipe<half, int8_t, float, M, K / K_ROUND, N> op;
        op.Init(a, b, c, quantAlpha);
        op.Process();
    } else {
        KernelFixpipe<half, float, float, M, K / K_ROUND, N> op;
        op.Init(a, b, c, quantAlpha);
        op.Process();
    }
    AscendC::PipeBarrier<PIPE_ALL>();
}

int32_t main(int32_t argc, char *argv[])
{
    // A No Trans, B No Trans
    constexpr uint32_t M = 128;
    constexpr uint32_t K = 128;
    constexpr uint32_t N = 256;
    size_t aFileSize = M * K * sizeof(half); 
    size_t bFileSize = K * N * sizeof(half); 
    size_t cFileSize;
    if constexpr (SCENARIO_NUM == 4 || SCENARIO_NUM == 5) {
        cFileSize = M * N * sizeof(int8_t);
    } else {
        cFileSize = M * N * sizeof(float);
    }
    size_t quantAlphaSize = 1 * N * sizeof(uint64_t);
    uint32_t numBlocks = 1;

    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t *aHost;
    uint8_t *aDevice;
    aclrtMallocHost((void **)(&aHost), aFileSize);
    aclrtMalloc((void **)&aDevice, aFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/x1_gm.bin", aFileSize, aHost, aFileSize);
    aclrtMemcpy(aDevice, aFileSize, aHost, aFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t *bHost;
    uint8_t *bDevice;
    aclrtMallocHost((void **)(&bHost), bFileSize);
    aclrtMalloc((void **)&bDevice, bFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/x2_gm.bin", bFileSize, bHost, bFileSize);
    aclrtMemcpy(bDevice, bFileSize, bHost, bFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t *cHost;
    uint8_t *cDevice;
    aclrtMallocHost((void **)(&cHost), cFileSize);
    aclrtMalloc((void **)&cDevice, cFileSize, ACL_MEM_MALLOC_HUGE_FIRST);

    uint8_t *quantAlphaHost;
    uint8_t *quantAlphaDevice;
    aclrtMallocHost((void **)(&quantAlphaHost), quantAlphaSize);
    aclrtMalloc((void **)&quantAlphaDevice, quantAlphaSize, ACL_MEM_MALLOC_HUGE_FIRST);
    // vector quant mode
    if constexpr (SCENARIO_NUM == 5) {
        ReadFile("./input/quant_pre.bin", quantAlphaSize, quantAlphaHost, quantAlphaSize);
    }
    aclrtMemcpy(quantAlphaDevice, quantAlphaSize, quantAlphaHost, quantAlphaSize, ACL_MEMCPY_HOST_TO_DEVICE);    

    fixpipe_l0c2gm<M, K, N><<<numBlocks, nullptr, stream>>>(aDevice, bDevice, cDevice, quantAlphaDevice);
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(cHost, cFileSize, cDevice, cFileSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", cHost, cFileSize);

    aclrtFree(aDevice);
    aclrtFreeHost(aHost);
    aclrtFree(bDevice);
    aclrtFreeHost(bHost);
    aclrtFree(cDevice);
    aclrtFreeHost(cHost);
    aclrtFree(quantAlphaDevice);
    aclrtFreeHost(quantAlphaHost);    

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();
    return 0;
}
