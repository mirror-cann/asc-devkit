/* !
 * \file mmad_gemv.asc
 * \brief 本样例介绍了GEMV（M=1）模式下的矩阵乘法。
 */
#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif
#include "acl/acl.h"
#include "kernel_operator.h"
#include "data_utils.h"

template <class T, class U, uint32_t N, uint32_t K>
class KernelMmad {
public:
    __aicore__ inline KernelMmad()
    {
#if defined(DISABLE_GEMV) && (DISABLE_GEMV == 1)
        // 关闭GEMV时，M对齐到16，K对齐到C0_SIZE
        aSizeAlign = BLOCK_CUBE * CeilAlign(K, C0_SIZE);
#else
        // 开启GEMV时，M=1，K对齐到分形（512B）
        aSizeAlign = CeilAlign(K, FRACTAL_SIZE);
#endif
        bSizeAlign = CeilAlign(K, C0_SIZE) * CeilAlign(N, BLOCK_CUBE);
        cSizeAlign = BLOCK_CUBE * CeilAlign(N, BLOCK_CUBE);

        a1Addr = ADDR_0;
        b1Addr = a1Addr + aSizeAlign * sizeof(U);
    }
    __aicore__ inline void Init(__gm__ uint8_t* a, __gm__ uint8_t* b, __gm__ uint8_t* c)
    {
        aGM.SetGlobalBuffer((__gm__ U *)a);
        bGM.SetGlobalBuffer((__gm__ U *)b);
        cGM.SetGlobalBuffer((__gm__ T *)c);
    }
    __aicore__ inline void Process()
    {
        AscendC::LocalTensor<U> a1Local(AscendC::TPosition::A1, a1Addr, aSizeAlign);
        AscendC::LocalTensor<U> b1Local(AscendC::TPosition::B1, b1Addr, bSizeAlign);

        // GM -> L1
        CopyIn(a1Local, b1Local);
        // L1 -> L0A
        AscendC::LocalTensor<U> a2Local(AscendC::TPosition::A2, ADDR_0, aSizeAlign);
        SplitA(a1Local, a2Local);
        // L1 -> L0B
        AscendC::LocalTensor<U> b2Local(AscendC::TPosition::B2, ADDR_0, bSizeAlign);
        SplitB(b1Local, b2Local);
        // Mmad
        AscendC::LocalTensor<T> co1Local(AscendC::TPosition::CO1, ADDR_0, cSizeAlign);
        Compute(a2Local, b2Local, co1Local);
        // L0C -> GM
        CopyOut(co1Local);
    }

private:
    // 向上整除
    __aicore__ inline uint32_t CeilDiv(uint32_t numerator, uint32_t denominator) 
    {
        return (numerator + denominator - 1) / denominator;
    }
    // 向上对齐
    __aicore__ inline uint32_t CeilAlign(uint32_t numerator, uint32_t denominator) 
    {
        return (numerator + denominator - 1) / denominator * denominator;
    }

    __aicore__ inline void CopyIn(AscendC::LocalTensor<U>& a1Local, AscendC::LocalTensor<U>& b1Local)
    {
        AscendC::Nd2NzParams nd2nzA1Params;

        // ND -> Nz
        nd2nzA1Params.ndNum = 1;
        nd2nzA1Params.nValue = M;
        nd2nzA1Params.dValue = K;
        nd2nzA1Params.srcNdMatrixStride = 0;
        nd2nzA1Params.srcDValue = K;
#if defined(DISABLE_GEMV) && (DISABLE_GEMV == 1)
        // L1上，A为Nz
        nd2nzA1Params.dstNzC0Stride = BLOCK_CUBE;
#else
        // L1上，A为vector
        nd2nzA1Params.dstNzC0Stride = 1;
#endif
        nd2nzA1Params.dstNzNStride = 1;
        nd2nzA1Params.dstNzMatrixStride = 0;
        AscendC::DataCopy(a1Local, aGM, nd2nzA1Params);
        AscendC::SetFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID0);

        AscendC::Nd2NzParams nd2nzB1Params;
        nd2nzB1Params.ndNum = 1;
        nd2nzB1Params.nValue = N;
        nd2nzB1Params.dValue = K;
        nd2nzB1Params.srcNdMatrixStride = 0;
        nd2nzB1Params.srcDValue = K;
        nd2nzB1Params.dstNzC0Stride = CeilAlign(N, BLOCK_CUBE);
        nd2nzB1Params.dstNzNStride = 1;
        nd2nzB1Params.dstNzMatrixStride = 0;
        AscendC::DataCopy(b1Local, bGM, nd2nzB1Params);
        AscendC::SetFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID1);
    }

    __aicore__ inline void SplitA(AscendC::LocalTensor<U>& a1Local, AscendC::LocalTensor<U>& a2Local)
    {
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID0);
#if defined(__NPU_ARCH__) && (__NPU_ARCH__ == 3510)
        // Nz -> Nz，__NPU_ARCH__为3510时，要求A2上的数据排布为: Nz
        AscendC::LoadData2DParamsV2 loadDataParams;
        loadDataParams.mStartPosition = 0;
        loadDataParams.kStartPosition = 0;
#if defined(DISABLE_GEMV) && (DISABLE_GEMV == 1)
        loadDataParams.mStep = CeilDiv(M, BLOCK_CUBE);
        loadDataParams.kStep = CeilDiv(K, C0_SIZE);
#else
        loadDataParams.mStep = 1;
        loadDataParams.kStep = CeilDiv(K, FRACTAL_SIZE);
#endif
        loadDataParams.srcStride = 1;
        loadDataParams.dstStride = 1;
        loadDataParams.ifTranspose = false;
#else
        // Nz -> Zz，__NPU_ARCH__为2201时，要求A2上的数据排布为: Zz
        AscendC::LoadData2DParams loadDataParams;
        loadDataParams.startIndex = 0;
        loadDataParams.repeatTimes = CeilDiv(K, FRACTAL_SIZE);
        loadDataParams.srcStride = 1;
        loadDataParams.dstGap = 0;
        loadDataParams.ifTranspose = false;
#endif
        AscendC::LoadData(a2Local, a1Local, loadDataParams);
        AscendC::SetFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID0);
    }

    __aicore__ inline void SplitB(AscendC::LocalTensor<U>& b1Local, AscendC::LocalTensor<U>& b2Local)
    {
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID1);
        // B2上的数据排布为: Zn
    #if defined(__NPU_ARCH__) && (__NPU_ARCH__ == 3510)
        AscendC::LoadData2DParamsV2 loadDataParams;
        loadDataParams.mStartPosition = 0;
        loadDataParams.kStartPosition = 0;
        loadDataParams.mStep = CeilDiv(N, BLOCK_CUBE);
        loadDataParams.kStep = CeilDiv(K, C0_SIZE);
        loadDataParams.srcStride = CeilDiv(N, BLOCK_CUBE);
        loadDataParams.dstStride = CeilDiv(N, BLOCK_CUBE);
        loadDataParams.ifTranspose = false;
    #else
        AscendC::LoadData2DParams loadDataParams;
        loadDataParams.repeatTimes = CeilDiv(N, BLOCK_CUBE) * CeilDiv(K, C0_SIZE);
        loadDataParams.srcStride = 1;
        loadDataParams.dstGap = 0;
        loadDataParams.ifTranspose = false;
    #endif
        AscendC::LoadData(b2Local, b1Local, loadDataParams);
        AscendC::SetFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID1);
    }

    __aicore__ inline void Compute(AscendC::LocalTensor<U>& a2Local, AscendC::LocalTensor<U>& b2Local,
                                   AscendC::LocalTensor<T>& co1Local)
    {
        AscendC::WaitFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID1);

        AscendC::MmadParams mmadParams;
        mmadParams.m = M;
        mmadParams.n = N;
        mmadParams.k = K;
#if defined(DISABLE_GEMV) && (DISABLE_GEMV == 1)
        // 关闭GEMV，仅Ascend 950PR/Ascend 950DT支持
        mmadParams.disableGemv = true;
#endif
        AscendC::Mmad(co1Local, a2Local, b2Local, mmadParams);
        AscendC::SetFlag<AscendC::HardEvent::M_FIX>(EVENT_ID0);
    }
    __aicore__ inline void CopyOut(AscendC::LocalTensor<T>& co1Local)
    {
        AscendC::WaitFlag<AscendC::HardEvent::M_FIX>(EVENT_ID0);
#if defined(__NPU_ARCH__) && (__NPU_ARCH__ == 3510)
        AscendC::FixpipeParamsArch3510<AscendC::CO2Layout::ROW_MAJOR> fixpipeParams;
#else
        AscendC::FixpipeParamsV220 fixpipeParams;
        fixpipeParams.ndNum = 1;
        fixpipeParams.srcNdStride = 0;
        fixpipeParams.dstNdStride = 0;
#endif
        fixpipeParams.mSize = M;
        fixpipeParams.nSize = N;
        fixpipeParams.srcStride = BLOCK_CUBE;
        fixpipeParams.dstStride = N;

        AscendC::Fixpipe(cGM, co1Local, fixpipeParams);
    }

private:
    AscendC::GlobalTensor<U> aGM;
    AscendC::GlobalTensor<U> bGM;
    AscendC::GlobalTensor<T> cGM;

    static constexpr uint32_t M = 1;
    static constexpr uint32_t BLOCK_CUBE = 16;
    static constexpr uint32_t C0_SIZE = 32 / sizeof(U);
    static constexpr uint64_t FRACTAL_SIZE = BLOCK_CUBE * C0_SIZE;
    static constexpr uint64_t ADDR_0 = 0;

    uint32_t aSizeAlign, bSizeAlign, cSizeAlign;
    uint64_t a1Addr, b1Addr;
};

template <uint32_t N, uint32_t K>
__global__ __cube__ void mmad_custom(__gm__ uint8_t* a, __gm__ uint8_t* b, __gm__ uint8_t* c)
{
    AscendC::InitSocState();
    KernelMmad<float, half, N, K> op;
    op.Init(a, b, c);
    op.Process();
    AscendC::PipeBarrier<PIPE_ALL>();
}

int32_t main(int32_t argc, char *argv[])
{
    constexpr uint32_t N = 32;
    constexpr uint32_t K = 256;
    size_t aFileSize = 1 * K * sizeof(half);
    size_t bFileSize = K * N * sizeof(half);
    size_t cFileSize = 1 * N * sizeof(float);

    uint32_t numBlocks = 1;

    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t *aHost;
    uint8_t *aDevice;
    aclrtMallocHost((void **)(&aHost), aFileSize);
    aclrtMalloc((void **)&aDevice, aFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/x1_gm.bin", aFileSize, aHost, aFileSize);
    aclrtMemcpy(aDevice, aFileSize, aHost, aFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t *bHost;
    uint8_t *bDevice;
    aclrtMallocHost((void **)(&bHost), bFileSize);
    aclrtMalloc((void **)&bDevice, bFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/x2_gm.bin", bFileSize, bHost, bFileSize);
    aclrtMemcpy(bDevice, bFileSize, bHost, bFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t *cHost;
    uint8_t *cDevice;
    aclrtMallocHost((void **)(&cHost), cFileSize);
    aclrtMalloc((void **)&cDevice, cFileSize, ACL_MEM_MALLOC_HUGE_FIRST);

    mmad_custom<N, K><<<numBlocks, nullptr, stream>>>(aDevice, bDevice, cDevice);
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(cHost, cFileSize, cDevice, cFileSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", cHost, cFileSize);

    aclrtFree(aDevice);
    aclrtFreeHost(aHost);
    aclrtFree(bDevice);
    aclrtFreeHost(bHost);
    aclrtFree(cDevice);
    aclrtFreeHost(cHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();
    return 0;
}