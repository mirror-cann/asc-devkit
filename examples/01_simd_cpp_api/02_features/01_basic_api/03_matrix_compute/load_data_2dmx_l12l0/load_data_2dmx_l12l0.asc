/* !
 * \file load_data_2dmx_l12l0.asc
 * \brief 本样例适用于Ascend 950PR/Ascend 950DT，介绍了在MX FP4/FP8矩阵乘法场景下，
 *        使用LoadData接口搬运A/B矩阵和scaleA/scaleB矩阵数据的方法。
 *        其中LoadData2DParamsV2结构体参数控制A/B矩阵搬运，
 *        LoadData2DMxParams结构体参数控制scaleA/scaleB矩阵搬运。
 *        共6种场景：
 *        - 场景1、3: FP4/FP8数据类型，isAtranspose=false，isBtranspose为true，单次调用LoadData
 *        - 场景2、4: FP4/FP8数据类型，isAtranspose=true，isBtranspose为false，单次调用LoadData
 *        - 场景5: FP4数据类型，isAtranspose=true，isBtranspose=false，A矩阵使用for循环调用LoadData
 *        - 场景6: FP8数据类型，isAtranspose=true，isBtranspose=false，A矩阵使用for循环调用LoadData
 */

#include "acl/acl.h"
#include "kernel_operator.h"
#include "data_utils.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

constexpr uint32_t scenarioNum = SCENARIO_NUM;
constexpr uint32_t SCALE_BASE_FACTOR = 64;
constexpr uint32_t SCALE_EVEN_NUMBER = 2;
constexpr uint32_t SCALE_CEIL_NUMBER = 32;
constexpr uint32_t FP4_M_STEP_ALIGN = 4;
constexpr uint32_t FP8_M_STEP_ALIGN = 2;
constexpr uint32_t FP8_C0SIZE = 32;

template <
    class TA, class TB, class TAL0Type, class TBL0Type, class U, uint32_t m, uint32_t n, uint32_t k, bool isAtranspose,
    bool isBtranspose>
class KernelMmadMX {
public:
    __aicore__ inline KernelMmadMX()
    {
        fractalShape[0] = 16;
        if constexpr (AscendC::IsSameType<TA, fp4x2_e1m2_t>::value || AscendC::IsSameType<TA, fp4x2_e2m1_t>::value) {
            fractalShape[1] = 64;
            fractalNum = 4;
            isFP4 = true;
            packedK = CeilDivision(k, 2);
        } else {
            fractalShape[1] = 32;
            fractalNum = 2;
            isFP4 = false;
            packedK = k;
        }

        scaleK = CeilDivision(k, SCALE_BASE_FACTOR) * SCALE_EVEN_NUMBER;
        alignK = CeilAlign(k, SCALE_BASE_FACTOR);

        if constexpr (!isAtranspose) {
            // GM上A矩阵的shape为[m,k], L1上的shape为[mAlignL1, kaAlignL1], L0上的shape为[mAlignL0, kaAlignL0]
            // L1->L0A调用LoadData，L1/L0上row和col分别向fractalShape[0]、fractalShape[1]对齐
            // L1上排布格式为Nz，A矩阵的对齐
            mAlignL1 = CeilAlign(m, fractalShape[0]);
            kaAlignL1 = alignK;
            aSizeAlignL1 = mAlignL1 * kaAlignL1;
            // L0上排布格式为Nz，A矩阵的对齐
            mAlignL0 = CeilAlign(m, fractalShape[0]);
            kaAlignL0 = alignK;
            aSizeAlignL0 = mAlignL0 * kaAlignL0;
        } else {
            // GM上A矩阵的shape为[k,m], L1上的shape为[kaAlignL1, mAlignL1], L0上的shape为[mAlignL0, kaAlignL0]
            // L1->L0A调用LoadData，L1和L0上row和col分别向fractalShape[0] * fractalNum、fractalShape[1]对齐
            // L1上排布格式为Nz，A矩阵的对齐
            kaAlignL1 = alignK;
            mAlignL1 = CeilAlign(m, fractalShape[1]);
            aSizeAlignL1 = kaAlignL1 * mAlignL1;
            // L0上排布格式为Nz，A矩阵的对齐
            mAlignL0 = CeilAlign(m, fractalShape[0] * fractalNum);
            kaAlignL0 = alignK;
            aSizeAlignL0 = mAlignL0 * kaAlignL0;
        }

        if constexpr (!isBtranspose) {
            // GM上B矩阵的shape为[k,n], L1上的shape为[kbAlignL1, nAlignL1], L0上的shape为[kbAlignL0, nAlignL0]
            // L1->L0B调用LoadData，L1上row和col分别向fractalShape[0] * fractalNum、fractalShape[1]对齐;
            // L0上row向fractalShape[1]对齐, col向fractalShape[0] * fractalNum对齐 L1上排布格式为Nz，B矩阵的对齐
            kbAlignL1 = alignK;
            nAlignL1 = CeilAlign(n, fractalShape[1]);
            bSizeAlignL1 = kbAlignL1 * nAlignL1;
            // L0上排布格式为Zn，B矩阵的对齐
            kbAlignL0 = alignK;
            nAlignL0 = CeilAlign(n, fractalShape[0] * fractalNum);
            bSizeAlignL0 = kbAlignL0 * nAlignL0;
        } else {
            // GM上B矩阵的shape为[n,k], L1上的shape为[nAlignL1, kbAlignL1], L0上的shape为[kbAlignL0, nAlignL0]
            // L1->L0B调用LoadData，L1/L0上row和col分别向fractalShape[0]、fractalShape[1]对齐
            // L1上排布格式为Nz，B矩阵的对齐
            nAlignL1 = CeilAlign(n, fractalShape[0]);
            kbAlignL1 = alignK;
            bSizeAlignL1 = nAlignL1 * kbAlignL1;
            // L1上排布格式为Zn，B矩阵的对齐
            kbAlignL0 = alignK;
            nAlignL0 = CeilAlign(n, fractalShape[0]);
            bSizeAlignL0 = kbAlignL0 * nAlignL0;
        }

        if constexpr (scenarioNum == 5 || scenarioNum == 6) {
            // A矩阵[k,m]转置输入，L1->L0A需要转置，for循环调用LoadData，按照方型搬运，每次for循环在L0A上跳过m方向尾脏数据分形，m方向多搬运数据不超过1个分形；
            // B矩阵[k, n]不转置输入，L1->L0B需要转置，调用一次LoadData，n方向多搬运数据不超过1个分形；
            // 矩阵计算Mmad计算量为CeilAlign(m, fractalShape[0]) * CeilAlign(n, fractalShape[0] * fractalNum)。
            mAlignL0 = CeilAlign(m, fractalShape[0]);
            kaAlignL0 = alignK;
            aSizeAlignL0 = mAlignL0 * kaAlignL0;
            // C
            cSizeAlignL0 = mAlignL0 * nAlignL0;
        } else if constexpr (scenarioNum == 2 || scenarioNum == 4) {
            // A矩阵[k,m]转置输入，L1->L0A需要转置，调用一次LoadData，按照方型搬运，m方向多搬运数据超过1个分形；
            // B矩阵[k, n]不转置输入，L1->L0B需要转置，调用一次LoadData，n方向多搬运数据不超过1个分形；
            // 矩阵计算Mmad计算量为CeilAlign(m, fractalShape[0] * fractalNum) * CeilAlign(n, fractalShape[0] *
            // fractalNum)。
            cSizeAlignL0 = mAlignL0 * nAlignL0;
        } else {
            cSizeAlignL0 = CeilAlign(m, 16) * CeilAlign(n, 16);
        }

        // L1/L0上排布格式为Zz，scaleA矩阵的对齐
        scaleMAlignL1 = CeilAlign(m, fractalShape[0]);
        scaleASizeAlignL1 = scaleMAlignL1 * scaleK;

        // L1/L0上排布格式为Nn，scaleB矩阵的对齐
        scaleNAlignL1 = CeilAlign(n, fractalShape[0]);
        scaleBSizeAlignL1 = scaleK * scaleNAlignL1;
    }

    __aicore__ inline void Init(
        __gm__ uint8_t* a, __gm__ uint8_t* b, __gm__ uint8_t* scaleA, __gm__ uint8_t* scaleB, __gm__ uint8_t* c)
    {
        aGM.SetGlobalBuffer((__gm__ TA*)a);
        bGM.SetGlobalBuffer((__gm__ TB*)b);
        scaleAGM.SetGlobalBuffer((__gm__ fp8_e8m0_t*)scaleA);
        scaleBGM.SetGlobalBuffer((__gm__ fp8_e8m0_t*)scaleB);
        cGM.SetGlobalBuffer((__gm__ U*)c);
    }

    __aicore__ inline void Process()
    {
        AscendC::LocalTensor<TA> a1Local(AscendC::TPosition::A1, a1Addr, aSizeAlignL1);
        AscendC::LocalTensor<TAL0Type> a2Local(AscendC::TPosition::A2, a2Addr, aSizeAlignL0);
        AscendC::LocalTensor<fp8_e8m0_t> scaleA1Local(AscendC::TPosition::A1, scaleA1Addr, scaleASizeAlignL1);

        AscendC::LocalTensor<TB> b1Local(AscendC::TPosition::B1, b1Addr, bSizeAlignL1);
        AscendC::LocalTensor<TBL0Type> b2Local(AscendC::TPosition::B2, b2Addr, bSizeAlignL0);
        AscendC::LocalTensor<fp8_e8m0_t> scaleB1Local(AscendC::TPosition::B1, scaleB1Addr, scaleBSizeAlignL1);

        AscendC::LocalTensor<U> c1Local(AscendC::TPosition::CO1, co1Addr, cSizeAlignL0);

        // ---- DataCopyInA / DataCopyInAScale: GM -> L1 ----
        // 将A矩阵和对应scaleA矩阵搬入L1。A矩阵使用DataCopy + Nd2NzParams，
        // scaleA矩阵按B16视图使用DataCopy + Dn2NzParams/Nd2NzParams。
        CopyInA1(a1Local);
        CopyInScaleA1(scaleA1Local);

        // ---- DataCopyInB / DataCopyInBScale: GM -> L1 ----
        // 将B矩阵和对应scaleB矩阵搬入L1。B矩阵使用DataCopy + Nd2NzParams，
        // scaleB矩阵按B16视图使用DataCopy + Dn2NzParams/Nd2NzParams。
        CopyInB1(b1Local);
        CopyInScaleB1(scaleB1Local);

        AscendC::SetFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID0);

        // ---- Fill: 无效数据置0，防止脏数据参与Mmad ----
        FillZeroInA1(a1Local);
        FillZeroInB1(b1Local);

        AscendC::PipeBarrier<PIPE_MTE1>();

        // ---- DataLoadA: L1 -> L0A / L0A_MX ----
        // 单次LoadData同时搬运A矩阵到L0A、scaleA矩阵到L0A_MX；
        // 场景5/6使用for循环调用LoadData，避免A转置时m方向多搬脏数据超过1个分形。
        if constexpr (scenarioNum == 5 || scenarioNum == 6) {
            SplitAWithLoop(a1Local, scaleA1Local, a2Local);
        } else {
            SplitA(a1Local, scaleA1Local, a2Local);
        }
        // ---- DataLoadB: L1 -> L0B / L0B_MX ----
        // 单次LoadData同时搬运B矩阵到L0B、scaleB矩阵到L0B_MX。
        SplitB(b1Local, scaleB1Local, b2Local);

        AscendC::SetFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID0);

        // ---- Compute: Mmad矩阵乘累加 ----
        // 场景2/4中A转置单次搬运会让m方向按fractalShape[0] *
        // fractalNum对齐，因此Mmad的m参数同步使用该对齐值，搬出时再跳过无效分形结果。 场景1/3/5/6按照原始m参与运算
        // k方向统一需要对齐到64
        AscendC::MmadParams mmadParams;
        if constexpr (scenarioNum == 2 || scenarioNum == 4) {
            // mmad默认m轴向16对齐，但是由于A转置过程m轴向2 * 16对齐，填充了一个全部由无效数据的16 * 32的分形，
            // 如果仍然设置mmadParams.m = m，cube单元会多读入无效数据的分形同时有效数据的分形也未被读入，
            // 此时可以通过设置m向32对齐，让此分形参与计算，搬出时跳过无效分形参与计算的得到的分形即可。
            mmadParams.m = CeilAlign(m, fractalShape[0] * fractalNum);
        } else {
            mmadParams.m = m;
        }
        mmadParams.n = n;
        mmadParams.k = alignK;
        mmadParams.cmatrixInitVal = true;
        AscendC::MmadMx(c1Local, a2Local, b2Local, mmadParams);

        AscendC::SetFlag<AscendC::HardEvent::M_FIX>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::M_FIX>(EVENT_ID0);

        AscendC::FixpipeParamsArch3510<AscendC::CO2Layout::ROW_MAJOR> fixpipeParams;
        fixpipeParams.nSize = n;
        fixpipeParams.mSize = m;
        if constexpr (scenarioNum == 2 || scenarioNum == 4) {
            fixpipeParams.srcStride = CeilAlign(m, fractalShape[0] * fractalNum);
        } else {
            fixpipeParams.srcStride = CeilAlign(m, fractalShape[0]);
        }
        fixpipeParams.dstStride = n;
        AscendC::Fixpipe<U, U, AscendC::CFG_ROW_MAJOR>(cGM, c1Local, fixpipeParams);
    }

private:
    __aicore__ inline uint16_t CeilDivision(uint16_t numerator, uint16_t denominator)
    {
        return (numerator + denominator - 1) / denominator;
    }

    __aicore__ inline uint16_t CeilAlign(uint16_t numerator, uint16_t denominator)
    {
        if (denominator == 0)
            return numerator;
        return (numerator + denominator - 1) / denominator * denominator;
    }

    // GM -> A1: 将A矩阵从GM搬入L1，并通过Nd2NzParams完成ND到Nz布局转换,
    // 根据接口约束，若输入是FP4数据类型，调用DataCopy指令完成ND2Nz过程中，指令内部会将基于B8类型处理，参数配置按照B8类型设置
    // isAtranspose=false时GM输入shape为[m, k]；isAtranspose=true时GM输入shape为[k, m]
    __aicore__ inline void CopyInA1(AscendC::LocalTensor<TA> a1Local)
    {
        AscendC::Nd2NzParams nd2nzA1Params;
        if constexpr (!isAtranspose) {
            nd2nzA1Params.ndNum = 1;             // ND矩阵的数目
            nd2nzA1Params.nValue = m;            // 源操作ND矩阵的行数
            nd2nzA1Params.dValue = packedK;      // 源操作ND矩阵的列数
            nd2nzA1Params.srcNdMatrixStride = 0; // 源操作数相邻ND矩阵间的起始地址偏移
            nd2nzA1Params.srcDValue = packedK;   // 源操作数同一ND矩阵内相邻行的起始地址偏移
            nd2nzA1Params.dstNzC0Stride = mAlignL1; // ND转Nz后，同一行数据切分后各段的起始地址间隔，单位32B
            nd2nzA1Params.dstNzNStride = 1; // ND矩阵第x行与第x+1行转Nz后在dst中的偏移
            nd2nzA1Params.dstNzMatrixStride = 0; // 目的Nz矩阵中，相邻Nz矩阵起始地址的偏移，配置为0时，无意义
        } else {
            uint16_t aColValue =
                (AscendC::IsSameType<TA, fp4x2_e1m2_t>::value || AscendC::IsSameType<TA, fp4x2_e2m1_t>::value) ?
                    CeilDivision(m, 2) :
                    m;
            nd2nzA1Params.ndNum = 1;  // ND矩阵的数目
            nd2nzA1Params.nValue = k; // 源操作ND矩阵的行数
            nd2nzA1Params.dValue = aColValue; // 源操作ND矩阵的列数，FP4类型下2个连续数据合并为1个FP8数据进行搬运
            nd2nzA1Params.srcNdMatrixStride = 0; // 源操作数相邻ND矩阵间的起始地址偏移
            nd2nzA1Params.srcDValue = aColValue; // 源操作数同一ND矩阵内相邻行的起始地址偏移
            nd2nzA1Params.dstNzC0Stride = alignK; // ND转Nz后，同一行数据切分后各段的起始地址间隔，单位32B
            nd2nzA1Params.dstNzNStride = 1; // ND矩阵第x行与第x+1行转Nz后在dst中的偏移
            nd2nzA1Params.dstNzMatrixStride = 0; // 目的Nz矩阵中，相邻Nz矩阵起始地址的偏移，配置为0时，无意义
        }
        AscendC::DataCopy(a1Local, aGM, nd2nzA1Params);
    }

    // GM -> B1: 将B矩阵从GM搬入L1，并通过Nd2NzParams完成ND到Nz布局转换,
    // 根据接口约束，若输入是FP4数据类型，调用DataCopy指令完成ND2Nz过程中，指令内部会将基于B8类型处理，参数配置按照B8类型设置
    // isBtranspose=false时GM输入shape为[k, n]；isBtranspose=true时GM输入shape为[n, k]
    __aicore__ inline void CopyInB1(AscendC::LocalTensor<TB> b1Local)
    {
        AscendC::Nd2NzParams nd2nzB1Params;
        if constexpr (!isBtranspose) {
            uint16_t bColValue =
                (AscendC::IsSameType<TB, fp4x2_e1m2_t>::value || AscendC::IsSameType<TB, fp4x2_e2m1_t>::value) ?
                    CeilDivision(n, 2) :
                    n;
            nd2nzB1Params.ndNum = 1;  // ND矩阵的数目
            nd2nzB1Params.nValue = k; // 源操作ND矩阵的行数
            nd2nzB1Params.dValue = bColValue; // 源操作ND矩阵的列数，FP4类型下2个连续数据合并为1个FP8数据进行搬运
            nd2nzB1Params.srcNdMatrixStride = 0; // 源操作数相邻ND矩阵间的起始地址偏移
            nd2nzB1Params.srcDValue = bColValue; // 源操作数同一ND矩阵内相邻行的起始地址偏移
            nd2nzB1Params.dstNzC0Stride = alignK; // ND转Nz后，同一行数据切分后各段的起始地址间隔，单位32B
            nd2nzB1Params.dstNzNStride = 1; // ND矩阵第x行与第x+1行转Nz后在dst中的偏移
            nd2nzB1Params.dstNzMatrixStride = 0; // 目的Nz矩阵中，相邻Nz矩阵起始地址的偏移，配置为0时，无意义
        } else {
            nd2nzB1Params.ndNum = 1;  // ND矩阵的数目
            nd2nzB1Params.nValue = n; // 源操作ND矩阵的行数
            nd2nzB1Params.dValue =
                packedK; // 源操作ND矩阵的列数，由于指令限制，若输入是FP4数据类型,则需要将2个连续数据合并为1个FP8数据进行搬运
            nd2nzB1Params.srcNdMatrixStride = 0; // 源操作数相邻ND矩阵间的起始地址偏移
            nd2nzB1Params.srcDValue = packedK;   // 源操作数同一ND矩阵内相邻行的起始地址偏移
            nd2nzB1Params.dstNzC0Stride = nAlignL1; // ND转Nz后，同一行数据切分后各段的起始地址间隔，单位32B
            nd2nzB1Params.dstNzNStride = 1; // ND矩阵第x行与第x+1行转Nz后在dst中的偏移
            nd2nzB1Params.dstNzMatrixStride = 0; // 目的Nz矩阵中，相邻Nz矩阵起始地址的偏移，配置为0时，无意义
        }
        AscendC::DataCopy(b1Local, bGM, nd2nzB1Params);
    }

    // GM -> A1: Scale为fp8_e8m0_t，硬件要求k方向2byte连续搬运, 在 GM->L1
    // 搬运时，按照B16(half)数据类型进行搬运，可实现L1上的为Zz, 且小分形为16*2的排布格式
    // isAtranspose=false时使用Dn2NzParams；isAtranspose=true时使用Nd2NzParams
    __aicore__ inline void CopyInScaleA1(AscendC::LocalTensor<fp8_e8m0_t> scaleA1Local)
    {
        AscendC::GlobalTensor<half> scaleAGMB16;
        scaleAGMB16.SetGlobalBuffer((__gm__ half*)(scaleAGM.GetPhyAddr()), m * scaleK / 2);
        auto scaleA1LocalB16 = scaleA1Local.ReinterpretCast<half>();
        if constexpr (!isAtranspose) {
            // 不转置输入时scaleA的GM shape为[m, scaleK]，按B16视图使用Dn2NzParams搬运
            AscendC::Dn2NzParams dn2nzParams;
            dn2nzParams.dnNum = 1;           // 源操作数中DN矩阵的个数
            dn2nzParams.dValue = m;          // 源操作DN矩阵的行数
            dn2nzParams.nValue = scaleK / 2; // 源操作DN矩阵的列数，按B16视图后2个fp8_e8m0_t合并为1个half
            dn2nzParams.srcDnMatrixStride = 0;  // 源操作数相邻DN矩阵间的起始地址偏移
            dn2nzParams.srcDValue = scaleK / 2; // 源操作数同一DN矩阵内相邻行的起始地址偏移
            dn2nzParams.dstNzC0Stride = scaleK / 2; // DN转Nz后，同一行数据切分后各段的起始地址间隔，单位32B
            dn2nzParams.dstNzNStride = 1;      // DN矩阵第x行与第x+1行转Nz后在dst中的偏移
            dn2nzParams.dstNzMatrixStride = 0; // 相邻Nz矩阵间的起始地址偏移

            AscendC::DataCopy(scaleA1LocalB16, scaleAGMB16, dn2nzParams);
        } else {
            // 转置输入时scaleA的GM shape为[scaleK, m, 2]，按B16视图使用Nd2NzParams搬运
            AscendC::Nd2NzParams nd2nzParams;
            nd2nzParams.ndNum = 1;           // 源操作数中ND矩阵的个数
            nd2nzParams.nValue = scaleK / 2; // 源操作ND矩阵的行数，按B16视图后2个fp8 scale合并为1个half
            nd2nzParams.dValue = m;          // 源操作ND矩阵的列数
            nd2nzParams.srcDValue = m;       // 源操作数同一ND矩阵内相邻行的起始地址偏移
            nd2nzParams.dstNzC0Stride = scaleK / 2; // ND转Nz后，同一行数据切分后各段的起始地址间隔，单位32B
            nd2nzParams.dstNzNStride = 1;      // ND矩阵第x行与第x+1行转Nz后在dst中的偏移
            nd2nzParams.dstNzMatrixStride = 0; // 相邻Nz矩阵间的起始地址偏移

            AscendC::DataCopy(scaleA1LocalB16, scaleAGMB16, nd2nzParams);
        }
    }

    // GM -> B1: Scale为fp8_e8m0_t，硬件要求k方向2byte连续搬运, 在 GM->L1
    // 搬运时，按照B16(half)数据类型进行搬运，可实现L1上的为Nn, 且小分形为16*2的排布格式
    // isBtranspose=true时使用Dn2NzParams；isBtranspose=false时使用Nd2NzParams
    __aicore__ inline void CopyInScaleB1(AscendC::LocalTensor<fp8_e8m0_t> scaleB1Local)
    {
        AscendC::GlobalTensor<half> scaleBGMB16;
        scaleBGMB16.SetGlobalBuffer((__gm__ half*)(scaleBGM.GetPhyAddr()), n * scaleK / 2);
        auto scaleB1LocalB16 = scaleB1Local.ReinterpretCast<half>();
        if constexpr (isBtranspose) {
            // 转置输入时scaleB的GM shape为[n, scaleK]，按B16视图使用Dn2NzParams搬运
            AscendC::Dn2NzParams dn2nzParams;
            dn2nzParams.dnNum = 1;           // 源操作数中DN矩阵的个数
            dn2nzParams.dValue = n;          // 源操作DN矩阵的行数
            dn2nzParams.nValue = scaleK / 2; // 源操作DN矩阵的列数，按B16视图后2个fp8 scale合并为1个half
            dn2nzParams.srcDnMatrixStride = 0;  // 源操作数相邻DN矩阵间的起始地址偏移
            dn2nzParams.srcDValue = scaleK / 2; // 源操作数同一DN矩阵内相邻行的起始地址偏移
            dn2nzParams.dstNzC0Stride = scaleK / 2; // DN转Nz后，同一行数据切分后各段的起始地址间隔，单位32B
            dn2nzParams.dstNzNStride = 1;      // DN矩阵第x行与第x+1行转Nz后在dst中的偏移
            dn2nzParams.dstNzMatrixStride = 0; // 相邻Nz矩阵间的起始地址偏移

            AscendC::DataCopy(scaleB1LocalB16, scaleBGMB16, dn2nzParams);
        } else {
            // 不转置输入时scaleB的GM shape为[scaleK, n, 2]，按B16视图使用Nd2NzParams搬运
            AscendC::Nd2NzParams nd2nzParams;
            nd2nzParams.ndNum = 1;           // 源操作数中ND矩阵的个数
            nd2nzParams.nValue = scaleK / 2; // 源操作ND矩阵的行数，按B16视图后2个fp8 scale合并为1个half
            nd2nzParams.dValue = n;          // 源操作ND矩阵的列数
            nd2nzParams.srcDValue = n;       // 源操作数同一ND矩阵内相邻行的起始地址偏移
            nd2nzParams.dstNzC0Stride = scaleK / 2; // ND转Nz后，同一行数据切分后各段的起始地址间隔，单位32B
            nd2nzParams.dstNzNStride = 1;      // ND矩阵第x行与第x+1行转Nz后在dst中的偏移
            nd2nzParams.dstNzMatrixStride = 0; // 相邻Nz矩阵间的起始地址偏移

            AscendC::DataCopy(scaleB1LocalB16, scaleBGMB16, nd2nzParams);
        }
    }

    __aicore__ inline void FillZeroInA1(AscendC::LocalTensor<TA> a1Local)
    {
        if constexpr (!isAtranspose) {
            // A矩阵GM上输入为[m, k]，k方向需要向64对齐，当输入数据类型为fp8时，DataCopy
            // k轴仅向32B对齐，此时需要将剩余k方向数据刷为0，防止脏数据参与计算
            if constexpr (AscendC::IsSameType<TA, fp8_e4m3fn_t>::value || AscendC::IsSameType<TA, fp8_e5m2_t>::value) {
                PadOneBlockInnerAxis(a1Local, m, packedK);
            }
        } else {
            // A矩阵GM上输入为[k, m]，k方向需要向64对齐，由于DataCopy k轴仅向16对齐，需要将剩余k方向脏数据数据刷为0
            PadZerosForOuterAxis(a1Local, k, m, alignK);
        }
    }

    __aicore__ inline void FillZeroInB1(AscendC::LocalTensor<TB> b1Local)
    {
        if constexpr (!isBtranspose) {
            // B矩阵GM上输入为[k, n]，k方向需要向64对齐，由于DataCopy k轴仅向16对齐，需要将剩余k方向脏数据数据刷为0
            PadZerosForOuterAxis(b1Local, k, n, alignK);
        } else {
            // B矩阵GM上输入为[n, k]，k方向需要向64对齐，当输入数据类型为fp8时，DataCopy
            // k轴仅向32B对齐，此时需要将剩余k方向数据刷为0，防止脏数据参与计算
            if constexpr (AscendC::IsSameType<TB, fp8_e4m3fn_t>::value || AscendC::IsSameType<TB, fp8_e5m2_t>::value) {
                PadOneBlockInnerAxis(b1Local, n, packedK);
            }
        }
    }

    template <typename T>
    __aicore__ inline void PadZerosForOuterAxis(
        const AscendC::LocalTensor<T>& dst, const int32_t height, const int32_t width, const int32_t alignHeight)
    {
        // 补齐row方向(height, alignHeight)范围内的无效数据。
        // 将输入按照uint16类型填0；dst位于A1/B1时，Fill的blockNum和dstGap单位为32B。
        auto padTensor = dst.template ReinterpretCast<uint16_t>();
        AscendC::InitConstValueParams<uint16_t> initConstValueParams;
        // repeatTimes表示迭代次数；以col方向做迭代。
        initConstValueParams.repeatTimes = CeilDivision(width, FP8_C0SIZE);
        // blockNum表示每次迭代初始化的数据块(32B)个数；这里每次填充row方向尾部无效行数。
        initConstValueParams.blockNum = alignHeight - height;
        // dstGap表示前一次迭代结束地址到后一次迭代起始地址的距离；跳过row方向有效数据。
        initConstValueParams.dstGap = height;
        // initValue表示初始化值；无效数据填0，防止参与Mmad计算。
        initConstValueParams.initValue = 0;
        // 起始地址定位到第一个需要补0的row分形。
        AscendC::Fill(padTensor[height * fractalShape[0]], initConstValueParams);
    }

    template <typename T>
    __aicore__ inline void PadOneBlockInnerAxis(
        const AscendC::LocalTensor<T>& dst, const int32_t height, const int32_t width)
    {
        // 补齐row方向尾部1个32B的无效数据。
        // 将输入按照uint16类型填0；dst位于A1/B1时，Fill的blockNum和dstGap单位为32B。
        const uint32_t heightAlign = CeilAlign(height, fractalShape[0]);
        auto padTensor = dst.template ReinterpretCast<uint16_t>();
        AscendC::InitConstValueParams<uint16_t> initConstValueParams;
        // repeatTimes表示迭代次数；以row方向做迭代。
        initConstValueParams.repeatTimes = heightAlign;
        // blockNum表示每次迭代初始化的数据块(32B)个数；这里每次只填充col方向尾部1个32B数据。
        initConstValueParams.blockNum = 1;
        // initValue表示初始化值；无效数据填0，防止参与Mmad计算。
        initConstValueParams.initValue = 0;
        // dstOffset定位到col方向当前已搬运数据末尾，后续Fill按row方向逐行填充尾部1个32B数据。
        uint32_t dstOffset = heightAlign * (CeilAlign(width, SCALE_CEIL_NUMBER) / 2);
        AscendC::Fill(padTensor[dstOffset], initConstValueParams);
    }

    // A1 -> A2: 调用一次LoadData，同时将A矩阵搬入L0A、scaleA矩阵搬入L0A_MX
    // LoadData2DParamsV2控制A矩阵搬运，LoadData2DMxParams控制scaleA矩阵搬运
    __aicore__ inline void SplitA(
        AscendC::LocalTensor<TA> a1Local, AscendC::LocalTensor<fp8_e8m0_t> scaleA1Local,
        AscendC::LocalTensor<TAL0Type> a2Local)
    {
        AscendC::LoadData2DParamsV2 loadDataParams;
        loadDataParams.sid = 0;
        // 从A矩阵L1源操作数的row方向第0个分形、col方向第0个32B块开始搬运
        loadDataParams.mStartPosition = 0;
        loadDataParams.kStartPosition = 0;

        AscendC::LoadData2DMxParams loadMxDataParams;
        // scaleA同步从L1源操作数的row方向第0个分形、col方向第0个32B块开始搬运
        loadMxDataParams.xStartPosition = 0;
        loadMxDataParams.yStartPosition = 0;
        if constexpr (!isAtranspose) {
            // A矩阵不转置输入[m, k]，L1 -> L0A不需要转置
            // mStep/kStep分别表示搬运row方向分形数、col方向32B块数
            loadDataParams.mStep = CeilDivision(mAlignL1, fractalShape[0]);
            loadDataParams.kStep = CeilDivision(kaAlignL1, fractalShape[1]);
            // srcStride/dstStride表示源/目的矩阵col方向相邻分形起始地址间隔，单位512B
            loadDataParams.srcStride = CeilDivision(mAlignL1, fractalShape[0]);
            loadDataParams.dstStride = CeilDivision(mAlignL0, fractalShape[0]);
            loadDataParams.ifTranspose = false;
        } else {
            // A矩阵转置输入[k, m]，L1 -> L0A需要转置，会发生小分形转置和大分形排布格式变化
            // 转置搬运时，L1上A矩阵shape为[kaAlignL1, mAlignL1]，row方向对应逻辑k维度，col方向对应逻辑m维度
            loadDataParams.mStep = CeilDivision(kaAlignL1, fractalShape[0]);
            loadDataParams.kStep = CeilDivision(mAlignL1, fractalShape[1]);
            // srcStride/dstStride表示源/目的矩阵col方向相邻分形起始地址间隔，单位512B
            loadDataParams.srcStride = CeilDivision(kaAlignL1, fractalShape[0]);
            loadDataParams.dstStride = CeilDivision(mAlignL0, fractalShape[0]);
            loadDataParams.ifTranspose = true;
        }
        // xStep/yStep配置scaleA的row/col方向搬运长度；stride按row方向相邻分形间隔配置
        loadMxDataParams.xStep = CeilDivision(scaleMAlignL1, fractalShape[0]);
        loadMxDataParams.yStep = scaleK / SCALE_EVEN_NUMBER;
        loadMxDataParams.srcStride = scaleK / SCALE_EVEN_NUMBER;
        loadMxDataParams.dstStride = scaleK / SCALE_EVEN_NUMBER;
        AscendC::LoadData(a2Local, a1Local, scaleA1Local, loadDataParams, loadMxDataParams);
    }

    // A1 -> A2: A矩阵转置输入时使用for循环调用LoadData
    // 每次循环搬运mStepAlign个分形，避免m方向多搬脏数据超过1个分形
    // 循环内通过mStartPosition推进A矩阵的row方向分块，scaleA矩阵仅在第一次循环搬运
    __aicore__ inline void SplitAWithLoop(
        AscendC::LocalTensor<TA> a1Local, AscendC::LocalTensor<fp8_e8m0_t> scaleA1Local,
        AscendC::LocalTensor<TAL0Type> a2Local)
    {
        uint16_t mStepAlign = isFP4 ? FP4_M_STEP_ALIGN : FP8_M_STEP_ALIGN;
        AscendC::LoadData2DParamsV2 loadDataParams;
        loadDataParams.sid = 0;
        // kStartPosition固定为0，每次循环通过mStartPosition选择A矩阵源row方向上的当前分块
        loadDataParams.kStartPosition = 0;
        // 转置搬运要求mStep按数据类型对齐：FP4为4个分形，FP8为2个分形
        loadDataParams.mStep = mStepAlign;
        // kStep对应A矩阵源col方向上的32B块数
        loadDataParams.kStep = CeilDivision(mAlignL0, fractalShape[1]);
        // srcStride/dstStride表示源/目的矩阵col方向相邻分形起始地址间隔，单位512B
        loadDataParams.srcStride = CeilDivision(kaAlignL1, fractalShape[0]);
        loadDataParams.dstStride = CeilDivision(mAlignL0, fractalShape[0]);
        loadDataParams.ifTranspose = true;

        AscendC::LoadData2DMxParams loadMxDataParams;
        // scaleA的row方向起始分形、col方向起始32B块固定为0
        loadMxDataParams.xStartPosition = 0;
        loadMxDataParams.yStartPosition = 0;
        // srcStride/dstStride表示scaleA源/目的矩阵row方向相邻分形起始地址间隔，单位32B
        loadMxDataParams.srcStride = scaleK / SCALE_EVEN_NUMBER;
        loadMxDataParams.dstStride = scaleK / SCALE_EVEN_NUMBER;

        uint32_t dstOffset = 0;
        uint16_t L0ALoopNum = CeilDivision(kaAlignL0, fractalShape[0] * fractalNum);
        for (uint16_t loopIdx = 0; loopIdx < L0ALoopNum; ++loopIdx) {
            // mStartPosition递增，A矩阵每次搬运按m方向更新起始地址，scaleA矩阵第一次for循环全部搬运完成，后续for循环不进行搬运
            loadDataParams.mStartPosition = mStepAlign * loopIdx;
            if (loopIdx != 0) {
                loadMxDataParams.xStep = 0;
                loadMxDataParams.yStep = 0;
            } else {
                loadMxDataParams.xStep = CeilDivision(scaleMAlignL1, fractalShape[0]);
                loadMxDataParams.yStep = scaleK / SCALE_EVEN_NUMBER;
            }
            AscendC::LoadData(a2Local[dstOffset], a1Local, scaleA1Local, loadDataParams, loadMxDataParams);
            dstOffset += CeilAlign(mAlignL0, fractalShape[0]) * fractalShape[1];
        }
    }

    // B1 -> B2: 调用一次LoadData，同时将B矩阵搬入L0B、scaleB矩阵搬入L0B_MX
    // LoadData2DParamsV2控制B矩阵搬运，LoadData2DMxParams控制scaleB矩阵搬运
    __aicore__ inline void SplitB(
        AscendC::LocalTensor<TB> b1Local, AscendC::LocalTensor<fp8_e8m0_t> scaleB1Local,
        AscendC::LocalTensor<TBL0Type> b2Local)
    {
        AscendC::LoadData2DParamsV2 loadDataParams;
        loadDataParams.sid = 0;
        // 从B矩阵L1源操作数的row方向第0个分形、col方向第0个32B块开始搬运
        loadDataParams.mStartPosition = 0;
        loadDataParams.kStartPosition = 0;

        AscendC::LoadData2DMxParams loadMxDataParams;
        // scaleB同步从L1源操作数的row方向第0个分形、col方向第0个32B块开始搬运
        loadMxDataParams.xStartPosition = 0;
        loadMxDataParams.yStartPosition = 0;

        if constexpr (isBtranspose) {
            // B矩阵转置输入[n, k]，L1 -> L0B不需要转置
            // mStep/kStep分别表示搬运row方向分形数、col方向32B块数
            loadDataParams.mStep = CeilDivision(nAlignL1, fractalShape[0]);
            loadDataParams.kStep = CeilDivision(kbAlignL1, fractalShape[1]);
            // srcStride/dstStride表示源/目的矩阵col方向相邻分形起始地址间隔，单位512B
            loadDataParams.srcStride = CeilDivision(nAlignL1, fractalShape[0]);
            loadDataParams.dstStride = CeilDivision(nAlignL0, fractalShape[0]);
            loadDataParams.ifTranspose = false;
        } else {
            // B矩阵不转置输入[k, n]，L1 -> L0B需要转置，会发生小分形转置和大分形排布格式变化
            // 转置搬运时，L1上B矩阵shape为[kbAlignL1, nAlignL1]，row方向对应逻辑k维度，col方向对应逻辑n维度
            loadDataParams.mStep = CeilDivision(kbAlignL1, fractalShape[0]);
            loadDataParams.kStep = CeilDivision(nAlignL1, fractalShape[1]);
            // srcStride/dstStride表示源/目的矩阵col方向相邻分形起始地址间隔，单位512B
            loadDataParams.srcStride = CeilDivision(kbAlignL1, fractalShape[0]);
            loadDataParams.dstStride = CeilDivision(nAlignL0, fractalShape[0]);
            loadDataParams.ifTranspose = true;
        }
        // xStep/yStep配置scaleB的row/col方向搬运长度；stride按row方向相邻分形间隔配置
        loadMxDataParams.xStep = CeilDivision(scaleNAlignL1, fractalShape[0]);
        loadMxDataParams.yStep = scaleK / SCALE_EVEN_NUMBER;
        loadMxDataParams.srcStride = scaleK / SCALE_EVEN_NUMBER;
        loadMxDataParams.dstStride = scaleK / SCALE_EVEN_NUMBER;
        AscendC::LoadData(b2Local, b1Local, scaleB1Local, loadDataParams, loadMxDataParams);
    }

private:
    AscendC::GlobalTensor<TA> aGM;
    AscendC::GlobalTensor<TB> bGM;
    AscendC::GlobalTensor<fp8_e8m0_t> scaleAGM;
    AscendC::GlobalTensor<fp8_e8m0_t> scaleBGM;
    AscendC::GlobalTensor<U> cGM;

    static constexpr uint32_t a1Addr = 0;
    static constexpr uint32_t a2Addr = 0;
    static constexpr uint32_t scaleA1Addr = 128 * 1024;
    static constexpr uint32_t b1Addr = 256 * 1024;
    static constexpr uint32_t b2Addr = 0;
    static constexpr uint32_t scaleB1Addr = 384 * 1024;
    static constexpr uint32_t co1Addr = 0;

    uint32_t mAlignL1 = m, kaAlignL1 = k, nAlignL1 = n, kbAlignL1 = k;
    uint32_t mAlignL0 = m, kaAlignL0 = k, nAlignL0 = n, kbAlignL0 = k;
    uint32_t scaleMAlignL1 = m, scaleNAlignL1 = n;
    uint32_t alignK = k;

    uint32_t aSizeAlignL1, bSizeAlignL1, scaleASizeAlignL1, scaleBSizeAlignL1;
    uint32_t aSizeAlignL0, bSizeAlignL0, scaleASizeAlignL0, scaleBSizeAlignL0, cSizeAlignL0;
    uint32_t fractalShape[2] = {0, 0};
    uint32_t fractalNum = 0;
    uint32_t packedK = k;
    uint32_t scaleK = k;
    bool isFP4 = false;
};

template <typename KernelType>
__aicore__ inline void RunKernel(
    __gm__ uint8_t* a, __gm__ uint8_t* b, __gm__ uint8_t* scaleA, __gm__ uint8_t* scaleB, __gm__ uint8_t* c)
{
    AscendC::InitSocState();
    KernelType op;
    op.Init(a, b, scaleA, scaleB, c);
    op.Process();
    AscendC::PipeBarrier<PIPE_ALL>();
}

template <uint32_t m, uint32_t n, uint32_t k>
__global__ __cube__ void KernelLoadDataL12L0Load2DMX(
    __gm__ uint8_t* a, __gm__ uint8_t* b, __gm__ uint8_t* scaleA, __gm__ uint8_t* scaleB, __gm__ uint8_t* c)
{
    if constexpr (scenarioNum == 1) {
        RunKernel<KernelMmadMX<fp4x2_e1m2_t, fp4x2_e2m1_t, fp4x2_e1m2_t, fp4x2_e2m1_t, float, m, n, k, false, true>>(
            a, b, scaleA, scaleB, c);
    } else if constexpr (scenarioNum == 2) {
        RunKernel<KernelMmadMX<fp4x2_e2m1_t, fp4x2_e1m2_t, fp4x2_e2m1_t, fp4x2_e1m2_t, float, m, n, k, true, false>>(
            a, b, scaleA, scaleB, c);
    } else if constexpr (scenarioNum == 3) {
        RunKernel<KernelMmadMX<fp8_e4m3fn_t, fp8_e5m2_t, fp8_e4m3fn_t, fp8_e5m2_t, float, m, n, k, false, true>>(
            a, b, scaleA, scaleB, c);
    } else if constexpr (scenarioNum == 4) {
        RunKernel<KernelMmadMX<fp8_e5m2_t, fp8_e4m3fn_t, fp8_e5m2_t, fp8_e4m3fn_t, float, m, n, k, true, false>>(
            a, b, scaleA, scaleB, c);
    } else if constexpr (scenarioNum == 5) {
        RunKernel<KernelMmadMX<fp4x2_e2m1_t, fp4x2_e1m2_t, fp4x2_e2m1_t, fp4x2_e1m2_t, float, m, n, k, true, false>>(
            a, b, scaleA, scaleB, c);
    } else if constexpr (scenarioNum == 6) {
        RunKernel<KernelMmadMX<fp8_e5m2_t, fp8_e4m3fn_t, fp8_e5m2_t, fp8_e4m3fn_t, float, m, n, k, true, false>>(
            a, b, scaleA, scaleB, c);
    }
}

int32_t main(int32_t argc, char* argv[])
{
    constexpr uint32_t m = 40;
    constexpr uint32_t n = 50;
    constexpr uint32_t k = 70;

    size_t aFileSize = 0;
    size_t bFileSize = 0;
    size_t scaleAFileSize = 0;
    size_t scaleBFileSize = 0;
    size_t cFileSize = 0;

    if constexpr (scenarioNum == 1 || scenarioNum == 2 || scenarioNum == 5) {
        aFileSize = m * k * sizeof(uint8_t) / 2;
        bFileSize = n * k * sizeof(uint8_t) / 2;
    } else {
        aFileSize = m * k * sizeof(uint8_t);
        bFileSize = n * k * sizeof(uint8_t);
    }

    constexpr uint32_t scaleK = (k + SCALE_BASE_FACTOR - 1) / SCALE_BASE_FACTOR * SCALE_EVEN_NUMBER;
    scaleAFileSize = m * scaleK * sizeof(uint8_t);
    scaleBFileSize = n * scaleK * sizeof(uint8_t);
    cFileSize = m * n * sizeof(float);

    uint32_t numBlocks = 1;

    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t* aHost;
    uint8_t* aDevice;
    aclrtMallocHost((void**)(&aHost), aFileSize);
    aclrtMalloc((void**)&aDevice, aFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/x1_gm.bin", aFileSize, aHost, aFileSize);
    aclrtMemcpy(aDevice, aFileSize, aHost, aFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t* bHost;
    uint8_t* bDevice;
    aclrtMallocHost((void**)(&bHost), bFileSize);
    aclrtMalloc((void**)&bDevice, bFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/x2_gm.bin", bFileSize, bHost, bFileSize);
    aclrtMemcpy(bDevice, bFileSize, bHost, bFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t* scaleAHost;
    uint8_t* scaleADevice;
    aclrtMallocHost((void**)(&scaleAHost), scaleAFileSize);
    aclrtMalloc((void**)&scaleADevice, scaleAFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/x1_scale_gm.bin", scaleAFileSize, scaleAHost, scaleAFileSize);
    aclrtMemcpy(scaleADevice, scaleAFileSize, scaleAHost, scaleAFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t* scaleBHost;
    uint8_t* scaleBDevice;
    aclrtMallocHost((void**)(&scaleBHost), scaleBFileSize);
    aclrtMalloc((void**)&scaleBDevice, scaleBFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/x2_scale_gm.bin", scaleBFileSize, scaleBHost, scaleBFileSize);
    aclrtMemcpy(scaleBDevice, scaleBFileSize, scaleBHost, scaleBFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t* cHost;
    uint8_t* cDevice;
    aclrtMallocHost((void**)(&cHost), cFileSize);
    aclrtMalloc((void**)&cDevice, cFileSize, ACL_MEM_MALLOC_HUGE_FIRST);

    KernelLoadDataL12L0Load2DMX<m, n, k>
        <<<numBlocks, nullptr, stream>>>(aDevice, bDevice, scaleADevice, scaleBDevice, cDevice);
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(cHost, cFileSize, cDevice, cFileSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", cHost, cFileSize);

    aclrtFree(aDevice);
    aclrtFreeHost(aHost);
    aclrtFree(bDevice);
    aclrtFreeHost(bHost);
    aclrtFree(scaleADevice);
    aclrtFreeHost(scaleAHost);
    aclrtFree(scaleBDevice);
    aclrtFreeHost(scaleBHost);
    aclrtFree(cDevice);
    aclrtFreeHost(cHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();
    return 0;
}
