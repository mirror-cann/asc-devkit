/* !
 * \file mmad_unitflag.asc
 * \brief 本样例介绍了Mmad计算如何使用unitFlag功能
 */

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

#include "acl/acl.h"
#include "kernel_operator.h"
#include "data_utils.h"

template <class T, class U, uint32_t M, uint32_t N, uint32_t K, uint32_t kRound>
class KernelMmad {
public:
    __aicore__ inline KernelMmad()
    {
        aSingleSize = CeilAlign(m, BLOCK_CUBE) * CeilAlign(k, C0_SIZE);
        bSingleSize = CeilAlign(k, C0_SIZE) * CeilAlign(n, BLOCK_CUBE);
        cSingleSize = CeilAlign(m, BLOCK_CUBE) * CeilAlign(n, BLOCK_CUBE);
    
        a1Addr = ADDR_0;
        b1Addr = a1Addr + aSingleSize * sizeof(U);
    }
    __aicore__ inline void Init(__gm__ uint8_t* a, __gm__ uint8_t* b, __gm__ uint8_t* c)
    {
        aGM.SetGlobalBuffer((__gm__ U *)a);
        bGM.SetGlobalBuffer((__gm__ U *)b);
        cGM.SetGlobalBuffer((__gm__ T *)c);
    }
    __aicore__ inline void Process()
    {
        AscendC::LocalTensor<U> a1Local(AscendC::TPosition::A1, a1Addr, aSingleSize);
        AscendC::LocalTensor<U> b1Local(AscendC::TPosition::B1, b1Addr, bSingleSize);
        
        AscendC::LocalTensor<U> a2Local(AscendC::TPosition::A2, ADDR_0, aSingleSize);
        AscendC::LocalTensor<U> b2Local(AscendC::TPosition::B2, ADDR_0, bSingleSize);
        AscendC::LocalTensor<T> co1Local(AscendC::TPosition::CO1, ADDR_0, cSingleSize);

        for (uint32_t kIndex = 0; kIndex < kRound; kIndex++) {
            AscendC::SetFlag<AscendC::HardEvent::MTE1_MTE2>(EVENT_ID0);
            AscendC::WaitFlag<AscendC::HardEvent::MTE1_MTE2>(EVENT_ID0);

            // GM --> L1
            CopyIn(kIndex, a1Local, b1Local);
            AscendC::SetFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID0);
            AscendC::WaitFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID0);

            // L1 --> L0A
            SplitA(kIndex, a1Local, a2Local);
            // L1 --> L0B
            SplitB(kIndex, b1Local, b2Local);
            AscendC::SetFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID0);
            AscendC::WaitFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID0);

            // Mmad
            Compute(kIndex, a2Local, b2Local, co1Local);
            AscendC::SetFlag<AscendC::HardEvent::M_MTE1>(EVENT_ID0);
            AscendC::WaitFlag<AscendC::HardEvent::M_MTE1>(EVENT_ID0);
        }
        AscendC::SetFlag<AscendC::HardEvent::M_FIX>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::M_FIX>(EVENT_ID0);
        // L0C --> GM
        CopyOut(co1Local);
    }

private:
    // 向上整除
    __aicore__ inline uint32_t CeilDiv(uint32_t numerator, uint32_t denominator) 
    {
        return (numerator + denominator - 1) / denominator;
    }
    // 向上对齐
    __aicore__ inline uint32_t CeilAlign(uint32_t numerator, uint32_t denominator) 
    {
        return (numerator + denominator - 1) / denominator * denominator;
    }

    __aicore__ inline void CopyIn(uint32_t kIndex, AscendC::LocalTensor<U>& a1Local, AscendC::LocalTensor<U>& b1Local)
    {
        AscendC::Nd2NzParams nd2nzA1Params;
        nd2nzA1Params.ndNum = 1;
        nd2nzA1Params.nValue = m;
        nd2nzA1Params.dValue = k;
        nd2nzA1Params.srcNdMatrixStride = 0;
        nd2nzA1Params.srcDValue = k;
        nd2nzA1Params.dstNzC0Stride = CeilAlign(m, BLOCK_CUBE);
        nd2nzA1Params.dstNzNStride = 1;
        nd2nzA1Params.dstNzMatrixStride = 0;
        AscendC::DataCopy(a1Local, aGM[kIndex * aSingleSize], nd2nzA1Params);

        AscendC::Nd2NzParams nd2nzB1Params;
        nd2nzB1Params.ndNum = 1;
        nd2nzB1Params.nValue = k;
        nd2nzB1Params.dValue = n;
        nd2nzB1Params.srcNdMatrixStride = 0;
        nd2nzB1Params.srcDValue = n;
        nd2nzB1Params.dstNzC0Stride = CeilAlign(k, C0_SIZE);
        nd2nzB1Params.dstNzNStride = 1;
        nd2nzB1Params.dstNzMatrixStride = 0;
        AscendC::DataCopy(b1Local, bGM[kIndex * bSingleSize], nd2nzB1Params);
    }

    __aicore__ inline void SplitA(uint32_t kIndex, AscendC::LocalTensor<U>& a1Local, AscendC::LocalTensor<U>& a2Local)
    {
#if defined(__NPU_ARCH__) && (__NPU_ARCH__ == 3510)
        // Nz -> Nz，__NPU_ARCH__为3510时，要求A2上的数据排布为：Nz
        AscendC::LoadData2DParamsV2 loadDataParams;
        loadDataParams.mStartPosition = 0;
        loadDataParams.kStartPosition = 0;
        loadDataParams.mStep = CeilDiv(m, BLOCK_CUBE);
        loadDataParams.kStep = CeilDiv(k, C0_SIZE);
        loadDataParams.srcStride = CeilDiv(m, BLOCK_CUBE);
        loadDataParams.dstStride = CeilDiv(m, BLOCK_CUBE);
        loadDataParams.ifTranspose = false;
        AscendC::LoadData(a2Local, a1Local, loadDataParams);
#else
        // Nz -> Zz，__NPU_ARCH__为2201时，要求A2上的数据排布为：Zz
        uint32_t dstOffset = CeilDiv(k, C0_SIZE) * FRACTAL_SIZE;
        uint32_t srcOffset = FRACTAL_SIZE;
        AscendC::LoadData2DParams loadDataParams;
        loadDataParams.repeatTimes = CeilDiv(k, C0_SIZE);
        loadDataParams.srcStride = CeilDiv(m, BLOCK_CUBE);
        loadDataParams.dstGap = 0;
        loadDataParams.ifTranspose = false;
        for (int i = 0; i < CeilDiv(m, BLOCK_CUBE); ++i) {
            AscendC::LoadData(a2Local[i * dstOffset], a1Local[i * srcOffset], loadDataParams);
        }
#endif
    }

    __aicore__ inline void SplitB(uint32_t kIndex, AscendC::LocalTensor<U>& b1Local, AscendC::LocalTensor<U>& b2Local)
    {
        uint32_t dstOffset = CeilDiv(n, BLOCK_CUBE) * FRACTAL_SIZE;
        uint32_t srcOffset = FRACTAL_SIZE;
        // Nz -> Zn
        AscendC::LoadData2DParams loadDataParams;
        loadDataParams.repeatTimes = CeilDiv(n, BLOCK_CUBE);
        loadDataParams.srcStride = CeilDiv(k, C0_SIZE);
        loadDataParams.dstGap = 0;
        loadDataParams.ifTranspose = true;
        for (int i = 0; i < CeilDiv(k, C0_SIZE); ++i) {
            AscendC::LoadData(b2Local[i * dstOffset], b1Local[i * srcOffset], loadDataParams);
        }
    }
    __aicore__ inline void Compute(uint32_t kIndex, AscendC::LocalTensor<U>& a2Local,
                                   AscendC::LocalTensor<U>& b2Local, AscendC::LocalTensor<T>& co1Local)
    {
        AscendC::MmadParams mmadParams;
        mmadParams.m = m;
        mmadParams.n = n;
        mmadParams.k = k;
        if (kIndex == 0) {
            mmadParams.cmatrixInitVal = true;
        } else {
            mmadParams.cmatrixInitVal = false;
        }
#if defined(ENABLE_UNITFLAG) && (ENABLE_UNITFLAG == 1)
        // 使能该功能时，Mmad指令的unitFlag在最后1个分形设置为3、其余分形计算设置为2即可。
        if (kIndex != kRound - 1) {
            mmadParams.unitFlag = 2;
        } else {
            mmadParams.unitFlag = 3;
        }
#endif
        AscendC::Mmad(co1Local, a2Local, b2Local, mmadParams);
        if ((m / BLOCK_CUBE) * (n / BLOCK_CUBE) < LIMIT_MNSIZE) {
            AscendC::PipeBarrier<PIPE_M>();
        }
        AscendC::SetFlag<AscendC::HardEvent::MTE2_M>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_M>(EVENT_ID0);
    }
    __aicore__ inline void CopyOut(AscendC::LocalTensor<T>& co1Local)
    {
        AscendC::SetFlag<AscendC::HardEvent::M_FIX>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::M_FIX>(EVENT_ID0);
#if defined(__NPU_ARCH__) && (__NPU_ARCH__ == 3510)
        AscendC::FixpipeParamsArch3510<AscendC::CO2Layout::ROW_MAJOR> fixpipeParams;
#else
        AscendC::FixpipeParamsV220 fixpipeParams;
        fixpipeParams.ndNum = 1;
        fixpipeParams.srcNdStride = 0;
        fixpipeParams.dstNdStride = 0;
#endif
        fixpipeParams.nSize = n;
        fixpipeParams.mSize = m;
        fixpipeParams.srcStride = CeilAlign(m, BLOCK_CUBE);
        fixpipeParams.dstStride = n;

        AscendC::Fixpipe(cGM, co1Local, fixpipeParams);
#if defined(ENABLE_UNITFLAG) && (ENABLE_UNITFLAG == 1)
        // unitFlag清空标志位，类型为bool。如果设为true,L0C中所有内存块的单元标志位都会设为0。
        // 旨在消除之前操作中unitFlag产生的多余影响，该操作属于可选项。
        bool isUnitFlag = true;
        AscendC::SetFixPipeConfig<T>(co1Local, isUnitFlag);
#endif
    }

private:
    AscendC::GlobalTensor<U> aGM;
    AscendC::GlobalTensor<U> bGM;
    AscendC::GlobalTensor<T> cGM;

    // 注意沿着K轴切分
    uint16_t m = M, k = K / kRound, n = N;
    uint16_t aSingleSize, bSingleSize, cSingleSize;
    uint64_t a1Addr, b1Addr;

    static constexpr uint32_t BLOCK_CUBE = 16;
    static constexpr uint32_t C0_SIZE = 32 / sizeof(U);
    static constexpr uint64_t FRACTAL_SIZE = BLOCK_CUBE * C0_SIZE;
    static constexpr uint64_t ADDR_0 = 0;
    static constexpr uint64_t LIMIT_MNSIZE = 10;
};

template <uint32_t M, uint32_t N, uint32_t K, uint32_t kRound>
__global__ __cube__ void mmad_with_unitflag_custom(__gm__ uint8_t* a, __gm__ uint8_t* b, __gm__ uint8_t* c)
{
    AscendC::InitSocState();
    KernelMmad<float, half, M, N, K, kRound> op;
    op.Init(a, b, c);
    op.Process();
    AscendC::PipeBarrier<PIPE_ALL>();
}

int32_t main(int32_t argc, char *argv[])
{
    constexpr uint32_t M = 128;
    constexpr uint32_t N = 256;
    constexpr uint32_t K = 512;
    constexpr uint32_t kRound = 8;

    size_t aFileSize = M * K * sizeof(half); 
    size_t bFileSize = K * N * sizeof(half); 
    size_t cFileSize = M * N * sizeof(float);
    uint32_t numBlocks = 1;

    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t *aHost;
    uint8_t *aDevice;
    aclrtMallocHost((void **)(&aHost), aFileSize);
    aclrtMalloc((void **)&aDevice, aFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/x1_gm.bin", aFileSize, aHost, aFileSize);
    aclrtMemcpy(aDevice, aFileSize, aHost, aFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t *bHost;
    uint8_t *bDevice;
    aclrtMallocHost((void **)(&bHost), bFileSize);
    aclrtMalloc((void **)&bDevice, bFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/x2_gm.bin", bFileSize, bHost, bFileSize);
    aclrtMemcpy(bDevice, bFileSize, bHost, bFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t *cHost;
    uint8_t *cDevice;
    aclrtMallocHost((void **)(&cHost), cFileSize);
    aclrtMalloc((void **)&cDevice, cFileSize, ACL_MEM_MALLOC_HUGE_FIRST);

    mmad_with_unitflag_custom<M, N, K, kRound><<<numBlocks, nullptr, stream>>>(aDevice, bDevice, cDevice);
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(cHost, cFileSize, cDevice, cFileSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", cHost, cFileSize);

    aclrtFree(aDevice);
    aclrtFreeHost(aHost);
    aclrtFree(bDevice);
    aclrtFreeHost(bHost);
    aclrtFree(cDevice);
    aclrtFreeHost(cHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();
    return 0;
}