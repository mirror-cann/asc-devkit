/* !
 * \file scalar_atomic_operations.asc
 * \brief 本样例基于 AtomicAdd/AtomicCas 接口，介绍在 GM 地址上进行标量原子加和原子比较交换的实现流程
 */

#include "acl/acl.h"
#include "data_utils.h"
#include "kernel_operator.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

constexpr uint32_t scenarioNum = SCENARIO_NUM;

__global__ __vector__ void scalar_atomic_operations_custom(__gm__ uint8_t* y)
{
    if constexpr (scenarioNum == 1) {
        // AtomicAdd：三个核分别对GM首个元素原子加1
        int32_t valueToAdd = 1;
        int32_t oldValue = AscendC::AtomicAdd(reinterpret_cast<__gm__ int32_t*>(y), valueToAdd);

        // 原子操作后插入同步
        AscendC::SetFlag<AscendC::HardEvent::S_MTE2>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::S_MTE2>(EVENT_ID0);
    } else {
        // AtomicCas：三个核分别对GM首个元素原子比较交换
        uint32_t expected = 1;
        uint32_t newValue = 2;
        uint32_t oldValue = AscendC::AtomicCas(reinterpret_cast<__gm__ uint32_t*>(y), expected, newValue);

        // 原子操作后插入同步
        AscendC::SetFlag<AscendC::HardEvent::S_MTE2>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::S_MTE2>(EVENT_ID0);
    }
}

int32_t main(int32_t argc, char* argv[])
{
    constexpr uint32_t NUM_BLOCKS = 3;
    constexpr uint32_t DATA_SIZE = 256;
    size_t outputByteSize = DATA_SIZE * sizeof(int32_t);

    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t *outHost;
    uint8_t *outDevice;

    aclrtMallocHost((void**)(&outHost), outputByteSize);
    aclrtMalloc((void**)&outDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);

    ReadFile("./input/input_y.bin", outputByteSize, outHost, outputByteSize);

    aclrtMemcpy(outDevice, outputByteSize, outHost, outputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);

    scalar_atomic_operations_custom<<<NUM_BLOCKS, nullptr, stream>>>(outDevice);
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(outHost, outputByteSize, outDevice, outputByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", outHost, outputByteSize);

    aclrtFree(outDevice);
    aclrtFreeHost(outHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();

    return 0;
}