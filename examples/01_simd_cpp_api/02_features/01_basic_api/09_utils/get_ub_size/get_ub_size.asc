/* !
 * \file get_ub_size.asc
 * \brief GetUBSize样例，展示GetUBSizeInBytes和GetRuntimeUBSize接口使用方法
 */

#include "acl/acl.h"
#include "data_utils.h"
#include "kernel_operator.h"
#include <cassert>

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

constexpr uint32_t scenarioNum = SCENARIO_NUM;

__global__ __vector__ void get_ub_size_custom(__gm__ uint8_t* x, __gm__ uint8_t* z)
{
    AscendC::InitSocState();
    uint32_t tileLength;
    uint32_t tileNum;
    if constexpr (scenarioNum == 1) {
        // 场景1：GetUBSizeInBytes，返回编译时常量
        constexpr uint32_t totalLength = 16384;
        if (totalLength > AscendC::GetUBSizeInBytes() / sizeof(half) / 2) {
            tileLength = AscendC::GetUBSizeInBytes() / sizeof(half) / 2;
        } else {
            tileLength = totalLength;
        }
        tileNum = totalLength / tileLength;
    } else if constexpr (scenarioNum == 2) {
        // 场景2：GetRuntimeUBSize，返回运行时变量
        constexpr uint32_t totalLength = 126976;
        if (totalLength > AscendC::GetRuntimeUBSize() / sizeof(half) / 2) {
            tileLength = AscendC::GetRuntimeUBSize() / sizeof(half) / 2;
        } else {
            tileLength = totalLength;
        }
        tileNum = totalLength / tileLength;
    }

    AscendC::GlobalTensor<half> xGm;
    AscendC::GlobalTensor<half> zGm;
    xGm.SetGlobalBuffer((__gm__ half*)x);
    zGm.SetGlobalBuffer((__gm__ half*)z);
    // 静态地址分配
    uint64_t xAddr = 0;
    uint64_t zAddr = xAddr + tileLength * sizeof(half);
    AscendC::LocalTensor<half> xLocal(AscendC::TPosition::VECIN, xAddr, tileLength);
    AscendC::LocalTensor<half> zLocal(AscendC::TPosition::VECOUT, zAddr, tileLength);

    for (int32_t i = 0; i < tileNum; i++) {
        // GM -> UB: MTE2流水搬运
        AscendC::DataCopy(xLocal, xGm[i * tileLength], tileLength);
        AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
        // Vector计算：Abs取绝对值
        AscendC::Abs(zLocal, xLocal, tileLength);
        AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        AscendC::SetFlag<AscendC::HardEvent::V_MTE2>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::V_MTE2>(EVENT_ID0);
        // UB -> GM: MTE3流水搬运
        AscendC::DataCopy(zGm[i * tileLength], zLocal, tileLength);
        AscendC::SetFlag<AscendC::HardEvent::MTE3_V>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE3_V>(EVENT_ID0);
    }

    AscendC::PipeBarrier<PIPE_ALL>();
}

int32_t main(int32_t argc, char* argv[])
{
    uint32_t numBlocks = 1;
    size_t inputByteSize = 0;
    size_t outputByteSize = 0;

    if constexpr (scenarioNum == 1) {
        inputByteSize = 16384 * sizeof(half);
        outputByteSize = 16384 * sizeof(half);
    } else if constexpr (scenarioNum == 2) {
        inputByteSize = 126976 * sizeof(half);
        outputByteSize = 126976 * sizeof(half);
    }

    int32_t deviceId = 0;
    aclError ret = aclrtSetDevice(deviceId);
    assert(ret == ACL_SUCCESS && "aclrtSetDevice failed!");
    aclrtStream stream = nullptr;
    ret = aclrtCreateStream(&stream);
    assert(ret == ACL_SUCCESS && "aclrtCreateStream failed!");

    uint8_t *xHost, *zHost;
    uint8_t *xDevice, *zDevice;

    ret = aclrtMallocHost((void**)(&xHost), inputByteSize);
    assert(ret == ACL_SUCCESS && "aclrtMallocHost xHost failed!");
    ret = aclrtMallocHost((void**)(&zHost), outputByteSize);
    assert(ret == ACL_SUCCESS && "aclrtMallocHost zHost failed!");
    ret = aclrtMalloc((void**)&xDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    assert(ret == ACL_SUCCESS && "aclrtMalloc xDevice failed!");
    ret = aclrtMalloc((void**)&zDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    assert(ret == ACL_SUCCESS && "aclrtMalloc zDevice failed!");

    ReadFile("./input/input_x.bin", inputByteSize, xHost, inputByteSize);
    ret = aclrtMemcpy(xDevice, inputByteSize, xHost, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
    assert(ret == ACL_SUCCESS && "aclrtMemcpy xHost to xDevice failed!");

    get_ub_size_custom<<<numBlocks, nullptr, stream>>>(xDevice, zDevice);
    ret = aclrtSynchronizeStream(stream);
    assert(ret == ACL_SUCCESS && "aclrtSynchronizeStream failed!");

    ret = aclrtMemcpy(zHost, outputByteSize, zDevice, outputByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    assert(ret == ACL_SUCCESS && "aclrtMemcpy zDevice to zHost failed!");
    WriteFile("./output/output.bin", zHost, outputByteSize);

    if (xDevice != nullptr) {
        aclrtFree(xDevice);
        xDevice = nullptr;
    }
    if (zDevice != nullptr) {
        aclrtFree(zDevice);
        zDevice = nullptr;
    }
    if (xHost != nullptr) {
        aclrtFreeHost(xHost);
        xHost = nullptr;
    }
    if (zHost != nullptr) {
        aclrtFreeHost(zHost);
        zHost = nullptr;
    }

    if (stream != nullptr) {
        aclrtDestroyStream(stream);
        stream = nullptr;
    }

    aclrtResetDevice(deviceId);
    aclFinalize();

    return 0;
}
