/* !
 * \file bank_conflict_ub.asc
 * \brief bank conflict operator performance tuning sample.
 */

#include "data_utils.h"
#include "kernel_operator.h"
#include "acl/acl.h"
#include "config.h"
using KernelEntry = void (*)(uint32_t, void*, uint8_t*, uint8_t*, uint8_t*);

struct ArgInfo {
    std::string fileName;
    size_t length;
};

constexpr uint32_t REPEAT_TIMES_FOR_INSTR_EXCUTE = 1000;

class KernelAdd {
public:
    __aicore__ inline KernelAdd() {}
    __aicore__ inline void Init(GM_ADDR x, GM_ADDR y, GM_ADDR z)
    {
        xGm.SetGlobalBuffer((__gm__ float*)x, TOTAL_LENGTH);
        yGm.SetGlobalBuffer((__gm__ float*)y, TOTAL_LENGTH);
        zGm.SetGlobalBuffer((__gm__ float*)z, TOTAL_LENGTH);
    }
    __aicore__ inline void Process()
    {
        AscendC::LocalTensor<float> xLocal(AscendC::TPosition::VECCALC, xLocalAddr, TOTAL_LENGTH);
        AscendC::LocalTensor<float> yLocal(AscendC::TPosition::VECCALC, yLocalAddr, TOTAL_LENGTH);
        AscendC::LocalTensor<float> zLocal(AscendC::TPosition::VECCALC, zLocalAddr, TOTAL_LENGTH);

        AscendC::DataCopy(xLocal, xGm, TOTAL_LENGTH);
        AscendC::DataCopy(yLocal, yGm, TOTAL_LENGTH);

        AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);

        uint32_t itemsPerIter = 256 / sizeof(float);        // 每次迭代计算的元素个数
        uint32_t repeatTimes = TOTAL_LENGTH / itemsPerIter; // 总共的迭代次数
        uint64_t mask = itemsPerIter;                       // 每次迭代计算的元素个数

        AscendC::PipeBarrier<PIPE_ALL>();
        uint64_t systemCycleBefore = AscendC::GetSystemCycle();

        for (int32_t i = 0; i < REPEAT_TIMES_FOR_INSTR_EXCUTE; ++i) {
            if constexpr (SCENARIO_NUM == 7) {
                // src0BlkStride = 0: 单次repeat内重复读同1个DataBlock
                // src0RepStride = 1：repeat之间，间隔1个DataBlock
                AscendC::Add(zLocal, xLocal, yLocal, mask, repeatTimes, {1, 0, 1, 8, 1, 8});
            } else if constexpr (SCENARIO_NUM == 8) {
                // src0BlkStride = 0: 单次repeat内重复读同1个DataBlock
                // src0RepStride = 8：repeat之间，间隔8个DataBlock
                AscendC::Add(zLocal, xLocal, yLocal, mask, repeatTimes, {1, 0, 1, 8, 8, 8});
            } else {
                // dstBlkStride, src0BlkStride, src1BlkStride, dstRepStride, src0RepStride, src1RepStride
                AscendC::Add(zLocal, xLocal, yLocal, mask, repeatTimes, {1, 1, 1, 8, 8, 8});
            }
        }
        AscendC::PipeBarrier<PIPE_ALL>();
        uint64_t systemCycleAfter = AscendC::GetSystemCycle();

        AscendC::printf("\nGetPhyAddr(xLocal) = %lu, %x", xLocal.GetPhyAddr(), xLocal.GetPhyAddr());
        AscendC::printf("\nGetPhyAddr(yLocal) = %lu, %x", yLocal.GetPhyAddr(), yLocal.GetPhyAddr());
        AscendC::printf("\nGetPhyAddr(zLocal) = %lu, %x", zLocal.GetPhyAddr(), zLocal.GetPhyAddr());
        AscendC::printf("\n[LOG] Scenario %d\n", SCENARIO_NUM);

        AscendC::printf("[LOG] systemCycleBefore: %lu\n", systemCycleBefore);
        AscendC::printf("[LOG] systemCycleAfter: %lu\n", systemCycleAfter);
        AscendC::printf(
            "[LOG] Add instruction has executed %d times, cost total cycles: %lu\n", REPEAT_TIMES_FOR_INSTR_EXCUTE,
            (systemCycleAfter - systemCycleBefore));

        AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);

        AscendC::DataCopy(zGm, zLocal, TOTAL_LENGTH);
    }

private:
    AscendC::GlobalTensor<float> xGm;
    AscendC::GlobalTensor<float> yGm;
    AscendC::GlobalTensor<float> zGm;
};

extern "C" __global__ __vector__ void add_custom(GM_ADDR x, GM_ADDR y, GM_ADDR z)
{
    AscendC::InitSocState();
    KernelAdd op;
    op.Init(x, y, z);
    op.Process();
    AscendC::PipeBarrier<PIPE_ALL>();
}

void add_custom_do(uint32_t numBlocks, void* stream, uint8_t* x, uint8_t* y, uint8_t* z)
{
    add_custom<<<numBlocks, nullptr, stream>>>(x, y, z);
}

void KernelCall(
    KernelEntry kernelEntry, uint32_t numBlocks, void* stream, std::vector<ArgInfo>& inputsInfo,
    std::vector<ArgInfo>& outputsInfo)
{
    std::vector<uint8_t*> inputHost(inputsInfo.size());
    std::vector<uint8_t*> inputDevice(inputsInfo.size());
    std::vector<uint8_t*> outputHost(outputsInfo.size());
    std::vector<uint8_t*> outputDevice(outputsInfo.size());

    for (uint32_t i = 0; i < inputsInfo.size(); i++) {
        aclrtMallocHost((void**)(&inputHost[i]), inputsInfo[i].length);
        aclrtMalloc((void**)(&inputDevice[i]), inputsInfo[i].length, ACL_MEM_MALLOC_HUGE_FIRST);
        ReadFile(inputsInfo[i].fileName, inputsInfo[i].length, inputHost[i], inputsInfo[i].length);
        aclrtMemcpy(
            inputDevice[i], inputsInfo[i].length, inputHost[i], inputsInfo[i].length, ACL_MEMCPY_HOST_TO_DEVICE);
    }

    for (uint32_t i = 0; i < outputsInfo.size(); i++) {
        aclrtMallocHost((void**)(&outputHost[i]), outputsInfo[i].length);
        aclrtMalloc((void**)(&outputDevice[i]), outputsInfo[i].length, ACL_MEM_MALLOC_HUGE_FIRST);
    }

    kernelEntry(numBlocks, stream, inputDevice[0], inputDevice[1], outputDevice[0]);
    aclrtSynchronizeStream(stream);
    for (uint32_t i = 0; i < outputsInfo.size(); i++) {
        aclrtMemcpy(
            outputHost[i], outputsInfo[i].length, outputDevice[i], outputsInfo[i].length, ACL_MEMCPY_DEVICE_TO_HOST);
        WriteFile(outputsInfo[i].fileName, outputHost[i], outputsInfo[i].length);
        aclrtFree(outputDevice[i]);
        aclrtFreeHost(outputHost[i]);
    }

    for (uint32_t i = 0; i < inputsInfo.size(); i++) {
        aclrtFree(inputDevice[i]);
        aclrtFreeHost(inputHost[i]);
    }
}

int32_t main(int32_t argc, char* argv[])
{
    uint32_t numBlocks = 1;
    uint32_t dataLen = 4096;
    size_t inputByteSize = dataLen * sizeof(float);
    size_t outputByteSize = dataLen * sizeof(float);

    std::vector<ArgInfo> inputsInfo = {{"./input/input_x.bin", inputByteSize}, {"./input/input_y.bin", inputByteSize}};
    std::vector<ArgInfo> outputsInfo = {{"./output/output_z.bin", outputByteSize}};

    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    KernelCall(add_custom_do, numBlocks, stream, inputsInfo, outputsInfo);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();

    return 0;
}
