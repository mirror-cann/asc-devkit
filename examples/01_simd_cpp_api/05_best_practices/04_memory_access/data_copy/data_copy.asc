/* !
 * \file data_copy.asc
 * \brief DataCopy best practices
 */

#include "data_copy_l1.h"
#include "data_copy_ub.h"
#include "data_utils.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

constexpr uint32_t scenarioNum = SCENARIO_NUM;

#if defined(ARCH_3510)
constexpr uint32_t AIV_CORE_NUM = 64;
constexpr uint32_t AIC_CORE_NUM = 32;
constexpr uint32_t UB_ADDR_CONFLICT_M = 8192;
constexpr uint32_t L1_ADDR_CONFLICT_M = 8192;
#else
constexpr uint32_t AIV_CORE_NUM = 48;
constexpr uint32_t AIC_CORE_NUM = 24;
constexpr uint32_t UB_ADDR_CONFLICT_M = 6144;
constexpr uint32_t L1_ADDR_CONFLICT_M = 6144;
#endif

template <uint32_t mValue, uint32_t nValue, uint32_t numBlocksValue, uint32_t tileMValue, uint32_t tileNValue>
struct ScenarioConfig {
    static constexpr uint32_t M = mValue;
    static constexpr uint32_t N = nValue;
    static constexpr uint32_t NUM_BLOCKS = numBlocksValue;
    static constexpr uint32_t SINGLE_CORE_M = M / NUM_BLOCKS;
    static constexpr uint32_t TILE_M = tileMValue;
    static constexpr uint32_t TILE_N = tileNValue;
};

template <uint32_t scenario>
struct UbScenario;

// UB 场景：1~4 为分块和尾块，5~6 为重复搬运，7~8 为同地址冲突。
template <>
struct UbScenario<1> : ScenarioConfig<12288, 12288, AIV_CORE_NUM, 1, 64> {};
template <>
struct UbScenario<2> : ScenarioConfig<12288, 12288, AIV_CORE_NUM, 64, 64> {};
template <>
struct UbScenario<3> : ScenarioConfig<12288, 12288, AIV_CORE_NUM, 64, 1024> {};
template <>
struct UbScenario<4> : ScenarioConfig<12288, 12287, AIV_CORE_NUM, 64, 1024> {};
template <>
struct UbScenario<5> : ScenarioConfig<12288, 12288, AIV_CORE_NUM, 64, 1024> {};
template <>
struct UbScenario<6> : ScenarioConfig<12288, 12288, AIV_CORE_NUM, 64, 1024> {};
template <>
struct UbScenario<7> : ScenarioConfig<UB_ADDR_CONFLICT_M, 512, AIV_CORE_NUM, 128, 64> {};
template <>
struct UbScenario<8> : ScenarioConfig<UB_ADDR_CONFLICT_M, 512, AIV_CORE_NUM, 128, 64> {};

template <uint32_t scenario>
struct L1Scenario;

// L1 场景：1~3 为分块和尾块，4~5 为重复搬运，6~7 为同地址冲突。
template <>
struct L1Scenario<1> : ScenarioConfig<12288, 12288, AIC_CORE_NUM, 64, 64> {};
template <>
struct L1Scenario<2> : ScenarioConfig<12288, 12288, AIC_CORE_NUM, 64, 256> {};
template <>
struct L1Scenario<3> : ScenarioConfig<12288, 12287, AIC_CORE_NUM, 64, 256> {};
template <>
struct L1Scenario<4> : ScenarioConfig<12288, 12288, AIC_CORE_NUM, 64, 1024> {};
template <>
struct L1Scenario<5> : ScenarioConfig<12288, 12288, AIC_CORE_NUM, 64, 1024> {};
template <>
struct L1Scenario<6> : ScenarioConfig<L1_ADDR_CONFLICT_M, 512, AIC_CORE_NUM, 256, 64> {};
template <>
struct L1Scenario<7> : ScenarioConfig<L1_ADDR_CONFLICT_M, 512, AIC_CORE_NUM, 256, 64> {};

#ifdef COPY_DST_UB
using CurrentScenario = UbScenario<scenarioNum>;
#elif defined(COPY_DST_L1)
using CurrentScenario = L1Scenario<scenarioNum>;
#endif

// 编译期固定当前场景参数，运行时只需要按输入数据执行对应 kernel。
constexpr uint32_t M = CurrentScenario::M;
constexpr uint32_t N = CurrentScenario::N;
constexpr uint32_t NUM_BLOCKS = CurrentScenario::NUM_BLOCKS;
constexpr uint32_t SINGLE_CORE_M = CurrentScenario::SINGLE_CORE_M;
constexpr uint32_t TILE_M = CurrentScenario::TILE_M;
constexpr uint32_t TILE_N = CurrentScenario::TILE_N;
constexpr size_t FILE_SIZE = M * N * sizeof(half);

template <uint32_t mValue, uint32_t nValue, uint32_t numBlocksValue, uint32_t singleCoreMValue,
    uint32_t tileMValue, uint32_t tileNValue>
__global__ __vector__ void kernel_data_copy_pad_gm2ub(GM_ADDR src)
{
    AscendC::InitSocState();
    KernelDataCopyPadGm2Ub<mValue, nValue, numBlocksValue, singleCoreMValue, tileMValue, tileNValue> op;
    op.Init(reinterpret_cast<__gm__ half*>(src));
    if constexpr (scenarioNum == 5) {
        op.ProcessRepeatWhole4Times();
    } else if constexpr (scenarioNum == 6) {
        op.ProcessSplitFourAndRepeat4Times();
    } else if constexpr (scenarioNum == 7) {
        op.ProcessFullMatrixSameAddr();
    } else if constexpr (scenarioNum == 8) {
        op.ProcessFullMatrixOffsetAddr();
    } else {
        op.Process();
    }
    AscendC::PipeBarrier<PIPE_ALL>();
}

template <uint32_t mValue, uint32_t nValue, uint32_t numBlocksValue, uint32_t singleCoreMValue,
    uint32_t tileMValue, uint32_t tileNValue>
__global__ __cube__ void kernel_data_copy_gm2l1(GM_ADDR src)
{
    AscendC::InitSocState();
    KernelDataCopyGm2L1<mValue, nValue, numBlocksValue, singleCoreMValue, tileMValue, tileNValue> op;
    op.Init(reinterpret_cast<__gm__ half*>(src));
    if constexpr (scenarioNum == 4) {
        op.ProcessRepeatWhole4Times();
    } else if constexpr (scenarioNum == 5) {
        op.ProcessSplitFourAndRepeat4Times();
    } else if constexpr (scenarioNum == 6) {
        op.ProcessFullMatrixSameAddr();
    } else if constexpr (scenarioNum == 7) {
        op.ProcessFullMatrixOffsetAddr();
    } else {
        op.Process();
    }
    AscendC::PipeBarrier<PIPE_ALL>();
}

int32_t main(int32_t argc, char* argv[])
{
    size_t fileSize = FILE_SIZE;
    uint32_t deviceId = 0;
    aclrtStream stream = nullptr;
    aclrtContext context;

    aclInit(nullptr);
    aclrtSetDevice(deviceId);
    aclrtCreateContext(&context, deviceId);
    aclrtCreateStream(&stream);

    uint8_t* inputHost;
    uint8_t* inputDevice;
    aclrtMallocHost((void**)(&inputHost), fileSize);
    aclrtMalloc((void**)&inputDevice, fileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/input.bin", fileSize, inputHost, fileSize);
    aclrtMemcpy(inputDevice, fileSize, inputHost, fileSize, ACL_MEMCPY_HOST_TO_DEVICE);

#ifdef COPY_DST_UB
    kernel_data_copy_pad_gm2ub<M, N, NUM_BLOCKS, SINGLE_CORE_M, TILE_M, TILE_N>
        <<<NUM_BLOCKS, nullptr, stream>>>(inputDevice);
#elif defined(COPY_DST_L1)
    kernel_data_copy_gm2l1<M, N, NUM_BLOCKS, SINGLE_CORE_M, TILE_M, TILE_N>
        <<<NUM_BLOCKS, nullptr, stream>>>(inputDevice);
#endif

    aclrtSynchronizeStream(stream);

    aclrtFree(inputDevice);
    aclrtFreeHost(inputHost);

    aclrtDestroyStream(stream);
    aclrtDestroyContext(context);
    aclrtResetDevice(deviceId);
    aclFinalize();

    return 0;
}
