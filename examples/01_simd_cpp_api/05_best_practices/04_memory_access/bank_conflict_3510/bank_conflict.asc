/*!
 * \file bank_conflict.asc
 * \brief UB bank conflict verification sample
 */

#include "acl/acl.h"
#include "data_utils.h"
#include "config.h"
#include "vf_func.h"
#include "kernel_operator.h"

struct ArgInfo {
    std::string fileName;
    size_t length;
};

constexpr int32_t A5_BANKGROUP_SIZE = 1024 * 32;
constexpr int32_t A5_BANK_SIZE = 1024 * 16;
constexpr uint32_t REPEAT_TIMES_FOR_INSTR_EXCUTE = 1000;

__aicore__ inline void Process(
    AscendC::GlobalTensor<T1> xGm, AscendC::GlobalTensor<T2> yGm, AscendC::GlobalTensor<T3> zGm,
    AscendC::LocalTensor<T1> xLocal, AscendC::LocalTensor<T2> yLocal, AscendC::LocalTensor<T3> zLocal)
{
    __ubuf__ T1* src0 = (__ubuf__ T1*)xLocal.GetPhyAddr();
    __ubuf__ T2* src1 = (__ubuf__ T2*)yLocal.GetPhyAddr();
    __ubuf__ T3* dst = (__ubuf__ T3*)zLocal.GetPhyAddr();

    AscendC::DataCopy(xLocal, xGm, TOTAL_LENGTH);
    AscendC::DataCopy(yLocal, yGm, TOTAL_LENGTH);
    AscendC::PipeBarrier<PIPE_ALL>();

    uint64_t systemCycleBefore = AscendC::GetSystemCycle();
    for (uint32_t i = 0; i < REPEAT_TIMES_FOR_INSTR_EXCUTE; ++i) {
#if SCENARIO_NUM == 1 || SCENARIO_NUM == 2 || SCENARIO_NUM == 3 || SCENARIO_NUM == 4 || SCENARIO_NUM == 5 || \
    SCENARIO_NUM == 7
        AddWithUnRollVF(src0, src1, dst);
#elif SCENARIO_NUM == 6
        AddWithoutUnRollVF(src0, src1, dst);
#elif SCENARIO_NUM == 8
        ComputeBoundVF(src0, src1, dst);
#elif SCENARIO_NUM == 9 || SCENARIO_NUM == 10
        GatherAndScatterVF(src0, src1, dst);
#elif SCENARIO_NUM == 11
        AddsByRowVF(src0, src1, dst);
#elif SCENARIO_NUM == 12
        AddsByColVF(src0, src1, dst);
#elif SCENARIO_NUM == 13
        AddsWithBlockOverlap(src0, src1, dst);
#elif SCENARIO_NUM == 14
        AddsWithRepeatOverlap(src0, src1, dst);
#endif
    }
    AscendC::PipeBarrier<PIPE_ALL>();
    uint64_t systemCycleAfter = AscendC::GetSystemCycle();

    AscendC::PRINTF("\n[LOG] Case %d\n", SCENARIO_NUM);
    AscendC::PRINTF("[LOG] systemCycleBefore: %lu\n", systemCycleBefore);
    AscendC::PRINTF("[LOG] systemCycleAfter: %lu\n", systemCycleAfter);
    AscendC::PRINTF(
        "[LOG] instruction executed %u times, cost total cycles: %lu\n", REPEAT_TIMES_FOR_INSTR_EXCUTE,
        (systemCycleAfter - systemCycleBefore));

    AscendC::DataCopy(zGm, zLocal, TOTAL_LENGTH);
}

extern "C" __global__ __vector__ void bank_conflict_kernel(__gm__ uint8_t* x, __gm__ uint8_t* y, __gm__ uint8_t* z)
{
    AscendC::InitSocState();

    AscendC::GlobalTensor<T1> xGm;
    AscendC::GlobalTensor<T2> yGm;
    AscendC::GlobalTensor<T3> zGm;

    xGm.SetGlobalBuffer((__gm__ T1*)x, TOTAL_LENGTH);
    yGm.SetGlobalBuffer((__gm__ T2*)y, TOTAL_LENGTH);
    zGm.SetGlobalBuffer((__gm__ T3*)z, TOTAL_LENGTH);

    AscendC::LocalTensor<T1> xLocal(AscendC::TPosition::VECCALC, xLocalAddr, TOTAL_LENGTH);
    AscendC::LocalTensor<T2> yLocal(AscendC::TPosition::VECCALC, yLocalAddr, TOTAL_LENGTH);
    AscendC::LocalTensor<T3> zLocal(AscendC::TPosition::VECCALC, zLocalAddr, TOTAL_LENGTH);

    Process(xGm, yGm, zGm, xLocal, yLocal, zLocal);
    AscendC::PipeBarrier<PIPE_ALL>();
}

int32_t main(int32_t argc, char* argv[])
{
    uint32_t numBlocks = 1;
    size_t xSize = TOTAL_LENGTH * sizeof(T1);
    size_t ySize = TOTAL_LENGTH * sizeof(T2);
    size_t zSize = TOTAL_LENGTH * sizeof(T3);

    std::vector<ArgInfo> inputsInfo = {{"./input/input_x.bin", xSize}, {"./input/input_y.bin", ySize}};
    std::vector<ArgInfo> outputsInfo = {{"./output/output_z.bin", zSize}};

    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    std::vector<uint8_t*> inputHost(inputsInfo.size());
    std::vector<uint8_t*> inputDevice(inputsInfo.size());
    std::vector<uint8_t*> outputHost(outputsInfo.size());
    std::vector<uint8_t*> outputDevice(outputsInfo.size());

    for (uint32_t i = 0; i < inputsInfo.size(); i++) {
        aclrtMallocHost((void**)(&inputHost[i]), inputsInfo[i].length);
        aclrtMalloc((void**)(&inputDevice[i]), inputsInfo[i].length, ACL_MEM_MALLOC_HUGE_FIRST);
        if (!ReadFile(inputsInfo[i].fileName, inputsInfo[i].length, inputHost[i], inputsInfo[i].length)) {
            ERROR_LOG("ReadFile failed: %s", inputsInfo[i].fileName.c_str());
            return -1;
        }
        aclrtMemcpy(
            inputDevice[i], inputsInfo[i].length, inputHost[i], inputsInfo[i].length, ACL_MEMCPY_HOST_TO_DEVICE);
    }

    for (uint32_t i = 0; i < outputsInfo.size(); i++) {
        aclrtMallocHost((void**)(&outputHost[i]), outputsInfo[i].length);
        aclrtMalloc((void**)(&outputDevice[i]), outputsInfo[i].length, ACL_MEM_MALLOC_HUGE_FIRST);
    }

    bank_conflict_kernel<<<numBlocks, nullptr, stream>>>(inputDevice[0], inputDevice[1], outputDevice[0]);

    aclrtSynchronizeStream(stream);

    for (uint32_t i = 0; i < inputsInfo.size(); i++) {
        aclrtFree(inputDevice[i]);
        aclrtFreeHost(inputHost[i]);
    }

    for (uint32_t i = 0; i < outputsInfo.size(); i++) {
        aclrtMemcpy(
            outputHost[i], outputsInfo[i].length, outputDevice[i], outputsInfo[i].length, ACL_MEMCPY_DEVICE_TO_HOST);
        if (!WriteFile(outputsInfo[i].fileName, outputHost[i], outputsInfo[i].length)) {
            ERROR_LOG("WriteFile failed: %s", outputsInfo[i].fileName.c_str());
            return -1;
        }
        aclrtFree(outputDevice[i]);
        aclrtFreeHost(outputHost[i]);
    }

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();

    return 0;
}
