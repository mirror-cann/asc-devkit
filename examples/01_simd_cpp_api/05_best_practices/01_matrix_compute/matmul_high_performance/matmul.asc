/* !
 * \file matmul.asc
 * \brief Combined all matmul samples with switch-case selection
 */

#include "matmul.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

__global__ __cube__ void matmul_custom(__gm__ uint8_t* a, __gm__ uint8_t* b, __gm__ uint8_t* bias, __gm__ uint8_t* c, __gm__ uint8_t* workspace,
                                       __gm__ uint8_t* tilingGm)
{
    TCubeTiling tiling;
    CopyTiling(&tiling, tilingGm);
    AscendC::TPipe pipe;

    MatmulKernel<half, half, half, half> matmulKernel;
    REGIST_MATMUL_OBJ(&pipe, GetSysWorkSpacePtr(), matmulKernel.matmulObj, &tiling);
    matmulKernel.Init(a, b, bias, c, tiling);
    matmulKernel.Process(&pipe);
}

__global__ __cube__ void matmul_custom_mdl(__gm__ uint8_t* a, __gm__ uint8_t* b, __gm__ uint8_t* bias, __gm__ uint8_t* c, __gm__ uint8_t* workspace,
                                           __gm__ uint8_t* tilingGm)
{
    TCubeTiling tiling;
    CopyTiling(&tiling, tilingGm);
    AscendC::TPipe pipe;

    MatmulKernel<half, half, half, half, true> matmulKernel;
    REGIST_MATMUL_OBJ(&pipe, GetSysWorkSpacePtr(), matmulKernel.matmulObj, &tiling);
    matmulKernel.Init(a, b, bias, c, tiling);
    matmulKernel.Process(&pipe);
}

__global__ __cube__ void matmul_custom_mdl_l2cache(__gm__ uint8_t* a, __gm__ uint8_t* b, __gm__ uint8_t* bias, __gm__ uint8_t* c, __gm__ uint8_t* workspace,
                                                   __gm__ uint8_t* tilingGm)
{
    TCubeTiling tiling;
    CopyTiling(&tiling, tilingGm);
    AscendC::TPipe pipe;
    MatmulKernelL2Cache<half, half, half, half> matmulKernel;
    matmulKernel.Init(a, b, bias, c, tiling);
    matmulKernel.Process(&pipe);
}

template <uint32_t singleN, uint32_t baseM, uint32_t depthA1Param, uint32_t stepKaParam>
__global__ __cube__ void matmul_custom_mdl_l2cache_constant(__gm__ uint8_t* a, __gm__ uint8_t* b, __gm__ uint8_t* bias, __gm__ uint8_t* c,
                                                            __gm__ uint8_t* workspace, __gm__ uint8_t* tilingGm)
{
    AscendC::TPipe pipe;
    MatmulKernelMdlL2CacheConstant<half, half, half, half, singleN, baseM, depthA1Param, stepKaParam, false> matmulKernel;
    matmulKernel.Init(a, b, bias, c, tilingGm);
    matmulKernel.Process(&pipe);
}

template <uint32_t singleN, uint32_t baseM, uint32_t depthA1Param, uint32_t stepKaParam>
__global__ __cube__ void matmul_custom_mdl_l2cache_constant_unitflag(__gm__ uint8_t* a, __gm__ uint8_t* b, __gm__ uint8_t* bias, __gm__ uint8_t* c,
                                                                     __gm__ uint8_t* workspace, __gm__ uint8_t* tilingGm)
{
    AscendC::TPipe pipe;
    MatmulKernelMdlL2CacheConstant<half, half, half, half, singleN, baseM, depthA1Param, stepKaParam, true> matmulKernel;
    matmulKernel.Init(a, b, bias, c, tilingGm);
    matmulKernel.Process(&pipe);
}

template <uint32_t baseM, bool isTiling>
void GenerateTilingSingleCore(platform_ascendc::PlatformAscendC* ascendcPlatform, uint8_t* tilingBuf)
{
    optiling::TCubeTiling tilingData;
    matmul_tiling::MatmulApiTiling tilingApi(*ascendcPlatform);
    SetTilingTypes<matmul_tiling::MatmulApiTiling, isTiling, baseM>(tilingApi, tilingData);
    if constexpr (!isTiling) {
        tilingData.set_baseK(64);
    }
    SetL1(tilingData);
    uint32_t tcubeTilingSize = tilingData.GetDataSize();
    tilingData.SaveToBuffer(tilingBuf, tcubeTilingSize);
}
template <uint32_t singleN, uint32_t singleNSplit, uint32_t baseM, uint32_t depthA1Param, uint32_t stepKaParam,
          bool isSplit, bool isMdl, bool isL1Cache, bool isL2Cache>
void GenerateTilingMultiCore(platform_ascendc::PlatformAscendC* ascendcPlatform, uint8_t* tilingBuf)
{
    optiling::TCubeTiling tilingData;
    matmul_tiling::MultiCoreMatmulTiling tilingApi(*ascendcPlatform);
    tilingApi.SetDim(ascendcPlatform->GetCoreNumAic());
    if constexpr (isSplit && !isL2Cache) {
        tilingApi.SetSingleShape(SINGLE_M_SPLIT, singleNSplit, K);
    } else if constexpr (!isSplit && !isL2Cache) {
        tilingApi.SetSingleShape(SINGLE_M, singleN, K);
    } else {
        tilingApi.SetSingleShape(SINGLE_M_L2CACHE, singleN, K);
    }
    SetTilingTypes<matmul_tiling::MultiCoreMatmulTiling, true, baseM>(tilingApi, tilingData);

    if constexpr (!isMdl) {
        SetL1(tilingData);
    } else if constexpr (isMdl && isL1Cache) {
        tilingData.set_depthA1(depthA1Param);
        tilingData.set_stepKa(stepKaParam);
    }
    uint32_t tcubeTilingSize = tilingData.GetDataSize();
    tilingData.SaveToBuffer(tilingBuf, tcubeTilingSize);
}

int32_t main(int32_t argc, char* argv[])
{
    printf("Usage: %s (compile-time scenarioNum=%u)\n", argv[0], (uint32_t)scenarioNum);
    printf("Running case %u...\n", (uint32_t)scenarioNum);

#if (NPU_ARCH == 2201)
    constexpr uint32_t SINGLE_N = 1536;
    constexpr uint32_t SINGLE_N_SPLIT = 683;
    constexpr uint32_t BASE_M = 128;
    constexpr uint32_t TILING_DEPTHA1_PARAM = 16;
    constexpr uint32_t TILING_STEPKA_PARAM = 8;
    constexpr uint32_t CORE_NUM = 24;
#elif (NPU_ARCH == 3510)
    constexpr uint32_t SINGLE_N = 1024;
    constexpr uint32_t SINGLE_N_SPLIT = 512;
    constexpr uint32_t BASE_M = 256;
    constexpr uint32_t TILING_DEPTHA1_PARAM = 8;
    constexpr uint32_t TILING_STEPKA_PARAM = 4;
    constexpr uint32_t CORE_NUM = 32;
#else
#error "Unsupported NPU_ARCH, only 2201 and 3510 are supported"
#endif

    const char* modeName = "";
    uint32_t numBlocks = 1;
    uint32_t singleM = SINGLE_M;
    uint32_t singleN = SINGLE_N;
    uint32_t singleK = SINGLE_K;
#if defined(ASCENDC_CPU_DEBUG) && (__NPU_ARCH__ == 2201)
    auto ascendc = platform_ascendc::PlatformAscendCManager::GetInstance("Ascend910B1");
#elif defined(ASCENDC_CPU_DEBUG) && (__NPU_ARCH__ == 3510)
    auto ascendc = platform_ascendc::PlatformAscendCManager::GetInstance("Ascend950PR_9589");
#else
    auto ascendc = platform_ascendc::PlatformAscendCManager::GetInstance();
#endif

    if constexpr (scenarioNum == 0) {
        modeName = "Single Core Basic";
        numBlocks = 1;
    } else if constexpr (scenarioNum == 1) {
        modeName = "Single Core Tiling";
        numBlocks = 1;
    } else if constexpr (scenarioNum == 2) {
        modeName = "Multi Core Split 2 12";
        numBlocks = CORE_NUM;
    } else if constexpr (scenarioNum == 3) {
        modeName = "Multi Core Split 4 6";
        numBlocks = CORE_NUM;
    } else if constexpr (scenarioNum == 4) {
        modeName = "Multi Core MDL";
        numBlocks = CORE_NUM;
    } else if constexpr (scenarioNum == 5) {
        modeName = "Multi Core MDL L1Cache";
        numBlocks = CORE_NUM;
    } else if constexpr (scenarioNum == 6) {
        modeName = "Multi Core MDL L1Cache L2Cache";
        numBlocks = CORE_NUM;
        singleM = 1024;
    } else if constexpr (scenarioNum == 7) {
        modeName = "Multi Core MDL L1Cache L2Cache Constant Tiling";
        numBlocks = CORE_NUM;
        singleM = 1024;
    } else if constexpr (scenarioNum == 8) {
        modeName = "Multi Core MDL L1Cache L2Cache Constant Tiling UnitFlag";
        numBlocks = CORE_NUM;
        singleM = 1024;
    } else {
        std::cout << "Invalid scenarioNum: " << scenarioNum << std::endl;
        return -1;
    }

    std::cout << "Running mode: " << modeName << std::endl;

    size_t aFileSize = static_cast<size_t>(M * K) * sizeof(uint16_t);
    size_t bFileSize = static_cast<size_t>(K * N) * sizeof(uint16_t);
    size_t cFileSize = static_cast<size_t>(M * N) * sizeof(uint16_t);
    size_t biasFileSize = static_cast<size_t>(N) * sizeof(uint16_t);

    size_t tilingFileSize;
    uint8_t* tilingBuf = nullptr;

    if constexpr (scenarioNum == 7 || scenarioNum == 8) {
        tilingFileSize = sizeof(MatmulProblemShape);
    } else {
        tilingFileSize = sizeof(TCubeTiling);
        tilingBuf = (uint8_t*)malloc(tilingFileSize);

        if constexpr (scenarioNum == 0) {
            GenerateTilingSingleCore<BASE_M>(ascendc, tilingBuf);
        } else if constexpr (scenarioNum == 1) {
            GenerateTilingSingleCore<BASE_M, true>(ascendc, tilingBuf);
        } else if constexpr (scenarioNum == 2) {
            GenerateTilingMultiCore<SINGLE_N, SINGLE_N_SPLIT, BASE_M, TILING_DEPTHA1_PARAM, TILING_STEPKA_PARAM, true>(ascendc,
                                                                                                                       tilingBuf);
        } else if constexpr (scenarioNum == 3) {
            GenerateTilingMultiCore<SINGLE_N, SINGLE_N_SPLIT, BASE_M, TILING_DEPTHA1_PARAM, TILING_STEPKA_PARAM>(ascendc, tilingBuf);
        } else if constexpr (scenarioNum == 4) {
            GenerateTilingMultiCore<SINGLE_N, SINGLE_N_SPLIT, BASE_M, TILING_DEPTHA1_PARAM, TILING_STEPKA_PARAM, false, true>(ascendc,
                                                                                                                              tilingBuf);
        } else if constexpr (scenarioNum == 5) {
            GenerateTilingMultiCore<SINGLE_N, SINGLE_N_SPLIT, BASE_M, TILING_DEPTHA1_PARAM, TILING_STEPKA_PARAM, false, true,
                                    true>(ascendc, tilingBuf);
        } else if constexpr (scenarioNum == 6) {
            GenerateTilingMultiCore<SINGLE_N, SINGLE_N_SPLIT, BASE_M, TILING_DEPTHA1_PARAM, TILING_STEPKA_PARAM, false, true,
                                    true, true>(ascendc, tilingBuf);
        }
    }

    size_t userWorkspaceSize = 0;
    size_t systemWorkspaceSize = static_cast<size_t>(ascendc->GetLibApiWorkSpaceSize());
    size_t workspaceSize = userWorkspaceSize + systemWorkspaceSize;

    int32_t deviceId = 0;
    aclrtStream stream = nullptr;
    aclrtContext context;

    aclInit(nullptr);
    aclrtSetDevice(deviceId);
    aclrtCreateContext(&context, deviceId);
    aclrtCreateStream(&stream);

    uint8_t* aHost;
    uint8_t* aDevice;
    aclrtMallocHost((void**)(&aHost), aFileSize);
    aclrtMalloc((void**)&aDevice, aFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/x1_gm.bin", aFileSize, aHost, aFileSize);
    aclrtMemcpy(aDevice, aFileSize, aHost, aFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t* bHost;
    uint8_t* bDevice;
    aclrtMallocHost((void**)(&bHost), bFileSize);
    aclrtMalloc((void**)&bDevice, bFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/x2_gm.bin", bFileSize, bHost, bFileSize);
    aclrtMemcpy(bDevice, bFileSize, bHost, bFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t* biasHost;
    uint8_t* biasDevice;
    if (IS_BIAS) {
        aclrtMallocHost((void**)(&biasHost), biasFileSize);
        aclrtMalloc((void**)&biasDevice, biasFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
        ReadFile("./input/bias_gm.bin", biasFileSize, biasHost, biasFileSize);
        aclrtMemcpy(biasDevice, biasFileSize, biasHost, biasFileSize, ACL_MEMCPY_HOST_TO_DEVICE);
    }

    uint8_t* cHost;
    uint8_t* cDevice;
    aclrtMallocHost((void**)(&cHost), cFileSize);
    aclrtMalloc((void**)&cDevice, cFileSize, ACL_MEM_MALLOC_HUGE_FIRST);

    uint8_t* workspaceDevice;
    aclrtMalloc((void**)&workspaceDevice, workspaceSize, ACL_MEM_MALLOC_HUGE_FIRST);

    uint8_t* tilingHost;
    uint8_t* tilingDevice;
    aclrtMallocHost((void**)(&tilingHost), tilingFileSize);
    aclrtMalloc((void**)&tilingDevice, tilingFileSize, ACL_MEM_MALLOC_HUGE_FIRST);

    if constexpr (scenarioNum == 7 || scenarioNum == 8) {
        const MatmulProblemShape shapes{numBlocks, M, N, K, singleM, singleN, singleK, 0};
        aclrtMemcpy(tilingHost, tilingFileSize, &shapes, tilingFileSize, ACL_MEMCPY_HOST_TO_HOST);
    } else {
        aclrtMemcpy(tilingHost, tilingFileSize, tilingBuf, tilingFileSize, ACL_MEMCPY_HOST_TO_HOST);
    }
    aclrtMemcpy(tilingDevice, tilingFileSize, tilingHost, tilingFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    constexpr auto selectedKernel = []() {
        if constexpr (scenarioNum >= 0 && scenarioNum <= 3) {
            return matmul_custom;
        } else if constexpr (scenarioNum == 4 || scenarioNum == 5) {
            return matmul_custom_mdl;
        } else if constexpr (scenarioNum == 6) {
            return matmul_custom_mdl_l2cache;
        } else if constexpr (scenarioNum == 7) {
            return matmul_custom_mdl_l2cache_constant<SINGLE_N, BASE_M, TILING_DEPTHA1_PARAM, TILING_STEPKA_PARAM>;
        } else if constexpr (scenarioNum == 8) {
            return matmul_custom_mdl_l2cache_constant_unitflag<SINGLE_N, BASE_M, TILING_DEPTHA1_PARAM, TILING_STEPKA_PARAM>;
        }
    }();
    selectedKernel<<<numBlocks, nullptr, stream>>>(aDevice, bDevice, biasDevice, cDevice, workspaceDevice, tilingDevice);

    aclrtSynchronizeStream(stream);
    aclrtMemcpy(cHost, cFileSize, cDevice, cFileSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", cHost, cFileSize);
    aclrtFree(aDevice);
    aclrtFreeHost(aHost);
    aclrtFree(bDevice);
    aclrtFreeHost(bHost);
    if (IS_BIAS) {
        aclrtFree(biasDevice);
        aclrtFreeHost(biasHost);
    }
    aclrtFree(workspaceDevice);
    aclrtFree(tilingDevice);
    aclrtFreeHost(tilingHost);
    aclrtFree(cDevice);
    aclrtFreeHost(cHost);

    aclrtDestroyStream(stream);
    aclrtDestroyContext(context);
    aclrtResetDevice(deviceId);
    aclFinalize();

    if (tilingBuf != nullptr) {
        free(tilingBuf);
    }
    return 0;
}
