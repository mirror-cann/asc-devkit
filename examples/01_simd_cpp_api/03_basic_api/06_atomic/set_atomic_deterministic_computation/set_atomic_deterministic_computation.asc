/* !
 * \file set_atomic_deterministic_computation.asc
 * \brief 演示三种不同场景下，原子操作的确定性计算
 */

#include "set_atomic_add_multi_aiv.h"
#include "set_atomic_add_single_aiv.h"
#include "set_atomic_add_multi_aic.h"
#include "acl/acl.h"
#include "data_utils.h"
#include "kernel_operator.h"
#include <cstring>

// 多个AIV核间的确定性计算
__global__ __vector__ void set_atomic_add_multi_aiv_custom(
    __gm__ uint8_t* src0, __gm__ uint8_t* src1, __gm__ uint8_t* src2, __gm__ uint8_t* src3, __gm__ uint8_t* src4,
    __gm__ uint8_t* inout_gm)
{
    // IBSet接口不支持静态Tensor编程
    AscendC::TPipe pipe;
    KernelSetAtomicAddMultiAIV op;
    op.Init(src0, src1, src2, src3, src4, inout_gm, &pipe);
    op.Process();
}

// 单个AIV核内的确定性计算
__global__ __vector__ void set_atomic_add_single_aiv_custom(
    __gm__ uint8_t* src0, __gm__ uint8_t* src1, __gm__ uint8_t* src2, __gm__ uint8_t* src3, __gm__ uint8_t* inout_gm)
{
    AscendC::InitSocState();
    KernelSetAtomicAddSingleAIV op;
    op.Init(src0, src1, src2, src3, inout_gm);
    op.Process();
    AscendC::PipeBarrier<PIPE_ALL>();
}

// 多个AIC核间的确定性计算
__global__ __cube__ void set_atomic_add_multi_aic_custom(
    __gm__ uint8_t* src0, __gm__ uint8_t* src1, __gm__ uint8_t* src2, __gm__ uint8_t* src3, __gm__ uint8_t* src4,
    __gm__ uint8_t* inout_gm)
{
    AscendC::InitSocState();
    KernelSetAtomicAddMultiAIC op;
    op.Init(src0, src1, src2, src3, src4, inout_gm);
    op.Process();
    AscendC::PipeBarrier<PIPE_ALL>();
}

// 场景配置常量
// SCENARIO_NUM == 1: 单个AIV核内的确定性计算
// SCENARIO_NUM == 2: 多个AIV核间的确定性计算
// SCENARIO_NUM == 3: 多个AIC核间的确定性计算

int32_t main(int32_t argc, char* argv[])
{
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    if constexpr (SCENARIO_NUM == 1) {
        // 单个AIV核内的确定性计算
        uint32_t numBlocks = 1;
        size_t inputByteSize = 8 * sizeof(float);
        size_t outputByteSize = 8 * sizeof(float);

        uint8_t *src0Host, *src1Host, *src2Host, *src3Host, *outHost;
        uint8_t *src0Device, *src1Device, *src2Device, *src3Device, *outDevice;

        aclrtMallocHost((void**)(&src0Host), inputByteSize);
        aclrtMallocHost((void**)(&src1Host), inputByteSize);
        aclrtMallocHost((void**)(&src2Host), inputByteSize);
        aclrtMallocHost((void**)(&src3Host), inputByteSize);
        aclrtMallocHost((void**)(&outHost), outputByteSize);
        aclrtMalloc((void**)&src0Device, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
        aclrtMalloc((void**)&src1Device, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
        aclrtMalloc((void**)&src2Device, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
        aclrtMalloc((void**)&src3Device, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
        aclrtMalloc((void**)&outDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);

        ReadFile("./input/input_gm.bin", inputByteSize, src0Host, inputByteSize);
        ReadFile("./input/input_x.bin", inputByteSize, src1Host, inputByteSize);
        ReadFile("./input/input_y.bin", inputByteSize, src2Host, inputByteSize);
        ReadFile("./input/input_z.bin", inputByteSize, src3Host, inputByteSize);

        aclrtMemcpy(src0Device, inputByteSize, src0Host, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
        aclrtMemcpy(src1Device, inputByteSize, src1Host, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
        aclrtMemcpy(src2Device, inputByteSize, src2Host, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
        aclrtMemcpy(src3Device, inputByteSize, src3Host, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);

        set_atomic_add_single_aiv_custom<<<numBlocks, 0, stream>>>(
            src0Device, src1Device, src2Device, src3Device, outDevice);
        aclrtSynchronizeStream(stream);

        aclrtMemcpy(outHost, outputByteSize, outDevice, outputByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
        WriteFile("./output/output.bin", outHost, outputByteSize);

        aclrtFree(src0Device);
        aclrtFree(src1Device);
        aclrtFree(src2Device);
        aclrtFree(src3Device);
        aclrtFree(outDevice);
        aclrtFreeHost(src0Host);
        aclrtFreeHost(src1Host);
        aclrtFreeHost(src2Host);
        aclrtFreeHost(src3Host);
        aclrtFreeHost(outHost);
    } else {
        // 多个AIV/AIC核间的确定性计算
        uint32_t numBlocks = 4;
        size_t inputByteSize = 8 * sizeof(float);
        size_t inputSyncByteSize = 256 * sizeof(int32_t);
        size_t outputByteSize = 8 * sizeof(float);

        uint8_t *src0Host, *src1Host, *src2Host, *src3Host, *src4Host, *outHost;
        uint8_t *src0Device, *src1Device, *src2Device, *src3Device, *src4Device, *outDevice;

        aclrtMallocHost((void**)(&src0Host), inputByteSize);
        aclrtMallocHost((void**)(&src1Host), inputByteSize);
        aclrtMallocHost((void**)(&src2Host), inputByteSize);
        aclrtMallocHost((void**)(&src3Host), inputByteSize);
        aclrtMallocHost((void**)(&src4Host), inputSyncByteSize);
        aclrtMallocHost((void**)(&outHost), outputByteSize);

        aclrtMalloc((void**)&src0Device, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
        aclrtMalloc((void**)&src1Device, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
        aclrtMalloc((void**)&src2Device, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
        aclrtMalloc((void**)&src3Device, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
        aclrtMalloc((void**)&src4Device, inputSyncByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
        aclrtMalloc((void**)&outDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);

        ReadFile("./input/input_gm.bin", inputByteSize, src0Host, inputByteSize);
        ReadFile("./input/input_x.bin", inputByteSize, src1Host, inputByteSize);
        ReadFile("./input/input_y.bin", inputByteSize, src2Host, inputByteSize);
        ReadFile("./input/input_z.bin", inputByteSize, src3Host, inputByteSize);
        ReadFile("./input/input_sync.bin", inputSyncByteSize, src4Host, inputSyncByteSize);

        aclrtMemcpy(src0Device, inputByteSize, src0Host, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
        aclrtMemcpy(src1Device, inputByteSize, src1Host, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
        aclrtMemcpy(src2Device, inputByteSize, src2Host, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
        aclrtMemcpy(src3Device, inputByteSize, src3Host, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
        aclrtMemcpy(src4Device, inputSyncByteSize, src4Host, inputSyncByteSize, ACL_MEMCPY_HOST_TO_DEVICE);

        memset(outHost, 0, outputByteSize);
        aclrtMemcpy(outDevice, outputByteSize, outHost, outputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);

        if constexpr (SCENARIO_NUM == 2) {
            set_atomic_add_multi_aiv_custom<<<numBlocks, 0, stream>>>(
                src0Device, src1Device, src2Device, src3Device, src4Device, outDevice);
        } else if constexpr (SCENARIO_NUM == 3) {
            set_atomic_add_multi_aic_custom<<<numBlocks, 0, stream>>>(
                src0Device, src1Device, src2Device, src3Device, src4Device, outDevice);
        }
        aclrtSynchronizeStream(stream);

        aclrtMemcpy(outHost, outputByteSize, outDevice, outputByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
        WriteFile("./output/output.bin", outHost, outputByteSize);

        aclrtFree(src0Device);
        aclrtFree(src1Device);
        aclrtFree(src2Device);
        aclrtFree(src3Device);
        aclrtFree(src4Device);
        aclrtFree(outDevice);

        aclrtFreeHost(src0Host);
        aclrtFreeHost(src1Host);
        aclrtFreeHost(src2Host);
        aclrtFreeHost(src3Host);
        aclrtFreeHost(src4Host);
        aclrtFreeHost(outHost);
    }

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();

    return 0;
}
