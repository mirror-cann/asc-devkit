/* !
 * \file mmad_mx.asc
 * \brief 本文介绍了带有量化功能的Mmad，以及4种不同的应用场景（包括不同的bias和C矩阵初始化方式）。
 */
#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif
#include "acl/acl.h"
#include "kernel_operator.h"
#include "data_utils.h"

constexpr uint32_t scenarioNum = SCENARIO_NUM;
constexpr bool HAS_BIAS_TENSOR = (scenarioNum == 2 || scenarioNum == 4);
constexpr uint32_t SCALE_BASE_FACTOR = 64;
constexpr uint32_t SCALE_EVEN_NUMBER = 2;
constexpr uint32_t SCALE_CEIL_NUMBER = 32;

template <class T, class TA, class TB, uint32_t m, uint32_t n, uint32_t k>
class KernelMmadMX {
public:
    __aicore__ inline KernelMmadMX()
    {
        fractalShape[0] = 16;
        if constexpr (AscendC::IsSameType<TA, fp4x2_e1m2_t>::value || AscendC::IsSameType<TA, fp4x2_e2m1_t>::value) {
            fractalShape[1] = 64;
            packedK = CeilDiv(k, 2);
        } else {
            fractalShape[1] = 32;
            packedK = k;
        }
        scaleK = CeilDiv(k, SCALE_BASE_FACTOR) * SCALE_EVEN_NUMBER;
        alignK = CeilAlign(k, SCALE_BASE_FACTOR);

        // A矩阵：L1上排布格式为Nz
        mAlignL1 = CeilAlign(m, fractalShape[0]);
        kaAlignL1 = alignK;
        aSizeAlignL1 = mAlignL1 * kaAlignL1;
        // A矩阵：L0上排布格式为Nz
        mAlignL0 = CeilAlign(m, fractalShape[0]);
        kaAlignL0 = alignK;
        aSizeAlignL0 = mAlignL0 * kaAlignL0;

        // B矩阵：L1上排布格式为Nz
        nAlignL1 = CeilAlign(n, fractalShape[0]);
        kbAlignL1 = alignK;
        bSizeAlignL1 = nAlignL1 * kbAlignL1;
        // B矩阵：L0上排布格式为Zn
        kbAlignL0 = alignK;
        nAlignL0 = CeilAlign(n, fractalShape[0]);
        bSizeAlignL0 = kbAlignL0 * nAlignL0;

        // scaleA矩阵：L1/L0上排布格式为Zz
        scaleMAlignL1 = CeilAlign(m, fractalShape[0]);
        scaleASizeAlignL1 = scaleMAlignL1 * scaleK;

        // scaleB矩阵：L1/L0上排布格式为Nn
        scaleNAlignL1 = CeilAlign(n, fractalShape[0]);
        scaleBSizeAlignL1 = scaleK * scaleNAlignL1;

        biasSizeAlign = CeilAlign(CeilDiv(n * sizeof(T), 32), 2) * 32;
        cSizeAlignL0 = mAlignL0 * nAlignL0;

        a1Addr = 0;
        scaleA1Addr = 128 * 1024;
        b1Addr = 192 * 1024;
        scaleB1Addr = 320 * 1024;
        c1Addr = 384 * 1024;
    }
    __aicore__ inline void Init(GM_ADDR a, GM_ADDR scaleA, GM_ADDR b, GM_ADDR scaleB, GM_ADDR bias, GM_ADDR c)
    {
        aGM.SetGlobalBuffer((__gm__ TA*)a);
        scaleAGM.SetGlobalBuffer((__gm__ fp8_e8m0_t*)scaleA);
        bGM.SetGlobalBuffer((__gm__ TB*)b);
        scaleBGM.SetGlobalBuffer((__gm__ fp8_e8m0_t*)scaleB);
        biasGM.SetGlobalBuffer((__gm__ T*)bias);
        cGM.SetGlobalBuffer((__gm__ T*)c);
    }
    __aicore__ inline void Process()
    {
        AscendC::LocalTensor<TA> a1Local(AscendC::TPosition::A1, a1Addr, aSizeAlignL1);
        AscendC::LocalTensor<fp8_e8m0_t> scaleA1Local(AscendC::TPosition::A1, scaleA1Addr, scaleASizeAlignL1);
        AscendC::LocalTensor<TB> b1Local(AscendC::TPosition::B1, b1Addr, bSizeAlignL1);
        AscendC::LocalTensor<fp8_e8m0_t> scaleB1Local(AscendC::TPosition::B1, scaleB1Addr, scaleBSizeAlignL1);
        AscendC::LocalTensor<T> bias1Local(AscendC::TPosition::C1, c1Addr, biasSizeAlign / sizeof(T));

        // GM -> L1
        CopyInA1(a1Local);
        CopyInScaleA1(scaleA1Local);
        CopyInB1(b1Local);
        CopyInScaleB1(scaleB1Local);
        if constexpr (HAS_BIAS_TENSOR) {
            CopyInBias(bias1Local);
        }

        AscendC::SetFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID0);

        // ---- Fill: 无效数据置0，防止脏数据参与Mmad ----
        FillZeroInA1(a1Local);
        FillZeroInB1(b1Local);

        AscendC::PipeBarrier<PIPE_MTE1>();

        // L1 -> L0A
        AscendC::LocalTensor<TA> a2Local(AscendC::TPosition::A2, 0, aSizeAlignL0);
        SplitA(a1Local, scaleA1Local, a2Local);

        // L1 -> L0B
        AscendC::LocalTensor<TB> b2Local(AscendC::TPosition::B2, 0, bSizeAlignL0);
        SplitB(b1Local, scaleB1Local, b2Local);

        // L1 -> BT
        AscendC::LocalTensor<T> bias2Local(AscendC::TPosition::C2, 0, biasSizeAlign / sizeof(T));
        if constexpr (HAS_BIAS_TENSOR) {
            SplitBias(bias1Local, bias2Local);
        }

        AscendC::SetFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID0);

        // Mmad
        AscendC::LocalTensor<T> co1Local(AscendC::TPosition::CO1, 0, cSizeAlignL0);
        Compute(a2Local, b2Local, bias2Local, co1Local);

        AscendC::SetFlag<AscendC::HardEvent::M_FIX>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::M_FIX>(EVENT_ID0);

        // L0C -> GM
        CopyOut(co1Local);
    }

private:
    // 向上整除
    __aicore__ inline uint32_t CeilDiv(uint32_t numerator, uint32_t denominator)
    {
        return (numerator + denominator - 1) / denominator;
    }
    // 向上对齐
    __aicore__ inline uint32_t CeilAlign(uint32_t numerator, uint32_t denominator)
    {
        return (numerator + denominator - 1) / denominator * denominator;
    }

    __aicore__ inline void CopyInA1(AscendC::LocalTensor<TA> a1Local)
    {
        AscendC::Nd2NzParams nd2nzA1Params;
        nd2nzA1Params.ndNum = 1;
        nd2nzA1Params.nValue = m;
        nd2nzA1Params.dValue = packedK;
        nd2nzA1Params.srcNdMatrixStride = 0;
        nd2nzA1Params.srcDValue = packedK;
        nd2nzA1Params.dstNzC0Stride = mAlignL1;
        nd2nzA1Params.dstNzNStride = 1;
        nd2nzA1Params.dstNzMatrixStride = 0;

        AscendC::DataCopy(a1Local, aGM, nd2nzA1Params);
    }

    __aicore__ inline void CopyInScaleA1(AscendC::LocalTensor<fp8_e8m0_t> scaleA1Local)
    {
        AscendC::GlobalTensor<half> scaleAGMB16;
        scaleAGMB16.SetGlobalBuffer((__gm__ half*)(scaleAGM.GetPhyAddr()), m * scaleK / 2);
        auto scaleA1LocalB16 = scaleA1Local.ReinterpretCast<half>();

        AscendC::Dn2NzParams dn2nzParams;
        dn2nzParams.dnNum = 1;
        dn2nzParams.dValue = m;
        dn2nzParams.nValue = scaleK / 2;
        dn2nzParams.srcDnMatrixStride = 0;
        dn2nzParams.srcDValue = scaleK / 2;
        dn2nzParams.dstNzC0Stride = scaleK / 2;
        dn2nzParams.dstNzNStride = 1;
        dn2nzParams.dstNzMatrixStride = 0;

        AscendC::DataCopy(scaleA1LocalB16, scaleAGMB16, dn2nzParams);
    }

    __aicore__ inline void CopyInB1(AscendC::LocalTensor<TB> b1Local)
    {
        AscendC::Nd2NzParams nd2nzB1Params;
        nd2nzB1Params.ndNum = 1;
        nd2nzB1Params.nValue = n;
        nd2nzB1Params.dValue = packedK;
        nd2nzB1Params.srcNdMatrixStride = 0;
        nd2nzB1Params.srcDValue = packedK;
        nd2nzB1Params.dstNzC0Stride = nAlignL1;
        nd2nzB1Params.dstNzNStride = 1;
        nd2nzB1Params.dstNzMatrixStride = 0;

        AscendC::DataCopy(b1Local, bGM, nd2nzB1Params);
    }

    __aicore__ inline void CopyInScaleB1(AscendC::LocalTensor<fp8_e8m0_t> scaleB1Local)
    {
        AscendC::GlobalTensor<half> scaleBGMB16;
        scaleBGMB16.SetGlobalBuffer((__gm__ half*)(scaleBGM.GetPhyAddr()), n * scaleK / 2);
        auto scaleB1LocalB16 = scaleB1Local.ReinterpretCast<half>();

        AscendC::Dn2NzParams dn2nzParams;
        dn2nzParams.dnNum = 1;
        dn2nzParams.dValue = n;
        dn2nzParams.nValue = scaleK / 2;
        dn2nzParams.srcDnMatrixStride = 0;
        dn2nzParams.srcDValue = scaleK / 2;
        dn2nzParams.dstNzC0Stride = scaleK / 2;
        dn2nzParams.dstNzNStride = 1;
        dn2nzParams.dstNzMatrixStride = 0;

        AscendC::DataCopy(scaleB1LocalB16, scaleBGMB16, dn2nzParams);
    }

    __aicore__ inline void CopyInBias(AscendC::LocalTensor<T> c1Local)
    {
        // 由于N可能非32B对齐，“基础数据搬运”无法处理非对齐数据，且“DataCopyPad”不支持GM到L1的搬运，
        // 因此，使用“随路转换ND2Nz搬运”实现Bias的GM到L1搬运，确保搬运到L1数据32B对齐。
        AscendC::Nd2NzParams nd2nzC1Params;
        nd2nzC1Params.ndNum = 1;
        nd2nzC1Params.nValue = 1;
        nd2nzC1Params.dValue = n;
        nd2nzC1Params.srcNdMatrixStride = 0;
        nd2nzC1Params.srcDValue = n;
        nd2nzC1Params.dstNzC0Stride = 1;
        nd2nzC1Params.dstNzNStride = 1;
        nd2nzC1Params.dstNzMatrixStride = 0;

        AscendC::DataCopy(c1Local, biasGM, nd2nzC1Params);
    }

    // A1 -> A2: 调用一次LoadData，同时将A矩阵搬入L0A、scaleA矩阵搬入L0A_MX
    // LoadData2DParamsV2控制A矩阵搬运，LoadData2DMxParams控制scaleA矩阵搬运
    __aicore__ inline void SplitA(
        AscendC::LocalTensor<TA> a1Local, AscendC::LocalTensor<fp8_e8m0_t> scaleA1Local,
        AscendC::LocalTensor<TA> a2Local)
    {
        AscendC::LoadData2DParamsV2 loadDataParams;
        loadDataParams.sid = 0;
        loadDataParams.mStartPosition = 0;
        loadDataParams.kStartPosition = 0;
        loadDataParams.mStep = CeilDiv(mAlignL1, fractalShape[0]);
        loadDataParams.kStep = CeilDiv(kaAlignL1, fractalShape[1]);
        loadDataParams.srcStride = CeilDiv(mAlignL1, fractalShape[0]);
        loadDataParams.dstStride = CeilDiv(mAlignL0, fractalShape[0]);
        loadDataParams.ifTranspose = false;

        AscendC::LoadData2DMxParams loadMxDataParams;
        loadMxDataParams.xStartPosition = 0;
        loadMxDataParams.yStartPosition = 0;
        loadMxDataParams.xStep = CeilDiv(scaleMAlignL1, fractalShape[0]);
        loadMxDataParams.yStep = scaleK / SCALE_EVEN_NUMBER;
        loadMxDataParams.srcStride = scaleK / SCALE_EVEN_NUMBER;
        loadMxDataParams.dstStride = scaleK / SCALE_EVEN_NUMBER;

        AscendC::LoadData(a2Local, a1Local, scaleA1Local, loadDataParams, loadMxDataParams);
    }

    // B1 -> B2: 调用一次LoadData，同时将B矩阵搬入L0B、scaleB矩阵搬入L0B_MX
    // LoadData2DParamsV2控制B矩阵搬运，LoadData2DMxParams控制scaleB矩阵搬运
    __aicore__ inline void SplitB(
        AscendC::LocalTensor<TB> b1Local, AscendC::LocalTensor<fp8_e8m0_t> scaleB1Local,
        AscendC::LocalTensor<TB> b2Local)
    {
        AscendC::LoadData2DParamsV2 loadDataParams;
        loadDataParams.sid = 0;
        loadDataParams.mStartPosition = 0;
        loadDataParams.kStartPosition = 0;
        loadDataParams.mStep = CeilDiv(nAlignL1, fractalShape[0]);
        loadDataParams.kStep = CeilDiv(kbAlignL1, fractalShape[1]);
        loadDataParams.srcStride = CeilDiv(nAlignL1, fractalShape[0]);
        loadDataParams.dstStride = CeilDiv(nAlignL0, fractalShape[0]);
        loadDataParams.ifTranspose = false;

        AscendC::LoadData2DMxParams loadMxDataParams;
        loadMxDataParams.xStartPosition = 0;
        loadMxDataParams.yStartPosition = 0;
        loadMxDataParams.xStep = CeilDiv(scaleNAlignL1, fractalShape[0]);
        loadMxDataParams.yStep = scaleK / SCALE_EVEN_NUMBER;
        loadMxDataParams.srcStride = scaleK / SCALE_EVEN_NUMBER;
        loadMxDataParams.dstStride = scaleK / SCALE_EVEN_NUMBER;

        AscendC::LoadData(b2Local, b1Local, scaleB1Local, loadDataParams, loadMxDataParams);
    }

    __aicore__ inline void SplitBias(AscendC::LocalTensor<T>& bias1Local, AscendC::LocalTensor<T>& bias2Local)
    {
        AscendC::DataCopyParams c12c2Params = {1, static_cast<uint16_t>(biasSizeAlign / 32), 0, 0};
        AscendC::DataCopy(bias2Local, bias1Local, c12c2Params);
    }

    __aicore__ inline void Compute(
        AscendC::LocalTensor<TA> a2Local, AscendC::LocalTensor<TB> b2Local, AscendC::LocalTensor<T>& bias2Local,
        AscendC::LocalTensor<T>& co1Local)
    {
        AscendC::MmadParams mmadParams;
        mmadParams.m = m;
        mmadParams.n = n;
        mmadParams.k = alignK;

        if constexpr (SCENARIO_NUM == 1) {
            // 不带Bias场景
            mmadParams.cmatrixInitVal = true; // C矩阵初始值为0
            AscendC::MmadMx(co1Local, a2Local, b2Local, mmadParams);
        } else if constexpr (SCENARIO_NUM == 2) {
            // 带Bias且不传入biasTensor，C矩阵的初始值来源于C2
            mmadParams.cmatrixInitVal = false;
            mmadParams.cmatrixSource = true;
            AscendC::MmadMx(co1Local, a2Local, b2Local, mmadParams);
        } else if constexpr (SCENARIO_NUM == 3) {
            // 不带Bias，C矩阵累加来源于CO1初始值
            // 第一次mmad计算，CO1的计算结果作为下一次mmad计算C矩阵的初始值
            AscendC::MmadMx(co1Local, a2Local, b2Local, mmadParams);
            mmadParams.cmatrixInitVal = false;
            mmadParams.cmatrixSource = false; // C矩阵的初始值来源于CO1
            AscendC::MmadMx(co1Local, a2Local, b2Local, mmadParams);
        } else {
            // 带Bias且传入biasTensor的场景，该场景下cmatrixSource参数无效
            mmadParams.cmatrixInitVal = false;
            AscendC::MmadMx(co1Local, a2Local, b2Local, bias2Local, mmadParams);
        }
    }
    __aicore__ inline void CopyOut(AscendC::LocalTensor<T>& co1Local)
    {
        AscendC::FixpipeParamsArch3510<AscendC::CO2Layout::ROW_MAJOR> fixpipeParams;
        fixpipeParams.mSize = m;
        fixpipeParams.nSize = n;
        fixpipeParams.srcStride = mAlignL0;
        fixpipeParams.dstStride = n;

        AscendC::Fixpipe<T, T, AscendC::CFG_ROW_MAJOR>(cGM, co1Local, fixpipeParams);
    }

    __aicore__ inline void FillZeroInA1(AscendC::LocalTensor<TA> a1Local)
    {
        // A矩阵GM上输入为[m, k]，k方向需要向64对齐，当输入数据类型为fp8时，DataCopy
        // k轴仅向32B对齐，此时需要将剩余k方向数据刷为0，防止脏数据参与计算
        if constexpr (AscendC::IsSameType<TA, fp8_e4m3fn_t>::value || AscendC::IsSameType<TA, fp8_e5m2_t>::value) {
            PadOneBlockInnerAxis(a1Local, m, packedK);
        }
    }

    __aicore__ inline void FillZeroInB1(AscendC::LocalTensor<TB> b1Local)
    {
        // B矩阵GM上输入为[n, k]，k方向需要向64对齐，由于DataCopy k轴仅向16对齐，需要将剩余k方向脏数据数据刷为0
        if constexpr (AscendC::IsSameType<TB, fp8_e4m3fn_t>::value || AscendC::IsSameType<TB, fp8_e5m2_t>::value) {
            PadOneBlockInnerAxis(b1Local, n, packedK);
        }
    }

    template <typename T1>
    __aicore__ inline void PadOneBlockInnerAxis(
        const AscendC::LocalTensor<T1>& dst, const int32_t height, const int32_t width)
    {
        // 补齐row方向尾部1个32B的无效数据。
        // 将输入按照uint16类型填0；dst位于A1/B1时，Fill的blockNum和dstGap单位为32B。
        const uint32_t heightAlign = CeilAlign(height, fractalShape[0]);
        auto padTensor = dst.template ReinterpretCast<uint16_t>();
        AscendC::InitConstValueParams<uint16_t> initConstValueParams;
        initConstValueParams.repeatTimes = heightAlign;
        initConstValueParams.blockNum = 1;
        initConstValueParams.initValue = 0;
        uint32_t dstOffset = heightAlign * (CeilAlign(width, SCALE_CEIL_NUMBER) / 2);
        AscendC::Fill(padTensor[dstOffset], initConstValueParams);
    }

private:
    AscendC::GlobalTensor<TA> aGM;
    AscendC::GlobalTensor<fp8_e8m0_t> scaleAGM;
    AscendC::GlobalTensor<TB> bGM;
    AscendC::GlobalTensor<fp8_e8m0_t> scaleBGM;
    AscendC::GlobalTensor<T> biasGM;
    AscendC::GlobalTensor<T> cGM;

    uint32_t mAlignL1 = m, kaAlignL1 = k, nAlignL1 = n, kbAlignL1 = k;
    uint32_t mAlignL0 = m, kaAlignL0 = k, nAlignL0 = n, kbAlignL0 = k;
    uint32_t scaleMAlignL1 = m, scaleNAlignL1 = n;
    uint32_t alignK = k;

    uint32_t aSizeAlignL1, bSizeAlignL1, scaleASizeAlignL1, scaleBSizeAlignL1, biasSizeAlign;
    uint32_t aSizeAlignL0, bSizeAlignL0, cSizeAlignL0;
    uint32_t fractalShape[2] = {0, 0};
    uint32_t packedK = k;
    uint32_t scaleK = k;

    uint64_t a1Addr, scaleA1Addr, b1Addr, scaleB1Addr, c1Addr;
};

template <typename KernelType>
__aicore__ inline void RunKernel(GM_ADDR a, GM_ADDR scaleA, GM_ADDR b, GM_ADDR scaleB, GM_ADDR bias, GM_ADDR c)
{
    AscendC::InitSocState();
    KernelType op;
    op.Init(a, scaleA, b, scaleB, bias, c);
    op.Process();
    AscendC::PipeBarrier<PIPE_ALL>();
}

template <uint32_t m, uint32_t n, uint32_t k>
__global__ __cube__ void KernelMmadMXCustom(
    GM_ADDR a, GM_ADDR scaleA, GM_ADDR b, GM_ADDR scaleB, GM_ADDR bias, GM_ADDR c)
{
    if constexpr (scenarioNum == 1) {
        RunKernel<KernelMmadMX<float, fp4x2_e1m2_t, fp4x2_e2m1_t, m, n, k>>(a, scaleA, b, scaleB, bias, c);
    } else if constexpr (scenarioNum == 2) {
        RunKernel<KernelMmadMX<float, fp4x2_e2m1_t, fp4x2_e1m2_t, m, n, k>>(a, scaleA, b, scaleB, bias, c);
    } else if constexpr (scenarioNum == 3) {
        RunKernel<KernelMmadMX<float, fp8_e4m3fn_t, fp8_e5m2_t, m, n, k>>(a, scaleA, b, scaleB, bias, c);
    } else if constexpr (scenarioNum == 4) {
        RunKernel<KernelMmadMX<float, fp8_e5m2_t, fp8_e4m3fn_t, m, n, k>>(a, scaleA, b, scaleB, bias, c);
    }
}

int32_t main(int32_t argc, char* argv[])
{
    constexpr uint32_t m = 40;
    constexpr uint32_t n = 50;
    constexpr uint32_t k = 70;
    constexpr uint32_t scaleK = (k + SCALE_BASE_FACTOR - 1) / SCALE_BASE_FACTOR * SCALE_EVEN_NUMBER;

    size_t aFileSize = 0;
    size_t scaleAFileSize = 0;
    size_t bFileSize = 0;
    size_t scaleBFileSize = 0;
    size_t biasFileSize = 0;
    size_t cFileSize = 0;

    if constexpr (scenarioNum == 1 || scenarioNum == 2) {
        // 场景1和2: A/B 矩阵为 FP4 类型 (两个元素打包成一个字节)，需要除以2
        aFileSize = m * k * sizeof(uint8_t) / 2;
        bFileSize = n * k * sizeof(uint8_t) / 2;
    } else {
        // 场景3和4: A/B 矩阵为 FP8 类型，占用一个字节
        aFileSize = m * k * sizeof(uint8_t);
        bFileSize = n * k * sizeof(uint8_t);
    }
    scaleAFileSize = m * scaleK * sizeof(uint8_t); // fp8_e8m0_t
    scaleBFileSize = n * scaleK * sizeof(uint8_t); // fp8_e8m0_t
    biasFileSize = n * sizeof(float);
    cFileSize = m * n * sizeof(float);

    uint32_t numBlocks = 1;

    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t* aHost;
    uint8_t* aDevice;
    aclrtMallocHost((void**)(&aHost), aFileSize);
    aclrtMalloc((void**)&aDevice, aFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/x1_gm.bin", aFileSize, aHost, aFileSize);
    aclrtMemcpy(aDevice, aFileSize, aHost, aFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t* scaleAHost;
    uint8_t* scaleADevice;
    aclrtMallocHost((void**)(&scaleAHost), scaleAFileSize);
    aclrtMalloc((void**)&scaleADevice, scaleAFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/x1_scale_gm.bin", scaleAFileSize, scaleAHost, scaleAFileSize);
    aclrtMemcpy(scaleADevice, scaleAFileSize, scaleAHost, scaleAFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t* bHost;
    uint8_t* bDevice;
    aclrtMallocHost((void**)(&bHost), bFileSize);
    aclrtMalloc((void**)&bDevice, bFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/x2_gm.bin", bFileSize, bHost, bFileSize);
    aclrtMemcpy(bDevice, bFileSize, bHost, bFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t* scaleBHost;
    uint8_t* scaleBDevice;
    aclrtMallocHost((void**)(&scaleBHost), scaleBFileSize);
    aclrtMalloc((void**)&scaleBDevice, scaleBFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/x2_scale_gm.bin", scaleBFileSize, scaleBHost, scaleBFileSize);
    aclrtMemcpy(scaleBDevice, scaleBFileSize, scaleBHost, scaleBFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t* biasHost;
    uint8_t* biasDevice;
    if constexpr (HAS_BIAS_TENSOR) {
        aclrtMallocHost((void**)(&biasHost), biasFileSize);
        aclrtMalloc((void**)&biasDevice, biasFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
        ReadFile("./input/bias_gm.bin", biasFileSize, biasHost, biasFileSize);
        aclrtMemcpy(biasDevice, biasFileSize, biasHost, biasFileSize, ACL_MEMCPY_HOST_TO_DEVICE);
    }

    uint8_t* cHost;
    uint8_t* cDevice;
    aclrtMallocHost((void**)(&cHost), cFileSize);
    aclrtMalloc((void**)&cDevice, cFileSize, ACL_MEM_MALLOC_HUGE_FIRST);

    KernelMmadMXCustom<m, n, k>
        <<<numBlocks, nullptr, stream>>>(aDevice, scaleADevice, bDevice, scaleBDevice, biasDevice, cDevice);
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(cHost, cFileSize, cDevice, cFileSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", cHost, cFileSize);

    aclrtFree(aDevice);
    aclrtFreeHost(aHost);
    aclrtFree(scaleADevice);
    aclrtFreeHost(scaleAHost);
    aclrtFree(bDevice);
    aclrtFreeHost(bHost);
    aclrtFree(scaleBDevice);
    aclrtFreeHost(scaleBHost);
    if constexpr (HAS_BIAS_TENSOR) {
        aclrtFree(biasDevice);
        aclrtFreeHost(biasHost);
    }
    aclrtFree(cDevice);
    aclrtFreeHost(cHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();
    return 0;
}
