/* !
 * \file load_data_l12l0.asc
 * \brief 本样例介绍了在矩阵乘法场景下，使用LoadData系列指令（Load2D、LoadDataWithTranspose、Load3DV2）将矩阵数据从L1搬运到L0A/L0B的方法，支持int4_t/int8_t/half/float四种数据类型，共14种转置场景组合。
 */

#include "acl/acl.h"
#include "kernel_operator.h"
#include "data_utils.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

constexpr uint32_t scenarioNum = SCENARIO_NUM;

/*  isAtranspose为false，表示GM上输入A矩阵不转置，输入为[m, k]，则L1-->L0A时矩阵A不需要转置；isAtranspose为true，表示GM上输入A矩阵转置，输入为[k, m]，则L1-->L0A时矩阵A需要转置；
    isBtranspose为false，表示GM上输入B矩阵不转置，输入为[k, m]，则L1-->L0B时矩阵B需要转置；isBtranspose为true，表示GM上输入B矩阵转置，输入为[n, k]，则L1-->L0B时矩阵B不需要转置；

    1) isL1Nz为真时，适用矩阵乘法的大部分场景代表L1上A、B矩阵的排列格式为Nz排布格式；
    2) isL1Nz为假时，适用场景为：输入数据类型为float、A矩阵转置或者B矩阵不转置时，
    由于L1上A、B矩阵的排列格式为Nz格式时不能直接调用LoadDataWithTransPose
    此时需要通过调整DataCopy Nd2Nz接口来实现GM-->L1随路做Nz2Zz，令L1上A、B矩阵为Zz排布格式, 在此之后才能调用LoadDataWithTransPose；
*/

template <class T, class U, uint32_t m, uint32_t n, uint32_t k, bool isAtranspose, bool isBtranspose, uint8_t loadData2AMode = 0, uint8_t loadData2BMode = 0, bool isL1Nz = true>
class KernelMmad {
public:
    __aicore__ inline KernelMmad()
    {
        //矩阵分形的shape为[16, 32/sizeof(T)]
        fractalShape[0] = 16;
        // 当输入数据类型为int4时，1个int4_t的元素为0.5byte，但是sizeof(int4b_t) = 1 Byte, fractalShape[1]需要单独处理
        fractalShape[1] = AscendC::IsSameType<T, AscendC::int4b_t>::value ? 32 / sizeof(T) * 2 : 32 / sizeof(T);
        //左、右矩阵分形的size，单位是元素数目
        fractalSize = fractalShape[0] * fractalShape[1];
        // 转置只能以方块形式，因此不同位宽下，方块中包含的分形个数不同
        // 当输入数据类型为S4时，4个16*64的Z分形，在row方向拼接为一个64*64的方块矩阵。
        // 当输入数据类型为S8时，2个16*32的Z分形，在row方向拼接为一个32*32的方块矩阵。
        // 当输入数据类型为F32时，2个16*8的Z分形，在col方向拼接为一个16*16的方块矩阵。
        // 当输入数据类型为F16时，16*16的Z分形不用拼接。
        if constexpr (AscendC::IsSameType<T, AscendC::int4b_t>::value) {
            fractalNum = 4;
        } else if constexpr (sizeof(T) == 2) {
            fractalNum = 1;
        } else {
            fractalNum = 2;
        }
        // 计算不同场景下，A矩阵、B矩阵各个方向对齐的shape参数
        if constexpr (AscendC::IsSameType<T, AscendC::int4b_t>::value || AscendC::IsSameType<T, int8_t>::value || AscendC::IsSameType<T, half>::value) {
            if constexpr (!isAtranspose) {
                // GM上A矩阵的shape为[m,k], L1上的shape为[mAlignL1, kAlignL1], L0上的shape为[mAlignL0, kAlignL0]
                // L1上排布格式为Nz，A矩阵的对齐
                mAlignL1 = CeilAlign(m, fractalShape[0]); // row
                kAlignL1 = CeilAlign(k, fractalShape[1]); // col
                aSizeAlignL1 = mAlignL1 * kAlignL1;
                // L0上排布格式为Zz，A矩阵的对齐
                mAlignL0 = CeilAlign(m, fractalShape[0]); // row
                kAlignL0 = CeilAlign(k, fractalShape[1]); // col
                aSizeAlignL0 = mAlignL0 * kAlignL0;
            } else {
                // GM上A矩阵的shape为[k,m], L1上的shape为[kAlignL1, mAlignL1], L0上的shape为[mAlignL0, kAlignL0]
                // L1->L0A 调用LoadDataWithTranspose需要将row方向连续fractalNum个小分形拼成1个方形做转置搬运，因此L1和L0的row方向需要向fractalShape[0] * fractalNum对齐
                // L1上排布格式为Nz，A矩阵的对齐
                kAlignL1 = CeilAlign(k, fractalShape[0] * fractalNum); // row
                mAlignL1 = CeilAlign(m, fractalShape[1]); // col
                aSizeAlignL1 = kAlignL1 * mAlignL1;
                // L0上排布格式为Zz，A矩阵的对齐
                mAlignL0 = CeilAlign(m, fractalShape[0] * fractalNum); // row
                kAlignL0 = CeilAlign(k, fractalShape[1]); // col
                aSizeAlignL0 = mAlignL0 * kAlignL0;
            }
            if constexpr (!isBtranspose) {
                // GM上B矩阵的shape为[k,n], L1上的shape为[kAlignL1, nAlignL1], L0上的shape为[kAlignL0, nAlignL0]
                // L1->L0B 调用LoadDataWithTranspose需要将row方向连续fractalNum个小分形拼成1个方形做转置搬运，因此L1的row方向和L0的col方向需要向fractalShape[0] * fractalNum对齐
                // L1上排布格式为Nz，B矩阵的对齐
                kAlignL1 = CeilAlign(k, fractalShape[0] * fractalNum); // row
                nAlignL1 = CeilAlign(n, fractalShape[1]); // col
                bSizeAlignL1 = kAlignL1 * nAlignL1;
                // L0上排布格式为Zn，B矩阵的对齐
                kAlignL0 = CeilAlign(k, fractalShape[1]); // row
                nAlignL0 = CeilAlign(n, fractalShape[0] * fractalNum); // col
                bSizeAlignL0 = kAlignL0 * nAlignL0;
            } else {
                // GM上B矩阵的shape为[n,k], L1上的shape为[nAlignL1, kAlignL1], L0上的shape为[kAlignL0, nAlignL0]
                // L1上排布格式为Nz, B矩阵的对齐
                nAlignL1 = CeilAlign(n, fractalShape[0]); // row
                kAlignL1 = CeilAlign(k, fractalShape[1]); // col
                bSizeAlignL1 = nAlignL1 * kAlignL1;
                // L0上排布格式为Zn，B矩阵的对齐
                kAlignL0 = CeilAlign(k, fractalShape[1]); // row
                nAlignL0 = CeilAlign(n, fractalShape[0]); // col
                bSizeAlignL0 = kAlignL0 * nAlignL0;
            }
        } else if constexpr (AscendC::IsSameType<T, float>::value && isL1Nz) {
            if constexpr (!isAtranspose) {
                // GM上A矩阵的shape为[m,k], L1上的shape为[mAlignL1, kAlignL1], L0上的shape为[mAlignL0, kAlignL0]
                // L1上排布格式为Nz，A矩阵的对齐
                mAlignL1 = CeilAlign(m, fractalShape[0]); // row
                kAlignL1 = CeilAlign(k, fractalShape[1]); // col
                aSizeAlignL1 = mAlignL1 * kAlignL1;
                // L0上排布格式为Zz，A矩阵的对齐
                mAlignL0 = CeilAlign(m, fractalShape[0]); // row
                kAlignL0 = CeilAlign(k, fractalShape[1]); // col
                aSizeAlignL0 = mAlignL0 * kAlignL0;
            } else {
                // GM上A矩阵的shape为[k,m], L1上的shape为[kAlignL1, mAlignL1], L0上的shape为[mAlignL0, kAlignL0]
                // L1->L0A 调用Load3dV2 L1上row和col分别向fractalShape[0], fractalShape[1]对齐; L0上row向fractalShape[0]对齐, col向fractalShape[1] * fractalNum对齐
                // L1上排布格式为Nz，A矩阵的对齐
                kAlignL1 = CeilAlign(k, fractalShape[0]);
                mAlignL1 = CeilAlign(m, fractalShape[1]);
                aSizeAlignL1 = kAlignL1 * mAlignL1;
                // L0上排布格式为Zz，A矩阵的对齐
                mAlignL0 = CeilAlign(m, fractalShape[0]); // row
                kAlignL0 = CeilAlign(k, fractalShape[1] * fractalNum); // col
                aSizeAlignL0 = mAlignL0 * kAlignL0;
            }
            if constexpr (!isBtranspose) {
                // GM上B矩阵的shape为[k,n], L1上的shape为[kAlignL1, nAlignL1], L0上的shape为[kAlignL0, nAlignL0]
                // L1->L0B 调用Load3dV2 L1上row和col分别向fractalShape[0], fractalShape[1]对齐; L0上row向fractalShape[0]对齐, col向fractalShape[1]对齐
                // L1上排布格式为Nz，B矩阵的对齐
                kAlignL1 = CeilAlign(k, fractalShape[0]); // row
                nAlignL1 = CeilAlign(n, fractalShape[1]); // col
                bSizeAlignL1 = kAlignL1 * nAlignL1;
                // L0上排布格式为Zn，B矩阵的对齐
                kAlignL0 = CeilAlign(k, fractalShape[0]); // row
                nAlignL0 = CeilAlign(n, fractalShape[1]); // col
                bSizeAlignL0 = kAlignL0 * nAlignL0;
            } else {
                // GM上B矩阵的shape为[n,k], L1上的shape为[nAlignL1, kAlignL1], L0上的shape为[kAlignL0, nAlignL0]
                // L1上排布格式为Nz, B矩阵的对齐
                nAlignL1 = CeilAlign(n, fractalShape[0]); // row
                kAlignL1 = CeilAlign(k, fractalShape[1]); // col
                bSizeAlignL1 = nAlignL1 * kAlignL1;
                // L0上排布格式为Zn，B矩阵的对齐
                kAlignL0 = CeilAlign(k, fractalShape[1]); // row
                nAlignL0 = CeilAlign(n, fractalShape[0]); // col
                bSizeAlignL0 = kAlignL0 * nAlignL0;
            }
        } else if constexpr (AscendC::IsSameType<T, float>::value && !isL1Nz) {
                // L1上的排布格式为Zz
                if constexpr (isAtranspose) {
                    // GM上A矩阵的shape为[k,m], L1上的shape为[kAlignL1, mAlignL1], L0上的shape为[mAlignL0, kAlignL0]
                    // L1上排布格式为Zz，L1->L0A 调用LoadDataWithTranspose需要将col方向连续fractalNum个小分形拼成1个方形做转置搬运，因此L1和L0的col方向需要向fractalShape[1] * fractalNum对齐
                    kAlignL1 = CeilAlign(k, fractalShape[0]); // row
                    mAlignL1 = CeilAlign(m, fractalShape[1] * fractalNum); // col
                    aSizeAlignL1 = kAlignL1 * mAlignL1;
                    // L0上排布格式为Zz，A矩阵的对齐
                    mAlignL0 = CeilAlign(m, fractalShape[0]); // row
                    kAlignL0 = CeilAlign(k, fractalShape[1] * fractalNum); // col
                    aSizeAlignL0 = mAlignL0 * kAlignL0;
                }
                if constexpr (!isBtranspose) {
                    // GM上B矩阵的shape为[k,n], L1上的shape为[kAlignL1, nAlignL1], L0上的shape为[kAlignL0, nAlignL0]
                    // L1上排布格式为Zz，L1->L0B 调用LoadDataWithTranspose需要将col方向连续fractalNum个小分形拼成1个方形做转置搬运，因此L1的col方向和L0的row方向需要向fractalShape[1] * fractalNum对齐
                    kAlignL1 = CeilAlign(k, fractalShape[0]); // 高度
                    nAlignL1 = CeilAlign(n, fractalShape[1] * fractalNum); // 宽度
                    bSizeAlignL1 = kAlignL1 * nAlignL1;
                    // L0上排布格式为Zn，B矩阵的对齐
                    kAlignL0 = CeilAlign(k, fractalShape[1] * fractalNum); // 高度
                    nAlignL0 = CeilAlign(n, fractalShape[0]); // 宽度
                    bSizeAlignL0 = kAlignL0 * nAlignL0;
                }
        }
        // C矩阵无视数据类型和a、b是否转置，m,n都向16对齐
        cSizeAlignL0 = CeilAlign(m, 16) * CeilAlign(n, 16);
    }
    __aicore__ inline void Init(__gm__ uint8_t* a, __gm__ uint8_t* b, __gm__ uint8_t* c)
    {
        aGM.SetGlobalBuffer((__gm__ T *)a);
        bGM.SetGlobalBuffer((__gm__ T *)b);
        cGM.SetGlobalBuffer((__gm__ U *)c);
    }
    __aicore__ inline void Process()
    {
        AscendC::LocalTensor<T> a1Local(AscendC::TPosition::A1, a1Addr, aSizeAlignL1);
        AscendC::LocalTensor<T> a2Local(AscendC::TPosition::A2, a2Addr, aSizeAlignL0);
        AscendC::LocalTensor<T> b1Local(AscendC::TPosition::B1, b1Addr, bSizeAlignL1);
        AscendC::LocalTensor<T> b2Local(AscendC::TPosition::B2, b2Addr, bSizeAlignL0);
        AscendC::LocalTensor<U> c1Local(AscendC::TPosition::CO1, co1Addr, cSizeAlignL0);
        // 1.GM -> L1 
        CopyInA1(a1Local);
        CopyInB1(b1Local);
        AscendC::SetFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID0);
        // 2.L1 -> L0
        if constexpr (!isAtranspose) {
            SplitA(a1Local, a2Local);
        } else {
            SplitATranspose(a1Local, a2Local);
        }

        if constexpr (!isBtranspose) {
            SplitBTranspose(b1Local, b2Local);
        } else {
            SplitB(b1Local, b2Local);
        }
        AscendC::SetFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID0);
        // 3.Mmad
        AscendC::MmadParams mmadParams;
        // 左矩阵A的row
        mmadParams.m = m;
        // 右矩阵B的col
        mmadParams.n = n;
        if constexpr (AscendC::IsSameType<T, AscendC::int4b_t>::value || AscendC::IsSameType<T, int8_t>::value) {
            if constexpr (!isBtranspose) {
                // mmad默认n轴向16对齐，但是由于B转置过程n轴向2 * 16对齐，填充了一个全部由无效数据的32 * 16的分形，
                // 如果仍然设置mmadParams.n = n，cube单元会多读入无效数据的分形同时有效数据的分形也未被读入。
                // 此时可以通过设置n向32对齐，让此分形参与计算，搬出时跳过无效分形参与计算的得到的分形即可
                mmadParams.n = CeilAlign(n, fractalShape[0] * fractalNum);
            }
        }
        // 左矩阵A的col、右矩阵B的row
        mmadParams.k = k;
        if constexpr (AscendC::IsSameType<T, float>::value && AscendC::IsSameType<U, float>::value) {
            if constexpr (isAtranspose) {
                // float输入数据类型，A转置场景输入为[k, m], 在搬入L0A过程中在K方向会对齐到16，为避免读入无效数据，需要开启kDirectionAlign功能
                mmadParams.kDirectionAlign = true;
            }
        }
        AscendC::Mmad(c1Local, a2Local, b2Local, mmadParams);
        AscendC::SetFlag<AscendC::HardEvent::M_FIX>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::M_FIX>(EVENT_ID0);
        // 4. L0C -> GM
        AscendC::FixpipeParamsV220 fixpipeParams;
        // 源Nz矩阵在N方向上的大小。
        fixpipeParams.nSize = n;
        // 源Nz矩阵在M方向上的大小。
        fixpipeParams.mSize = m;
        // 源Nz矩阵中相邻Z排布的起始地址偏移
        // 源操作数来源于L0c，因此m只需要向16对齐，与数据类型无关
        fixpipeParams.srcStride = CeilAlign(m, fractalShape[0]);
        fixpipeParams.dstStride = n;
        // 源Nz矩阵的数目，也就是传输ND矩阵的数目
        fixpipeParams.ndNum = 1;
        // 不同Nz矩阵起始地址之间的间隔，当ndNum配置为1时，配置为0即可，不生效。
        fixpipeParams.srcNdStride = 0;
        // 不同ND矩阵起始地址之间的间隔，当ndNum配置为1时，配置为0即可，不生效。
        fixpipeParams.dstNdStride = 0;
        AscendC::Fixpipe(cGM, c1Local, fixpipeParams);
    }
    

private:
    __aicore__ inline uint16_t CeilDivision(uint16_t numerator, uint16_t denominator) 
    {
        return (numerator + denominator - 1) / denominator;
    }

    __aicore__ inline uint16_t CeilAlign(uint16_t numerator, uint16_t denominator) 
    {
        return (numerator + denominator - 1) / denominator * denominator;
    }
    __aicore__ inline void CopyInA1(AscendC::LocalTensor<T> a1Local)
    {
        // GM-->L1,搬运A矩阵
        AscendC::Nd2NzParams nd2nzA1Params;
        if constexpr (!isAtranspose) {
            // 传输ND矩阵的数目
            nd2nzA1Params.ndNum = 1;
            // ND矩阵的行数
            nd2nzA1Params.nValue = m;
            // ND矩阵的列数
            nd2nzA1Params.dValue = k;
            // 只传输了1个ND矩阵，该参数无效
            nd2nzA1Params.srcNdMatrixStride = 0;
            // 源操作数同一ND矩阵的相邻行起始地址间的偏移
            nd2nzA1Params.srcDValue = k;

            // 以下这个参数取A矩阵在L1上，高度方向的对齐后的长度
            // 由于A不转置，因此对于四种数据类型该参数均相同
            nd2nzA1Params.dstNzC0Stride = mAlignL1;

            nd2nzA1Params.dstNzNStride = 1;
            nd2nzA1Params.dstNzMatrixStride = 0;
            // int4_t输入数据类型，与列数(数据连续方向)相关的参数要除2, 指令内部搬运会把2个int4_t看做1个int8_t进行搬运
            if constexpr (AscendC::IsSameType<T, AscendC::int4b_t>::value) {
                nd2nzA1Params.dValue = k >> 1;
                nd2nzA1Params.srcDValue = k >> 1;
            }
        } else {
            nd2nzA1Params.ndNum = 1;
            nd2nzA1Params.nValue = k;
            nd2nzA1Params.dValue = m;
            nd2nzA1Params.srcNdMatrixStride = 0;
            nd2nzA1Params.srcDValue = m;// int4_t不支持A转置输入，因此这里不需要特殊处理int4_t数据类型
            nd2nzA1Params.dstNzNStride = 1;
            nd2nzA1Params.dstNzMatrixStride = 0;
            // 以下这个参数取A矩阵在L1上，高度方向的对齐后的长度
            // 由于A转置，因此四种数据类型下，该参数的配置不相同
            if constexpr (AscendC::IsSameType<T, int8_t>::value || AscendC::IsSameType<T, half>::value || (AscendC::IsSameType<T, float>::value && isL1Nz)) {
                nd2nzA1Params.dstNzC0Stride = kAlignL1;
            } else if constexpr (AscendC::IsSameType<T, float>::value && !isL1Nz) {
                /*A矩阵转置(a转置)，输入数据类型为float类型时，为了调用LoadDataWithTranspose接口，要求L1上A矩阵的排布必须是Zz,
                因此需要在GM-->L1阶段调用DataCopyNd2Nz 指令时通过巧妙地配置Nd2NzParams结构体来实现Nd2Zz的效果。
                
                DataCopyNd2Nz 指令实现Nd2Zz效果的核心思想在于将1个ND矩阵沿着高度轴以步长16进行切分，看作CeilDivision(k, 16)个ND矩阵。
                由于搬运后CeilDivision(k, 16)个Nz矩阵在高度轴方向有且仅有1个分形，因此最终搬运到L1上的A矩阵等效于Zz排列。
                */
                nd2nzA1Params.ndNum = CeilDivision(k, fractalShape[0]);
                nd2nzA1Params.nValue = fractalShape[0];
                nd2nzA1Params.dValue = m;
                nd2nzA1Params.srcNdMatrixStride = fractalShape[0] * m;
                nd2nzA1Params.srcDValue = m;
                nd2nzA1Params.dstNzC0Stride = fractalShape[0];
                nd2nzA1Params.dstNzNStride = 1;
                nd2nzA1Params.dstNzMatrixStride = fractalShape[0] * CeilAlign(m, fractalShape[1] * fractalNum);
            }
        }
        AscendC::DataCopy(a1Local, aGM, nd2nzA1Params);
    }

    __aicore__ inline void CopyInB1(AscendC::LocalTensor<T> b1Local)
    {
        // GM-->L1,搬运B矩阵
        AscendC::Nd2NzParams nd2nzB1Params;
        if constexpr (!isBtranspose) {
            nd2nzB1Params.ndNum = 1;
            nd2nzB1Params.nValue = k;
            nd2nzB1Params.dValue = n;
            nd2nzB1Params.srcNdMatrixStride = 0;
            nd2nzB1Params.srcDValue = n;
            nd2nzB1Params.dstNzNStride = 1;
            nd2nzB1Params.dstNzMatrixStride = 0;

            // 以下这个参数取B矩阵在L1上，高度方向的对齐后的长度
            // 由于B矩阵在不同数据类型下的分形排布不同，因此四种数据类型下，该参数的配置不相同
            if constexpr (AscendC::IsSameType<T, AscendC::int4b_t>::value || AscendC::IsSameType<T, int8_t>::value || AscendC::IsSameType<T, half>::value || (AscendC::IsSameType<T, float>::value && isL1Nz)) {
                nd2nzB1Params.dstNzC0Stride = kAlignL1;
            } else if constexpr (AscendC::IsSameType<T, float>::value && !isL1Nz) {
                /*B矩阵不转置(b转置)，输入数据类型为float类型时，为了调用LoadDataWithTranspose接口，要求L1上B矩阵的排布必须是Zz,
                因此需要在GM-->L1阶段调用DataCopyNd2Nz 指令时通过巧妙地配置Nd2NzParams结构体来实现Nd2Zz的效果。
                
                DataCopyNd2Nz 指令实现Nd2Zz效果的核心思想在于将1个ND矩阵沿着高度轴以步长16进行切分，看作CeilDivision(k, 16)个ND矩阵。
                由于搬运后CeilDivision(k, 16)个Nz矩阵在高度轴方向有且仅有1个分形，因此最终搬运到L1上的B矩阵等效于Zz排列。
                */
                nd2nzB1Params.ndNum = CeilDivision(k, fractalShape[0]);
                nd2nzB1Params.nValue = fractalShape[0];
                nd2nzB1Params.dValue = n;
                nd2nzB1Params.srcNdMatrixStride = fractalShape[0] * n;
                nd2nzB1Params.srcDValue = n;
                nd2nzB1Params.dstNzC0Stride = fractalShape[0];
                nd2nzB1Params.dstNzNStride = 1;
                nd2nzB1Params.dstNzMatrixStride = fractalShape[0] * CeilAlign(n, fractalShape[1] * fractalNum);
            }
            // int4_t输入数据类型，与列数(数据连续方向)相关的参数要除2, 指令内部搬运会把2个int4_t看做1个int8_t进行搬运
            if constexpr (AscendC::IsSameType<T, AscendC::int4b_t>::value) {
                nd2nzB1Params.dValue = n >> 1;
                nd2nzB1Params.srcDValue = n >> 1;
            }
        } else {
            nd2nzB1Params.ndNum = 1;
            nd2nzB1Params.nValue = n;
            nd2nzB1Params.dValue = k;
            nd2nzB1Params.srcNdMatrixStride = 0;
            nd2nzB1Params.srcDValue = k;
            // int4_t输入数据类型，与列数(数据连续方向)相关的参数要除2, 指令内部搬运会把2个int4_t看做1个int8_t进行搬运
            if constexpr (AscendC::IsSameType<T, AscendC::int4b_t>::value) {
                nd2nzB1Params.dValue = k >> 1;
                nd2nzB1Params.srcDValue = k >> 1;
            }
            // 以下这个参数取B矩阵在L1上，高度方向的对齐后的长度
            // 由于B转置，因此四种数据类型下，该参数的配置相同
            nd2nzB1Params.dstNzC0Stride = nAlignL1;
            nd2nzB1Params.dstNzNStride = 1;
            nd2nzB1Params.dstNzMatrixStride = 0;
        }
        AscendC::DataCopy(b1Local, bGM, nd2nzB1Params);
    }

    __aicore__ inline void SplitA(AscendC::LocalTensor<T> a1Local, AscendC::LocalTensor<T> a2Local)
    {
        if constexpr (loadData2AMode == 0) {
            // Load2d: Nz -> Zz
            uint32_t dstOffset = CeilDivision(k, fractalShape[1]) * fractalSize;
            uint32_t srcOffset = fractalSize;
            AscendC::LoadData2DParams loadDataParams;
            loadDataParams.repeatTimes = CeilDivision(k, fractalShape[1]);
            loadDataParams.srcStride = CeilDivision(m, fractalShape[0]);
            loadDataParams.dstGap = 0;
            loadDataParams.ifTranspose = false;
            for (int i = 0; i < CeilDivision(m, fractalShape[0]); ++i) {
                AscendC::LoadData(a2Local[i * dstOffset], a1Local[i * srcOffset], loadDataParams);
            }
        } else if constexpr (loadData2AMode == 2) {
            // Load3dV2: Nz -> Zz
            AscendC::LoadData3DParamsV2<T> loadDataParams;
            // 源操作数height
            loadDataParams.l1H = 1;
            // 源操作数width
            loadDataParams.l1W = CeilAlign(m, fractalShape[0]);
            // 源操作数的通道数，
            // img2col的结果矩阵高度为ho * wo,根据ho和wo的计算公式，代入卷积核宽度、卷积核滑动步长、卷积核膨胀系数等参数可知：ho * wo = loadDataParams.l1H * loadDataParams.l1w
            // img2col的结果矩阵宽度为ci * kh * kw,代入kh=1,kw=1，可知结果矩阵的宽度为ci=loadDataParams.channelSize = m
            loadDataParams.channelSize = CeilAlign(k, fractalShape[1]);
            // 该指令在目的操作数width维度的传输长度，如果不覆盖最右侧的分形，对于half类型，应为16的倍数，对于int8_t/uint8_t应为32的倍数；覆盖的情况则无倍数要求。
            loadDataParams.kExtension = CeilAlign(k, fractalShape[1]);
            // 该指令在目的操作数height维度的传输长度，如果不覆盖最下侧的分形，对于half/int8_t/uint8_t，应为16的倍数；覆盖的情况则无倍数要求。
            loadDataParams.mExtension = CeilAlign(m, fractalShape[0]);
            // 卷积核在源操作数width维度滑动的步长
            loadDataParams.strideW = 1;
            // 卷积核在源操作数height维度滑动的步长
            loadDataParams.strideH = 1;
            // 卷积核width
            loadDataParams.filterW = 1;
            // 卷积核height
            loadDataParams.filterH = 1;
            // 卷积核width膨胀系数
            loadDataParams.dilationFilterW = 1;
            // 卷积核height膨胀系数
            loadDataParams.dilationFilterH = 1;
            loadDataParams.filterSizeW = false;
            loadDataParams.filterSizeH = false;
            loadDataParams.enTranspose = false;
            loadDataParams.fMatrixCtrl = false;
            AscendC::LoadData(a2Local, a1Local, loadDataParams);
        }
    }

    __aicore__ inline void SplitATranspose(AscendC::LocalTensor<T> a1Local, AscendC::LocalTensor<T> a2Local)
    {
         if constexpr (AscendC::IsSameType<T, int8_t>::value) {
            SplitATransposeForS8(a1Local, a2Local);
        } else if constexpr (AscendC::IsSameType<T, half>::value) {
            SplitATransposeForB16(a1Local, a2Local);
        } else if constexpr (AscendC::IsSameType<T, float>::value) {
            SplitATransposeForB32(a1Local, a2Local);
        }
    }

    __aicore__ inline void SplitATransposeForS8(AscendC::LocalTensor<T> a1Local, AscendC::LocalTensor<T> a2Local)
    {
        if constexpr (loadData2AMode == 1) {
            // LoadDataWithTranspose: Nz-> Zz
            // 根据以下函数原型，offset的数据类型是uint32_t
            // __aicore__ inline LocalTensor operator[](const uint32_t offset) const
            // dstoffset要根据A矩阵在L0上，宽度方向的对齐来求解
            uint32_t dstOffset = CeilDivision(k, fractalShape[1]) * fractalSize * fractalNum;
            // srcoffset要根据A矩阵在L1上，高度方向的对齐来求解
            uint32_t srcOffset = CeilDivision(k, fractalShape[0] * fractalNum) * fractalSize * fractalNum;

            AscendC::LoadData2dTransposeParams loadDataParams;
            // 搬运起始位置为源操作数中第几个方块矩阵（0 为源操作数中第1个方块矩阵)
            loadDataParams.startIndex = 0;
            // 迭代次数,每次迭代转置一个方块矩阵
            loadDataParams.repeatTimes = CeilDivision(k, fractalShape[0] * fractalNum);
            // 相邻迭代间，源操作数前一个分形与后一个分形起始地址的间隔。单位是方块矩阵的大小
            loadDataParams.srcStride = 1;
            // 相邻迭代间，目的操作数前一个迭代第一个分形的结束地址到下一个迭代第一个分形起始地址的间隔，单位：512B
            loadDataParams.dstGap = 0;
            // 每个迭代内目的操作数转置前一个分形结束地址与后一个分形起始地址的间隔，单位为512B
            loadDataParams.dstFracGap = CeilDivision(k, fractalShape[1]) - 1;
            for (int i = 0; i < CeilDivision(m, fractalShape[1]); ++i) {
                AscendC::LoadDataWithTranspose(a2Local[i * dstOffset], a1Local[i * srcOffset], loadDataParams);
            }
        }
    }

    __aicore__ inline void SplitATransposeForB16(AscendC::LocalTensor<T> a1Local, AscendC::LocalTensor<T> a2Local)
    {

        if constexpr (loadData2AMode == 0) {
            // Load2d: Nz -> Zz
            uint32_t dstOffset = CeilDivision(k, fractalShape[0]) * fractalSize;
            uint32_t srcOffset = CeilDivision(k, fractalShape[0]) * fractalSize;
            AscendC::LoadData2DParams loadDataParams;
            // 迭代次数，每个迭代可以处理512B数据
            loadDataParams.repeatTimes = CeilDivision(k, fractalShape[0]);
            // 相邻迭代间，源操作数前一个分形与后一个分形起始地址的间隔，单位：512B
            loadDataParams.srcStride = 1;
            // 相邻迭代间，目的操作数前一个分形结束地址与后一个分形起始地址的间隔，单位：512B
            loadDataParams.dstGap = 0;
            // 是否启用转置功能，对每个分形矩阵进行转置，默认为false
            loadDataParams.ifTranspose = true;
            for (int i = 0; i < CeilDivision(m, fractalShape[1]); ++i) {
                AscendC::LoadData(a2Local[i * dstOffset], a1Local[i * srcOffset], loadDataParams);
            }
        } else if constexpr (loadData2AMode == 1) {
            // LoadDataWithTranspose: Nz -> Zz
            // 根据以下函数原型，offset的数据类型是uint32_t
            // __aicore__ inline LocalTensor operator[](const uint32_t offset) const

            // dstoffset要根据A矩阵在L0上，宽度方向的对齐来求解
            uint32_t dstOffset = CeilDivision(k, fractalShape[1]) * fractalSize * fractalNum;
            // srcoffset要根据A矩阵在L1上，高度方向的对齐来求解
            uint32_t srcOffset = CeilDivision(k, fractalShape[0] * fractalNum) * fractalSize * fractalNum;

            AscendC::LoadData2dTransposeParams loadDataParams;
            // 搬运起始位置为源操作数中第几个方块矩阵（0 为源操作数中第1个方块矩阵)
            loadDataParams.startIndex = 0;
            // 迭代次数,每次迭代转置一个方块矩阵
            loadDataParams.repeatTimes = CeilDivision(k, fractalShape[0] * fractalNum);
            // 相邻迭代间，源操作数前一个分形与后一个分形起始地址的间隔。单位是方块矩阵的大小
            loadDataParams.srcStride = 1;
            // 相邻迭代间，目的操作数前一个迭代第一个分形的结束地址到下一个迭代第一个分形起始地址的间隔，单位：512B
            loadDataParams.dstGap = 0;
            // 每个迭代内目的操作数转置前一个分形结束地址与后一个分形起始地址的间隔，单位为512B
            loadDataParams.dstFracGap = CeilDivision(k, fractalShape[1]) - 1;
            for (int i = 0; i < CeilDivision(m, fractalShape[1]); ++i) {
                AscendC::LoadDataWithTranspose(a2Local[i * dstOffset], a1Local[i * srcOffset], loadDataParams);
            }
        } else if constexpr (loadData2AMode == 2) {
            // Load3dV2: Nz -> Zz
            AscendC::LoadData3DParamsV2<T> loadDataParams;
            // 源操作数height
            loadDataParams.l1H = 1;
            // 源操作数width
            loadDataParams.l1W = CeilAlign(k, fractalShape[0]);
            // 源操作数的通道数，
            // img2col的结果矩阵高度为ho * wo,根据ho和wo的计算公式，代入卷积核宽度、卷积核滑动步长、卷积核膨胀系数等参数可知：ho * wo = loadDataParams.l1H * loadDataParams.l1w
            // img2col的结果矩阵宽度为ci * kh * kw,代入kh=1,kw=1，可知结果矩阵的宽度为ci=loadDataParams.channelSize = m
            loadDataParams.channelSize = CeilAlign(m, fractalShape[1]);
            // 该指令在目的操作数width维度的传输长度，如果不覆盖最右侧的分形，对于half类型，应为16的倍数，对于int8_t/uint8_t应为32的倍数；覆盖的情况则无倍数要求。
            loadDataParams.kExtension = CeilAlign(m, fractalShape[1]);
            // 该指令在目的操作数height维度的传输长度，如果不覆盖最下侧的分形，对于half/int8_t/uint8_t，应为16的倍数；覆盖的情况则无倍数要求。
            loadDataParams.mExtension = CeilAlign(k, fractalShape[1] * fractalNum);
            // 卷积核在源操作数width维度滑动的步长
            loadDataParams.strideW = 1;
            // 卷积核在源操作数height维度滑动的步长
            loadDataParams.strideH = 1;
            // 卷积核width
            loadDataParams.filterW = 1;
            // 卷积核height
            loadDataParams.filterH = 1;
            // 卷积核width膨胀系数
            loadDataParams.dilationFilterW = 1;
            // 卷积核height膨胀系数
            loadDataParams.dilationFilterH = 1;
            loadDataParams.filterSizeW = false;
            loadDataParams.filterSizeH = false;
            loadDataParams.enTranspose = true;
            loadDataParams.fMatrixCtrl = false;
            AscendC::LoadData(a2Local, a1Local, loadDataParams);
        }
    }

    __aicore__ inline void SplitATransposeForB32(AscendC::LocalTensor<T> a1Local, AscendC::LocalTensor<T> a2Local)
    {
        if constexpr (loadData2AMode == 2) {
            // Load3dV2: Nz -> Zz
            AscendC::LoadData3DParamsV2<T> loadDataParams;
            // 源操作数height
            loadDataParams.l1H = 1;
            // 源操作数width
            loadDataParams.l1W = CeilAlign(k, fractalShape[0]);
            // 源操作数的通道数，
            // img2col的结果矩阵高度为ho * wo,根据ho和wo的计算公式，代入卷积核宽度、卷积核滑动步长、卷积核膨胀系数等参数可知：ho * wo = loadDataParams.l1H * loadDataParams.l1w
            // img2col的结果矩阵宽度为ci * kh * kw,代入kh=1,kw=1，可知结果矩阵的宽度为ci=loadDataParams.channelSize = m
            loadDataParams.channelSize = CeilAlign(m, fractalShape[1]);
            // 该指令在目的操作数width维度的传输长度，如果不覆盖最右侧的分形，对于half类型，应为16的倍数，对于int8_t/uint8_t应为32的倍数；覆盖的情况则无倍数要求。
            loadDataParams.kExtension = CeilAlign(m, fractalShape[1]);
            // 该指令在目的操作数height维度的传输长度，如果不覆盖最下侧的分形，对于half/int8_t/uint8_t/int4_t，应为16的倍数；覆盖的情况则无倍数要求。
            loadDataParams.mExtension = CeilAlign(k, fractalShape[1] * fractalNum);
            // 卷积核在源操作数width维度滑动的步长
            loadDataParams.strideW = 1;
            // 卷积核在源操作数height维度滑动的步长
            loadDataParams.strideH = 1;
            // 卷积核width
            loadDataParams.filterW = 1;
            // 卷积核height
            loadDataParams.filterH = 1;
            // 卷积核width膨胀系数
            loadDataParams.dilationFilterW = 1;
            // 卷积核height膨胀系数
            loadDataParams.dilationFilterH = 1;
            loadDataParams.filterSizeW = false;
            loadDataParams.filterSizeH = false;
            loadDataParams.enTranspose = true;
            loadDataParams.fMatrixCtrl = false;
            AscendC::LoadData(a2Local, a1Local, loadDataParams);
        } else if constexpr (!isL1Nz) {
            // LoadDataWithTranspose: Zz -> Zz
            // A矩阵在L0A上shape为[M，K]、Zz排布，因此dstoffset要根据A矩阵在K轴方向的对齐来求解
            uint32_t dstOffset = CeilDivision(k, fractalShape[1] * fractalNum) * fractalSize * fractalNum;
            // A矩阵在L1上shape为[k, m]、Zz排布，因此srcoffset为1个分形包含的元素个数
            uint32_t srcOffset = fractalSize * fractalNum;

            AscendC::LoadData2dTransposeParams loadDataParams;
            // 搬运起始位置为源操作数中第几个方块矩阵（0 为源操作数中第1个方块矩阵)
            loadDataParams.startIndex = 0;
            // 迭代次数,每次迭代转置一个方块矩阵
            loadDataParams.repeatTimes = CeilDivision(k, fractalShape[1] * fractalNum);
            // 相邻迭代间，源操作数前一个分形与后一个分形起始地址的间隔。单位是方块矩阵的大小
            loadDataParams.srcStride = CeilDivision(m, fractalShape[1] * fractalNum);
            // 相邻迭代间，目的操作数前一个迭代第一个分形的结束地址到下一个迭代第一个分形起始地址的间隔，单位：512B
            loadDataParams.dstGap = 1;
            // 每个迭代内目的操作数转置前一个分形结束地址与后一个分形起始地址的间隔，单位为512B
            loadDataParams.dstFracGap = 0;
            for (int i = 0; i < CeilDivision(m, fractalShape[1] * fractalNum); ++i) {
                AscendC::LoadDataWithTranspose(a2Local[i * dstOffset], a1Local[i * srcOffset], loadDataParams);
            }
        }
    }

    __aicore__ inline void SplitB(AscendC::LocalTensor<T> b1Local, AscendC::LocalTensor<T> b2Local)
    {
        if constexpr (loadData2BMode == 0) {
            // Load2d: Nz -> Zn
            uint32_t dstOffset = CeilDivision(n, fractalShape[0]) * fractalSize;
            uint32_t srcOffset = CeilDivision(n, fractalShape[0]) * fractalSize;

            AscendC::LoadData2DParams loadDataParams;
            loadDataParams.repeatTimes = CeilDivision(n, fractalShape[0]);
            loadDataParams.srcStride = 1;
            loadDataParams.dstGap = 0;
            loadDataParams.ifTranspose = false;
            for (int i = 0; i < CeilDivision(k, fractalShape[1]); ++i) {
                AscendC::LoadData(b2Local[i * dstOffset], b1Local[i * srcOffset], loadDataParams);
            }
        }
    }

    __aicore__ inline void SplitBTranspose(AscendC::LocalTensor<T> b1Local, AscendC::LocalTensor<T> b2Local)
    {
        if constexpr (AscendC::IsSameType<T, AscendC::int4b_t>::value || AscendC::IsSameType<T, int8_t>::value) {
            SplitBTransposeForS4S8(b1Local, b2Local);
        } else if constexpr (AscendC::IsSameType<T, half>::value) {
            SplitBTransposeForB16(b1Local, b2Local);
        } else if constexpr (AscendC::IsSameType<T, float>::value) {
            SplitBTransposeForB32(b1Local, b2Local);
        }
    }

    __aicore__ inline void SplitBTransposeForS4S8(AscendC::LocalTensor<T> b1Local, AscendC::LocalTensor<T> b2Local)
    {
        if constexpr (loadData2BMode == 1) {
            // LoadDataWithTranspose: Nz -> Zn
            uint32_t dstOffset = CeilDivision(n, fractalShape[0] * fractalNum) * fractalSize * fractalNum;
            uint32_t srcOffset = fractalSize * fractalNum;
            AscendC::LoadData2dTransposeParams loadDataParams;
            loadDataParams.startIndex = 0;
            loadDataParams.repeatTimes = CeilDivision(n, fractalShape[1]);
            loadDataParams.srcStride = CeilDivision(k, fractalShape[0] * fractalNum);
            loadDataParams.dstGap = 1;
            loadDataParams.dstFracGap = 0;
            for (int i = 0; i < CeilDivision(k, fractalShape[0] * fractalNum); ++i) {
                AscendC::LoadDataWithTranspose(b2Local[i * dstOffset], b1Local[i * srcOffset], loadDataParams);
            }
        }
    }

    __aicore__ inline void SplitBTransposeForB16(AscendC::LocalTensor<T> b1Local, AscendC::LocalTensor<T> b2Local)
    {
        if constexpr (loadData2BMode == 0) {
            // Load2d: Nz -> Zn
            uint32_t dstOffset = CeilDivision(n, fractalShape[0] * fractalNum) * fractalSize * fractalNum;
            uint32_t srcOffset = fractalSize * fractalNum;

            AscendC::LoadData2DParams loadDataParams;
            loadDataParams.repeatTimes = CeilDivision(n, fractalShape[0] * fractalNum);
            loadDataParams.srcStride = CeilDivision(k, fractalShape[0] * fractalNum);
            loadDataParams.dstGap = 0;
            loadDataParams.ifTranspose = true;
            for (int i = 0; i < CeilDivision(k, fractalShape[0] * fractalNum); ++i) {
                AscendC::LoadData(b2Local[i * dstOffset], b1Local[i * srcOffset], loadDataParams);
            }
        } else if constexpr (loadData2BMode == 1) {
            // LoadDataWithTranspose: Nz -> Zn
            uint32_t dstOffset = CeilDivision(n, fractalShape[0] * fractalNum) * fractalSize * fractalNum;
            uint32_t srcOffset = fractalSize * fractalNum;
            AscendC::LoadData2dTransposeParams loadDataParams;
            loadDataParams.startIndex = 0;
            loadDataParams.repeatTimes = CeilDivision(n, fractalShape[1]);
            loadDataParams.srcStride = CeilDivision(k, fractalShape[0] * fractalNum);
            loadDataParams.dstGap = 0;
            loadDataParams.dstFracGap = 0;
            for (int i = 0; i < CeilDivision(k, fractalShape[0] * fractalNum); ++i) {
                AscendC::LoadDataWithTranspose(b2Local[i * dstOffset], b1Local[i * srcOffset], loadDataParams);
            }
        } else if constexpr (loadData2BMode == 2) {
            // Load3dV2: Nz -> Zn
            AscendC::LoadData3DParamsV2<T> loadDataParams;
            loadDataParams.l1H = 1;
            loadDataParams.l1W = CeilAlign(k, fractalShape[0]);
            loadDataParams.channelSize = CeilAlign(n, fractalShape[1]);
            loadDataParams.kExtension = CeilAlign(n, fractalShape[1]);
            loadDataParams.mExtension = CeilAlign(k, fractalShape[0]);
            loadDataParams.strideW = 1;
            loadDataParams.strideH = 1;
            loadDataParams.filterW = 1;
            loadDataParams.filterH = 1;
            loadDataParams.dilationFilterW = 1;
            loadDataParams.dilationFilterH = 1;
            loadDataParams.filterSizeW = false;
            loadDataParams.filterSizeH = false;
            // 对于Load3Dv2接口，当目的地址为L0B时，b矩阵会自动转置，loadDataParams.enTranspose仅在目的地址为L0A时生效。
            loadDataParams.enTranspose = true;
            loadDataParams.fMatrixCtrl = false;
            AscendC::LoadData(b2Local, b1Local, loadDataParams);
        }
    }

    __aicore__ inline void SplitBTransposeForB32(AscendC::LocalTensor<T> b1Local, AscendC::LocalTensor<T> b2Local)
    {
        if constexpr (loadData2BMode == 2) {
            // Load3dV2: Nz -> Zn
            AscendC::LoadData3DParamsV2<T> loadDataParams;
            loadDataParams.l1H = 1;
            loadDataParams.l1W = CeilAlign(k, fractalShape[0]);
            loadDataParams.channelSize = CeilAlign(n, fractalShape[1]);
            loadDataParams.kExtension = CeilAlign(n, fractalShape[1]);
            loadDataParams.mExtension = CeilAlign(k, fractalShape[0]);
            loadDataParams.strideW = 1;
            loadDataParams.strideH = 1;
            loadDataParams.filterW = 1;
            loadDataParams.filterH = 1;
            loadDataParams.dilationFilterW = 1;
            loadDataParams.dilationFilterH = 1;
            loadDataParams.filterSizeW = false;
            loadDataParams.filterSizeH = false;
            loadDataParams.enTranspose = true;
            loadDataParams.fMatrixCtrl = false;
            AscendC::LoadData(b2Local, b1Local, loadDataParams);
        } else if constexpr (!isL1Nz) {
            // LoadDataWithTranspose: Zz -> Zn
            // B矩阵在L0B上shape为[K，N]、Zn排布，因此dstoffset要根据B矩阵在N轴方向的对齐来求解
            uint32_t dstOffset = CeilDivision(n, fractalShape[0]) * fractalSize * fractalNum;
            // B矩阵在L1上shape为[k, n]、Zz排布，因此srcoffset要根据B矩阵在N轴方向的对齐来求解
            uint32_t srcOffset = CeilDivision(n, fractalShape[1] * fractalNum) * fractalSize * fractalNum;

            AscendC::LoadData2dTransposeParams loadDataParams;
            // 搬运起始位置为源操作数中第几个方块矩阵（0 为源操作数中第1个方块矩阵)
            loadDataParams.startIndex = 0;
            // 迭代次数,每次迭代转置一个方块矩阵
            loadDataParams.repeatTimes = CeilDivision(n, fractalShape[1] * fractalNum);
            // 相邻迭代间，源操作数前一个分形与后一个分形起始地址的间隔。单位是方块矩阵的大小
            loadDataParams.srcStride = 1;
            // 相邻迭代间，目的操作数前一个迭代第一个分形的结束地址到下一个迭代第一个分形起始地址的间隔，单位：512B
            loadDataParams.dstGap = 0;
            // 每个迭代内目的操作数转置前一个分形结束地址与后一个分形起始地址的间隔，单位为512B
            loadDataParams.dstFracGap = CeilDivision(n, fractalShape[0]) - 1;
            for (int i = 0; i < CeilDivision(k, fractalShape[0]); ++i) {
                AscendC::LoadDataWithTranspose(b2Local[i * dstOffset], b1Local[i * srcOffset], loadDataParams);
            }
        }
    }

private:
    AscendC::GlobalTensor<T> aGM;
    AscendC::GlobalTensor<T> bGM;
    AscendC::GlobalTensor<U> cGM;

    static constexpr uint32_t a1Addr = 0;
    static constexpr uint32_t a2Addr = 0;
    static constexpr uint32_t b1Addr = 128 * 1024;
    static constexpr uint32_t b2Addr = 0;
    static constexpr uint32_t co1Addr = 0;

    uint32_t mAlignL1 = m, kAlignL1 = k, nAlignL1 = n;
    uint32_t mAlignL0 = m, kAlignL0 = k, nAlignL0 = n;

    uint32_t aSizeAlignL1, bSizeAlignL1;
    uint32_t aSizeAlignL0, bSizeAlignL0, cSizeAlignL0;
    uint32_t fractalShape[2] = {0, 0};
    uint32_t fractalSize = 0;
    uint32_t fractalNum = 0;
};

template<typename KernelType>
__aicore__ inline void RunKernel(__gm__ uint8_t* a, __gm__ uint8_t* b, __gm__ uint8_t* c)
{
    AscendC::InitSocState();
    KernelType op;
    op.Init(a, b, c);
    op.Process();
    AscendC::PipeBarrier<PIPE_ALL>();
}

template <uint32_t m, uint32_t n, uint32_t k>
__global__ __cube__ void KernelLoadDataL12L0(__gm__ uint8_t* a, __gm__ uint8_t* b, __gm__ uint8_t* c)
{
    // 共计14种场景
    // 4种数据类型，与A、B是否转置组合，共13种场景
    // 针对输入数据为float，A矩阵转置并且B矩阵不转置在L1-->L0过程中调用LoadDataWithTranspose新增1个场景
    if constexpr (scenarioNum == 1) {
        // 输入数据类型为int4_t, A矩阵输入为[m, k], B矩阵输入为[n, k], L1->L0A调用Load2D, L1->L0B调用Load2D
        RunKernel<KernelMmad<AscendC::int4b_t, int32_t, m, n, k, false, true, 0, 0>>(a, b, c);
    } else if constexpr (scenarioNum == 2) {
        // 输入数据类型为int4_t, A矩阵输入为[m, k], B矩阵输入为[k, n], L1->L0A调用Load3DV2, L1->L0B调用LoadDataWithTranspose
        RunKernel<KernelMmad<AscendC::int4b_t, int32_t, m, n, k, false, false, 2, 1>>(a, b, c);
    } else if constexpr (scenarioNum == 3) {
        // 输入数据类型为int8_t, A矩阵输入为[m, k], B矩阵输入为[n, k], L1->L0A调用Load2D, L1->L0B调用Load2D
        RunKernel<KernelMmad<int8_t, int32_t, m, n, k, false, true, 0, 0>>(a, b, c);
    } else if constexpr (scenarioNum == 4) {
        // 输入数据类型为int8_t, A矩阵输入为[m, k], B矩阵输入为[n, k], L1->L0A调用Load3DV2, L1->L0B调用Load2D
        RunKernel<KernelMmad<int8_t, int32_t, m, n, k, false, true, 2, 0>>(a, b, c);
    } else if constexpr (scenarioNum == 5) {
        // 输入数据类型为int8_t, A矩阵输入为[k, m], B矩阵输入为[k, n], L1->L0A调用LoadDataWithTranspose, L1->L0B调用LoadDataWithTranspose
        RunKernel<KernelMmad<int8_t, int32_t, m, n, k, true, false, 1, 1>>(a, b, c);
    } else if constexpr (scenarioNum == 6) {
        // 输入数据类型为half, A矩阵输入为[m, k], B矩阵输入为[n, k], L1->L0A调用Load2D, L1->L0B调用Load2D
        RunKernel<KernelMmad<half, float, m, n, k, false, true, 0, 0>>(a, b, c);
    } else if constexpr (scenarioNum == 7) {
        // 输入数据类型为half, A矩阵输入为[m, k], B矩阵输入为[n, k], L1->L0A调用Load3DV2, L1->L0B调用Load2D
        RunKernel<KernelMmad<half, float, m, n, k, false, true, 2, 0>>(a, b, c);
    } else if constexpr (scenarioNum == 8) {
        // 输入数据类型为half, A矩阵输入为[k, m], B矩阵输入为[k, n], L1->L0A调用Load2D, L1->L0B调用Load2D
        RunKernel<KernelMmad<half, float, m, n, k, true, false, 0, 0>>(a, b, c);
    } else if constexpr (scenarioNum == 9) {
        // 输入数据类型为half, A矩阵输入为[k, m], B矩阵输入为[k, n], L1->L0A调用LoadDataWithTranspose, L1->L0B调用LoadDataWithTranspose
        RunKernel<KernelMmad<half, float, m, n, k, true, false, 1, 1>>(a, b, c);
    } else if constexpr (scenarioNum == 10) {
        // 输入数据类型为half, A矩阵输入为[k, m], B矩阵输入为[k, n], L1->L0A调用Load3DV2, L1->L0B调用Load3DV2
        RunKernel<KernelMmad<half, float, m, n, k, true, false, 2, 2>>(a, b, c);
    } else if constexpr (scenarioNum == 11) {
        // 输入数据类型为float, A矩阵输入为[m, k], B矩阵输入为[n, k], L1->L0A调用Load2D, L1->L0B调用Load2D
        RunKernel<KernelMmad<float, float, m, n, k, false, true, 0, 0>>(a, b, c);
    } else if constexpr (scenarioNum == 12) {
        // 输入数据类型为float, A矩阵输入为[m, k], B矩阵输入为[n, k], L1->L0A调用Load3DV2, L1->L0B调用Load2D
        RunKernel<KernelMmad<float, float, m, n, k, false, true, 2, 0>>(a, b, c);
    } else if constexpr (scenarioNum == 13) {
        // 输入数据类型为float, A矩阵输入为[k, m], B矩阵输入为[k, n], L1->L0A调用Load3DV2, L1->L0B调用Load3DV2
        RunKernel<KernelMmad<float, float, m, n, k, true, false, 2, 2>>(a, b, c);
    } else {
        // scenarioNum == 14
        // 输入数据类型为float, A矩阵输入为[k, m], B矩阵输入为[k, n], GM->L1 搬运成Zz格式， L1->L0A调用LoadDataWithTranspose, L1->L0B调用LoadDataWithTranspose
        constexpr bool isL1Nz = false;
        RunKernel<KernelMmad<float, float, m, n, k, true, false, 1, 1, isL1Nz>>(a, b, c);
    }
}

int32_t main(int32_t argc, char *argv[])
{
    constexpr uint32_t m = 40;
    constexpr uint32_t n = 50;
    constexpr uint32_t k = 70;
    size_t aFileSize = 0;
    size_t bFileSize = 0;
    size_t cFileSize = 0;

    if constexpr (scenarioNum <= 2) {
        aFileSize = m * k * sizeof(int8_t);
        bFileSize = k * n * sizeof(int8_t);
        cFileSize = m * n * sizeof(int32_t);
    } else if constexpr (scenarioNum <= 5) {
        aFileSize = m * k * sizeof(int8_t);
        bFileSize = k * n * sizeof(int8_t);
        cFileSize = m * n * sizeof(int32_t);
    } else if constexpr (scenarioNum <= 10) {
        aFileSize = m * k * sizeof(half);
        bFileSize = k * n * sizeof(half);
        cFileSize = m * n * sizeof(float);
    } else {
        aFileSize = m * k * sizeof(float);
        bFileSize = k * n * sizeof(float);
        cFileSize = m * n * sizeof(float);
    }
    uint32_t numBlocks = 1;

    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t *aHost;
    uint8_t *aDevice;
    aclrtMallocHost((void **)(&aHost), aFileSize);
    aclrtMalloc((void **)&aDevice, aFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/x1_gm.bin", aFileSize, aHost, aFileSize);
    aclrtMemcpy(aDevice, aFileSize, aHost, aFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t *bHost;
    uint8_t *bDevice;
    aclrtMallocHost((void **)(&bHost), bFileSize);
    aclrtMalloc((void **)&bDevice, bFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/x2_gm.bin", bFileSize, bHost, bFileSize);
    aclrtMemcpy(bDevice, bFileSize, bHost, bFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t *cHost;
    uint8_t *cDevice;
    aclrtMallocHost((void **)(&cHost), cFileSize);
    aclrtMalloc((void **)&cDevice, cFileSize, ACL_MEM_MALLOC_HUGE_FIRST);

    KernelLoadDataL12L0<m, n, k><<<numBlocks, nullptr, stream>>>(aDevice, bDevice, cDevice);
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(cHost, cFileSize, cDevice, cFileSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", cHost, cFileSize);

    aclrtFree(aDevice);
    aclrtFreeHost(aHost);
    aclrtFree(bDevice);
    aclrtFreeHost(bHost);
    aclrtFree(cDevice);
    aclrtFreeHost(cHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();
    return 0;
}