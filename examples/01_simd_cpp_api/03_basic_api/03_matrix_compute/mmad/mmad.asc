/* !
 * \file mmad.asc
 * \brief 本文介绍了int4b_t / int8_t / bfloat16 /
 * float，四种数据类型下的矩阵乘法，包含3种启用bias的方式和kDirectionAlign参数的使用。
 */
#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif
#include "acl/acl.h"
#include "kernel_operator.h"
#include "data_utils.h"

constexpr uint32_t scenarioNum = SCENARIO_NUM;
constexpr bool HAS_BIAS_TENSOR = (SCENARIO_NUM == 1 || SCENARIO_NUM == 3);
constexpr uint32_t BLOCK_CUBE = 16;
constexpr uint64_t ADDR_0 = 0;

template <class T, class U, uint32_t M, uint32_t N, uint32_t K, bool isATranspose, bool isBTranspose>
class KernelMmad {
public:
    __aicore__ inline KernelMmad()
    {
        // 根据不同输入类型设置c0Size
        if constexpr (SCENARIO_NUM == 1) {
            c0Size = 32;
            fractalNum = 2;
            // A、B 都不转
            aSizeAlignL1 = CeilAlign(M, BLOCK_CUBE) * CeilAlign(K, c0Size);
            aSizeAlignL0 = CeilAlign(M, BLOCK_CUBE) * CeilAlign(K, c0Size);
            bSizeAlignL1 = CeilAlign(K, BLOCK_CUBE * fractalNum) * CeilAlign(N, c0Size);
            bSizeAlignL0 = CeilAlign(K, c0Size) * CeilAlign(N, BLOCK_CUBE * fractalNum);
        } else if constexpr (SCENARIO_NUM == 2) {
            c0Size = 16;
            fractalNum = 1;
            // A不转，B转
            aSizeAlignL1 = CeilAlign(M, BLOCK_CUBE) * CeilAlign(K, c0Size);
            aSizeAlignL0 = CeilAlign(M, BLOCK_CUBE) * CeilAlign(K, c0Size);
            bSizeAlignL1 = CeilAlign(N, BLOCK_CUBE) * CeilAlign(K, c0Size);
            bSizeAlignL0 = CeilAlign(K, c0Size) * CeilAlign(N, BLOCK_CUBE);
        } else if constexpr (SCENARIO_NUM == 3) {
            c0Size = 8;
            fractalNum = 2;
            // A、B都转
            aSizeAlignL1 = CeilAlign(K, BLOCK_CUBE) * CeilAlign(M, c0Size * fractalNum);
            aSizeAlignL0 = CeilAlign(M, BLOCK_CUBE) * CeilAlign(K, c0Size * fractalNum);
            bSizeAlignL1 = CeilAlign(N, BLOCK_CUBE) * CeilAlign(K, c0Size);
            bSizeAlignL0 = CeilAlign(K, c0Size) * CeilAlign(N, BLOCK_CUBE);
        } else {
            c0Size = 64;
            fractalNum = 4;
            // A不转，B转
            aSizeAlignL1 = CeilAlign(M, BLOCK_CUBE) * CeilAlign(K, c0Size);
            aSizeAlignL0 = CeilAlign(M, BLOCK_CUBE) * CeilAlign(K, c0Size);
            bSizeAlignL1 = CeilAlign(N, BLOCK_CUBE) * CeilAlign(K, c0Size);
            bSizeAlignL0 = CeilAlign(K, c0Size) * CeilAlign(N, BLOCK_CUBE);
        }
        fractalSize = BLOCK_CUBE * c0Size;
        cSizeAlignL0 = CeilAlign(M, BLOCK_CUBE) * CeilAlign(N, BLOCK_CUBE);

#if defined(__NPU_ARCH__) && (__NPU_ARCH__ == 3510)
        // 对于Ascend 950PR/Ascend 950DT，C1->C2，要求待搬运数据的连续传输数据块长度（blockLen）的单位是32B，
        // 且数据类型为b32时值需为偶数
        biasSizeAlign = CeilAlign(CeilDiv(N * sizeof(T), 32), 2) * 32;
#else
        // Atlas A3 训练系列产品/Atlas A3 推理系列产品、Atlas A2 训练系列产品/Atlas A2 推理系列产品，
        // C1->C2，要求blockLen的单位是64B
        biasSizeAlign = CeilAlign(N * sizeof(T), 64);
#endif
        a1Addr = ADDR_0;
        b1Addr = a1Addr + aSizeAlignL1 * sizeof(U);
        c1Addr = a1Addr + b1Addr + bSizeAlignL1 * sizeof(U);
    }
    __aicore__ inline void Init(__gm__ uint8_t* a, __gm__ uint8_t* b, __gm__ uint8_t* bias, __gm__ uint8_t* c)
    {
        aGM.SetGlobalBuffer((__gm__ U*)a);
        bGM.SetGlobalBuffer((__gm__ U*)b);
        biasGM.SetGlobalBuffer((__gm__ T*)bias);
        cGM.SetGlobalBuffer((__gm__ T*)c);
    }
    __aicore__ inline void Process()
    {
        AscendC::LocalTensor<U> a1Local(AscendC::TPosition::A1, a1Addr, aSizeAlignL1);
        AscendC::LocalTensor<U> b1Local(AscendC::TPosition::B1, b1Addr, bSizeAlignL1);
        AscendC::LocalTensor<T> bias1Local(AscendC::TPosition::C1, c1Addr, biasSizeAlign / sizeof(T));

        // GM -> L1
        CopyIn(a1Local, b1Local, bias1Local);
        // L1 -> L0A
        AscendC::LocalTensor<U> a2Local(AscendC::TPosition::A2, ADDR_0, aSizeAlignL0);
        if constexpr (isATranspose) {
            SplitATranspose(a1Local, a2Local);
        } else {
            SplitA(a1Local, a2Local);
        }
        // L1 -> L0B
        AscendC::LocalTensor<U> b2Local(AscendC::TPosition::B2, ADDR_0, bSizeAlignL0);
        if constexpr (!isBTranspose) {
            SplitBTranspose(b1Local, b2Local);
        } else {
            SplitB(b1Local, b2Local);
        }
        // L1 -> BT
        AscendC::LocalTensor<T> bias2Local(AscendC::TPosition::C2, ADDR_0, biasSizeAlign / sizeof(T));
        if constexpr (HAS_BIAS_TENSOR) {
            SplitBias(bias1Local, bias2Local);
        }
        // Mmad
        AscendC::LocalTensor<T> co1Local(AscendC::TPosition::CO1, ADDR_0, cSizeAlignL0);
        Compute(a2Local, b2Local, bias2Local, co1Local);
        // L0C -> GM
        CopyOut(co1Local);
    }

private:
    // 向上整除
    __aicore__ inline uint32_t CeilDiv(uint32_t numerator, uint32_t denominator)
    {
        return (numerator + denominator - 1) / denominator;
    }
    // 向上对齐
    __aicore__ inline uint32_t CeilAlign(uint32_t numerator, uint32_t denominator)
    {
        return (numerator + denominator - 1) / denominator * denominator;
    }

    __aicore__ inline void CopyIn(
        AscendC::LocalTensor<U>& a1Local, AscendC::LocalTensor<U>& b1Local, AscendC::LocalTensor<T>& bias1Local)
    {
        if constexpr (isATranspose) {
#if defined(__NPU_ARCH__) && (__NPU_ARCH__ == 3510)
            // ND -> Nz
            AscendC::Nd2NzParams nd2nzA1Params;
            nd2nzA1Params.ndNum = 1;
            nd2nzA1Params.nValue = K;
            nd2nzA1Params.dValue = M;
            nd2nzA1Params.srcNdMatrixStride = 0;
            nd2nzA1Params.srcDValue = M;
            nd2nzA1Params.dstNzC0Stride = CeilAlign(K, BLOCK_CUBE);
            nd2nzA1Params.dstNzNStride = 1;
            nd2nzA1Params.dstNzMatrixStride = 0;
            AscendC::DataCopy(a1Local, aGM, nd2nzA1Params);
#else
            // ND -> Zz
            AscendC::Nd2NzParams nd2nzA1Params;
            nd2nzA1Params.ndNum = K / BLOCK_CUBE;
            nd2nzA1Params.nValue = BLOCK_CUBE;
            nd2nzA1Params.dValue = M;
            nd2nzA1Params.srcNdMatrixStride = BLOCK_CUBE * M;
            nd2nzA1Params.srcDValue = M;
            nd2nzA1Params.dstNzC0Stride = BLOCK_CUBE;
            nd2nzA1Params.dstNzNStride = 1;
            nd2nzA1Params.dstNzMatrixStride = BLOCK_CUBE * CeilAlign(M, c0Size * fractalNum);
            AscendC::DataCopy(a1Local, aGM, nd2nzA1Params);
            // 若K非对齐，需要单独处理尾块
            uint32_t tailK = K % BLOCK_CUBE;
            if (tailK) {
                AscendC::Nd2NzParams nd2nzA1ParamsTail;
                nd2nzA1ParamsTail.ndNum = 1;
                nd2nzA1ParamsTail.nValue = tailK;
                nd2nzA1ParamsTail.dValue = M;
                nd2nzA1ParamsTail.srcNdMatrixStride = 0;
                nd2nzA1ParamsTail.srcDValue = M;
                nd2nzA1ParamsTail.dstNzC0Stride = BLOCK_CUBE;
                nd2nzA1ParamsTail.dstNzNStride = 1;
                nd2nzA1ParamsTail.dstNzMatrixStride = 0;
                AscendC::DataCopy(
                    a1Local[(K - tailK) * CeilAlign(M, c0Size * fractalNum)], aGM[(K - tailK) * M], nd2nzA1ParamsTail);
            }
#endif
        } else {
            // ND -> Nz
            AscendC::Nd2NzParams nd2nzA1Params;
            nd2nzA1Params.ndNum = 1;
            nd2nzA1Params.nValue = M;
            nd2nzA1Params.dValue = K;
            nd2nzA1Params.srcNdMatrixStride = 0;
            nd2nzA1Params.srcDValue = K;
            nd2nzA1Params.dstNzC0Stride = CeilAlign(M, BLOCK_CUBE);
            nd2nzA1Params.dstNzNStride = 1;
            nd2nzA1Params.dstNzMatrixStride = 0;
            if constexpr (AscendC::IsSameType<U, AscendC::int4b_t>::value) {
                // 两个int4b_t合并成int8_t, 进行GM-->L1, nd2nz的搬运
                nd2nzA1Params.dValue = K >> 1;
                nd2nzA1Params.srcDValue = K >> 1;
            }
            AscendC::DataCopy(a1Local, aGM, nd2nzA1Params);
        }
        AscendC::SetFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID0);

        AscendC::Nd2NzParams nd2nzB1Params;
        if constexpr (isBTranspose) {
            nd2nzB1Params.ndNum = 1;
            nd2nzB1Params.nValue = N;
            nd2nzB1Params.dValue = K;
            nd2nzB1Params.srcNdMatrixStride = 0;
            nd2nzB1Params.srcDValue = K;
            nd2nzB1Params.dstNzC0Stride = CeilAlign(N, BLOCK_CUBE);
            nd2nzB1Params.dstNzNStride = 1;
            nd2nzB1Params.dstNzMatrixStride = 0;
            if constexpr (AscendC::IsSameType<U, AscendC::int4b_t>::value) {
                // 两个int4b_t合并成int8_t, 进行GM-->L1, nd2nz的搬运
                nd2nzB1Params.dValue = K >> 1;
                nd2nzB1Params.srcDValue = K >> 1;
            }
        } else {
            nd2nzB1Params.ndNum = 1;
            nd2nzB1Params.nValue = K;
            nd2nzB1Params.dValue = N;
            nd2nzB1Params.srcNdMatrixStride = 0;
            nd2nzB1Params.srcDValue = N;
            nd2nzB1Params.dstNzC0Stride = CeilAlign(K, BLOCK_CUBE * fractalNum);
            nd2nzB1Params.dstNzNStride = 1;
            nd2nzB1Params.dstNzMatrixStride = 0;
        }
        AscendC::DataCopy(b1Local, bGM, nd2nzB1Params);
        AscendC::SetFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID1);

        if constexpr (HAS_BIAS_TENSOR) {
            // 由于N可能非32B对齐，“基础数据搬运”无法处理非对齐数据，且“DataCopyPad”不支持GM到L1的搬运，
            // 因此，使用“随路转换ND2Nz搬运”实现Bias的GM到L1搬运，确保搬运到L1数据32B对齐。
            AscendC::Nd2NzParams nd2nzC1Params = {1, 1, N, 0, N, 1, 1, 0};
            AscendC::DataCopy(bias1Local, biasGM, nd2nzC1Params);
            AscendC::SetFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID2);
        }
    }

    __aicore__ inline void SplitA(AscendC::LocalTensor<U>& a1Local, AscendC::LocalTensor<U>& a2Local)
    {
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID0);
#if defined(__NPU_ARCH__) && (__NPU_ARCH__ == 3510)
        // Nz -> Nz, __NPU_ARCH__为3510时，要求A2上的数据排布为: Nz
        AscendC::LoadData2DParamsV2 loadDataParams;
        loadDataParams.mStartPosition = 0;
        loadDataParams.kStartPosition = 0;
        loadDataParams.mStep = CeilDiv(M, BLOCK_CUBE);
        loadDataParams.kStep = CeilDiv(K, c0Size);
        loadDataParams.srcStride = CeilDiv(M, BLOCK_CUBE);
        loadDataParams.dstStride = CeilDiv(M, BLOCK_CUBE);
        loadDataParams.ifTranspose = false;
        AscendC::LoadData(a2Local, a1Local, loadDataParams);
#else
        // Nz -> Zz, __NPU_ARCH__为2201时，要求A2上的数据排布为: Zz
        uint32_t dstOffset = CeilDiv(K, c0Size) * fractalSize;
        uint32_t srcOffset = fractalSize;
        AscendC::LoadData2DParams loadDataParams;
        loadDataParams.startIndex = 0;
        loadDataParams.repeatTimes = CeilDiv(K, c0Size);
        loadDataParams.srcStride = CeilDiv(M, BLOCK_CUBE);
        loadDataParams.dstGap = 0;
        loadDataParams.ifTranspose = false;
        for (int i = 0; i < CeilDiv(M, BLOCK_CUBE); ++i) {
            AscendC::LoadData(a2Local[i * dstOffset], a1Local[i * srcOffset], loadDataParams);
        }
#endif
        AscendC::SetFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID0);
    }

    __aicore__ inline void SplitATranspose(AscendC::LocalTensor<U>& a1Local, AscendC::LocalTensor<U>& a2Local)
    {
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID0);
#if defined(__NPU_ARCH__) && (__NPU_ARCH__ == 3510)
        // Nz -> Nz, __NPU_ARCH__为3510时，要求A2上的数据排布为: Nz
        AscendC::LoadData2DParamsV2 loadDataParams;
        loadDataParams.mStartPosition = 0;
        loadDataParams.kStartPosition = 0;
        // 开启转置时，b4 mStep必须是4的倍数，b8 mStep必须是2的倍数，b32 kStep必须是2的倍数
        loadDataParams.mStep = CeilDiv(K, BLOCK_CUBE);
        loadDataParams.kStep = CeilAlign(CeilDiv(M, c0Size), 2);
        loadDataParams.srcStride = CeilDiv(K, BLOCK_CUBE);
        loadDataParams.dstStride = CeilDiv(M, c0Size * fractalNum);
        loadDataParams.ifTranspose = true;
        AscendC::LoadData(a2Local, a1Local, loadDataParams);
#else
        // Nz -> Zz, __NPU_ARCH__为2201时，要求A2上的数据排布为: Zz
        uint32_t dstOffset = CeilDiv(K, c0Size * fractalNum) * fractalSize * fractalNum;
        uint32_t srcOffset = fractalSize * fractalNum;

        AscendC::LoadData2dTransposeParams loadDataParams;
        loadDataParams.startIndex = 0;
        loadDataParams.repeatTimes = CeilDiv(K, c0Size * fractalNum);
        loadDataParams.srcStride = CeilDiv(M, c0Size * fractalNum);
        loadDataParams.dstGap = 1;
        loadDataParams.dstFracGap = 0;
        for (int i = 0; i < CeilDiv(M, c0Size * fractalNum); ++i) {
            AscendC::LoadDataWithTranspose(a2Local[i * dstOffset], a1Local[i * srcOffset], loadDataParams);
        }
#endif
        AscendC::SetFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID0);
    }

    __aicore__ inline void SplitB(AscendC::LocalTensor<U>& b1Local, AscendC::LocalTensor<U>& b2Local)
    {
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID1);
        // B2上的数据排布为: Zn
        AscendC::LoadData2DParams loadDataParams;
        loadDataParams.repeatTimes = CeilDiv(N, BLOCK_CUBE) * CeilDiv(K, c0Size);
        loadDataParams.srcStride = 1;
        loadDataParams.dstGap = 0;
        loadDataParams.ifTranspose = false;
        AscendC::LoadData(b2Local, b1Local, loadDataParams);
        AscendC::SetFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID1);
    }

    __aicore__ inline void SplitBTranspose(AscendC::LocalTensor<U>& b1Local, AscendC::LocalTensor<U>& b2Local)
    {
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID1);
        uint32_t dstOffset = CeilDiv(N, BLOCK_CUBE * fractalNum) * fractalSize * fractalNum;
        uint32_t srcOffset = fractalSize * fractalNum;
        AscendC::LoadData2dTransposeParams loadDataParams;
        loadDataParams.startIndex = 0;
        loadDataParams.repeatTimes = CeilDiv(N, c0Size);
        loadDataParams.srcStride = CeilDiv(K, BLOCK_CUBE * fractalNum);
        loadDataParams.dstGap = 1;
        loadDataParams.dstFracGap = 0;
        for (int i = 0; i < CeilDiv(K, BLOCK_CUBE * fractalNum); ++i) {
            AscendC::LoadDataWithTranspose(b2Local[i * dstOffset], b1Local[i * srcOffset], loadDataParams);
        }
        AscendC::SetFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID1);
    }

    __aicore__ inline void SplitBias(AscendC::LocalTensor<T>& bias1Local, AscendC::LocalTensor<T>& bias2Local)
    {
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID2);
#if defined(__NPU_ARCH__) && (__NPU_ARCH__ == 3510)
        AscendC::DataCopyParams c12c2Params = {1, static_cast<uint16_t>(biasSizeAlign / 32), 0, 0};
#else
        AscendC::DataCopyParams c12c2Params = {1, static_cast<uint16_t>(biasSizeAlign / 64), 0, 0};
#endif
        AscendC::DataCopy(bias2Local, bias1Local, c12c2Params);
        AscendC::SetFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID2);
    }

    __aicore__ inline void Compute(
        AscendC::LocalTensor<U>& a2Local, AscendC::LocalTensor<U>& b2Local, AscendC::LocalTensor<T>& bias2Local,
        AscendC::LocalTensor<T>& co1Local)
    {
        AscendC::WaitFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID1);

        AscendC::MmadParams mmadParams;
        mmadParams.m = M;
        mmadParams.n = N;
        mmadParams.k = K;

        if constexpr (AscendC::IsSameType<U, int8_t>::value && !isBTranspose) {
            mmadParams.n = CeilAlign(N, BLOCK_CUBE * fractalNum);
        }
        if constexpr (AscendC::IsSameType<U, float>::value && isATranspose) {
            mmadParams.kDirectionAlign = true;
        }

        if constexpr (SCENARIO_NUM == 1) {
            // 带Bias且不传入biasTensor，C矩阵的初始值来源于C2
            mmadParams.cmatrixInitVal = false;
            mmadParams.cmatrixSource = true;
            AscendC::WaitFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID2);
            AscendC::Mmad(co1Local, a2Local, b2Local, mmadParams);
        } else if constexpr (SCENARIO_NUM == 2) {
            // 不带Bias，C矩阵累加来源于CO1初始值
            // 第一次mmad计算，CO1的计算结果作为下一次mmad计算C矩阵的初始值
            AscendC::Mmad(co1Local, a2Local, b2Local, mmadParams);
            mmadParams.cmatrixInitVal = false;
            mmadParams.cmatrixSource = false; // C矩阵的初始值来源于CO1
            AscendC::Mmad(co1Local, a2Local, b2Local, mmadParams);
        } else if constexpr (SCENARIO_NUM == 3) {
            // 带Bias且传入biasTensor的场景，该场景下cmatrixSource参数无效
            mmadParams.cmatrixInitVal = false;
            AscendC::WaitFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID2);
            AscendC::Mmad(co1Local, a2Local, b2Local, bias2Local, mmadParams);
        } else {
            // 不带Bias场景
            mmadParams.cmatrixInitVal = true; // C矩阵初始值为0
            AscendC::Mmad(co1Local, a2Local, b2Local, mmadParams);
        }
        AscendC::SetFlag<AscendC::HardEvent::M_FIX>(EVENT_ID0);
    }
    __aicore__ inline void CopyOut(AscendC::LocalTensor<T>& co1Local)
    {
        AscendC::WaitFlag<AscendC::HardEvent::M_FIX>(EVENT_ID0);
#if defined(__NPU_ARCH__) && (__NPU_ARCH__ == 3510)
        AscendC::FixpipeParamsArch3510<AscendC::CO2Layout::ROW_MAJOR> fixpipeParams;
#else
        AscendC::FixpipeParamsV220 fixpipeParams;
        fixpipeParams.ndNum = 1;
        fixpipeParams.srcNdStride = 0;
        fixpipeParams.dstNdStride = 0;
#endif
        fixpipeParams.mSize = M;
        fixpipeParams.nSize = N;
        fixpipeParams.srcStride = CeilAlign(M, BLOCK_CUBE);
        fixpipeParams.dstStride = N;

        AscendC::Fixpipe(cGM, co1Local, fixpipeParams);
    }

private:
    AscendC::GlobalTensor<U> aGM;
    AscendC::GlobalTensor<U> bGM;
    AscendC::GlobalTensor<T> biasGM;
    AscendC::GlobalTensor<T> cGM;

    uint32_t c0Size, fractalSize, fractalNum;
    uint32_t aSizeAlignL1, bSizeAlignL1, biasSizeAlign, aSizeAlignL0, bSizeAlignL0, cSizeAlignL0;

    uint64_t a1Addr, b1Addr, c1Addr;
};

template <uint32_t M, uint32_t N, uint32_t K>
__global__ __cube__ void mmad_custom(__gm__ uint8_t* a, __gm__ uint8_t* b, __gm__ uint8_t* bias, __gm__ uint8_t* c)
{
    AscendC::InitSocState();
    if constexpr (scenarioNum == 1) {
        KernelMmad<int32_t, int8_t, M, N, K, false, false> op;
        op.Init(a, b, bias, c);
        op.Process();
    } else if constexpr (scenarioNum == 2) {
        KernelMmad<float, bfloat16_t, M, N, K, false, true> op;
        op.Init(a, b, bias, c);
        op.Process();
    } else if constexpr (scenarioNum == 3) {
        KernelMmad<float, float, M, N, K, true, true> op;
        op.Init(a, b, bias, c);
        op.Process();
    } else {
        KernelMmad<int32_t, AscendC::int4b_t, M, N, K, false, true> op;
        op.Init(a, b, bias, c);
        op.Process();
    }
    AscendC::PipeBarrier<PIPE_ALL>();
}

int32_t main(int32_t argc, char* argv[])
{
    constexpr uint32_t M = 30;
    constexpr uint32_t N = 40;
    constexpr uint32_t K = 70;
    size_t aFileSize = 0;
    size_t bFileSize = 0;
    size_t biasFileSize = 0;
    size_t cFileSize = 0;

    if constexpr (scenarioNum == 1) {
        aFileSize = M * K * sizeof(int8_t);
        bFileSize = K * N * sizeof(int8_t);
        biasFileSize = N * sizeof(int32_t);
        cFileSize = M * N * sizeof(int32_t);
    } else if constexpr (scenarioNum == 2) {
        aFileSize = M * K * sizeof(bfloat16_t);
        bFileSize = K * N * sizeof(bfloat16_t);
        biasFileSize = N * sizeof(float);
        cFileSize = M * N * sizeof(float);
    } else if constexpr (scenarioNum == 3) {
        aFileSize = M * K * sizeof(float);
        bFileSize = K * N * sizeof(float);
        biasFileSize = N * sizeof(float);
        cFileSize = M * N * sizeof(float);
    } else {
        aFileSize = M * K * sizeof(int8_t) / 2;
        bFileSize = K * N * sizeof(int8_t) / 2;
        biasFileSize = N * sizeof(int32_t);
        cFileSize = M * N * sizeof(int32_t);
    }
    uint32_t numBlocks = 1;

    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t* aHost;
    uint8_t* aDevice;
    aclrtMallocHost((void**)(&aHost), aFileSize);
    aclrtMalloc((void**)&aDevice, aFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/x1_gm.bin", aFileSize, aHost, aFileSize);
    aclrtMemcpy(aDevice, aFileSize, aHost, aFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t* bHost;
    uint8_t* bDevice;
    aclrtMallocHost((void**)(&bHost), bFileSize);
    aclrtMalloc((void**)&bDevice, bFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/x2_gm.bin", bFileSize, bHost, bFileSize);
    aclrtMemcpy(bDevice, bFileSize, bHost, bFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t* biasHost;
    uint8_t* biasDevice;
    if constexpr (HAS_BIAS_TENSOR) {
        aclrtMallocHost((void**)(&biasHost), biasFileSize);
        aclrtMalloc((void**)&biasDevice, biasFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
        ReadFile("./input/bias_gm.bin", biasFileSize, biasHost, biasFileSize);
        aclrtMemcpy(biasDevice, biasFileSize, biasHost, biasFileSize, ACL_MEMCPY_HOST_TO_DEVICE);
    }

    uint8_t* cHost;
    uint8_t* cDevice;
    aclrtMallocHost((void**)(&cHost), cFileSize);
    aclrtMalloc((void**)&cDevice, cFileSize, ACL_MEM_MALLOC_HUGE_FIRST);

    mmad_custom<M, N, K><<<numBlocks, nullptr, stream>>>(aDevice, bDevice, biasDevice, cDevice);
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(cHost, cFileSize, cDevice, cFileSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", cHost, cFileSize);

    aclrtFree(aDevice);
    aclrtFreeHost(aHost);
    aclrtFree(bDevice);
    aclrtFreeHost(bHost);
    if constexpr (HAS_BIAS_TENSOR) {
        aclrtFree(biasDevice);
        aclrtFreeHost(biasHost);
    }
    aclrtFree(cDevice);
    aclrtFreeHost(cHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();
    return 0;
}