/* !
 * \file move_reg_scenario_2.asc
 * \brief 场景2：复合计算场景 - Select掩码选择计算
 */

#include "acl/acl.h"
#include "kernel_operator.h"
#include "data_utils.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

__aicore__ __inline__ constexpr uint32_t DivCeil(uint32_t a, uint32_t b) { return (a + b - 1) / b; }

template <typename T>
__simd_vf__ inline void SelectVF(
    __ubuf__ T* xAddr, __ubuf__ T* yAddr, __ubuf__ T* maskAddr, __ubuf__ T* zAddr, uint32_t repeatTimes,
    uint32_t oneRepeatSize, uint32_t maskRepeatSize)
{
    AscendC::Reg::RegTensor<T> xReg;
    AscendC::Reg::RegTensor<T> yReg;
    AscendC::Reg::RegTensor<T> mReg;
    AscendC::Reg::MaskReg maskReg = AscendC::Reg::CreateMask<T>();
    AscendC::Reg::UnalignRegForLoad ureg;
    AscendC::Reg::RegTensor<T> zReg;
    AscendC::Reg::MaskReg storeMask = AscendC::Reg::CreateMask<T, AscendC::Reg::MaskPattern::ALL>();

    AscendC::Reg::LoadUnAlignPre(ureg, maskAddr);
    for (uint16_t i = 0; i < repeatTimes; ++i) {
        AscendC::Reg::LoadAlign<T, AscendC::Reg::PostLiteral::POST_MODE_UPDATE>(xReg, xAddr, oneRepeatSize);
        AscendC::Reg::LoadAlign<T, AscendC::Reg::PostLiteral::POST_MODE_UPDATE>(yReg, yAddr, oneRepeatSize);
        AscendC::Reg::LoadUnAlign(mReg, ureg, maskAddr, maskRepeatSize);
        AscendC::Reg::MaskGenWithRegTensor<T, 0>(maskReg, mReg);
        AscendC::Reg::Select(zReg, xReg, yReg, maskReg);
        AscendC::Reg::StoreAlign<T, AscendC::Reg::PostLiteral::POST_MODE_UPDATE>(zAddr, zReg, oneRepeatSize, storeMask);
    }
}

template <typename T, uint32_t totalLength, uint32_t maskLength>
class KernelScenario2 {
public:
    __aicore__ inline void Init(__gm__ uint8_t* x, __gm__ uint8_t* y, __gm__ uint8_t* mask, __gm__ uint8_t* z)
    {
        this->xGm.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(x));
        this->yGm.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(y));
        this->maskGm.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(mask));
        this->zGm.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(z));
    }

    __aicore__ inline void Process()
    {
        AscendC::LocalMemAllocator<AscendC::Hardware::UB> ubAllocator;
        AscendC::LocalTensor<T> xLocal = ubAllocator.Alloc<T, totalLength>();
        AscendC::LocalTensor<T> yLocal = ubAllocator.Alloc<T, totalLength>();
        AscendC::LocalTensor<T> maskLocal = ubAllocator.Alloc<T, maskLength>();
        AscendC::LocalTensor<T> zLocal = ubAllocator.Alloc<T, totalLength>();

        AscendC::DataCopy(xLocal, xGm, totalLength);
        AscendC::DataCopy(yLocal, yGm, totalLength);
        AscendC::DataCopy(maskLocal, maskGm, maskLength);
        AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);

        __ubuf__ T* xAddr = reinterpret_cast<__ubuf__ T*>(xLocal.GetPhyAddr());
        __ubuf__ T* yAddr = reinterpret_cast<__ubuf__ T*>(yLocal.GetPhyAddr());
        __ubuf__ T* maskAddr = reinterpret_cast<__ubuf__ T*>(maskLocal.GetPhyAddr());
        __ubuf__ T* zAddr = reinterpret_cast<__ubuf__ T*>(zLocal.GetPhyAddr());
        constexpr uint32_t oneRepeatSize = AscendC::GetVecLen() / sizeof(T);
        constexpr uint32_t maskRepeatSize = oneRepeatSize / (sizeof(T) * 8);
        uint16_t repeatTimes = DivCeil(totalLength, oneRepeatSize);
        asc_vf_call<SelectVF<T>>(xAddr, yAddr, maskAddr, zAddr, repeatTimes, oneRepeatSize, maskRepeatSize);

        AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);

        AscendC::DataCopy(zGm, zLocal, totalLength);
    }

private:
    AscendC::GlobalTensor<T> xGm;
    AscendC::GlobalTensor<T> yGm;
    AscendC::GlobalTensor<T> maskGm;
    AscendC::GlobalTensor<T> zGm;
};

template <typename T, uint32_t totalLength, uint32_t maskLength>
__global__ __vector__ void move_reg_scenario_2(
    __gm__ uint8_t* x, __gm__ uint8_t* y, __gm__ uint8_t* mask, __gm__ uint8_t* z)
{
    AscendC::InitSocState();
    KernelScenario2<T, totalLength, maskLength> kernel;
    kernel.Init(x, y, mask, z);
    kernel.Process();
    AscendC::PipeBarrier<PIPE_ALL>();
}

static bool CompareResult(const void* outputData, uint32_t outSize)
{
    void* goldenData;
    aclrtMallocHost((void**)(&goldenData), outSize);
    size_t goldenSize = outSize;

    bool ret = ReadFile("./output/golden.bin", goldenSize, goldenData, goldenSize);
    if (ret) {
        printf("ReadFile golden.bin success!\n");
    } else {
        printf("test failed!\n");
        aclrtFreeHost(goldenData);
        return false;
    }

    constexpr float EPS = 1e-4;
    int64_t wrongNum = 0;

    for (size_t i = 0; i < outSize / sizeof(float); i++) {
        float a = (reinterpret_cast<const float*>(outputData))[i];
        float b = (reinterpret_cast<const float*>(goldenData))[i];
        float ae = std::abs(a - b);
        float re = ae / std::abs(b + EPS);
        if (ae > EPS && re > EPS) {
            printf("CompareResult golden.bin failed output is %lf, golden is %lf\n", a, b);
            wrongNum++;
        }
    }

    aclrtFreeHost(goldenData);
    if (wrongNum != 0) {
        return false;
    } else {
        printf("CompareResult golden.bin success!\n");
        return true;
    }
}

int32_t main(int32_t argc, char* argv[])
{
    uint32_t numBlocks = 1;
    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    constexpr uint32_t totalLength = 256;
    constexpr uint32_t maskLength = 32;
    size_t inputByteSize = static_cast<size_t>(1) * totalLength * sizeof(float);
    size_t maskByteSize = static_cast<size_t>(1) * maskLength * sizeof(float);
    size_t outputByteSize = static_cast<size_t>(1) * totalLength * sizeof(float);

    uint8_t *xHost, *yHost, *maskHost, *zHost;
    uint8_t *xDevice, *yDevice, *maskDevice, *zDevice;
    aclrtMallocHost((void**)(&xHost), inputByteSize);
    aclrtMallocHost((void**)(&yHost), inputByteSize);
    aclrtMallocHost((void**)(&maskHost), maskByteSize);
    aclrtMallocHost((void**)(&zHost), outputByteSize);
    aclrtMalloc((void**)&xDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&yDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&maskDevice, maskByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&zDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);

    ReadFile("./input/input_x.bin", inputByteSize, xHost, inputByteSize);
    ReadFile("./input/input_y.bin", inputByteSize, yHost, inputByteSize);
    ReadFile("./input/input_mask.bin", maskByteSize, maskHost, maskByteSize);
    aclrtMemcpy(xDevice, inputByteSize, xHost, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(yDevice, inputByteSize, yHost, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(maskDevice, maskByteSize, maskHost, maskByteSize, ACL_MEMCPY_HOST_TO_DEVICE);

    move_reg_scenario_2<float, totalLength, maskLength>
        <<<numBlocks, nullptr, stream>>>(xDevice, yDevice, maskDevice, zDevice);
    aclrtSynchronizeStream(stream);
    aclrtMemcpy(zHost, outputByteSize, zDevice, outputByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", zHost, outputByteSize);

    bool goldenResult = CompareResult(zHost, outputByteSize);
    if (goldenResult) {
        printf("test pass!\n");
    } else {
        printf("test failed!\n");
    }

    aclrtFree(xDevice);
    aclrtFree(yDevice);
    aclrtFree(maskDevice);
    aclrtFree(zDevice);
    aclrtFreeHost(xHost);
    aclrtFreeHost(yHost);
    aclrtFreeHost(maskHost);
    aclrtFreeHost(zHost);
    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();
    return 0;
}