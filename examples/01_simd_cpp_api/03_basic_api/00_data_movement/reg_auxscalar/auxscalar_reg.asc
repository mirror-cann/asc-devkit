/* !
 * \file auxscalar_reg.asc
 * \brief 演示使用AuxScalar方式从UB读取标量数据，结合Reg::Adds进行向量与标量加法计算，
 *        并使用Reg::StoreAlign写回UB
 */

#include "acl/acl.h"
#include "kernel_operator.h"
#include "data_utils.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

constexpr uint32_t totalLength = 512;

template <typename T>
__simd_vf__ inline void AuxScalarAddsVF(
    __ubuf__ T* xAddr, __ubuf__ T* scalarAddr, __ubuf__ T* zAddr, uint32_t repeatTimes, uint32_t oneRepeatSize)
{
    AscendC::Reg::RegTensor<T> xReg;
    AscendC::Reg::RegTensor<T> zReg;
    AscendC::Reg::MaskReg mask = AscendC::Reg::CreateMask<T, AscendC::Reg::MaskPattern::ALL>();

    // 使用PostUpdate模式，LoadAlign/StoreAlign执行后自动更新地址指针
    for (uint16_t i = 0; i < repeatTimes; ++i) {
        // 通过AuxScalar方式从UB读取标量：直接使用__ubuf__指针下标访问
        T scalar = scalarAddr[i];
        // LoadAlign PostUpdate: 加载后xAddr自动 += oneRepeatSize
        AscendC::Reg::LoadAlign<T, AscendC::Reg::PostLiteral::POST_MODE_UPDATE>(xReg, xAddr, oneRepeatSize);
        AscendC::Reg::Adds(zReg, xReg, scalar, mask);
        // StoreAlign PostUpdate: 写出后zAddr自动 += oneRepeatSize
        AscendC::Reg::StoreAlign<T, AscendC::Reg::PostLiteral::POST_MODE_UPDATE>(zAddr, zReg, oneRepeatSize, mask);
    }
}

template <typename T, uint32_t singleCoreLength>
class KernelAuxScalar {
public:
    __aicore__ inline void Init(__gm__ uint8_t* x, __gm__ uint8_t* scalar, __gm__ uint8_t* z)
    {
        xGm.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(x));
        scalarGm.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(scalar));
        zGm.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(z));
    }

    __aicore__ inline void Process()
    {
        AscendC::LocalMemAllocator<AscendC::Hardware::UB> ubAllocator;
        AscendC::LocalTensor<T> xLocal = ubAllocator.Alloc<T, singleCoreLength>();
        AscendC::LocalTensor<T> scalarLocal = ubAllocator.Alloc<T, 16>(); // 4个scalar + padding，32字节对齐
        AscendC::LocalTensor<T> zLocal = ubAllocator.Alloc<T, singleCoreLength>();

        // CopyIn: GM -> UB（scalar数据需32字节对齐，16个half = 32字节）
        constexpr uint32_t scalarAlignCount = 16;
        AscendC::DataCopy(xLocal, xGm, singleCoreLength);
        AscendC::DataCopy(scalarLocal, scalarGm, scalarAlignCount);
        AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);

        __ubuf__ T* xAddr = reinterpret_cast<__ubuf__ T*>(xLocal.GetPhyAddr());
        __ubuf__ T* scalarAddr = reinterpret_cast<__ubuf__ T*>(scalarLocal.GetPhyAddr());
        __ubuf__ T* zAddr = reinterpret_cast<__ubuf__ T*>(zLocal.GetPhyAddr());
        constexpr uint32_t oneRepeatSize = AscendC::GetVecLen() / sizeof(T);
        uint16_t repeatTimes = AscendC::CeilDivision(singleCoreLength, oneRepeatSize);

        // Compute: AuxScalar方式读取4个UB标量 + Adds计算 + StoreAlign PostUpdate写回
        asc_vf_call<AuxScalarAddsVF<T>>(xAddr, scalarAddr, zAddr, repeatTimes, oneRepeatSize);

        AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);

        // CopyOut: UB -> GM
        AscendC::DataCopy(zGm, zLocal, singleCoreLength);
    }

private:
    AscendC::GlobalTensor<T> xGm;
    AscendC::GlobalTensor<T> scalarGm;
    AscendC::GlobalTensor<T> zGm;
};

__global__ __vector__ void auxscalar_reg(__gm__ uint8_t* x, __gm__ uint8_t* scalar, __gm__ uint8_t* z)
{
    AscendC::InitSocState();
    constexpr uint32_t singleCoreLength = totalLength;
    KernelAuxScalar<half, singleCoreLength> kernel;
    kernel.Init(x, scalar, z);
    kernel.Process();
    AscendC::PipeBarrier<PIPE_ALL>();
}

static bool CompareResult(const void* outputData, const void* goldenData, uint32_t outSize)
{
    int64_t wrongNum = 0;
    size_t count = outSize / sizeof(uint16_t);
    for (size_t i = 0; i < count; i++) {
        uint16_t a = (reinterpret_cast<const uint16_t*>(outputData))[i];
        uint16_t b = (reinterpret_cast<const uint16_t*>(goldenData))[i];
        if (a != b) {
            printf("CompareResult failed at %zu: output=0x%04x, golden=0x%04x\n", i, a, b);
            wrongNum++;
        }
        if (wrongNum > 10) {
            printf("... (too many errors, truncated)\n");
            break;
        }
    }
    if (wrongNum != 0) {
        return false;
    } else {
        printf("CompareResult success!\n");
        return true;
    }
}

int32_t main(int32_t argc, char* argv[])
{
    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);
    uint32_t numBlocks = 1;

    size_t xByteSize = totalLength * sizeof(half);
    size_t scalarByteSize = 16 * sizeof(half); // 16个half = 32字节，满足DataCopy对齐要求
    size_t zByteSize = totalLength * sizeof(half);
    uint8_t *xHost, *scalarHost, *zHost;
    uint8_t *xDevice, *scalarDevice, *zDevice;
    aclrtMallocHost((void**)(&xHost), xByteSize);
    aclrtMallocHost((void**)(&scalarHost), scalarByteSize);
    aclrtMallocHost((void**)(&zHost), zByteSize);
    aclrtMalloc((void**)&xDevice, xByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&scalarDevice, scalarByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&zDevice, zByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    size_t xFileSize = xByteSize;
    size_t scalarFileSize = scalarByteSize;
    ReadFile("./input/input_x.bin", xFileSize, xHost, xByteSize);
    ReadFile("./input/input_y.bin", scalarFileSize, scalarHost, scalarByteSize);
    aclrtMemcpy(xDevice, xByteSize, xHost, xByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(scalarDevice, scalarByteSize, scalarHost, scalarByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
    auxscalar_reg<<<numBlocks, nullptr, stream>>>(xDevice, scalarDevice, zDevice);
    aclrtSynchronizeStream(stream);
    aclrtMemcpy(zHost, zByteSize, zDevice, zByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", zHost, zByteSize);
    void* golden;
    aclrtMallocHost((void**)(&golden), zByteSize);
    size_t goldenSize = zByteSize;
    ReadFile("./output/golden.bin", goldenSize, golden, zByteSize);
    bool result = CompareResult(zHost, golden, zByteSize);
    aclrtFreeHost(golden);
    if (result) {
        printf("test pass!\n");
    } else {
        printf("test failed!\n");
    }
    aclrtFree(xDevice);
    aclrtFree(scalarDevice);
    aclrtFree(zDevice);
    aclrtFreeHost(xHost);
    aclrtFreeHost(scalarHost);
    aclrtFreeHost(zHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();
    return 0;
}
