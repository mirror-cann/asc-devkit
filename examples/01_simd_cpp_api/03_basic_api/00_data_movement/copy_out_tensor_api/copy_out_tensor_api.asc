/* !
 * \file copy_out_tensor_api.asc
 * \brief copy_out_tensor_api
 */

#include "acl/acl.h"
#include "tensor_api/tensor.h"
#include "basic_api/kernel_basic_intf.h"
#include "basic_api/kernel_operator_block_sync_intf.h"
#include "data_utils.h"

struct MatmulTiling {
    int32_t m;
    int32_t n;
    int32_t k;
    int32_t singleCoreM;
    int32_t singleCoreN;
    int32_t singleCoreK;
};

struct CoreIterInfo {
    uint32_t mIter;
    uint32_t mIterIdx;
    uint32_t nIterIdx;
    int32_t actualSingleCoreM;
    int32_t actualSingleCoreN;
};

// Custom CopyL0C2UBTrait parameters used only for L0C to UB copies
constexpr AscendC::Te::DualDstMode gDualDstMode =
    (SCENARIO_NUM == 3) ? AscendC::Te::DualDstMode::DUAL_DST_SPLIT_N : AscendC::Te::DualDstMode::DUAL_DST_SPLIT_M;
constexpr AscendC::Te::CopyL0C2UBTrait COPY_L0C2UB_TRAIT =
    AscendC::Te::CopyL0C2UBTrait{AscendC::Te::RoundMode::DEFAULT, false, false, gDualDstMode};
struct CopyL0C2UBTraitCustom {
    using TraitType = AscendC::Te::CopyL0C2UBTrait;
    static constexpr const TraitType value = COPY_L0C2UB_TRAIT;
};

// Copy tiling information from GM to a local struct
__aicore__ inline void CopyTilingFromGM(__gm__ MatmulTiling* srcInfo, MatmulTiling& dstInfo)
{
    auto srcPtr = reinterpret_cast<__gm__ int32_t*>(srcInfo);
    auto dstPtr = reinterpret_cast<int32_t*>(&dstInfo);
    for (size_t i = 0; i < sizeof(MatmulTiling) / sizeof(int32_t); ++i) {
        dstPtr[i] = srcPtr[i];
    }
}

// Calculate iteration information for the current core from tiling parameters and the core index
__aicore__ inline CoreIterInfo CalcCoreIterInfo(const MatmulTiling& tiling)
{
    uint32_t mIter = (tiling.m + tiling.singleCoreM - 1) / tiling.singleCoreM;
    auto blockIdx = AscendC::GetBlockIdx();
    if ASCEND_IS_AIV {
        blockIdx /= 2;
    }
    uint32_t mIterIdx = blockIdx % mIter;
    uint32_t nIterIdx = blockIdx / mIter;
    int32_t actualSingleCoreM = tiling.m - mIterIdx * tiling.singleCoreM;
    actualSingleCoreM = actualSingleCoreM < tiling.singleCoreM ? actualSingleCoreM : tiling.singleCoreM;
    int32_t actualSingleCoreN = tiling.n - nIterIdx * tiling.singleCoreN;
    actualSingleCoreN = actualSingleCoreN < tiling.singleCoreN ? actualSingleCoreN : tiling.singleCoreN;
    return {mIter, mIterIdx, nIterIdx, actualSingleCoreM, actualSingleCoreN};
}

template <
    typename A_TYPE, typename B_TYPE, typename C_TYPE, typename BIAS_TYPE, int32_t baseM, int32_t baseN, int32_t baseK,
    int32_t stepM, int32_t stepN, int32_t stepK>
__global__ __mix__(1, 2) void copy_out_tensor_api(
    __gm__ A_TYPE* x, __gm__ B_TYPE* y, __gm__ C_TYPE* z, __gm__ BIAS_TYPE* bias, __gm__ MatmulTiling* tilingInfo)
{
    AscendC::InitSocState();
    using namespace AscendC::Te;

    // 1. Copy tiling information from GM
    MatmulTiling tiling;
    CopyTilingFromGM(tilingInfo, tiling);

    // 2. Get SCENARIO_NUM
    constexpr uint32_t scenarioNum = SCENARIO_NUM;

    // 3. Calculate iteration information for the current core
    CoreIterInfo iterInfo = CalcCoreIterInfo(tiling);

    int32_t m = tiling.m;
    int32_t n = tiling.n;
    int32_t k = tiling.k;
    int32_t singleCoreM = tiling.singleCoreM;
    int32_t singleCoreN = tiling.singleCoreN;
    int32_t singleCoreK = tiling.singleCoreK;

    // 4. Create GM tensors and slices
    auto gmPtrA = MakeMemPtr(x);
    auto gmPtrB = MakeMemPtr(y);
    auto gmPtrC = MakeMemPtr(z);
    auto gmPtrBias = MakeMemPtr(bias);

    auto gmA = MakeTensor(gmPtrA, MakeFrameLayout<NDExtLayoutPtn>(m, k));
    auto gmB = MakeTensor(gmPtrB, MakeFrameLayout<NDExtLayoutPtn>(k, n));
    auto gmC = MakeTensor(gmPtrC, MakeFrameLayout<NDExtLayoutPtn>(m, n));
    auto gmBias = MakeTensor(gmPtrBias, MakeFrameLayout<NDExtLayoutPtn>(1, n));

    // Slice the current single-core data block from the complete GM tensors.
    auto globalA =
        gmA.Slice(MakeCoord(iterInfo.mIterIdx * singleCoreM, 0), MakeShape(iterInfo.actualSingleCoreM, singleCoreK));
    auto globalB =
        gmB.Slice(MakeCoord(0, iterInfo.nIterIdx * singleCoreN), MakeShape(singleCoreK, iterInfo.actualSingleCoreN));
    auto globalC = gmC.Slice(
        MakeCoord(iterInfo.mIterIdx * singleCoreM, iterInfo.nIterIdx * singleCoreN),
        MakeShape(iterInfo.actualSingleCoreM, iterInfo.actualSingleCoreN));
    auto globalBias =
        gmBias.Slice(MakeCoord(0, iterInfo.nIterIdx * singleCoreN), MakeShape(1, iterInfo.actualSingleCoreN));
    // 5. Create L1 tensors
    auto l1ALayout = MakeFrameLayout<NZLayoutPtn, A_TYPE>(baseM * stepM, baseK * stepK);
    auto l1BLayout = MakeFrameLayout<NZLayoutPtn, B_TYPE>(baseK * stepK, baseN * stepN);
    auto l1BiasLayout = MakeFrameLayout<NDExtLayoutPtn>(1, baseN * stepN);
    auto ubLayout = MakeFrameLayout<NDExtLayoutPtn>(iterInfo.actualSingleCoreM, iterInfo.actualSingleCoreN);

    __cbuf__ A_TYPE l1ABuf[baseM * stepM * baseK * stepK];
    __cbuf__ B_TYPE l1BBuf[baseK * stepK * baseN * stepN];
    __cbuf__ BIAS_TYPE l1BiasBuf[baseN * stepN];
    __ca__ A_TYPE l0ABuf[baseM * baseK];
    __cb__ B_TYPE l0BBuf[baseK * baseN];
    __biasbuf__ BIAS_TYPE l0BiasBuf[baseN];
    __cc__ C_TYPE l0CBuf[baseM * baseN];
    __ubuf__ C_TYPE ubBuf[baseM * stepM * baseN * stepN / 2];

    auto l1APtr = MakeMemPtr(l1ABuf);
    auto l1BPtr = MakeMemPtr(l1BBuf);
    auto l1BiasPtr = MakeMemPtr(l1BiasBuf);
    auto l0APtr = MakeMemPtr(l0ABuf);
    auto l0BPtr = MakeMemPtr(l0BBuf);
    auto l0BiasPtr = MakeMemPtr(l0BiasBuf);
    auto l0CPtr = MakeMemPtr(l0CBuf);
    auto ubPtr = MakeMemPtr(ubBuf);

    auto l1ATensor = MakeTensor(l1APtr, l1ALayout);
    auto l1BTensor = MakeTensor(l1BPtr, l1BLayout);
    auto l1BiasTensor = MakeTensor(l1BiasPtr, l1BiasLayout);
    auto ubTensor = MakeTensor(ubPtr, ubLayout);
    auto copyGM2L1Atom = MakeCopy(CopyGM2L1{}, CopyGM2L1TraitDefault{});
    auto copyL12BTAtom = MakeCopy(CopyL12BT{}, CopyL12BTTraitDefault{});
    auto copyL12L0AAtom = MakeCopy(CopyL12L0A{}, CopyL12L0ATraitDefault{});
    auto copyL12L0BAtom = MakeCopy(CopyL12L0B{}, CopyL12L0BTraitDefault{});
    auto copyL0C2GMAtom = MakeCopy(CopyL0C2GM{}, CopyL0C2GMTraitDefault{});
    auto copyL0C2UBAtom = MakeCopy(CopyL0C2UB{}, CopyL0C2UBTraitCustom{});
    auto copyUB2GMAtom = MakeCopy(CopyUB2GM{}, CopyUB2GMTraitDefault{});
    auto mmadAtom = MakeMmad(MmadOperation{}, MmadTraitDefault{});

    // 6. Calculate loop counts
    uint32_t mLoop = (iterInfo.actualSingleCoreM + baseM - 1) / baseM;
    uint32_t nLoop = (iterInfo.actualSingleCoreN + baseN - 1) / baseN;
    uint32_t kLoop = (singleCoreK + baseK - 1) / baseK;
    uint32_t tileM = (iterInfo.actualSingleCoreM % baseM != 0) ? iterInfo.actualSingleCoreM % baseM : baseM;
    uint32_t tileN = (iterInfo.actualSingleCoreN % baseN != 0) ? iterInfo.actualSingleCoreN % baseN : baseN;
    uint32_t tileK = (singleCoreK % baseK != 0) ? singleCoreK % baseK : baseK;

    if ASCEND_IS_AIC {
        AscendC::SetFlag<AscendC::HardEvent::MTE1_MTE2>(EVENT_ID0);
        AscendC::SetFlag<AscendC::HardEvent::M_MTE1>(EVENT_ID0);
        AscendC::SetFlag<AscendC::HardEvent::FIX_M>(EVENT_ID0);
        AscendC::SetFlag<AscendC::HardEvent::MTE1_MTE2>(EVENT_ID1);
        AscendC::SetFlag<AscendC::HardEvent::M_MTE1>(EVENT_ID1);

        // 7. Main compute loop
        for (uint32_t i = 0; i < mLoop; i++) {
            uint16_t curM = (i + 1 == mLoop) ? tileM : baseM;
            for (uint32_t j = 0; j < nLoop; j++) {
                uint16_t curN = (j + 1 == nLoop) ? tileN : baseN;
                auto l0CLayout = MakeFrameLayout<NZLayoutPtn>(curM, curN);
                auto l0BiasLayout = MakeFrameLayout<NDExtLayoutPtn>(1, curN);
                auto l0CTensor = MakeTensor(l0CPtr, l0CLayout);
                auto l0BiasTensor = MakeTensor(l0BiasPtr, l0BiasLayout);

                // Move bias along the N dimension to L1 and then L0 for the first Mmad of this N tile
                AscendC::WaitFlag<AscendC::HardEvent::MTE1_MTE2>(EVENT_ID1);
                Copy(copyGM2L1Atom, l1BiasTensor, globalBias.Slice(MakeCoord(0, j * baseN), MakeShape(1, curN)));
                AscendC::SetFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID1);
                AscendC::WaitFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID1);
                AscendC::WaitFlag<AscendC::HardEvent::M_MTE1>(EVENT_ID1);
                Copy(copyL12BTAtom, l0BiasTensor, l1BiasTensor.Slice(MakeCoord(0, 0), MakeShape(1, curN)));
                AscendC::SetFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID1);
                AscendC::SetFlag<AscendC::HardEvent::MTE1_MTE2>(EVENT_ID1);

                for (uint32_t kIter = 0; kIter < kLoop; kIter++) {
                    uint16_t curK = (kIter + 1 == kLoop) ? tileK : baseK;
                    auto l0ALayout = MakeFrameLayout<NZLayoutPtn, A_TYPE>(curM, curK);
                    auto l0BLayout = MakeFrameLayout<ZNLayoutPtn, B_TYPE>(curK, curN);
                    auto l0ATensor = MakeTensor(l0APtr, l0ALayout);
                    auto l0BTensor = MakeTensor(l0BPtr, l0BLayout);

                    // GM -> L1
                    if (kIter % stepK == 0) {
                        uint16_t curStepK = static_cast<uint16_t>(singleCoreK - kIter * baseK);
                        curStepK = curStepK < baseK * stepK ? curStepK : baseK * stepK;
                        AscendC::WaitFlag<AscendC::HardEvent::MTE1_MTE2>(EVENT_ID0);
                        Copy(
                            copyGM2L1Atom, l1ATensor,
                            globalA.Slice(MakeCoord(i * baseM, kIter * baseK), MakeShape(curM, curStepK)));
                        Copy(
                            copyGM2L1Atom, l1BTensor,
                            globalB.Slice(MakeCoord(kIter * baseK, j * baseN), MakeShape(curStepK, curN)));
                        AscendC::SetFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID0);
                        AscendC::WaitFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID0);
                    }

                    // L1 -> L0
                    AscendC::WaitFlag<AscendC::HardEvent::M_MTE1>(EVENT_ID0);
                    Copy(
                        copyL12L0AAtom, l0ATensor,
                        l1ATensor.Slice(MakeCoord(0, kIter % stepK * baseK), MakeShape(curM, curK)));
                    Copy(
                        copyL12L0BAtom, l0BTensor,
                        l1BTensor.Slice(MakeCoord(kIter % stepK * baseK, 0), MakeShape(curK, curN)));
                    if ((kIter + 1) % stepK == 0 || kIter + 1 == kLoop) {
                        AscendC::SetFlag<AscendC::HardEvent::MTE1_MTE2>(EVENT_ID0);
                    }
                    AscendC::SetFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID0);
                    AscendC::WaitFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID0);

                    if (kIter == 0) {
                        AscendC::WaitFlag<AscendC::HardEvent::FIX_M>(EVENT_ID0);
                    }

                    // Mmad compute
                    if (kIter == 0) {
                        AscendC::WaitFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID1);
                        Mmad(
                            mmadAtom.with(MmadParams(
                                curM, curN, curK, scenarioNum == 1 ? ((kIter == kLoop - 1) ? 3 : 2) : 0, true)),
                            l0CTensor, l0ATensor, l0BTensor, l0BiasTensor);
                        AscendC::SetFlag<AscendC::HardEvent::M_MTE1>(EVENT_ID1);
                    } else {
                        Mmad(
                            mmadAtom.with(MmadParams(
                                curM, curN, curK, scenarioNum == 1 ? ((kIter == kLoop - 1) ? 3 : 2) : 0, false)),
                            l0CTensor, l0ATensor, l0BTensor);
                    }
                    if (kIter == kLoop - 1) {
                        AscendC::SetFlag<AscendC::HardEvent::M_FIX>(EVENT_ID0);
                    }
                    AscendC::SetFlag<AscendC::HardEvent::M_MTE1>(EVENT_ID0);
                }

                AscendC::WaitFlag<AscendC::HardEvent::M_FIX>(EVENT_ID0);
                if constexpr (scenarioNum < 2) {
                    // L0C -> GM
                    FixpipeParams params;
                    if constexpr (scenarioNum == 1) {
                        params.unitFlag = 3;
                    }
                    Copy(
                        copyL0C2GMAtom.with(params),
                        globalC.Slice(MakeCoord(i * baseM, j * baseN), MakeShape(curM, curN)), l0CTensor);
                } else {
                    // L0C -> UB
                    if constexpr (scenarioNum == 2) {
                        // Split along the M dimension
                        Copy(
                            copyL0C2UBAtom, ubTensor.Slice(MakeCoord(i * baseM / 2, j * baseN), MakeShape(curM, curN)),
                            l0CTensor);
                    } else if constexpr (scenarioNum == 3) {
                        // Split along the N dimension
                        Copy(
                            copyL0C2UBAtom, ubTensor.Slice(MakeCoord(i * baseM, j * baseN / 2), MakeShape(curM, curN)),
                            l0CTensor);
                    }
                    AscendC::CrossCoreSetFlag<0x2, PIPE_FIX>(0x8);
                }
                AscendC::SetFlag<AscendC::HardEvent::FIX_M>(EVENT_ID0);
            }
        }

        AscendC::WaitFlag<AscendC::HardEvent::M_MTE1>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE1_MTE2>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::FIX_M>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE1_MTE2>(EVENT_ID1);
        AscendC::WaitFlag<AscendC::HardEvent::M_MTE1>(EVENT_ID1);
    }

    if ASCEND_IS_AIV {
        if constexpr (scenarioNum > 1) {
            for (uint32_t i = 0; i < mLoop; i++) {
                uint16_t curM = (i + 1 == mLoop) ? tileM : baseM;
                for (uint32_t j = 0; j < nLoop; j++) {
                    uint16_t curN = (j + 1 == nLoop) ? tileN : baseN;
                    AscendC::CrossCoreWaitFlag(0x8);
                    if constexpr (scenarioNum == 2) {
                        // Split along the M dimension
                        Copy(
                            copyUB2GMAtom,
                            globalC.Slice(
                                MakeCoord(i * baseM + AscendC::GetSubBlockIdx() * curM / 2, j * baseN),
                                MakeShape(curM / 2, curN)),
                            ubTensor.Slice(MakeCoord(i * baseM / 2, j * baseN), MakeShape(curM / 2, curN)));
                    } else if constexpr (scenarioNum == 3) {
                        // Split along the N dimension
                        Copy(
                            copyUB2GMAtom,
                            globalC.Slice(
                                MakeCoord(i * baseM, j * baseN + AscendC::GetSubBlockIdx() * curN / 2),
                                MakeShape(curM, curN / 2)),
                            ubTensor.Slice(MakeCoord(i * baseM, j * baseN / 2), MakeShape(curM, curN / 2)));
                    }
                }
            }
        }
    }
    AscendC::PipeBarrier<PIPE_ALL>();
}

int32_t main(int32_t argc, char* argv[])
{
    using A_TYPE = half;
    using B_TYPE = half;
    using C_TYPE = float;
    using BIAS_TYPE = float;

    // Tiling info filled into struct (dynamic at runtime)
    MatmulTiling tiling;
    tiling.m = 1024;
    tiling.n = 1024;
    tiling.k = 256;
    tiling.singleCoreM = 256;
    tiling.singleCoreN = 128;
    tiling.singleCoreK = 256;

    // Static tiling parameters (compile-time constants)
    constexpr int32_t BASE_M = 128;
    constexpr int32_t BASE_N = 128;
    constexpr int32_t BASE_K = 64;
    constexpr int32_t STEP_M = 1;
    constexpr int32_t STEP_N = 1;
    constexpr int32_t STEP_K = 4;

    constexpr uint32_t NUM_BLOCKS = 32;

    size_t param1FileSize = tiling.m * tiling.k * sizeof(A_TYPE);
    size_t param2FileSize = tiling.n * tiling.k * sizeof(B_TYPE);
    size_t param3FileSize = tiling.m * tiling.n * sizeof(C_TYPE);
    size_t param4FileSize = tiling.n * sizeof(BIAS_TYPE);

    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t *xHost, *yHost, *zHost, *biasHost;
    A_TYPE* xDevice;
    B_TYPE* yDevice;
    C_TYPE* zDevice;
    BIAS_TYPE* biasDevice;

    aclrtMallocHost((void**)(&xHost), param1FileSize);
    aclrtMallocHost((void**)(&yHost), param2FileSize);
    aclrtMallocHost((void**)(&zHost), param3FileSize);
    aclrtMallocHost((void**)(&biasHost), param4FileSize);
    aclrtMalloc((void**)&xDevice, param1FileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&yDevice, param2FileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&zDevice, param3FileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&biasDevice, param4FileSize, ACL_MEM_MALLOC_HUGE_FIRST);

    ReadFile("./input/input_x.bin", param1FileSize, xHost, param1FileSize);
    ReadFile("./input/input_y.bin", param2FileSize, yHost, param2FileSize);
    ReadFile("./input/bias.bin", param4FileSize, biasHost, param4FileSize);

    aclrtMemcpy(xDevice, param1FileSize, xHost, param1FileSize, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(yDevice, param2FileSize, yHost, param2FileSize, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(biasDevice, param4FileSize, biasHost, param4FileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    // Allocate and copy tiling info struct to device
    MatmulTiling* tilingHost;
    MatmulTiling* tilingDevice;
    aclrtMallocHost((void**)(&tilingHost), sizeof(MatmulTiling));
    aclrtMalloc((void**)&tilingDevice, sizeof(MatmulTiling), ACL_MEM_MALLOC_HUGE_FIRST);
    *tilingHost = tiling;
    aclrtMemcpy(tilingDevice, sizeof(MatmulTiling), tilingHost, sizeof(MatmulTiling), ACL_MEMCPY_HOST_TO_DEVICE);

    copy_out_tensor_api<A_TYPE, B_TYPE, C_TYPE, BIAS_TYPE, BASE_M, BASE_N, BASE_K, STEP_M, STEP_N, STEP_K>
        <<<NUM_BLOCKS, nullptr, stream>>>(xDevice, yDevice, zDevice, biasDevice, tilingDevice);
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(zHost, param3FileSize, zDevice, param3FileSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", zHost, param3FileSize);

    aclrtFree(xDevice);
    aclrtFree(yDevice);
    aclrtFree(zDevice);
    aclrtFree(biasDevice);
    aclrtFree(tilingDevice);
    aclrtFreeHost(xHost);
    aclrtFreeHost(yHost);
    aclrtFreeHost(zHost);
    aclrtFreeHost(biasHost);
    aclrtFreeHost(tilingHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();

    return 0;
}
