/* !
 * \file ld_st_reg_unalign.asc
 * \brief 演示LoadUnAlign和StoreUnAlign接口在多场景下的使用方法
 *        场景1：单核地址非对齐数据搬运
 *        场景2：多核地址非对齐、数据量非对齐数据搬运
 */

#include "acl/acl.h"
#include "kernel_operator.h"
#include "data_utils.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

constexpr uint32_t scenarioNum = SCENARIO_NUM;

// 场景1：单核Kernel
template <typename T, uint32_t count>
class KernelScenario1 {
public:
    __aicore__ inline void Init(__gm__ uint8_t* x, __gm__ uint8_t* y)
    {
        this->xGm.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(x));
        this->yGm.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(y));
    }

    __aicore__ inline void Process()
    {
        AscendC::LocalMemAllocator<AscendC::Hardware::UB> ubAllocator;
        AscendC::LocalTensor<T> xLocal = ubAllocator.Alloc<T>(count);
        AscendC::LocalTensor<T> yLocal = ubAllocator.Alloc<T>(count);

        AscendC::DataCopy(xLocal, xGm, count);
        AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);

        AscendC::Duplicate<T>(yLocal, 0, count);

        __ubuf__ T* srcAddr = reinterpret_cast<__ubuf__ T*>(xLocal.GetPhyAddr());
        __ubuf__ T* dstAddr = reinterpret_cast<__ubuf__ T*>(yLocal.GetPhyAddr());
        constexpr uint32_t oneRepeatSize = AscendC::GetVecLen() / sizeof(T);
        asc_vf_call<CopyVF>(dstAddr + 1, srcAddr + 1, oneRepeatSize);

        AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);

        AscendC::DataCopy(yGm, yLocal, count);
    }

    __simd_vf__ static inline void CopyVF(__ubuf__ T* dstAddr, __ubuf__ T* srcAddr, uint16_t oneRepeatSize)
    {
        AscendC::Reg::RegTensor<T> srcReg, dstReg;
        AscendC::Reg::UnalignRegForLoad ureg0;
        AscendC::Reg::UnalignRegForStore ureg1;

        AscendC::Reg::LoadUnAlignPre(ureg0, srcAddr);
        for (uint16_t i = 0; i < 2; ++i) {
            AscendC::Reg::LoadUnAlign(srcReg, ureg0, srcAddr, oneRepeatSize);
            AscendC::Reg::StoreUnAlign(dstAddr, srcReg, ureg1, oneRepeatSize);
        }
        AscendC::Reg::StoreUnAlignPost(dstAddr, ureg1, 0);
    }

private:
    AscendC::GlobalTensor<T> xGm;
    AscendC::GlobalTensor<T> yGm;
};

// 场景2：多核Kernel
template <typename T, uint32_t totalM, uint32_t singleCoreM, uint32_t inputN, uint32_t outputN>
class KernelScenario2 {
public:
    __aicore__ inline void Init(__gm__ uint8_t* x, __gm__ uint8_t* y)
    {
        AscendC::InitSocState();
        xGm.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(x));
        yGm.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(y));

        constexpr uint32_t mIndex = (totalM + singleCoreM - 1) / singleCoreM;
        constexpr uint32_t tailSingleCoreM = totalM - (mIndex - 1) * singleCoreM;

        uint32_t blockIdx = AscendC::GetBlockIdx();
        if (blockIdx >= mIndex) {
            return;
        }

        actualSingleCoreM = (blockIdx == (mIndex - 1)) ? tailSingleCoreM : singleCoreM;
        xGm = xGm[blockIdx * singleCoreM * inputN];
        yGm = yGm[blockIdx * singleCoreM * outputN];

        // ub 要求32B对齐
        constexpr uint32_t alignSize = 32 / sizeof(T);
        inputSize = actualSingleCoreM * inputN;
        alignInputSize = AscendC::AlignUp(inputSize, alignSize);
        outputSize = actualSingleCoreM * outputN;
        alignOutputSize = AscendC::AlignUp(outputSize, alignSize);
    }

    __aicore__ inline void Process()
    {
        AscendC::LocalMemAllocator<AscendC::Hardware::UB> ubAllocator;
        AscendC::LocalTensor<T> xLocal = ubAllocator.Alloc<T>(alignInputSize);
        AscendC::LocalTensor<T> yLocal = ubAllocator.Alloc<T>(alignOutputSize);

        uint32_t blockLen = inputSize * sizeof(T);
        AscendC::DataCopyExtParams copyParams = {1, blockLen, 0, 0, 0};
        uint8_t rpad = alignInputSize - inputSize;
        AscendC::DataCopyPadExtParams<T> padParams = {false, 0, rpad, 0};
        AscendC::DataCopyPad<T>(xLocal, xGm, copyParams, padParams);

        AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);

        __ubuf__ T* srcAddr = reinterpret_cast<__ubuf__ T*>(xLocal.GetPhyAddr());
        __ubuf__ T* dstAddr = reinterpret_cast<__ubuf__ T*>(yLocal.GetPhyAddr());

        constexpr uint32_t oneRepeatInputSize = AscendC::GetVecLen() / sizeof(T);
        // 每个DataBlock大小为32B
        constexpr uint32_t oneRepeatOutputSize = AscendC::GetVecLen() / 32;
        uint16_t repeatTimes = AscendC::CeilDivision(inputN, oneRepeatInputSize);

        for (uint32_t m = 0; m < actualSingleCoreM; ++m) {
            asc_vf_call<ReduceDataBlockVF>(
                dstAddr + m * outputN, srcAddr + m * inputN, inputN, oneRepeatInputSize, oneRepeatOutputSize,
                repeatTimes);
        }

        AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);

        AscendC::DataCopy(yGm, yLocal, outputSize);
    }

    __simd_vf__ static inline void ReduceDataBlockVF(
        __ubuf__ T* dstAddr, __ubuf__ T* srcAddr, uint32_t inputSize, uint32_t oneRepeatInputSize,
        uint32_t oneRepeatOutputSize, uint32_t repeatTimes)
    {
        AscendC::Reg::RegTensor<T> srcReg;
        AscendC::Reg::RegTensor<T> dstReg;
        AscendC::Reg::UnalignRegForLoad uregLoad;
        AscendC::Reg::UnalignRegForStore uregStore;
        AscendC::Reg::MaskReg mask;

        AscendC::Reg::LoadUnAlignPre(uregLoad, srcAddr);
        for (uint16_t i = 0; i < repeatTimes; ++i) {
            mask = AscendC::Reg::UpdateMask<T>(inputSize);
            AscendC::Reg::LoadUnAlign(srcReg, uregLoad, srcAddr, oneRepeatInputSize);
            AscendC::Reg::ReduceDataBlock<AscendC::Reg::ReduceType::MAX>(dstReg, srcReg, mask);
            AscendC::Reg::StoreUnAlign(dstAddr, dstReg, uregStore, oneRepeatOutputSize);
        }
        AscendC::Reg::StoreUnAlignPost(dstAddr, uregStore, 0);
    }

private:
    AscendC::GlobalTensor<T> xGm;
    AscendC::GlobalTensor<T> yGm;
    uint32_t actualSingleCoreM;
    uint32_t inputSize;
    uint32_t alignInputSize;
    uint32_t outputSize;
    uint32_t alignOutputSize;
};

// 输入shape为[M, N]，M方向分核处理，N方向每DataBlock（即16个元素）ReduceMax为1个元素
template <typename T, uint32_t totalM, uint32_t singleCoreM, uint32_t inputN, uint32_t outputN>
__global__ __vector__ void ld_st_reg_unalign_kernel(__gm__ uint8_t* x, __gm__ uint8_t* y)
{
    AscendC::InitSocState();
    if constexpr (scenarioNum == 1) {
        KernelScenario1<T, inputN> kernel;
        kernel.Init(x, y);
        kernel.Process();
    } else if constexpr (scenarioNum == 2) {
        KernelScenario2<T, totalM, singleCoreM, inputN, outputN> kernel;
        kernel.Init(x, y);
        kernel.Process();
    }
    AscendC::PipeBarrier<PIPE_ALL>();
}

bool CompareResult(const void* outputData, uint32_t outSize)
{
    void* goldenData;
    aclrtMallocHost((void**)(&goldenData), outSize);
    size_t goldenSize = outSize;
    bool ret = ReadFile("./output/golden.bin", goldenSize, goldenData, goldenSize);
    if (!ret) {
        printf("ReadFile golden.bin failed!\n");
        aclrtFreeHost(goldenData);
        return false;
    }

    constexpr float EPS = 1e-3;
    int64_t wrongNum = 0;

    if constexpr (scenarioNum == 1) {
        const float* output = reinterpret_cast<const float*>(outputData);
        const float* golden = reinterpret_cast<const float*>(goldenData);
        uint32_t totalSize = outSize / sizeof(float);

        for (uint32_t i = 0; i < totalSize; ++i) {
            float a = output[i];
            float b = golden[i];
            if (std::abs(a - b) > EPS) {
                if (wrongNum < 5) {
                    printf("Mismatch at index %u: output=%f, golden=%f\n", i, a, b);
                }
                wrongNum++;
            }
        }
    } else if constexpr (scenarioNum == 2) {
        const uint16_t* output = reinterpret_cast<const uint16_t*>(outputData);
        const uint16_t* golden = reinterpret_cast<const uint16_t*>(goldenData);
        uint32_t totalSize = outSize / sizeof(uint16_t);

        for (uint32_t i = 0; i < totalSize; ++i) {
            if (output[i] != golden[i]) {
                if (wrongNum < 5) {
                    printf("Mismatch at index %u: output=%u, golden=%u\n", i, (uint32_t)output[i], (uint32_t)golden[i]);
                }
                wrongNum++;
            }
        }
    }

    aclrtFreeHost(goldenData);
    if (wrongNum == 0) {
        printf("test pass!\n");
        return true;
    } else {
        printf("test fail! wrong count: %ld\n", wrongNum);
        return false;
    }
}

int32_t main(int32_t argc, char* argv[])
{
    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint32_t numBlocks;
    size_t inputByteSize;
    size_t outputByteSize;
    if constexpr (scenarioNum == 1) {
        using DataType = float;
        constexpr uint32_t totalM = 1;
        constexpr uint32_t singleCoreM = 1;
        constexpr uint32_t inputN = 1024;
        constexpr uint32_t outputN = 1024;

        numBlocks = (totalM + singleCoreM - 1) / singleCoreM;
        inputByteSize = static_cast<size_t>(1) * totalM * inputN * sizeof(DataType);
        outputByteSize = static_cast<size_t>(1) * totalM * outputN * sizeof(DataType);
    } else {
        using DataType = uint16_t;
        constexpr uint32_t totalM = 14;
        constexpr uint32_t singleCoreM = 4;
        constexpr uint32_t inputN = 255;
        constexpr uint32_t outputN = 16;

        numBlocks = (totalM + singleCoreM - 1) / singleCoreM;
        inputByteSize = static_cast<size_t>(1) * totalM * inputN * sizeof(DataType);
        outputByteSize = static_cast<size_t>(1) * totalM * outputN * sizeof(DataType);
    }

    uint8_t* xHost;
    uint8_t* yHost;
    uint8_t* xDevice;
    uint8_t* yDevice;

    aclrtMallocHost((void**)(&xHost), inputByteSize);
    aclrtMallocHost((void**)(&yHost), outputByteSize);
    aclrtMalloc((void**)&xDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&yDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);

    ReadFile("./input/input_x.bin", inputByteSize, xHost, inputByteSize);
    aclrtMemcpy(xDevice, inputByteSize, xHost, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);

    if constexpr (scenarioNum == 1) {
        ld_st_reg_unalign_kernel<float, 1, 1, 1024, 1024><<<numBlocks, nullptr, stream>>>(xDevice, yDevice);
    } else {
        ld_st_reg_unalign_kernel<uint16_t, 14, 4, 255, 16><<<numBlocks, nullptr, stream>>>(xDevice, yDevice);
    }

    aclrtSynchronizeStream(stream);
    aclrtMemcpy(yHost, outputByteSize, yDevice, outputByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", yHost, outputByteSize);

    bool result = CompareResult(yHost, outputByteSize);

    aclrtFree(xDevice);
    aclrtFree(yDevice);
    aclrtFreeHost(xHost);
    aclrtFreeHost(yHost);
    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();

    return result ? 0 : 1;
}
