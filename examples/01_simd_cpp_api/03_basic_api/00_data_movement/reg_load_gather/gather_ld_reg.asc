/* !
 * \file gather_ld_reg.asc
 * \brief 演示使用Gather和GatherB接口实现离散数据搬入功能
 *        - 场景1：使用Gather接口（从UB按索引收集数据到RegTensor）
 *        - 场景2：使用GatherB接口（按DataBlock收集）
 */

#include "acl/acl.h"
#include "kernel_operator.h"
#include "data_utils.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

constexpr uint32_t totalLength = 128;
constexpr uint32_t srcLength = 1024;

#if SCENARIO_NUM == 1

template <typename T, typename IndexT>
__simd_vf__ inline void GatherVF(
    __ubuf__ T* dstAddr, __ubuf__ T* srcAddr, __ubuf__ IndexT* indexAddr, uint32_t count, uint32_t oneRepeatSize)
{
    AscendC::Reg::RegTensor<T> dstReg;
    AscendC::Reg::RegTensor<IndexT> indexReg;
    AscendC::Reg::MaskReg mask = AscendC::Reg::CreateMask<T, AscendC::Reg::MaskPattern::ALL>();
    uint16_t repeatTimes = AscendC::CeilDivision(count, oneRepeatSize);

    for (uint16_t i = 0; i < repeatTimes; ++i) {
        mask = AscendC::Reg::UpdateMask<T>(count);
        AscendC::Reg::LoadAlign(indexReg, indexAddr + i * oneRepeatSize);
        AscendC::Reg::Gather(dstReg, srcAddr, indexReg, mask);
        AscendC::Reg::StoreAlign(dstAddr + i * oneRepeatSize, dstReg, mask);
    }
}

template <typename T, typename IndexT, uint32_t singleCoreLength>
class KernelGather {
public:
    __aicore__ inline void Init(__gm__ uint8_t* src, __gm__ uint8_t* index, __gm__ uint8_t* dst)
    {
        srcGm.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(src));
        indexGm.SetGlobalBuffer(reinterpret_cast<__gm__ IndexT*>(index));
        dstGm.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(dst));
    }

    __aicore__ inline void Process()
    {
        AscendC::LocalMemAllocator<AscendC::Hardware::UB> ubAllocator;
        AscendC::LocalTensor<T> srcLocal = ubAllocator.Alloc<T, srcLength>();
        AscendC::LocalTensor<IndexT> indexLocal = ubAllocator.Alloc<IndexT, singleCoreLength>();
        AscendC::LocalTensor<T> dstLocal = ubAllocator.Alloc<T, singleCoreLength>();

        AscendC::DataCopy(srcLocal, srcGm, srcLength);
        AscendC::DataCopy(indexLocal, indexGm, singleCoreLength);
        AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);

        __ubuf__ T* srcAddr = reinterpret_cast<__ubuf__ T*>(srcLocal.GetPhyAddr());
        __ubuf__ IndexT* indexAddr = reinterpret_cast<__ubuf__ IndexT*>(indexLocal.GetPhyAddr());
        __ubuf__ T* dstAddr = reinterpret_cast<__ubuf__ T*>(dstLocal.GetPhyAddr());
        constexpr uint32_t oneRepeatSize = AscendC::GetVecLen() / sizeof(T);

        asc_vf_call<GatherVF<T, IndexT>>(dstAddr, srcAddr, indexAddr, singleCoreLength, oneRepeatSize);

        AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);

        AscendC::DataCopy(dstGm, dstLocal, singleCoreLength);
    }

private:
    AscendC::GlobalTensor<T> srcGm;
    AscendC::GlobalTensor<IndexT> indexGm;
    AscendC::GlobalTensor<T> dstGm;
};

__global__ __vector__ void gather_ld_reg(__gm__ uint8_t* src, __gm__ uint8_t* index, __gm__ uint8_t* dst)
{
    AscendC::InitSocState();
    constexpr uint32_t singleCoreLength = totalLength;
    KernelGather<half, uint16_t, singleCoreLength> kernel;
    kernel.Init(src, index, dst);
    kernel.Process();
    AscendC::PipeBarrier<PIPE_ALL>();
}

#elif SCENARIO_NUM == 2

template <typename T>
__simd_vf__ inline void GatherBVF(
    __ubuf__ T* dstAddr, __ubuf__ T* srcAddr, __ubuf__ uint32_t* indexAddr, uint32_t count, uint32_t oneRepeatSize,
    uint32_t indexRepeatSize)
{
    AscendC::Reg::RegTensor<T> dstReg;
    AscendC::Reg::RegTensor<uint32_t> indexReg;
    AscendC::Reg::MaskReg mask = AscendC::Reg::CreateMask<T, AscendC::Reg::MaskPattern::ALL>();
    uint16_t repeatTimes = AscendC::CeilDivision(count, oneRepeatSize);

    for (uint16_t i = 0; i < repeatTimes; ++i) {
        mask = AscendC::Reg::UpdateMask<T>(count);
        AscendC::Reg::LoadAlign(indexReg, indexAddr + i * indexRepeatSize);
        AscendC::Reg::GatherB(dstReg, srcAddr, indexReg, mask);
        AscendC::Reg::StoreAlign(dstAddr + i * oneRepeatSize, dstReg, mask);
    }
}

template <typename T, uint32_t singleCoreLength>
class KernelGatherB {
public:
    __aicore__ inline void Init(__gm__ uint8_t* src, __gm__ uint8_t* index, __gm__ uint8_t* dst)
    {
        srcGm.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(src));
        indexGm.SetGlobalBuffer(reinterpret_cast<__gm__ uint32_t*>(index));
        dstGm.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(dst));
    }

    __aicore__ inline void Process()
    {
        AscendC::LocalMemAllocator<AscendC::Hardware::UB> ubAllocator;
        constexpr uint32_t elementsPerBlock = 32 / sizeof(T);
        constexpr uint32_t numDataBlocks = singleCoreLength / elementsPerBlock;
        AscendC::LocalTensor<T> srcLocal = ubAllocator.Alloc<T, srcLength>();
        AscendC::LocalTensor<uint32_t> indexLocal = ubAllocator.Alloc<uint32_t, numDataBlocks>();
        AscendC::LocalTensor<T> dstLocal = ubAllocator.Alloc<T, singleCoreLength>();

        AscendC::DataCopy(srcLocal, srcGm, srcLength);
        AscendC::DataCopy(indexLocal, indexGm, numDataBlocks);
        AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);

        __ubuf__ T* srcAddr = reinterpret_cast<__ubuf__ T*>(srcLocal.GetPhyAddr());
        __ubuf__ uint32_t* indexAddr = reinterpret_cast<__ubuf__ uint32_t*>(indexLocal.GetPhyAddr());
        __ubuf__ T* dstAddr = reinterpret_cast<__ubuf__ T*>(dstLocal.GetPhyAddr());
        constexpr uint32_t oneRepeatSize = AscendC::GetVecLen() / sizeof(T);
        constexpr uint32_t indexRepeatSize = oneRepeatSize / elementsPerBlock;

        asc_vf_call<GatherBVF<T>>(dstAddr, srcAddr, indexAddr, singleCoreLength, oneRepeatSize, indexRepeatSize);

        AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);

        AscendC::DataCopy(dstGm, dstLocal, singleCoreLength);
    }

private:
    AscendC::GlobalTensor<T> srcGm;
    AscendC::GlobalTensor<uint32_t> indexGm;
    AscendC::GlobalTensor<T> dstGm;
};

__global__ __vector__ void gather_ld_reg(__gm__ uint8_t* src, __gm__ uint8_t* index, __gm__ uint8_t* dst)
{
    AscendC::InitSocState();
    constexpr uint32_t singleCoreLength = totalLength;
    KernelGatherB<half, singleCoreLength> kernel;
    kernel.Init(src, index, dst);
    kernel.Process();
    AscendC::PipeBarrier<PIPE_ALL>();
}

#endif

static bool CompareResult(const void* outputData, const void* goldenData, uint32_t outSize, uint32_t elementSize)
{
    int64_t wrongNum = 0;
    size_t count = outSize / elementSize;
    for (size_t i = 0; i < count; i++) {
        if (elementSize == 4) {
            uint32_t a = (reinterpret_cast<const uint32_t*>(outputData))[i];
            uint32_t b = (reinterpret_cast<const uint32_t*>(goldenData))[i];
            if (a != b) {
                printf("CompareResult failed at %zu: output=0x%08x, golden=0x%08x\n", i, a, b);
                wrongNum++;
            }
        } else {
            uint16_t a = (reinterpret_cast<const uint16_t*>(outputData))[i];
            uint16_t b = (reinterpret_cast<const uint16_t*>(goldenData))[i];
            if (a != b) {
                printf("CompareResult failed at %zu: output=0x%04x, golden=0x%04x\n", i, a, b);
                wrongNum++;
            }
        }
        if (wrongNum > 10) {
            printf("... (too many errors, truncated)\n");
            break;
        }
    }
    if (wrongNum != 0) {
        return false;
    } else {
        printf("CompareResult success!\n");
        return true;
    }
}

int32_t main(int32_t argc, char* argv[])
{
    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);
    uint32_t numBlocks = 1;

    size_t byteSize = totalLength * sizeof(half);
#if SCENARIO_NUM == 1
    size_t srcByteSize = srcLength * sizeof(half);
    size_t indexByteSize = totalLength * sizeof(uint16_t);
#elif SCENARIO_NUM == 2
    size_t srcByteSize = srcLength * sizeof(half);
    constexpr uint32_t elementsPerBlock = 32 / sizeof(half);
    constexpr uint32_t numDataBlocks = totalLength / elementsPerBlock;
    size_t indexByteSize = numDataBlocks * sizeof(uint32_t);
#endif
    uint8_t *srcHost, *indexHost, *dstHost;
    uint8_t *srcDevice, *indexDevice, *dstDevice;
    aclrtMallocHost((void**)(&srcHost), srcByteSize);
    aclrtMallocHost((void**)(&indexHost), indexByteSize);
    aclrtMallocHost((void**)(&dstHost), byteSize);
    aclrtMalloc((void**)&srcDevice, srcByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&indexDevice, indexByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&dstDevice, byteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    size_t srcFileSize = srcByteSize;
    size_t indexFileSize = indexByteSize;
    ReadFile("./input/input_x.bin", srcFileSize, srcHost, srcByteSize);
    ReadFile("./input/input_y.bin", indexFileSize, indexHost, indexByteSize);
    aclrtMemcpy(srcDevice, srcByteSize, srcHost, srcByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(indexDevice, indexByteSize, indexHost, indexByteSize, ACL_MEMCPY_HOST_TO_DEVICE);

    gather_ld_reg<<<numBlocks, nullptr, stream>>>(srcDevice, indexDevice, dstDevice);
    aclrtSynchronizeStream(stream);
    aclrtMemcpy(dstHost, byteSize, dstDevice, byteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", dstHost, byteSize);
    void* golden;
    aclrtMallocHost((void**)(&golden), byteSize);
    size_t goldenSize = byteSize;
    ReadFile("./output/golden.bin", goldenSize, golden, byteSize);
    bool result = CompareResult(dstHost, golden, byteSize, sizeof(half));
    aclrtFreeHost(golden);
    if (result) {
        printf("test pass!\n");
    } else {
        printf("test failed!\n");
    }
    aclrtFree(srcDevice);
    aclrtFree(indexDevice);
    aclrtFree(dstDevice);
    aclrtFreeHost(srcHost);
    aclrtFreeHost(indexHost);
    aclrtFreeHost(dstHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();
    return 0;
}
