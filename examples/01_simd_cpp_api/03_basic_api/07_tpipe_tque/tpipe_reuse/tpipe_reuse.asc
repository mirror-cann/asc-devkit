/* !
 * \file tpipe_reuse.asc
 * \brief TPipe复用样例，实现TPipe重复申请与释放
 */

#include <cassert>
#include "acl/acl.h"
#include "data_utils.h"
#include "kernel_operator.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

template <typename T, uint32_t totalLength>
__aicore__ inline void Process(__gm__ uint8_t* src_gm, __gm__ uint8_t* dst_gm, AscendC::TPipe* pipe)
{
    AscendC::GlobalTensor<T> src_global;
    AscendC::GlobalTensor<T> dst_global;
    src_global.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(src_gm), totalLength);
    dst_global.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(dst_gm), totalLength);

    AscendC::TQue<AscendC::TPosition::VECIN, 1> inQueueX;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> outQueue;
    pipe->InitBuffer(inQueueX, 1, totalLength * sizeof(T));
    pipe->InitBuffer(outQueue, 1, totalLength * sizeof(T));

    AscendC::LocalTensor<T> srcLocal = inQueueX.AllocTensor<T>();
    AscendC::DataCopy(srcLocal, src_global, totalLength);
    inQueueX.EnQue(srcLocal);

    srcLocal = inQueueX.DeQue<T>();
    AscendC::LocalTensor<T> dstLocal = outQueue.AllocTensor<T>();
    T scalar_value = 3;
    AscendC::Muls(dstLocal, srcLocal, scalar_value, totalLength);
    outQueue.EnQue<T>(dstLocal);
    inQueueX.FreeTensor(srcLocal);

    dstLocal = outQueue.DeQue<T>();
    AscendC::DataCopy(dst_global, dstLocal, totalLength);
    outQueue.FreeTensor(dstLocal);
}

__global__ __vector__ void tpipe_reuse_custom(__gm__ uint8_t* x, __gm__ uint8_t* z)
{
    constexpr uint32_t totalLength = 128;

    AscendC::TPipe pipe1;
    Process<float, totalLength>(x, z, &pipe1);
    pipe1.Destroy(); // 重复申请需要前一个对象先Destroy，后一个对象才能Init

    AscendC::TPipe pipe2;
    Process<float, totalLength>(x, z, &pipe2);
    pipe2.Destroy();
}

int32_t main(int32_t argc, char* argv[])
{
    uint32_t numBlocks = 1;
    size_t inputByteSize = 128 * sizeof(float);
    size_t outputByteSize = inputByteSize;

    int32_t deviceId = 0;
    aclrtStream stream = nullptr;

    uint8_t* xHost = nullptr;
    uint8_t* zHost = nullptr;
    uint8_t* xDevice = nullptr;
    uint8_t* zDevice = nullptr;

    // ACL initialization related operations
    aclError ret = ACL_SUCCESS;
    ret = aclInit(nullptr);
    assert(ret == ACL_SUCCESS && "aclInit failed!");

    ret = aclrtSetDevice(deviceId);
    assert(ret == ACL_SUCCESS && "aclrtSetDevice failed!");

    ret = aclrtCreateStream(&stream);
    assert(ret == ACL_SUCCESS && "aclrtCreateStream failed!");

    // Host memory allocation
    ret = aclrtMallocHost((void**)(&xHost), inputByteSize);
    assert(ret == ACL_SUCCESS && "aclrtMallocHost xHost failed!");

    ret = aclrtMallocHost((void**)(&zHost), outputByteSize);
    assert(ret == ACL_SUCCESS && "aclrtMallocHost zHost failed!");

    // Device memory allocation
    ret = aclrtMalloc((void**)&xDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    assert(ret == ACL_SUCCESS && "aclrtMalloc xDevice failed!");

    ret = aclrtMalloc((void**)&zDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    assert(ret == ACL_SUCCESS && "aclrtMalloc zDevice failed!");

    ReadFile("./input/input_x.bin", inputByteSize, xHost, inputByteSize);

    // Host to device memory copy
    ret = aclrtMemcpy(xDevice, inputByteSize, xHost, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
    assert(ret == ACL_SUCCESS && "aclrtMemcpy xHost to xDevice failed!");

    // Launch custom operator
    tpipe_reuse_custom<<<numBlocks, nullptr, stream>>>(xDevice, zDevice);
    ret = aclrtSynchronizeStream(stream);
    assert(ret == ACL_SUCCESS && "aclrtSynchronizeStream failed!");

    // Device to host memory copy
    ret = aclrtMemcpy(zHost, outputByteSize, zDevice, outputByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    assert(ret == ACL_SUCCESS && "aclrtMemcpy zDevice to zHost failed!");
    WriteFile("./output/output.bin", zHost, outputByteSize);

    // Resource release: Follow the order of first allocation then release to avoid memory leaks
    if (xDevice != nullptr) {
        aclrtFree(xDevice);
        xDevice = nullptr;
    }
    if (zDevice != nullptr) {
        aclrtFree(zDevice);
        zDevice = nullptr;
    }
    if (xHost != nullptr) {
        aclrtFreeHost(xHost);
        xHost = nullptr;
    }
    if (zHost != nullptr) {
        aclrtFreeHost(zHost);
        zHost = nullptr;
    }

    if (stream != nullptr) {
        aclrtDestroyStream(stream);
        stream = nullptr;
    }

    aclrtResetDevice(deviceId);
    aclFinalize();

    return 0;
}
