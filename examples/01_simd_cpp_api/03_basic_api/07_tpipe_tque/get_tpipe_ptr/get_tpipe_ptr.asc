/* !
 * \file get_tpipe_ptr.asc
 * \brief GetTPipePtr样例，获取全局TPipe指针并使用
 */

#include <iostream>
#include <vector>
#include <algorithm>
#include <iterator>
#include <cassert>
#include <cmath>
#include "acl/acl.h"
#include "kernel_operator.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

constexpr uint32_t BUFFER_NUM = 2; // tensor num for each queue

template <uint32_t totalLength, uint32_t tileNum>
__aicore__ inline void Process(__gm__ uint8_t* x, __gm__ uint8_t* y, __gm__ uint8_t* z)
{
    uint32_t blockNum = AscendC::GetBlockNum();
    ascendc_assert(blockNum != 0 && "block dim can not be zero!");
    uint32_t blockLength = totalLength / blockNum;
    ascendc_assert(tileNum != 0 && "tile num can not be zero!");
    uint32_t tileLength = blockLength / tileNum / BUFFER_NUM;

    AscendC::GlobalTensor<float> xGm;
    AscendC::GlobalTensor<float> yGm;
    AscendC::GlobalTensor<float> zGm;
    xGm.SetGlobalBuffer((__gm__ float*)x + blockLength * AscendC::GetBlockIdx(), blockLength);
    yGm.SetGlobalBuffer((__gm__ float*)y + blockLength * AscendC::GetBlockIdx(), blockLength);
    zGm.SetGlobalBuffer((__gm__ float*)z + blockLength * AscendC::GetBlockIdx(), blockLength);

    AscendC::TQue<AscendC::TPosition::VECIN, BUFFER_NUM> inQueueX, inQueueY;
    AscendC::TQue<AscendC::TPosition::VECOUT, BUFFER_NUM> outQueueZ;
    // 获取TPipe指针并使用
    GetTPipePtr()->InitBuffer(inQueueX, BUFFER_NUM, tileLength * sizeof(float));
    GetTPipePtr()->InitBuffer(inQueueY, BUFFER_NUM, tileLength * sizeof(float));
    GetTPipePtr()->InitBuffer(outQueueZ, BUFFER_NUM, tileLength * sizeof(float));

    int32_t loopCount = tileNum * BUFFER_NUM;
    for (int32_t i = 0; i < loopCount; i++) {
        AscendC::LocalTensor<float> xLocal = inQueueX.AllocTensor<float>();
        AscendC::LocalTensor<float> yLocal = inQueueY.AllocTensor<float>();
        AscendC::DataCopy(xLocal, xGm[i * tileLength], tileLength);
        AscendC::DataCopy(yLocal, yGm[i * tileLength], tileLength);
        inQueueX.EnQue(xLocal);
        inQueueY.EnQue(yLocal);

        xLocal = inQueueX.DeQue<float>();
        yLocal = inQueueY.DeQue<float>();
        AscendC::LocalTensor<float> zLocal = outQueueZ.AllocTensor<float>();
        AscendC::Add(zLocal, xLocal, yLocal, tileLength);
        outQueueZ.EnQue<float>(zLocal);
        inQueueX.FreeTensor(xLocal);
        inQueueY.FreeTensor(yLocal);

        zLocal = outQueueZ.DeQue<float>();
        AscendC::DataCopy(zGm[i * tileLength], zLocal, tileLength);
        outQueueZ.FreeTensor(zLocal);
    }
}

template <uint32_t totalLength, uint32_t tileNum>
__global__ __vector__ void get_tpipe_ptr_custom(__gm__ uint8_t* x, __gm__ uint8_t* y, __gm__ uint8_t* z)
{
    AscendC::TPipe pipe;
    Process<totalLength, tileNum>(x, y, z);
}

template <uint32_t totalLength>
std::vector<float> kernel_add(std::vector<float>& x, std::vector<float>& y)
{
    // Pre-check: Ensure input vectors match the fixed sample length.
    assert(x.size() == totalLength && y.size() == totalLength && "Input vector length must match totalLength!");
    constexpr uint32_t numBlocks = 8;
    size_t totalByteSize = totalLength * sizeof(float);
    int32_t deviceId = 0;
    aclrtStream stream = nullptr;
    uint8_t* xHost = reinterpret_cast<uint8_t*>(x.data());
    uint8_t* yHost = reinterpret_cast<uint8_t*>(y.data());
    uint8_t* zHost = nullptr;
    uint8_t* xDevice = nullptr;
    uint8_t* yDevice = nullptr;
    uint8_t* zDevice = nullptr;

    // ACL initialization related operations
    aclError ret = ACL_SUCCESS;
    ret = aclInit(nullptr);
    assert(ret == ACL_SUCCESS && "aclInit failed!");

    ret = aclrtSetDevice(deviceId);
    assert(ret == ACL_SUCCESS && "aclrtSetDevice failed!");

    ret = aclrtCreateStream(&stream);
    assert(ret == ACL_SUCCESS && "aclrtCreateStream failed!");

    // Host memory allocation
    ret = aclrtMallocHost((void**)(&zHost), totalByteSize);
    assert(ret == ACL_SUCCESS && "aclrtMallocHost failed!");

    // Device memory allocation
    ret = aclrtMalloc((void**)&xDevice, totalByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    assert(ret == ACL_SUCCESS && "aclrtMalloc xDevice failed!");

    ret = aclrtMalloc((void**)&yDevice, totalByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    assert(ret == ACL_SUCCESS && "aclrtMalloc yDevice failed!");

    ret = aclrtMalloc((void**)&zDevice, totalByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    assert(ret == ACL_SUCCESS && "aclrtMalloc zDevice failed!");

    // Host to device memory copy
    ret = aclrtMemcpy(xDevice, totalByteSize, xHost, totalByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
    assert(ret == ACL_SUCCESS && "aclrtMemcpy xHost to xDevice failed!");

    ret = aclrtMemcpy(yDevice, totalByteSize, yHost, totalByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
    assert(ret == ACL_SUCCESS && "aclrtMemcpy yHost to yDevice failed!");

    // Launch custom operator
    get_tpipe_ptr_custom<totalLength, numBlocks><<<numBlocks, nullptr, stream>>>(xDevice, yDevice, zDevice);
    ret = aclrtSynchronizeStream(stream);
    assert(ret == ACL_SUCCESS && "aclrtSynchronizeStream failed!");

    // Device to host memory copy
    ret = aclrtMemcpy(zHost, totalByteSize, zDevice, totalByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    assert(ret == ACL_SUCCESS && "aclrtMemcpy zDevice to zHost failed!");

    std::vector<float> z((float*)zHost, (float*)(zHost + totalByteSize));

    // Resource release: Follow the order of first allocation then release to avoid memory leaks
    if (xDevice != nullptr) {
        aclrtFree(xDevice);
        xDevice = nullptr;
    }
    if (yDevice != nullptr) {
        aclrtFree(yDevice);
        yDevice = nullptr;
    }
    if (zDevice != nullptr) {
        aclrtFree(zDevice);
        zDevice = nullptr;
    }
    if (zHost != nullptr) {
        aclrtFreeHost(zHost);
        zHost = nullptr;
    }

    if (stream != nullptr) {
        aclrtDestroyStream(stream);
        stream = nullptr;
    }

    aclrtResetDevice(deviceId);
    aclFinalize();

    return z;
}

uint32_t VerifyResult(std::vector<float>& output, std::vector<float>& golden)
{
    auto printTensor = [](std::vector<float>& tensor, const char* name) {
        constexpr size_t maxPrintSize = 20;
        std::cout << name << ": ";
        size_t printSize = std::min(tensor.size(), maxPrintSize);
        std::copy(tensor.begin(), tensor.begin() + printSize, std::ostream_iterator<float>(std::cout, " "));
        if (tensor.size() > maxPrintSize) {
            std::cout << "...";
        }
        std::cout << std::endl;
    };

    printTensor(output, "Output");
    printTensor(golden, "Golden");

    // First check if the lengths are consistent
    if (output.size() != golden.size()) {
        std::cout << "[Failed] Output and Golden have different lengths!" << std::endl;
        return 1;
    }

    // Floating-point data cannot be directly compared with std::equal, an error tolerance needs to be set
    constexpr float eps = 1e-6f;
    bool isEqual = true;
    for (size_t i = 0; i < output.size(); ++i) {
        if (fabs(output[i] - golden[i]) > eps) {
            isEqual = false;
            break;
        }
    }

    if (isEqual) {
        std::cout << "[Success] Case accuracy verification passed." << std::endl;
        return 0;
    } else {
        std::cout << "[Failed] Case accuracy verification failed!" << std::endl;
        return 1;
    }
}

int32_t main(int32_t argc, char* argv[])
{
    constexpr uint32_t totalLength = 8 * 2048;
    constexpr float valueX = 1.2f;
    constexpr float valueY = 2.3f;
    std::vector<float> x(totalLength, valueX);
    std::vector<float> y(totalLength, valueY);

    std::vector<float> output = kernel_add<totalLength>(x, y);

    std::vector<float> golden(totalLength, valueX + valueY);
    return VerifyResult(output, golden);
}
