/* !
 * \file ctrl_spr.asc
 * \brief
 * 基于SetCtrlSpr、GetCtrlSpr、ResetCtrlSpr接口，实现对CTRL寄存器（控制寄存器）的特定比特位的设置、读取和重置功能，并验证非饱和模式
 */

#include "acl/acl.h"
#include "data_utils.h"
#include "kernel_operator.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

template <typename T, uint32_t DATA_SIZE, uint32_t CTRL_SIZE>
class KernelCtrlSpr {
public:
    __aicore__ inline KernelCtrlSpr() {}
    __aicore__ inline void Init(uint64_t srcAddr, uint64_t dstCtrlAddr, uint64_t dstSatAddr)
    {
        srcGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(srcAddr), DATA_SIZE);
        dstCtrlGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ int64_t*>(dstCtrlAddr), CTRL_SIZE);
        dstSatGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(dstSatAddr), DATA_SIZE);
    }

    __aicore__ inline void Process()
    {
        AscendC::LocalMemAllocator<AscendC::Hardware::UB> ubAllocator;
        AscendC::LocalTensor<T> srcLocal = ubAllocator.Alloc<T, DATA_SIZE>();
        AscendC::LocalTensor<T> dstLocal = ubAllocator.Alloc<T, DATA_SIZE>();
        AscendC::LocalTensor<int64_t> ctrlLocal = ubAllocator.Alloc<int64_t, CTRL_SIZE>();

        AscendC::DataCopy(srcLocal, srcGlobal, DATA_SIZE);
        AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(0);

        AscendC::SetCtrlSpr<60, 60>(1);
        AscendC::SetCtrlSpr<48, 48>(1);

        int64_t valueCtrlAfterSet = AscendC::GetCtrlSpr<48, 48>();
        AscendC::Duplicate(ctrlLocal, valueCtrlAfterSet, CTRL_SIZE / 2);

        AscendC::Adds(dstLocal, srcLocal, (T)1.0, DATA_SIZE);

        AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(0);
        AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(0);

        AscendC::DataCopy(dstSatGlobal, dstLocal, DATA_SIZE);

        AscendC::ResetCtrlSpr<48, 48>();
        AscendC::ResetCtrlSpr<60, 60>();

        int64_t valueCtrlAfterReset = AscendC::GetCtrlSpr<48, 48>();
        AscendC::Duplicate(ctrlLocal[CTRL_SIZE / 2], valueCtrlAfterReset, CTRL_SIZE / 2);

        AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(0);
        AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(0);

        AscendC::DataCopy(dstCtrlGlobal, ctrlLocal, CTRL_SIZE);

        AscendC::PipeBarrier<PIPE_ALL>();
    }

private:
    AscendC::GlobalTensor<T> srcGlobal;
    AscendC::GlobalTensor<T> dstSatGlobal;
    AscendC::GlobalTensor<int64_t> dstCtrlGlobal;
};

template <uint32_t DATA_SIZE, uint32_t CTRL_SIZE>
__global__ __vector__ void kernel_ctrl_spr(__gm__ uint8_t* srcGm, __gm__ uint8_t* dstCtrlGm, __gm__ uint8_t* dstSatGm)
{
    AscendC::InitSocState();

    KernelCtrlSpr<half, DATA_SIZE, CTRL_SIZE> op;
    op.Init((uint64_t)srcGm, (uint64_t)dstCtrlGm, (uint64_t)dstSatGm);
    op.Process();
}

int32_t main(int32_t argc, char* argv[])
{
    constexpr uint32_t NUM_BLOCKS = 1;
    constexpr uint32_t DATA_SIZE = 256;
    constexpr uint32_t CTRL_SIZE = 8;
    size_t inputByteSize = NUM_BLOCKS * DATA_SIZE * sizeof(half);
    size_t outputCtrlByteSize = NUM_BLOCKS * CTRL_SIZE * sizeof(int64_t);
    size_t outputSatByteSize = NUM_BLOCKS * DATA_SIZE * sizeof(half);

    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t *srcHost, *dstCtrlHost, *dstSatHost;
    uint8_t *srcDevice, *dstCtrlDevice, *dstSatDevice;

    aclrtMallocHost((void**)(&srcHost), inputByteSize);
    aclrtMallocHost((void**)(&dstCtrlHost), outputCtrlByteSize);
    aclrtMallocHost((void**)(&dstSatHost), outputSatByteSize);
    aclrtMalloc((void**)&srcDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&dstCtrlDevice, outputCtrlByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&dstSatDevice, outputSatByteSize, ACL_MEM_MALLOC_HUGE_FIRST);

    ReadFile("./input/input.bin", inputByteSize, srcHost, inputByteSize);
    aclrtMemcpy(srcDevice, inputByteSize, srcHost, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);

    kernel_ctrl_spr<DATA_SIZE, CTRL_SIZE><<<NUM_BLOCKS, nullptr, stream>>>(srcDevice, dstCtrlDevice, dstSatDevice);
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(dstCtrlHost, outputCtrlByteSize, dstCtrlDevice, outputCtrlByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    aclrtMemcpy(dstSatHost, outputSatByteSize, dstSatDevice, outputSatByteSize, ACL_MEMCPY_DEVICE_TO_HOST);

    WriteFile("./output/output_ctrl.bin", dstCtrlHost, outputCtrlByteSize);
    WriteFile("./output/output_sat.bin", dstSatHost, outputSatByteSize);

    aclrtFree(srcDevice);
    aclrtFree(dstCtrlDevice);
    aclrtFree(dstSatDevice);
    aclrtFreeHost(srcHost);
    aclrtFreeHost(dstCtrlHost);
    aclrtFreeHost(dstSatHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();

    return 0;
}