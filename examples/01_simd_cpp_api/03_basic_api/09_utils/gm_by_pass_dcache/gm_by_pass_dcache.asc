/* !
 * \file gm_by_pass_dcache.asc
 * \brief 基于WriteGmByPassDCache和ReadGmByPassDCache接口，实现不经过DCache从GM地址读取和写入数据
 */

#include "acl/acl.h"
#include "data_utils.h"
#include "kernel_operator.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

constexpr int32_t ADD_VALUE = 100;
constexpr uint32_t DATA_SIZE = 1024;

template <typename T>
class KernelGmByPassDcache {
public:
    __aicore__ inline KernelGmByPassDcache() {}
    __aicore__ inline void Init(__gm__ uint8_t* srcGm, __gm__ uint8_t* dstGm)
    {
        srcGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(srcGm));
        dstGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(dstGm));
    }

    __aicore__ inline void Process()
    {
        __gm__ T* srcAddr = const_cast<__gm__ T*>(srcGlobal.GetPhyAddr());
        T value = AscendC::ReadGmByPassDCache<T>(srcAddr);
        // 同步指令：用于阻塞后续的指令执行，直到所有之前的内存访问指令（需要等待的内存位置可通过参数控制）执行结束
        AscendC::DataSyncBarrier<AscendC::MemDsbT::DDR>(); // DDR，等待GM访问指令
        __gm__ T* dstAddr = const_cast<__gm__ T*>(dstGlobal.GetPhyAddr());
        AscendC::WriteGmByPassDCache<T>(dstAddr, value + ADD_VALUE);
    }

private:
    AscendC::GlobalTensor<T> srcGlobal;
    AscendC::GlobalTensor<T> dstGlobal;
};

__global__ __vector__ void kernel_gm_by_pass_dcache(__gm__ uint8_t* srcGm, __gm__ uint8_t* dstGm)
{
    AscendC::InitSocState();
    KernelGmByPassDcache<int32_t> op;
    op.Init(srcGm, dstGm);
    op.Process();
    AscendC::PipeBarrier<PIPE_ALL>();
}

int32_t main(int32_t argc, char* argv[])
{
    constexpr uint32_t NUM_BLOCKS = 1;
    size_t inputByteSize = DATA_SIZE * sizeof(int32_t);
    size_t outputByteSize = inputByteSize;

    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t *xHost, *zHost;
    uint8_t *xDevice, *zDevice;

    aclrtMallocHost((void**)(&xHost), inputByteSize);
    aclrtMallocHost((void**)(&zHost), outputByteSize);
    aclrtMalloc((void**)&xDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&zDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);

    ReadFile("./input/input_x.bin", inputByteSize, xHost, inputByteSize);

    aclrtMemcpy(xDevice, inputByteSize, xHost, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);

    kernel_gm_by_pass_dcache<<<NUM_BLOCKS, nullptr, stream>>>(xDevice, zDevice);
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(zHost, outputByteSize, zDevice, outputByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", zHost, outputByteSize);

    aclrtFree(xDevice);
    aclrtFree(zDevice);
    aclrtFreeHost(xHost);
    aclrtFreeHost(zHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();

    return 0;
}
