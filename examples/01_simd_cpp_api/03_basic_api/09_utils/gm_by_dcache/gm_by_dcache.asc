/* !
 * \file gm_by_dcache.asc
 * \brief reading and writing data from GM addresses through DCache (Data Cache)
 */

#include <cstdint>
#include <vector>
#include <algorithm>
#include <iterator>
#include <iostream>
#include <cmath>

#include "acl/acl.h"

#include "kernel_operator.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

template <uint32_t TILE_NUM>
__aicore__ inline void WaitBlocksReady(__gm__ int32_t* flagWorkspace)
{
    AscendC::GlobalTensor<int32_t> flagGm;
    flagGm.SetGlobalBuffer(flagWorkspace);

    bool notReady = true;
    while (notReady) {
        notReady = false;
        for (int32_t i = 0; i < TILE_NUM; ++i) {
            int32_t index = i * 64 / sizeof(int32_t);
            AscendC::DataCacheCleanAndInvalid<
                int32_t, AscendC::CacheLine::SINGLE_CACHE_LINE, AscendC::DcciDst::CACHELINE_OUT>(flagGm[index]);
            int32_t flag = flagGm.GetValue(index);
            if (flag != i) {
                notReady = true;
                break;
            }
        }
    }
}

template <typename T, uint32_t TILE_NUM, uint32_t TILE_LENGTH>
__vector__ __global__ void gm_by_dcache_custom(__gm__ T* x, __gm__ int32_t* workspace, __gm__ T* z)
{
    AscendC::InitSocState();
    uint32_t blockIdx = AscendC::GetBlockIdx();
    constexpr uint32_t repeatLength = 256 / sizeof(T);
    constexpr uint32_t repeatTimes = TILE_LENGTH / repeatLength;
    __gm__ int32_t* flagWorkspace = workspace + TILE_NUM * repeatTimes * sizeof(T) / sizeof(int32_t);

    AscendC::GlobalTensor<T> xGm;
    AscendC::GlobalTensor<T> reduceTmpGm;
    AscendC::GlobalTensor<int32_t> flagGm;
    xGm.SetGlobalBuffer(x + blockIdx * TILE_LENGTH);
    reduceTmpGm.SetGlobalBuffer(
        reinterpret_cast<__gm__ T*>(workspace + blockIdx * repeatTimes * sizeof(T) / sizeof(int32_t)));
    flagGm.SetGlobalBuffer(flagWorkspace + blockIdx * 64 / sizeof(int32_t));

    AscendC::LocalMemAllocator<AscendC::Hardware::UB> ubAllocator;
    AscendC::LocalTensor<T> srcLocal = ubAllocator.Alloc<T, TILE_LENGTH>();
    AscendC::LocalTensor<T> dstLocal = ubAllocator.Alloc<T, repeatTimes>();

    AscendC::DataCopy(srcLocal, xGm, TILE_LENGTH);

    AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
    AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
    AscendC::ReduceRepeat<AscendC::ReduceType::SUM, T>(dstLocal, srcLocal, repeatLength, repeatTimes, 1, 1, 8);

    AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
    AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
    AscendC::DataCopy(reduceTmpGm, dstLocal, repeatTimes);

    AscendC::SetFlag<AscendC::HardEvent::MTE3_S>(EVENT_ID0);
    AscendC::WaitFlag<AscendC::HardEvent::MTE3_S>(EVENT_ID0);
    flagGm.SetValue(0, blockIdx);
    AscendC::DataCacheCleanAndInvalid<int32_t, AscendC::CacheLine::SINGLE_CACHE_LINE, AscendC::DcciDst::CACHELINE_OUT>(
        flagGm);

    if (blockIdx > 0) {
        return;
    }

    WaitBlocksReady<TILE_NUM>(flagWorkspace);

    AscendC::GlobalTensor<T> zGm;
    zGm.SetGlobalBuffer(z);

    AscendC::SetFlag<AscendC::HardEvent::MTE3_MTE2>(EVENT_ID0);
    AscendC::WaitFlag<AscendC::HardEvent::MTE3_MTE2>(EVENT_ID0);
    AscendC::DataCopy(srcLocal, reduceTmpGm, TILE_NUM * repeatTimes);

    AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
    AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
    AscendC::ReduceRepeat<AscendC::ReduceType::SUM, T>(dstLocal, srcLocal, repeatLength, 1, 1, 1, 8);

    AscendC::SetFlag<AscendC::HardEvent::MTE3_S>(EVENT_ID0);
    AscendC::WaitFlag<AscendC::HardEvent::MTE3_S>(EVENT_ID0);
    zGm.SetValue(0, dstLocal.GetValue(0));

    AscendC::PipeBarrier<PIPE_ALL>();
}

template <typename T, uint32_t TILE_NUM, uint32_t TILE_LENGTH>
std::vector<T> kernel_gm_by_dcache(std::vector<T>& x, std::vector<int32_t>& workspace)
{
    size_t inputByteSize = TILE_NUM * TILE_LENGTH * sizeof(T);
    size_t workspaceByteSize = TILE_NUM * (TILE_LENGTH * sizeof(float) / 256) * sizeof(float) + TILE_NUM * 64;
    size_t outputByteSize = 1 * sizeof(T);
    T* xDevice = nullptr;
    int32_t* workspaceDevice = nullptr;
    T* zDevice = nullptr;
    uint8_t* zHost = nullptr;

    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    aclrtMalloc((void**)&xDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&workspaceDevice, workspaceByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&zDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMallocHost((void**)&zHost, outputByteSize);

    aclrtMemcpy(xDevice, inputByteSize, x.data(), inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(workspaceDevice, workspaceByteSize, workspace.data(), workspaceByteSize, ACL_MEMCPY_HOST_TO_DEVICE);

    gm_by_dcache_custom<T, TILE_NUM, TILE_LENGTH><<<TILE_NUM, 0, stream>>>(xDevice, workspaceDevice, zDevice);
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(zHost, outputByteSize, zDevice, outputByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    std::vector<T> z((T*)zHost, (T*)(zHost + outputByteSize));

    aclrtFree(xDevice);
    aclrtFree(workspaceDevice);
    aclrtFree(zDevice);
    aclrtFreeHost(zHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();

    return z;
}

template <typename T>
uint32_t VerifyResult(std::vector<T>& output, std::vector<T>& golden)
{
    auto printTensor = [](std::vector<T>& tensor, const char* name) {
        std::cout << name << ": ";
        std::copy(tensor.begin(), tensor.end(), std::ostream_iterator<T>(std::cout, " "));
        std::cout << std::endl;
    };
    printTensor(output, "Output");
    printTensor(golden, "Golden");

    constexpr T tolerance = 1e-3f;
    for (size_t i = 0; i < golden.size(); ++i) {
        if (std::fabs(output[i] - golden[i]) > tolerance) {
            std::cout << "test failed! diff at index " << i << ": output=" << output[i] << ", golden=" << golden[i]
                      << std::endl;
            return 1;
        }
    }
    std::cout << "test pass!" << std::endl;
    return 0;
}

int32_t main(int32_t argc, char* argv[])
{
    constexpr uint32_t TILE_NUM = 4;
    constexpr uint32_t TILE_LENGTH = 1024;
    constexpr uint32_t totalInputLength = TILE_NUM * TILE_LENGTH;
    constexpr uint32_t workspaceGMLength =
        TILE_NUM * (TILE_LENGTH * sizeof(float) / 256) * sizeof(float) + TILE_NUM * 64;
    std::vector<float> x(totalInputLength);
    std::vector<int32_t> workspace(workspaceGMLength);
    std::vector<float> golden(1);

    golden[0] = 0;
    for (uint32_t i = 0; i < totalInputLength; ++i) {
        x[i] = (i % 100) * 0.1f;
        golden[0] += x[i];
    }

    std::vector<float> output = kernel_gm_by_dcache<float, TILE_NUM, TILE_LENGTH>(x, workspace);

    return VerifyResult<float>(output, golden);
}
