/* !
 * \file histogram.asc
 * \brief 演示使用Histograms接口实现直方图统计功能
 *        - 输入：uint8_t数据，值范围[0, 255]
 *        - 输出：uint16_t直方图，256个bin，每个bin存储对应值的计数
 *        - 使用LoadAlign/StoreAlign的postUpdate模式
 */

#include "acl/acl.h"
#include "kernel_operator.h"
#include "data_utils.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

constexpr uint32_t totalLength = 256;

template <typename T, typename U>
__simd_vf__ inline void HistogramsVF(__ubuf__ U* dstAddr, __ubuf__ T* srcAddr,
                                       uint32_t count, uint32_t oneRepeatSize)
{
    AscendC::Reg::RegTensor<T> srcReg;
    AscendC::Reg::RegTensor<U> dst0Reg;
    AscendC::Reg::RegTensor<U> dst1Reg;
    AscendC::Reg::MaskReg maskU8 = AscendC::Reg::CreateMask<T, AscendC::Reg::MaskPattern::ALL>();
    AscendC::Reg::MaskReg maskU16 = AscendC::Reg::CreateMask<U, AscendC::Reg::MaskPattern::ALL>();
    uint16_t repeatTimes = AscendC::CeilDivision(count, oneRepeatSize);

    AscendC::Reg::Duplicate(dst0Reg, (U)0);
    AscendC::Reg::Duplicate(dst1Reg, (U)0);

    for (uint16_t i = 0; i < repeatTimes; ++i) {
        AscendC::Reg::LoadAlign<T, AscendC::Reg::PostLiteral::POST_MODE_UPDATE>(srcReg, srcAddr, oneRepeatSize);
        AscendC::Reg::Histograms<T, U, AscendC::Reg::HistogramsBinType::BIN0, AscendC::Reg::HistogramsType::FREQUENCY>(
            dst0Reg, srcReg, maskU8);
        AscendC::Reg::Histograms<T, U, AscendC::Reg::HistogramsBinType::BIN1, AscendC::Reg::HistogramsType::FREQUENCY>(
            dst1Reg, srcReg, maskU8);
    }

    AscendC::Reg::StoreAlign<U, AscendC::Reg::PostLiteral::POST_MODE_UPDATE>(dstAddr, dst0Reg, 128, maskU16);
    AscendC::Reg::StoreAlign<U, AscendC::Reg::PostLiteral::POST_MODE_UPDATE>(dstAddr, dst1Reg, 128, maskU16);
}

template <typename T, typename U, uint32_t singleCoreLength>
class KernelHistogram {
public:
    __aicore__ inline void Init(__gm__ uint8_t* src, __gm__ uint8_t* dst)
    {
        srcGm.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(src));
        dstGm.SetGlobalBuffer(reinterpret_cast<__gm__ U*>(dst));
    }

    __aicore__ inline void Process()
    {
        AscendC::LocalMemAllocator<AscendC::Hardware::UB> ubAllocator;
        AscendC::LocalTensor<T> srcLocal = ubAllocator.Alloc<T, singleCoreLength>();
        constexpr uint32_t dstLength = 256;
        AscendC::LocalTensor<U> dstLocal = ubAllocator.Alloc<U, dstLength>();

        AscendC::DataCopy(srcLocal, srcGm, singleCoreLength);
        AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);

        __ubuf__ T* srcAddr = reinterpret_cast<__ubuf__ T*>(srcLocal.GetPhyAddr());
        __ubuf__ U* dstAddr = reinterpret_cast<__ubuf__ U*>(dstLocal.GetPhyAddr());
        constexpr uint32_t oneRepeatSize = AscendC::GetVecLen() / sizeof(T);

        asc_vf_call<HistogramsVF<T, U>>(dstAddr, srcAddr, singleCoreLength, oneRepeatSize);

        AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);

        AscendC::DataCopy(dstGm, dstLocal, dstLength);
    }

private:
    AscendC::GlobalTensor<T> srcGm;
    AscendC::GlobalTensor<U> dstGm;
};

__global__ __vector__ void histogram(__gm__ uint8_t* src, __gm__ uint8_t* dst)
{
    AscendC::InitSocState();
    constexpr uint32_t singleCoreLength = totalLength;
    KernelHistogram<uint8_t, uint16_t, singleCoreLength> kernel;
    kernel.Init(src, dst);
    kernel.Process();
    AscendC::PipeBarrier<PIPE_ALL>();
}

static bool CompareResult(const void* outputData, const void* goldenData, uint32_t outSize, uint32_t elementSize)
{
    int64_t wrongNum = 0;
    size_t count = outSize / elementSize;
    for (size_t i = 0; i < count; i++) {
        uint16_t a = (reinterpret_cast<const uint16_t*>(outputData))[i];
        uint16_t b = (reinterpret_cast<const uint16_t*>(goldenData))[i];
        if (a != b) {
            printf("CompareResult failed at %zu: output=%u, golden=%u\n", i, a, b);
            wrongNum++;
        }
        if (wrongNum > 10) {
            printf("... (too many errors, truncated)\n");
            break;
        }
    }
    if (wrongNum != 0) {
        return false;
    } else {
        printf("CompareResult success!\n");
        return true;
    }
}

int32_t main(int32_t argc, char* argv[])
{
    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);
    uint32_t numBlocks = 1;

    size_t srcByteSize = totalLength * sizeof(uint8_t);
    size_t dstByteSize = 256 * sizeof(uint16_t);
    uint8_t *srcHost, *dstHost;
    uint8_t *srcDevice, *dstDevice;
    aclrtMallocHost((void**)(&srcHost), srcByteSize);
    aclrtMallocHost((void**)(&dstHost), dstByteSize);
    aclrtMalloc((void**)&srcDevice, srcByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&dstDevice, dstByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    size_t srcFileSize = srcByteSize;
    ReadFile("./input/input_x.bin", srcFileSize, srcHost, srcByteSize);
    aclrtMemcpy(srcDevice, srcByteSize, srcHost, srcByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
    histogram<<<numBlocks, nullptr, stream>>>(srcDevice, dstDevice);
    aclrtSynchronizeStream(stream);
    aclrtMemcpy(dstHost, dstByteSize, dstDevice, dstByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", dstHost, dstByteSize);
    void* golden; aclrtMallocHost((void**)(&golden), dstByteSize);
    size_t goldenSize = dstByteSize;
    ReadFile("./output/golden.bin", goldenSize, golden, dstByteSize);
    bool result = CompareResult(dstHost, golden, dstByteSize, sizeof(uint16_t));
    aclrtFreeHost(golden);
    if (result) { printf("test pass!\n"); } else { printf("test failed!\n"); }
    aclrtFree(srcDevice); aclrtFree(dstDevice);
    aclrtFreeHost(srcHost); aclrtFreeHost(dstHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();
    return 0;
}