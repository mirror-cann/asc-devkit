/* !
 * \file reduce_pair_elem.asc
 * \brief 本样例展示了ReducePairElem<SUM>的使用，对输入Tensor进行成对求和归约
 */

#include "acl/acl.h"
#include "data_utils.h"
#include "kernel_operator.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

__global__ __vector__ void reduce_pair_elem_custom(__gm__ uint8_t* x, __gm__ uint8_t* z)
{
    constexpr int SRC_DATA_SIZE = 128;
    constexpr int DST_DATA_SIZE = 64;
    AscendC::InitSocState();
    AscendC::GlobalTensor<half> srcGlobal;
    AscendC::GlobalTensor<half> dstGlobal;
    srcGlobal.SetGlobalBuffer((__gm__ half*)x);
    dstGlobal.SetGlobalBuffer((__gm__ half*)z);

    AscendC::LocalMemAllocator<AscendC::Hardware::UB> ubAllocator;
    AscendC::LocalTensor<half> srcLocal = ubAllocator.Alloc<half, SRC_DATA_SIZE>();
    AscendC::LocalTensor<half> dstLocal = ubAllocator.Alloc<half, DST_DATA_SIZE>();

    AscendC::DataCopy(srcLocal, srcGlobal, SRC_DATA_SIZE);
    AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
    AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);

    half zero(0);
    AscendC::Duplicate(dstLocal, zero, DST_DATA_SIZE);
    // mask逐bit模式，128个bit位全为1，代表128个half类型元素都参与计算
    uint64_t mask[2] = {UINT64_MAX, UINT64_MAX};
    int repeat = 1;
    // repeat = 1, 128 elements one repeat, 128 elements total
    // srcBlkStride = 1, no gap between blocks in one repeat
    // dstRepStride = 1, srcRepStride = 8, no gap between repeats
    AscendC::ReducePairElem<AscendC::ReduceType::SUM, half>(dstLocal, srcLocal, mask, repeat, 1, 1, 8);

    AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
    AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
    AscendC::DataCopy(dstGlobal, dstLocal, DST_DATA_SIZE);
    AscendC::PipeBarrier<PIPE_ALL>();
}

int32_t main(int32_t argc, char* argv[])
{
    uint32_t numBlocks = 1;
    size_t inputByteSize = 128 * sizeof(half);
    size_t outputByteSize = 64 * sizeof(half);

    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t *xHost, *zHost;
    uint8_t *xDevice, *zDevice;

    aclrtMallocHost((void**)(&xHost), inputByteSize);
    aclrtMallocHost((void**)(&zHost), outputByteSize);
    aclrtMalloc((void**)&xDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&zDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);

    ReadFile("./input/input_x.bin", inputByteSize, xHost, inputByteSize);

    aclrtMemcpy(xDevice, inputByteSize, xHost, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);

    reduce_pair_elem_custom<<<numBlocks, nullptr, stream>>>(xDevice, zDevice);
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(zHost, outputByteSize, zDevice, outputByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", zHost, outputByteSize);

    aclrtFree(xDevice);
    aclrtFree(zDevice);
    aclrtFreeHost(xHost);
    aclrtFreeHost(zHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();

    return 0;
}
