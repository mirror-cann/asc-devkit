/* !
 * \file tbufpool_management.asc
 * \brief TBufPool内存管理样例，展示TBufPool资源分配、内存划分、内存复用和自定义TBufPool等使用方式
 */

#include "acl/acl.h"
#include "data_utils.h"
#include "kernel_operator.h"
#include <cassert>

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

constexpr uint32_t scenarioNum = SCENARIO_NUM;

using namespace AscendC;

/**
 * @brief 用户自定义TBufPool类，实现非连续内存块分配和内存共享
 */
class MyBufPool {
public:
    __aicore__ inline MyBufPool() { Init(); }

    template <class T>
    __aicore__ inline bool InitBuffer(T& que, uint8_t num, uint32_t len)
    {
        len = (len + 32 - 1) / 32 * 32; // 保证内存块长度32字节对齐
        auto ptr = this->GetBufHandle(this->GetCurBufSize());
        auto curPoolAddr = this->GetCurAddr();

        // call internal func to initial bufhandle
        que.InitStartBufHandle(ptr, num, len);
        for (uint32_t i = 0; i < num; i++) {
            que.InitBufHandle(this, i, ptr, curPoolAddr + i * len, len);
        }

        this->SetCurAddr(curPoolAddr + num * len);
        this->SetCurBufSize(this->GetCurBufSize() + num);

        return true;
    }

    template <AscendC::TPosition bufPos>
    __aicore__ inline bool InitBuffer(AscendC::TBuf<bufPos>& buf, uint32_t len)
    {
        len = (len + 32 - 1) / 32 * 32; // 保证内存块长度32字节对齐
        auto ptr = this->GetBufHandle(this->GetCurBufSize());
        auto curPoolAddr = this->GetCurAddr();

        // call internal func to initial bufhandle
        buf.InitStartBufHandle(ptr, 1, len);
        buf.InitBufHandle(this, 0, ptr, curPoolAddr, len);

        this->SetCurAddr(curPoolAddr + len);
        this->SetCurBufSize(this->GetCurBufSize() + 1);
        return true;
    }
    EXTERN_IMPL_BUFPOOL(MyBufPool, AscendC::TPosition::VECCALC, 16);
};

/**
 * @brief TBufPool内存管理样例Kernel类，通过模板参数传入BUF_SIZE和MASK
 */
template <uint32_t bufSize, uint32_t mask>
class KernelBufPool {
public:
    __aicore__ inline KernelBufPool() {}

    __aicore__ inline void Init(
        __gm__ uint8_t* src0Gm, __gm__ uint8_t* src1Gm, __gm__ uint8_t* dstGm, AscendC::TPipe* pipeIn)
    {
        pipe = pipeIn;
        src0Global.SetGlobalBuffer((__gm__ half*)src0Gm);
        src1Global.SetGlobalBuffer((__gm__ half*)src1Gm);
        dstGlobal.SetGlobalBuffer((__gm__ half*)dstGm);
    }

    // 场景1：TBufPool内存复用
    __aicore__ inline void ProcessBufPoolReuse()
    {
        // 初始化TBufPool内存资源池，tbufPool2复用tbufPool1的起始地址及长度
        pipe->InitBufPool(tbufPool1, bufSize * 3);
        pipe->InitBufPool(tbufPool2, bufSize * 3, tbufPool1);

        tbufPool1.InitBuffer(srcQue0, 1, bufSize);
        tbufPool1.InitBuffer(srcQue1, 1, bufSize);
        tbufPool1.InitBuffer(dstQue0, 1, bufSize);
        CopyIn();
        Compute();
        CopyOut();
        tbufPool1.Reset();

        tbufPool2.InitBuffer(srcQue2, 1, bufSize);
        tbufPool2.InitBuffer(srcQue3, 1, bufSize);
        tbufPool2.InitBuffer(dstQue1, 1, bufSize);
        CopyIn1();
        Compute1();
        CopyOut1();
        tbufPool2.Reset();
    }

    // 场景2：TBufPool资源细分
    __aicore__ inline void ProcessBufPoolSubdivision()
    {
        // 初始化TBufPool资源池tbufPool0，并在其中继续划分tbufPool1和tbufPool2
        pipe->InitBufPool(tbufPool0, bufSize * 4);
        tbufPool0.InitBufPool(tbufPool1, bufSize * 2);
        tbufPool0.InitBuffer(srcQue0, 1, bufSize * 2);
        // tbufPool2复用tbufPool1的起始地址及长度
        tbufPool0.InitBufPool(tbufPool2, bufSize * 2, tbufPool1);

        tbufPool1.InitBuffer(srcQue1, 1, bufSize);
        tbufPool1.InitBuffer(dstQue0, 1, bufSize);
        CopyIn();
        Compute();
        CopyOut();
        tbufPool1.Reset();

        tbufPool2.InitBuffer(srcQue2, 1, bufSize);
        tbufPool2.InitBuffer(dstQue1, 1, bufSize);
        CopyIn1();
        Compute1();
        CopyOut1();
        tbufPool2.Reset();
        tbufPool0.Reset();
        pipe->Reset();
    }

    // 场景3：自定义TBufPool
    __aicore__ inline void ProcessCustomizedBufPool()
    {
        // 使用EXTERN_IMPL_BUFPOOL宏实现自定义TBufPool，为MyBufPool划分内存并分配TQue和TBuf
        pipe->InitBufPool(myBufPool0, bufSize * 3);
        myBufPool0.InitBuffer(srcQue0, 1, bufSize);
        myBufPool0.InitBuffer(srcBuf1, bufSize);
        myBufPool0.InitBuffer(dstQue0, 1, bufSize);

        CopyIn();
        Compute();
        CopyOut();
        myBufPool0.Reset();
        pipe->Reset();
    }

private:
    __aicore__ inline void CopyIn()
    {
        AscendC::LocalTensor<half> src0Local = srcQue0.AllocTensor<half>();
        AscendC::LocalTensor<half> src1Local;
        if constexpr (scenarioNum == 3) {
            src1Local = srcBuf1.Get<half>();
        } else {
            src1Local = srcQue1.AllocTensor<half>();
        }
        AscendC::DataCopy(src0Local, src0Global, mask);
        AscendC::DataCopy(src1Local, src1Global, mask);
        srcQue0.EnQue(src0Local);
        if constexpr (scenarioNum != 3) {
            srcQue1.EnQue(src1Local);
        }
    }
    __aicore__ inline void Compute()
    {
        AscendC::LocalTensor<half> src0Local = srcQue0.DeQue<half>();
        AscendC::LocalTensor<half> src1Local;
        if constexpr (scenarioNum == 3) {
            src1Local = srcBuf1.Get<half>();
        } else {
            src1Local = srcQue1.DeQue<half>();
        }
        AscendC::LocalTensor<half> dstLocal = dstQue0.AllocTensor<half>();
        AscendC::Add(dstLocal, src0Local, src1Local, mask);
        dstQue0.EnQue<half>(dstLocal);
        srcQue0.FreeTensor(src0Local);
        if constexpr (scenarioNum != 3) {
            srcQue1.FreeTensor(src1Local);
        }
    }
    __aicore__ inline void CopyOut()
    {
        AscendC::LocalTensor<half> dstLocal = dstQue0.DeQue<half>();
        AscendC::DataCopy(dstGlobal, dstLocal, mask);
        dstQue0.FreeTensor(dstLocal);
    }

    __aicore__ inline void CopyIn1()
    {
        AscendC::LocalTensor<half> src0Local;
        AscendC::LocalTensor<half> src1Local;
        if constexpr (scenarioNum == 1) {
            src0Local = srcQue2.AllocTensor<half>();
            src1Local = srcQue3.AllocTensor<half>();
        } else if constexpr (scenarioNum == 2) {
            src0Local = srcQue0.AllocTensor<half>();
            src1Local = srcQue2.AllocTensor<half>();
        }
        AscendC::DataCopy(src0Local, src0Global, mask);
        AscendC::DataCopy(src1Local, src1Global, mask);
        if constexpr (scenarioNum == 1) {
            srcQue2.EnQue(src0Local);
            srcQue3.EnQue(src1Local);
        } else if constexpr (scenarioNum == 2) {
            srcQue0.EnQue(src0Local);
            srcQue2.EnQue(src1Local);
        }
    }
    __aicore__ inline void Compute1()
    {
        AscendC::LocalTensor<half> src0Local;
        AscendC::LocalTensor<half> src1Local;
        if constexpr (scenarioNum == 1) {
            src0Local = srcQue2.DeQue<half>();
            src1Local = srcQue3.DeQue<half>();
        } else if constexpr (scenarioNum == 2) {
            src0Local = srcQue0.DeQue<half>();
            src1Local = srcQue2.DeQue<half>();
        }
        AscendC::LocalTensor<half> dstLocal = dstQue1.AllocTensor<half>();
        AscendC::Add(dstLocal, src0Local, src1Local, mask);
        dstQue1.EnQue<half>(dstLocal);
        if constexpr (scenarioNum == 1) {
            srcQue2.FreeTensor(src0Local);
            srcQue3.FreeTensor(src1Local);
        } else if constexpr (scenarioNum == 2) {
            srcQue0.FreeTensor(src0Local);
            srcQue2.FreeTensor(src1Local);
        }
    }
    __aicore__ inline void CopyOut1()
    {
        AscendC::LocalTensor<half> dstLocal = dstQue1.DeQue<half>();
        AscendC::DataCopy(dstGlobal, dstLocal, mask);
        dstQue1.FreeTensor(dstLocal);
    }

private:
    AscendC::TPipe* pipe;
    AscendC::TBufPool<AscendC::TPosition::VECCALC> tbufPool0, tbufPool1, tbufPool2;
    MyBufPool myBufPool0; // 自定义TBufPool
    AscendC::TBuf<AscendC::TPosition::VECIN> srcBuf1;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> srcQue0, srcQue1, srcQue2, srcQue3;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> dstQue0, dstQue1;
    AscendC::GlobalTensor<half> src0Global, src1Global, dstGlobal;
};

__global__ __vector__ void tbufpool_management_custom(__gm__ uint8_t* x, __gm__ uint8_t* y, __gm__ uint8_t* z)
{
    AscendC::TPipe pipe;
    if constexpr (scenarioNum == 1) {
        // 场景1：TBufPool内存复用
        KernelBufPool<65536, 512> op;
        op.Init(x, y, z, &pipe);
        op.ProcessBufPoolReuse();
    } else if constexpr (scenarioNum == 2) {
        // 场景2：TBufPool资源细分
        KernelBufPool<32768, 16384> op;
        op.Init(x, y, z, &pipe);
        op.ProcessBufPoolSubdivision();
    } else if constexpr (scenarioNum == 3) {
        // 场景3：自定义TBufPool
        KernelBufPool<65536, 32768> op;
        op.Init(x, y, z, &pipe);
        op.ProcessCustomizedBufPool();
    } else {
        AscendC::printf("scenarioNum %d is not supported!\n", scenarioNum);
    }
}

int32_t main(int32_t argc, char* argv[])
{
    uint32_t numBlocks = 1;
    size_t inputByteSize = 0;
    size_t outputByteSize = 0;

    if constexpr (scenarioNum == 1) {
        inputByteSize = 3 * 65536 * sizeof(half);
        outputByteSize = 3 * 65536 * sizeof(half);
    } else if constexpr (scenarioNum == 2) {
        inputByteSize = 4 * 32768 * sizeof(half);
        outputByteSize = 4 * 32768 * sizeof(half);
    } else if constexpr (scenarioNum == 3) {
        inputByteSize = 65536 * sizeof(half);
        outputByteSize = 65536 * sizeof(half);
    }

    int32_t deviceId = 0;
    aclError ret = aclrtSetDevice(deviceId);
    assert(ret == ACL_SUCCESS && "aclrtSetDevice failed!");
    aclrtStream stream = nullptr;
    ret = aclrtCreateStream(&stream);
    assert(ret == ACL_SUCCESS && "aclrtCreateStream failed!");

    uint8_t *xHost, *yHost, *zHost;
    uint8_t *xDevice, *yDevice, *zDevice;

    ret = aclrtMallocHost((void**)(&xHost), inputByteSize);
    assert(ret == ACL_SUCCESS && "aclrtMallocHost xHost failed!");
    ret = aclrtMallocHost((void**)(&yHost), inputByteSize);
    assert(ret == ACL_SUCCESS && "aclrtMallocHost yHost failed!");
    ret = aclrtMallocHost((void**)(&zHost), outputByteSize);
    assert(ret == ACL_SUCCESS && "aclrtMallocHost zHost failed!");
    ret = aclrtMalloc((void**)&xDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    assert(ret == ACL_SUCCESS && "aclrtMalloc xDevice failed!");
    ret = aclrtMalloc((void**)&yDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    assert(ret == ACL_SUCCESS && "aclrtMalloc yDevice failed!");
    ret = aclrtMalloc((void**)&zDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    assert(ret == ACL_SUCCESS && "aclrtMalloc zDevice failed!");

    ReadFile("./input/input_x.bin", inputByteSize, xHost, inputByteSize);
    ReadFile("./input/input_y.bin", inputByteSize, yHost, inputByteSize);

    ret = aclrtMemcpy(xDevice, inputByteSize, xHost, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
    assert(ret == ACL_SUCCESS && "aclrtMemcpy xHost to xDevice failed!");
    ret = aclrtMemcpy(yDevice, inputByteSize, yHost, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
    assert(ret == ACL_SUCCESS && "aclrtMemcpy yHost to yDevice failed!");

    tbufpool_management_custom<<<numBlocks, nullptr, stream>>>(xDevice, yDevice, zDevice);
    ret = aclrtSynchronizeStream(stream);
    assert(ret == ACL_SUCCESS && "aclrtSynchronizeStream failed!");

    ret = aclrtMemcpy(zHost, outputByteSize, zDevice, outputByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    assert(ret == ACL_SUCCESS && "aclrtMemcpy zDevice to zHost failed!");
    WriteFile("./output/output.bin", zHost, outputByteSize);

    if (xDevice != nullptr) {
        aclrtFree(xDevice);
        xDevice = nullptr;
    }
    if (yDevice != nullptr) {
        aclrtFree(yDevice);
        yDevice = nullptr;
    }
    if (zDevice != nullptr) {
        aclrtFree(zDevice);
        zDevice = nullptr;
    }
    if (xHost != nullptr) {
        aclrtFreeHost(xHost);
        xHost = nullptr;
    }
    if (yHost != nullptr) {
        aclrtFreeHost(yHost);
        yHost = nullptr;
    }
    if (zHost != nullptr) {
        aclrtFreeHost(zHost);
        zHost = nullptr;
    }

    if (stream != nullptr) {
        aclrtDestroyStream(stream);
        stream = nullptr;
    }

    aclrtResetDevice(deviceId);
    aclFinalize();

    return 0;
}
