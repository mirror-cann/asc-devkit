/* !
 * \file tensor_allocation.asc
 * \brief allocation and usage of GlobalTensor, LocalTensor, and RegTensor
 */

#include <cstdint>
#include <vector>
#include <algorithm>
#include <iterator>
#include <iostream>
#include <cmath>

#include "acl/acl.h"

#include "kernel_operator.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

constexpr uint32_t scenarioNum = SCENARIO_NUM;

template <typename T, uint32_t TOTAL_LENGTH>
class TensorAllocationKernel {
public:
    __aicore__ inline TensorAllocationKernel(){};
    __aicore__ inline void Init(__gm__ T* x, __gm__ T* y, __gm__ T* z);
    __aicore__ inline void Process1();
    __aicore__ inline void Process2();
    __aicore__ inline void Process3();
    __aicore__ inline void Process4();

private:
    AscendC::GlobalTensor<T> xGlobal;
    AscendC::GlobalTensor<T> yGlobal;
    AscendC::GlobalTensor<T> zGlobal;
};

template <typename T, uint32_t TOTAL_LENGTH>
__aicore__ inline void TensorAllocationKernel<T, TOTAL_LENGTH>::Init(__gm__ T* x, __gm__ T* y, __gm__ T* z)
{
    xGlobal.SetGlobalBuffer(x, TOTAL_LENGTH);
    yGlobal.SetGlobalBuffer(y, TOTAL_LENGTH);
    zGlobal.SetGlobalBuffer(z, TOTAL_LENGTH);
}

template <typename T, uint32_t TOTAL_LENGTH>
__aicore__ inline void TensorAllocationKernel<T, TOTAL_LENGTH>::Process1()
{
    AscendC::TPipe pipe;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> inQueueX;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> inQueueY;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> outQueueZ;
    pipe.InitBuffer(inQueueX, 1, TOTAL_LENGTH * sizeof(T));
    pipe.InitBuffer(inQueueY, 1, TOTAL_LENGTH * sizeof(T));
    pipe.InitBuffer(outQueueZ, 1, TOTAL_LENGTH * sizeof(T));
    AscendC::LocalTensor<T> xLocal;
    AscendC::LocalTensor<T> yLocal;
    AscendC::LocalTensor<T> zLocal;

    xLocal = inQueueX.AllocTensor<T>();
    yLocal = inQueueY.AllocTensor<T>();
    AscendC::DataCopy(xLocal, xGlobal, TOTAL_LENGTH);
    AscendC::DataCopy(yLocal, yGlobal, TOTAL_LENGTH);
    inQueueX.EnQue(xLocal);
    inQueueY.EnQue(yLocal);

    xLocal = inQueueX.DeQue<T>();
    yLocal = inQueueY.DeQue<T>();
    zLocal = outQueueZ.AllocTensor<T>();
    AscendC::Add(zLocal, xLocal, yLocal, TOTAL_LENGTH);
    outQueueZ.EnQue<T>(zLocal);
    inQueueX.FreeTensor(xLocal);
    inQueueY.FreeTensor(yLocal);

    zLocal = outQueueZ.DeQue<T>();
    AscendC::DataCopy(zGlobal, zLocal, TOTAL_LENGTH);
    outQueueZ.FreeTensor(zLocal);
}

template <typename T, uint32_t TOTAL_LENGTH>
__aicore__ inline void TensorAllocationKernel<T, TOTAL_LENGTH>::Process2()
{
    AscendC::LocalMemAllocator<AscendC::Hardware::UB> ubAllocator;
    AscendC::LocalTensor<T> xLocal = ubAllocator.Alloc<T, TOTAL_LENGTH>();
    AscendC::LocalTensor<T> yLocal = ubAllocator.Alloc<T>(TOTAL_LENGTH);
    AscendC::LocalTensor<T> zLocal = ubAllocator.Alloc<T>(TOTAL_LENGTH);

    AscendC::DataCopy(xLocal, xGlobal, TOTAL_LENGTH);
    AscendC::DataCopy(yLocal, yGlobal, TOTAL_LENGTH);

    AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
    AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);

    AscendC::Add(zLocal, xLocal, yLocal, TOTAL_LENGTH);

    AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
    AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);

    AscendC::DataCopy(zGlobal, zLocal, TOTAL_LENGTH);
}

template <typename T, uint32_t TOTAL_LENGTH>
__aicore__ inline void TensorAllocationKernel<T, TOTAL_LENGTH>::Process3()
{
    constexpr uint32_t xAddr = 0;
    constexpr uint32_t yAddr = TOTAL_LENGTH * sizeof(T);
    constexpr uint32_t zAddr = yAddr + TOTAL_LENGTH * sizeof(T);

    AscendC::LocalTensor<T> xLocal(AscendC::TPosition::VECIN, xAddr, TOTAL_LENGTH);
    AscendC::LocalTensor<T> yLocal(AscendC::TPosition::VECIN, yAddr, TOTAL_LENGTH);
    AscendC::LocalTensor<T> zLocal(AscendC::TPosition::VECOUT, zAddr, TOTAL_LENGTH);

    AscendC::DataCopy(xLocal, xGlobal, TOTAL_LENGTH);
    AscendC::DataCopy(yLocal, yGlobal, TOTAL_LENGTH);

    AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
    AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);

    AscendC::Add(zLocal, xLocal, yLocal, TOTAL_LENGTH);

    AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
    AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);

    AscendC::DataCopy(zGlobal, zLocal, TOTAL_LENGTH);
}

#if defined(__NPU_ARCH__) && (__NPU_ARCH__ == 3510)
template <typename T>
__simd_vf__ inline void AddVF(
    __ubuf__ T* xAddr, __ubuf__ T* yAddr, __ubuf__ T* zAddr, uint32_t repeatTimes, uint32_t oneRepeatSize)
{
    AscendC::Reg::MaskReg mask = AscendC::Reg::CreateMask<T, AscendC::Reg::MaskPattern::ALL>();
    AscendC::Reg::RegTensor<T> xReg, yReg, zReg;
    for (uint16_t i = 0; i < repeatTimes; ++i) {
        AscendC::Reg::LoadAlign(xReg, xAddr + i * oneRepeatSize);
        AscendC::Reg::LoadAlign(yReg, yAddr + i * oneRepeatSize);
        AscendC::Reg::Add(zReg, yReg, xReg, mask);
        AscendC::Reg::StoreAlign(zAddr + i * oneRepeatSize, zReg, mask);
    }
}
#endif

template <typename T, uint32_t TOTAL_LENGTH>
__aicore__ inline void TensorAllocationKernel<T, TOTAL_LENGTH>::Process4()
{
#if defined(__NPU_ARCH__) && (__NPU_ARCH__ == 3510)
    AscendC::LocalMemAllocator<AscendC::Hardware::UB> ubAllocator;
    AscendC::LocalTensor<T> xLocal = ubAllocator.Alloc<T, TOTAL_LENGTH>();
    AscendC::LocalTensor<T> yLocal = ubAllocator.Alloc<T>(TOTAL_LENGTH);
    AscendC::LocalTensor<T> zLocal = ubAllocator.Alloc<T>(TOTAL_LENGTH);

    AscendC::DataCopy(xLocal, xGlobal, TOTAL_LENGTH);
    AscendC::DataCopy(yLocal, yGlobal, TOTAL_LENGTH);

    AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
    AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);

    __ubuf__ T* xAddr = reinterpret_cast<__ubuf__ T*>(xLocal.GetPhyAddr());
    __ubuf__ T* yAddr = reinterpret_cast<__ubuf__ T*>(yLocal.GetPhyAddr());
    __ubuf__ T* zAddr = reinterpret_cast<__ubuf__ T*>(zLocal.GetPhyAddr());
    constexpr uint32_t oneRepeatSize = AscendC::GetVecLen() / sizeof(T);
    uint16_t repeatTimes = AscendC::CeilDivision(TOTAL_LENGTH, oneRepeatSize);
    asc_vf_call<AddVF<T>>(xAddr, yAddr, zAddr, repeatTimes, oneRepeatSize);

    AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
    AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);

    AscendC::DataCopy(zGlobal, zLocal, TOTAL_LENGTH);
#endif
}

template <typename T, uint32_t TOTAL_LENGTH>
__vector__ __global__ void tensor_allocate_custom(__gm__ T* x, __gm__ T* y, __gm__ T* z)
{
    AscendC::InitSocState();
    TensorAllocationKernel<T, TOTAL_LENGTH> op;
    op.Init(x, y, z);
    if constexpr (scenarioNum == 1) {
        op.Process1();
    } else if constexpr (scenarioNum == 2) {
        op.Process2();
    } else if constexpr (scenarioNum == 3) {
        op.Process3();
    } else if constexpr (scenarioNum == 4) {
        op.Process4();
    }
    AscendC::PipeBarrier<PIPE_ALL>();
}

template <typename T, uint32_t TOTAL_LENGTH>
std::vector<T> kernel_tensor_allocate(std::vector<T>& x, std::vector<T>& y)
{
    size_t dataByteSize = TOTAL_LENGTH * sizeof(T);
    constexpr uint32_t blockNum = 1;
    T* xDevice = nullptr;
    T* yDevice = nullptr;
    T* zDevice = nullptr;
    uint8_t* zHost = nullptr;

    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    aclrtMalloc((void**)&xDevice, dataByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&yDevice, dataByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&zDevice, dataByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMallocHost((void**)&zHost, dataByteSize);

    aclrtMemcpy(xDevice, dataByteSize, x.data(), dataByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(yDevice, dataByteSize, y.data(), dataByteSize, ACL_MEMCPY_HOST_TO_DEVICE);

    tensor_allocate_custom<T, TOTAL_LENGTH><<<blockNum, 0, stream>>>(xDevice, yDevice, zDevice);
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(zHost, dataByteSize, zDevice, dataByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    std::vector<T> z((T*)zHost, (T*)(zHost + dataByteSize));

    aclrtFree(xDevice);
    aclrtFree(yDevice);
    aclrtFree(zDevice);
    aclrtFreeHost(zHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();

    return z;
}

template <typename T>
uint32_t VerifyResult(std::vector<T>& output, std::vector<T>& golden)
{
    constexpr T tolerance = 1e-3f;
    for (size_t i = 0; i < golden.size(); ++i) {
        if (std::fabs(output[i] - golden[i]) > tolerance) {
            std::cout << "test failed! diff at index " << i << ": output=" << output[i] << ", golden=" << golden[i]
                      << std::endl;
            return 1;
        }
    }
    std::cout << "test pass!" << std::endl;
    return 0;
}

int32_t main(int32_t argc, char* argv[])
{
    constexpr uint32_t total_length = 1024;
    std::vector<float> x(total_length);
    std::vector<float> y(total_length);
    std::vector<float> golden(total_length);

    for (uint32_t i = 0; i < total_length; ++i) {
        x[i] = (i % 100) * 0.1f;
        y[i] = ((i + 50) % 100) * 0.2f;
        golden[i] = x[i] + y[i];
    }

    std::vector<float> output = kernel_tensor_allocate<float, total_length>(x, y);

    return VerifyResult<float>(output, golden);
}
