#include "acl/acl.h"
#include "kernel_operator.h"
#include "data_utils.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

__aicore__ __inline__ constexpr uint32_t DivCeil(uint32_t a, uint32_t b) { return (a + b - 1) / b; }

constexpr uint32_t scenarioNum = SCENARIO_NUM;

template <typename T>
__simd_vf__ inline void RegSyncVf(__ubuf__ T* dataAddr, uint16_t oneRepeatSize, uint32_t repeatTimes, uint32_t count)
{
    AscendC::Reg::RegTensor<T> reg0;
    AscendC::Reg::MaskReg mask;
    __ubuf__ T* srcAddr = dataAddr;
    __ubuf__ T* dstAddr = dataAddr;
    for (uint16_t i = 0; i < repeatTimes; i++) {
        mask = AscendC::Reg::UpdateMask<T>(count);
        AscendC::Reg::LoadAlign<T, AscendC::Reg::PostLiteral::POST_MODE_UPDATE>(reg0, srcAddr, oneRepeatSize);
        AscendC::Reg::Exp(reg0, reg0, mask);
        AscendC::Reg::StoreAlign<T, AscendC::Reg::PostLiteral::POST_MODE_UPDATE>(dstAddr, reg0, oneRepeatSize, mask);
    }
}

constexpr float maxInitValue = -10000.0;
template <typename T>
__simd_vf__ inline void SoftmaxVf(
    __ubuf__ T* dstAddr, __ubuf__ T* srcAddr, __ubuf__ T* tmpAddr, uint16_t oneRepeatSize, uint32_t repeatTimes,
    uint32_t dataSize)
{
    AscendC::Reg::RegTensor<T> srcReg;
    AscendC::Reg::MaskReg mask;
    AscendC::Reg::MaskReg fullMask = AscendC::Reg::CreateMask<T, AscendC::Reg::MaskPattern::ALL>();

    // 求 max = Max(src)
    AscendC::Reg::RegTensor<T> maxReg;
    AscendC::Reg::RegTensor<T> tmpReg;
    AscendC::Reg::Duplicate(maxReg, maxInitValue, fullMask);
    __ubuf__ T* srcBufAddr = srcAddr;
    uint32_t count = dataSize;
    for (uint16_t i = 0; i < repeatTimes; i++) {
        mask = AscendC::Reg::UpdateMask<T>(count);
        AscendC::Reg::LoadAlign<T, AscendC::Reg::PostLiteral::POST_MODE_UPDATE>(srcReg, srcBufAddr, oneRepeatSize);
        AscendC::Reg::Max(maxReg, maxReg, srcReg, mask);
    }
    AscendC::Reg::Reduce<AscendC::Reg::ReduceType::MAX>(tmpReg, maxReg, fullMask);
    AscendC::Reg::Duplicate(maxReg, tmpReg, fullMask);

    // 求 exp(src - max)，exp结果暂存到 UBUF 中，然后求 sum(exp)
    AscendC::Reg::RegTensor<T> subReg;
    AscendC::Reg::RegTensor<T> expReg;
    AscendC::Reg::RegTensor<T> sumReg;
    AscendC::Reg::Duplicate(sumReg, 0, fullMask);
    count = dataSize;
    __ubuf__ T* tmpBufAddr = tmpAddr;
    srcBufAddr = srcAddr;
    for (uint16_t i = 0; i < repeatTimes; i++) {
        mask = AscendC::Reg::UpdateMask<T>(count);
        AscendC::Reg::LoadAlign<T, AscendC::Reg::PostLiteral::POST_MODE_UPDATE>(srcReg, srcBufAddr, oneRepeatSize);
        AscendC::Reg::Sub(subReg, srcReg, maxReg, mask);
        AscendC::Reg::Exp(expReg, subReg, mask);
        AscendC::Reg::StoreAlign<T, AscendC::Reg::PostLiteral::POST_MODE_UPDATE>(
            tmpBufAddr, expReg, oneRepeatSize, mask);
        AscendC::Reg::Add(sumReg, sumReg, expReg, mask);
    }
    AscendC::Reg::Reduce<AscendC::Reg::ReduceType::SUM>(tmpReg, sumReg, fullMask);
    AscendC::Reg::Duplicate(sumReg, tmpReg, fullMask);

    // 写读依赖：上一步写入tmpAddr，下一步读取tmpAddr，中间需要插入写读同步，手动保证数据搬运的时序。
    AscendC::Reg::LocalMemBar<AscendC::Reg::MemType::VEC_STORE, AscendC::Reg::MemType::VEC_LOAD>();

    // 从 UBUF 取出暂存的 exp，求 exp / sum，结果搬出
    AscendC::Reg::RegTensor<T> dstReg;
    tmpBufAddr = tmpAddr;
    count = dataSize;
    for (uint16_t i = 0; i < repeatTimes; i++) {
        mask = AscendC::Reg::UpdateMask<T>(count);
        AscendC::Reg::LoadAlign<T, AscendC::Reg::PostLiteral::POST_MODE_UPDATE>(expReg, tmpBufAddr, oneRepeatSize);
        AscendC::Reg::Div(dstReg, expReg, sumReg, mask);
        AscendC::Reg::StoreAlign<T, AscendC::Reg::PostLiteral::POST_MODE_UPDATE>(dstAddr, dstReg, oneRepeatSize, mask);
    }
}

template <typename T, uint32_t count>
__global__ __vector__ void reg_sync(__gm__ uint8_t* x, __gm__ uint8_t* z)
{
    AscendC::InitSocState();

    AscendC::GlobalTensor<T> xGm, zGm;
    xGm.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(x));
    zGm.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(z));

    AscendC::LocalMemAllocator<AscendC::Hardware::UB> ubAllocator;
    AscendC::LocalTensor<T> xLocal = ubAllocator.Alloc<T, count>();
    __ubuf__ T* xAddr = reinterpret_cast<__ubuf__ T*>(xLocal.GetPhyAddr());

    AscendC::DataCopy(xLocal, xGm, count);
    AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
    AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);

    constexpr uint32_t oneRepeatSize = AscendC::GetVecLen() / sizeof(T);
    uint16_t repeatTimes = DivCeil(count, oneRepeatSize);

    if constexpr (scenarioNum == 1) {
        asc_vf_call<RegSyncVf<T>>(xAddr, oneRepeatSize, repeatTimes, count);

        AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        AscendC::DataCopy(zGm, xLocal, count);
    } else {
        AscendC::LocalTensor<T> tmpLocal = ubAllocator.Alloc<T, count>();
        __ubuf__ T* tmpAddr = reinterpret_cast<__ubuf__ T*>(tmpLocal.GetPhyAddr());
        AscendC::LocalTensor<T> zLocal = ubAllocator.Alloc<T, count>();
        __ubuf__ T* zAddr = reinterpret_cast<__ubuf__ T*>(zLocal.GetPhyAddr());

        asc_vf_call<SoftmaxVf<T>>(zAddr, xAddr, tmpAddr, oneRepeatSize, repeatTimes, count);

        AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        AscendC::DataCopy(zGm, zLocal, count);
    }
    AscendC::PipeBarrier<PIPE_ALL>();
}

static bool CompareResult(const void* outputData, uint32_t outSize)
{
    void* goldenData;
    aclrtMallocHost((void**)(&goldenData), outSize);
    size_t goldenSize = outSize;

    bool ret = ReadFile("./output/golden.bin", goldenSize, goldenData, goldenSize);
    if (ret) {
        printf("ReadFile golden.bin success!\n");
    } else {
        printf("test failed!\n");
        aclrtFreeHost(goldenData);
        return false;
    }

    constexpr float EPS = 1e-4;
    int64_t wrongNum = 0;

    for (size_t i = 0; i < outSize / sizeof(float); i++) {
        float a = (reinterpret_cast<const float*>(outputData))[i];
        float b = (reinterpret_cast<const float*>(goldenData))[i];
        float ae = std::abs(a - b);
        float re = ae / std::abs(b + EPS);
        if (ae > EPS && re > EPS) {
            printf("CompareResult golden.bin failed output is %lf, golden is %lf\n", a, b);
            wrongNum++;
        }
    }

    aclrtFreeHost(goldenData);
    if (wrongNum != 0) {
        return false;
    } else {
        printf("CompareResult golden.bin success!\n");
        return true;
    }
}

int32_t main(int32_t argc, char* argv[])
{
    uint32_t numBlocks = 1;
    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);
    constexpr uint32_t count = 1024;
    size_t inputByteSize = static_cast<size_t>(1) * count * sizeof(float);
    size_t outputByteSize = static_cast<size_t>(1) * count * sizeof(float);
    uint8_t *xHost, *zHost;
    uint8_t *xDevice, *zDevice;
    aclrtMallocHost((void**)(&xHost), inputByteSize);
    aclrtMallocHost((void**)(&zHost), outputByteSize);
    aclrtMalloc((void**)&xDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&zDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/input_x.bin", inputByteSize, xHost, inputByteSize);
    aclrtMemcpy(xDevice, inputByteSize, xHost, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
    reg_sync<float, count><<<numBlocks, nullptr, stream>>>(xDevice, zDevice);
    aclrtSynchronizeStream(stream);
    aclrtMemcpy(zHost, outputByteSize, zDevice, outputByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", zHost, outputByteSize);
    bool goldenResult = CompareResult(zHost, outputByteSize);
    if (goldenResult) {
        printf("test pass!\n");
    } else {
        printf("test failed!\n");
    }
    aclrtFree(xDevice);
    aclrtFree(zDevice);
    aclrtFreeHost(xHost);
    aclrtFreeHost(zHost);
    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();
    return 0;
}
