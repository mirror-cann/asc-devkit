/*!
 * \file ms_sanitizer.asc
 * \brief 基于Add的msSanitizer调测样例。
 */
#include <algorithm>
#include <cstdint>
#include <iostream>
#include <iterator>
#include <vector>

#include "acl/acl.h"
#include "kernel_operator.h"

template <typename T, uint32_t blockLength>
__global__ __vector__ void add_custom(__gm__ T* x, __gm__ T* y, __gm__ T* z)
{
    AscendC::InitSocState();

    AscendC::GlobalTensor<T> xGm;
    AscendC::GlobalTensor<T> yGm;
    AscendC::GlobalTensor<T> zGm;
    xGm.SetGlobalBuffer(x + block_idx * blockLength, blockLength);
    yGm.SetGlobalBuffer(y + block_idx * blockLength, blockLength);
    // 正确初始化zGm。删除该行后，可触发未初始化检测。
    zGm.SetGlobalBuffer(z + block_idx * blockLength, blockLength);

    AscendC::LocalMemAllocator<AscendC::Hardware::UB> ubAllocator;
    AscendC::LocalTensor<T> xLocal = ubAllocator.Alloc<T, blockLength>();
    AscendC::LocalTensor<T> yLocal = ubAllocator.Alloc<T, blockLength>();
    AscendC::LocalTensor<T> zLocal = ubAllocator.Alloc<T, blockLength>();

    // 1. 正确的DataCopy。
    AscendC::DataCopy(xLocal, xGm, blockLength);
    // 2. 错误示例：搬运长度写成blockLength * 2，会触发非法读写。
    // AscendC::DataCopy(xLocal, xGm, blockLength * 2);
    // 3. 错误示例：xLocal[5]不满足32B对齐要求，会触发非对齐访问。
    // AscendC::DataCopy(xLocal[5], xGm, blockLength);

    AscendC::DataCopy(yLocal, yGm, blockLength);

    // Add读取xLocal/yLocal前，需要等待MTE2搬运完成；删除后会触发RAW竞争。
    AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
    AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);

    AscendC::Add(zLocal, xLocal, yLocal, blockLength);

    // MTE3搬出zLocal前，需要等待Vector计算完成。
    AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
    AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
    AscendC::DataCopy(zGm, zLocal, blockLength);
    AscendC::PipeBarrier<PIPE_ALL>();
}

template <typename T>
std::vector<T> kernel_add(std::vector<T> &x, std::vector<T> &y)
{
    constexpr uint32_t numBlocks = 8;
    constexpr uint32_t blockLength = 2048;
    uint32_t totalLength = x.size();
    size_t totalByteSize = totalLength * sizeof(T);
    int32_t deviceId = 0;
    aclrtStream stream = nullptr;
    T* xDevice = nullptr;
    T* yDevice = nullptr;
    T* zDevice = nullptr;
    std::vector<T> z(totalLength);

    aclInit(nullptr);
    aclrtSetDevice(deviceId);
    aclrtCreateStream(&stream);

    // 1. 正确的Device侧输入内存申请。
    aclrtMalloc((void**)&xDevice, totalByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    // 2. 错误示例：实际只使用totalByteSize，却申请5倍大小，会触发未使用内存检测。
    // aclrtMalloc((void**)&xDevice, totalByteSize * 5, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&yDevice, totalByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&zDevice, totalByteSize, ACL_MEM_MALLOC_HUGE_FIRST);

    aclrtMemcpy(xDevice, totalByteSize, x.data(), totalByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(yDevice, totalByteSize, y.data(), totalByteSize, ACL_MEMCPY_HOST_TO_DEVICE);

    add_custom<T, blockLength><<<numBlocks, nullptr, stream>>>(xDevice, yDevice, zDevice);
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(z.data(), totalByteSize, zDevice, totalByteSize, ACL_MEMCPY_DEVICE_TO_HOST);

    aclrtFree(xDevice);
    aclrtFree(yDevice);
    // 正确释放Device侧输出内存。删除该行后，可触发内存泄漏检测。
    aclrtFree(zDevice);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();

    return z;
}

template <typename T>
uint32_t VerifyResult(std::vector<T> &output, std::vector<T> &golden)
{
    auto printTensor = [](std::vector<T> &tensor, const char *name) {
        constexpr size_t maxPrintSize = 20;
        std::cout << name << ": ";
        std::copy(tensor.begin(), tensor.begin() + std::min(tensor.size(), maxPrintSize),
            std::ostream_iterator<T>(std::cout, " "));
        if (tensor.size() > maxPrintSize) {
            std::cout << "...";
        }
        std::cout << std::endl;
    };
    printTensor(output, "Output");
    printTensor(golden, "Golden");
    if (std::equal(golden.begin(), golden.end(), output.begin())) {
        std::cout << "test pass!" << std::endl;
        return 0;
    } else {
        std::cout << "test failed!" << std::endl;
        return 1;
    }
}

int32_t main(int32_t argc, char* argv[])
{
    using DataType = float;
    constexpr uint32_t totalLength = 8 * 2048;
    std::vector<DataType> x(totalLength);
    std::vector<DataType> y(totalLength);
    for (uint32_t i = 0; i < totalLength; ++i) {
        x[i] = static_cast<DataType>(i * 0.1f);
        y[i] = static_cast<DataType>(i * 0.2f);
    }

    std::vector<DataType> output = kernel_add(x, y);

    std::vector<DataType> golden(totalLength);
    for (uint32_t i = 0; i < totalLength; ++i) {
        golden[i] = x[i] + y[i];
    }
    return VerifyResult(output, golden);
}
