/*!
 * \file cube_buffer_dump.asc
 * \brief 以dav-3510 HiFloat8量化MatMul为背景，打印L1、Bias Table Buffer和Fixpipe Buffer中的关键数据
 */

#include <cstdint>
#include <iostream>
#include <vector>
#include "acl/acl.h"
#include "data_utils.h"
#include "kernel_operator.h"

namespace {
constexpr uint32_t MATMUL_M = 16;
constexpr uint32_t MATMUL_N = 16;
constexpr uint32_t MATMUL_K = 32;
constexpr uint32_t A_ELEMENT_COUNT = MATMUL_M * MATMUL_K;
constexpr uint32_t B_ELEMENT_COUNT = MATMUL_K * MATMUL_N;
constexpr uint32_t BIAS_ELEMENT_COUNT = MATMUL_N;
constexpr uint32_t QUANT_ELEMENT_COUNT = MATMUL_N;
constexpr uint32_t OUTPUT_ELEMENT_COUNT = MATMUL_M * MATMUL_N;
constexpr uint32_t A_L1_DUMP_ELEMENT_COUNT = 32;
constexpr uint32_t MMAD_N = 32;
constexpr uint32_t B_L1_ELEMENT_COUNT = MATMUL_K * MMAD_N;
constexpr uint32_t L0C_ELEMENT_COUNT = MATMUL_M * MMAD_N;

constexpr uint32_t A_DATA_BYTES = A_ELEMENT_COUNT * sizeof(uint8_t);
constexpr uint32_t B_DATA_BYTES = B_ELEMENT_COUNT * sizeof(uint8_t);
constexpr uint32_t B_L1_DATA_BYTES = B_L1_ELEMENT_COUNT * sizeof(uint8_t);
constexpr uint32_t BIAS_DATA_BYTES = BIAS_ELEMENT_COUNT * sizeof(float);
constexpr uint32_t QUANT_DATA_BYTES = QUANT_ELEMENT_COUNT * sizeof(uint64_t);
constexpr uint32_t OUTPUT_DATA_BYTES = OUTPUT_ELEMENT_COUNT * sizeof(uint16_t);
constexpr uint32_t DATA_BLOCK_BYTES = 32;
constexpr uint32_t FIXPIPE_BLOCK_BYTES = 64;

constexpr uint64_t A_L1_ADDR = 0;
constexpr uint64_t B_L1_ADDR = A_L1_ADDR + A_DATA_BYTES;
constexpr uint64_t BIAS_L1_ADDR = B_L1_ADDR + B_L1_DATA_BYTES;
constexpr uint64_t QUANT_L1_ADDR = BIAS_L1_ADDR + BIAS_DATA_BYTES;
constexpr uint64_t BIAS_BT_ADDR = 0;
constexpr uint64_t QUANT_FIXPIPE_ADDR = 0;

} // namespace

class KernelQuantMatmulHifp8 {
public:
    __aicore__ inline void Init(GM_ADDR aInput, GM_ADDR bInput, GM_ADDR biasInput, GM_ADDR quantInput, GM_ADDR output)
    {
        aGm.SetGlobalBuffer((__gm__ hifloat8_t*)aInput, A_ELEMENT_COUNT);
        bGm.SetGlobalBuffer((__gm__ hifloat8_t*)bInput, B_ELEMENT_COUNT);
        biasGm.SetGlobalBuffer((__gm__ float*)biasInput, BIAS_ELEMENT_COUNT);
        quantGm.SetGlobalBuffer((__gm__ uint64_t*)quantInput, QUANT_ELEMENT_COUNT);
        outputGm.SetGlobalBuffer((__gm__ bfloat16_t*)output, OUTPUT_ELEMENT_COUNT);
    }

    __aicore__ inline void Process()
    {
        AscendC::LocalTensor<hifloat8_t> aL1(AscendC::TPosition::A1, A_L1_ADDR, A_ELEMENT_COUNT);
        AscendC::LocalTensor<hifloat8_t> bL1(AscendC::TPosition::B1, B_L1_ADDR, B_L1_ELEMENT_COUNT);
        AscendC::LocalTensor<float> biasL1(AscendC::TPosition::C1, BIAS_L1_ADDR, BIAS_ELEMENT_COUNT);
        AscendC::LocalTensor<uint64_t> quantL1(AscendC::TPosition::C1, QUANT_L1_ADDR, QUANT_ELEMENT_COUNT);

        CopyInputsToL1(aL1, bL1, biasL1, quantL1);
        DumpL1Inputs(aL1, biasL1, quantL1);

        AscendC::LocalTensor<float> biasBt(AscendC::TPosition::C2, BIAS_BT_ADDR, BIAS_ELEMENT_COUNT);
        AscendC::LocalTensor<uint64_t> quantFixpipe(
            AscendC::TPosition::C2PIPE2GM, QUANT_FIXPIPE_ADDR, QUANT_ELEMENT_COUNT);
        AscendC::LocalTensor<hifloat8_t> aL0(AscendC::TPosition::A2, 0, A_ELEMENT_COUNT);
        AscendC::LocalTensor<hifloat8_t> bL0(AscendC::TPosition::B2, 0, B_L1_ELEMENT_COUNT);

        CopyL1ToSpecialBuffers(biasBt, biasL1, quantFixpipe, quantL1);
        CopyL1ToL0(aL0, aL1, bL0, bL1);
        AscendC::PipeBarrier<PIPE_ALL>();
        DumpSpecialBuffers(biasBt, quantFixpipe);

        AscendC::LocalTensor<float> cL0(AscendC::TPosition::CO1, 0, L0C_ELEMENT_COUNT);
        Compute(cL0, aL0, bL0, biasBt);
        CopyOutput(cL0, quantFixpipe);
    }

private:
    __aicore__ inline void CopyInputsToL1(
        const AscendC::LocalTensor<hifloat8_t>& aL1, const AscendC::LocalTensor<hifloat8_t>& bL1,
        const AscendC::LocalTensor<float>& biasL1, const AscendC::LocalTensor<uint64_t>& quantL1)
    {
        AscendC::Nd2NzParams aParams{1, MATMUL_M, MATMUL_K, 0, MATMUL_K, MATMUL_M, 1, 0};
        AscendC::Nd2NzParams bParams{1, MATMUL_K, MATMUL_N, 0, MATMUL_N, MATMUL_K, 1, 0};
        AscendC::Nd2NzParams biasParams{1, 1, MATMUL_N, 0, MATMUL_N, 1, 1, 0};
        AscendC::DataCopy(aL1, aGm, aParams);
        AscendC::DataCopy(bL1, bGm, bParams);
        AscendC::DataCopy(biasL1, biasGm, biasParams);
        AscendC::DataCopy(quantL1, quantGm, QUANT_ELEMENT_COUNT);
        AscendC::SetFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID0);
    }

    __aicore__ inline void DumpL1Inputs(
        const AscendC::LocalTensor<hifloat8_t>& aL1, const AscendC::LocalTensor<float>& biasL1,
        const AscendC::LocalTensor<uint64_t>& quantL1)
    {
        AscendC::printf("========== QuantMatmulHifp8 matrix A in L1 Buffer ==========\n");
        AscendC::DumpTensor(aL1, 100, A_L1_DUMP_ELEMENT_COUNT);
        AscendC::printf("========== QuantMatmulHifp8 bias in L1 Buffer ==========\n");
        AscendC::DumpTensor(biasL1, 101, BIAS_ELEMENT_COUNT);
        AscendC::printf("========== QuantMatmulHifp8 per-channel scale in L1 Buffer ==========\n");
        AscendC::DumpTensor(quantL1, 102, QUANT_ELEMENT_COUNT);
    }

    __aicore__ inline void CopyL1ToSpecialBuffers(
        const AscendC::LocalTensor<float>& biasBt, const AscendC::LocalTensor<float>& biasL1,
        const AscendC::LocalTensor<uint64_t>& quantFixpipe, const AscendC::LocalTensor<uint64_t>& quantL1)
    {
        AscendC::DataCopyParams biasParams{1, BIAS_DATA_BYTES / DATA_BLOCK_BYTES, 0, 0};
        AscendC::DataCopy(biasBt, biasL1, biasParams);
        AscendC::DataCopyParams quantParams{1, QUANT_DATA_BYTES / FIXPIPE_BLOCK_BYTES, 0, 0};
        AscendC::DataCopy(quantFixpipe, quantL1, quantParams);
    }

    __aicore__ inline void CopyL1ToL0(
        const AscendC::LocalTensor<hifloat8_t>& aL0, const AscendC::LocalTensor<hifloat8_t>& aL1,
        const AscendC::LocalTensor<hifloat8_t>& bL0, const AscendC::LocalTensor<hifloat8_t>& bL1)
    {
        AscendC::LoadData2DParamsV2 aParams;
        aParams.mStep = MATMUL_M / 16;
        aParams.kStep = MATMUL_K * sizeof(hifloat8_t) / DATA_BLOCK_BYTES;
        aParams.srcStride = MATMUL_M / 16;
        aParams.dstStride = MATMUL_M / 16;
        AscendC::LoadData(aL0, aL1, aParams);

        AscendC::LoadData2DParamsV2 bParams;
        bParams.mStep = MATMUL_K / 16;
        bParams.kStep = MMAD_N * sizeof(hifloat8_t) / DATA_BLOCK_BYTES;
        bParams.srcStride = MATMUL_K / 16;
        bParams.dstStride = MMAD_N * sizeof(hifloat8_t) / DATA_BLOCK_BYTES;
        bParams.ifTranspose = true;
        AscendC::LoadData(bL0, bL1, bParams);
        AscendC::SetFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID1);
        AscendC::WaitFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID1);
    }

    __aicore__ inline void DumpSpecialBuffers(
        const AscendC::LocalTensor<float>& biasBt, const AscendC::LocalTensor<uint64_t>& quantFixpipe)
    {
        AscendC::printf("========== QuantMatmulHifp8 bias in Bias Table Buffer ==========\n");
        AscendC::DumpTensor(biasBt, 201, BIAS_ELEMENT_COUNT);
        AscendC::printf("========== QuantMatmulHifp8 per-channel scale in Fixpipe Buffer ==========\n");
        AscendC::DumpTensor(quantFixpipe, 301, QUANT_ELEMENT_COUNT);
    }

    __aicore__ inline void Compute(
        const AscendC::LocalTensor<float>& cL0, const AscendC::LocalTensor<hifloat8_t>& aL0,
        const AscendC::LocalTensor<hifloat8_t>& bL0, const AscendC::LocalTensor<float>& biasBt)
    {
        AscendC::MmadParams params;
        params.m = MATMUL_M;
        params.n = MMAD_N;
        params.k = MATMUL_K;
        params.cmatrixInitVal = false;
        AscendC::Mmad<float, hifloat8_t, hifloat8_t, float>(cL0, aL0, bL0, biasBt, params);
        AscendC::SetFlag<AscendC::HardEvent::M_FIX>(EVENT_ID2);
        AscendC::WaitFlag<AscendC::HardEvent::M_FIX>(EVENT_ID2);
    }

    __aicore__ inline void CopyOutput(
        const AscendC::LocalTensor<float>& cL0, const AscendC::LocalTensor<uint64_t>& quantFixpipe)
    {
        AscendC::SetFixPipeConfig(quantFixpipe);
        AscendC::FixpipeParamsArch3510<AscendC::CO2Layout::ROW_MAJOR> params(MATMUL_N, MATMUL_M, MATMUL_M, MATMUL_N);
        params.quantPre = QuantMode_t::VQF322BF16_PRE;
        AscendC::Fixpipe<bfloat16_t, float, AscendC::CFG_ROW_MAJOR>(outputGm, cL0, params);
    }

private:
    AscendC::GlobalTensor<hifloat8_t> aGm;
    AscendC::GlobalTensor<hifloat8_t> bGm;
    AscendC::GlobalTensor<float> biasGm;
    AscendC::GlobalTensor<uint64_t> quantGm;
    AscendC::GlobalTensor<bfloat16_t> outputGm;
};

__global__ __cube__ void QuantMatmulHifp8(
    GM_ADDR aInput, GM_ADDR bInput, GM_ADDR biasInput, GM_ADDR quantInput, GM_ADDR output)
{
    AscendC::InitSocState();
    KernelQuantMatmulHifp8 op;
    op.Init(aInput, bInput, biasInput, quantInput, output);
    op.Process();
    AscendC::PipeBarrier<PIPE_ALL>();
}

int32_t main(int32_t argc, char* argv[])
{
    std::vector<uint8_t> aInput(A_ELEMENT_COUNT);
    std::vector<uint8_t> bInput(B_ELEMENT_COUNT);
    std::vector<float> biasInput(BIAS_ELEMENT_COUNT);
    std::vector<uint64_t> quantInput(QUANT_ELEMENT_COUNT);
    std::vector<uint16_t> output(OUTPUT_ELEMENT_COUNT);
    size_t aFileSize = A_DATA_BYTES;
    size_t bFileSize = B_DATA_BYTES;
    size_t biasFileSize = BIAS_DATA_BYTES;
    size_t quantFileSize = QUANT_DATA_BYTES;
    if (!ReadFile("./input/a_gm.bin", aFileSize, aInput.data(), A_DATA_BYTES) || aFileSize != A_DATA_BYTES ||
        !ReadFile("./input/b_gm.bin", bFileSize, bInput.data(), B_DATA_BYTES) || bFileSize != B_DATA_BYTES ||
        !ReadFile("./input/bias_gm.bin", biasFileSize, biasInput.data(), BIAS_DATA_BYTES) ||
        biasFileSize != BIAS_DATA_BYTES ||
        !ReadFile("./input/scale_gm.bin", quantFileSize, quantInput.data(), QUANT_DATA_BYTES) ||
        quantFileSize != QUANT_DATA_BYTES) {
        std::cerr << "Read input failed" << std::endl;
        return 1;
    }

    uint8_t* aDevice = nullptr;
    uint8_t* bDevice = nullptr;
    uint8_t* biasDevice = nullptr;
    uint8_t* quantDevice = nullptr;
    uint8_t* outputDevice = nullptr;
    int32_t deviceId = 0;
    aclInit(nullptr);
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    aclrtMalloc((void**)&aDevice, A_DATA_BYTES, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&bDevice, B_DATA_BYTES, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&biasDevice, BIAS_DATA_BYTES, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&quantDevice, QUANT_DATA_BYTES, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&outputDevice, OUTPUT_DATA_BYTES, ACL_MEM_MALLOC_HUGE_FIRST);

    aclrtMemcpy(aDevice, A_DATA_BYTES, aInput.data(), A_DATA_BYTES, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(bDevice, B_DATA_BYTES, bInput.data(), B_DATA_BYTES, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(biasDevice, BIAS_DATA_BYTES, biasInput.data(), BIAS_DATA_BYTES, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(quantDevice, QUANT_DATA_BYTES, quantInput.data(), QUANT_DATA_BYTES, ACL_MEMCPY_HOST_TO_DEVICE);

    QuantMatmulHifp8<<<1, 0, stream>>>(aDevice, bDevice, biasDevice, quantDevice, outputDevice);
    aclrtSynchronizeStream(stream);
    aclrtMemcpy(output.data(), OUTPUT_DATA_BYTES, outputDevice, OUTPUT_DATA_BYTES, ACL_MEMCPY_DEVICE_TO_HOST);
    bool writeSuccess = WriteFile("./output/output.bin", output.data(), OUTPUT_DATA_BYTES);

    aclrtFree(outputDevice);
    aclrtFree(quantDevice);
    aclrtFree(biasDevice);
    aclrtFree(bDevice);
    aclrtFree(aDevice);
    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();
    return writeSuccess ? 0 : 1;
}
