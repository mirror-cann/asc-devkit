/*!
 * \file simd_vf_dump.asc
 * \brief 使用vector编程模式，展示simd_vf侧asc_dump_ubuf/asc_dump/asc_dump_reg接口的基本使用方法
 */

#include "acl/acl.h"
#include "utils/debug/asc_dump.h"
#include "kernel_operator.h"
#include "data_utils.h"

namespace {
constexpr uint32_t DATA_LEN = 32;
constexpr uint32_t REG_COUNT = 32;
} // namespace

// simd_vf dump演示: 使用asc_dump_ubuf打印UB数据
__simd_vf__ inline void DumpUbufData(__ubuf__ float* x)
{
    asc_dump_ubuf<float>(x, 5, 32);
    asc_dump<float>(x, 5, 16);
}

// simd_vf dump演示: 使用asc_dump_reg打印Reg数据
__simd_vf__ inline void DumpRegData(__ubuf__ float* x)
{
    AscendC::Reg::RegTensor<float> srcReg;
    AscendC::Reg::MaskReg maskReg;
    uint32_t count = REG_COUNT;
    maskReg = AscendC::Reg::UpdateMask<float>(count);
    AscendC::Reg::LoadAlign(srcReg, x);
    AscendC::Reg::Duplicate<float>(srcReg, (float)3);

    asc_dump_reg<float>(srcReg, 5, 32);
    AscendC::Reg::Duplicate<float>(srcReg, (float)4);
    asc_dump<float>(srcReg, 5, 16);
}

// simd_vf dump演示: 使用asc_dump打印UB数据
__simd_vf__ inline void DumpModifiedUbuf(__ubuf__ float* x) { asc_dump<float>(x, 5, 32); }

__global__ __vector__ void simd_vf_dump_kernel(__gm__ uint8_t* x, __gm__ uint8_t* z)
{
    uint32_t xLength = DATA_LEN;

    AscendC::GlobalTensor<float> gmInput;
    AscendC::GlobalTensor<float> gmOutput;
    gmInput.SetGlobalBuffer((__gm__ float*)x, xLength);
    gmOutput.SetGlobalBuffer((__gm__ float*)z, xLength);

    AscendC::LocalMemAllocator<AscendC::Hardware::UB> ubAllocator;
    AscendC::LocalTensor<float> ubInput = ubAllocator.Alloc<float, DATA_LEN>();

    AscendC::DataCopy(ubInput, gmInput, xLength);
    AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
    AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);

    AscendC::printf("[aicore] simd_vf dump demo start ...\n");

    // 1. 调用asc_dump_ubuf接口：打印UB数据
    AscendC::printf("========== UB data (asc_dump_ubuf + asc_dump) ==========\n");
    asc_vf_call<DumpUbufData>((__ubuf__ float*)ubInput.GetPhyAddr());

    // 2. 调用asc_dump_reg接口：从UB加载到Reg后打印Reg数据
    AscendC::printf("========== Register data (asc_dump_reg + asc_dump) ==========\n");
    asc_vf_call<DumpRegData>((__ubuf__ float*)ubInput.GetPhyAddr());

    // 3. 调用asc_dump接口：打印UB数据
    AscendC::printf("========== UB data (asc_dump) ==========\n");
    asc_vf_call<DumpModifiedUbuf>((__ubuf__ float*)ubInput.GetPhyAddr());

    // 4. 执行Adds计算（x + 1.0），将结果写回GM，用于后续校验
    AscendC::Adds(ubInput, ubInput, 1.0f, xLength);
    AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
    AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
    AscendC::DataCopy(gmOutput, ubInput, xLength);

    AscendC::printf("[aicore] simd_vf dump demo end ...\n");
}

int32_t main(int32_t argc, char* argv[])
{
    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    constexpr uint32_t xTotalLength = DATA_LEN;
    size_t fileSize = xTotalLength * sizeof(float);

    uint8_t* xHost;
    uint8_t* xDevice;
    aclrtMallocHost((void**)(&xHost), fileSize);
    aclrtMalloc((void**)&xDevice, fileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/x_gm.bin", fileSize, xHost, fileSize);
    aclrtMemcpy(xDevice, fileSize, xHost, fileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t* zHost;
    uint8_t* zDevice;
    aclrtMallocHost((void**)(&zHost), fileSize);
    aclrtMalloc((void**)&zDevice, fileSize, ACL_MEM_MALLOC_HUGE_FIRST);

    constexpr uint32_t numBlocks = 1;
    simd_vf_dump_kernel<<<numBlocks, nullptr, stream>>>(xDevice, zDevice);
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(zHost, fileSize, zDevice, fileSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", zHost, fileSize);

    aclrtFree(xDevice);
    aclrtFreeHost(xHost);
    aclrtFree(zDevice);
    aclrtFreeHost(zHost);
    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();
    return 0;
}
