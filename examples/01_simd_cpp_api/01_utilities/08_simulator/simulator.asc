/*!
 * \file simulator.asc
 * \brief 基于MatmulLeakyRelu的CAmodel仿真样例。
 */
#include <cstdint>
#include <iostream>

#include "acl/acl.h"
#include "data_utils.h"
#include "kernel_operator.h"
#include "kernel_tiling/kernel_tiling.h"
#include "lib/matmul_intf.h"
#include "tiling/platform/platform_ascendc.h"
#include "tiling/tiling_api.h"

/*
 * matmul_leakyrelu_custom完成矩阵乘、Bias加法和LeakyRelu激活的融合计算。
 *
 * __mix__(1, 2)表示核函数按Cube:Vector = 1:2的比例执行。
 * Host侧kernel launch的numBlocks表示Kernel直调时启动的AIV侧逻辑任务数量；
 * 本样例numBlocks = 2，用于启动2个AIV侧逻辑任务，与SetDim(2)生成的2个AIV逻辑核切分结果对应。
 *
 * 当前样例规格为M=512、N=16、K=128，SetDim(2)对应2个AIV逻辑核。
 * 当前tiling结果仅按M轴分核切分2份，每个逻辑核负责singleCoreM * N = 256 * 16的C矩阵输出区域。
 * 通过SetFixSplit(128, 16, 128)固定baseShape，Cube侧单次Iterate计算baseM * baseN = 128 * 16的输出块，
 * 每个逻辑核需要2次Iterate完成自身负责的256 * 16输出区域。
 * 每次Iterate完成后，Vector侧读取VECIN中的128 * 16个Matmul中间结果，执行同等数量元素的
 * LeakyRelu激活，再将激活结果搬运回GM中对应的C矩阵输出区域。
 *
 * MIX分离模式下Matmul API由AIV侧发起。AIV执行Iterate时通知AIC完成Cube矩阵计算，
 * AIC计算完成后再通知AIV获取结果并执行后续Vector侧融合计算。
 */
template <typename T>
__global__ __mix__(1, 2) void matmul_leakyrelu_custom(__gm__ uint8_t* a, __gm__ uint8_t* b, __gm__ uint8_t* bias,
    __gm__ uint8_t* c, __kfc_workspace__ __gm__ uint8_t* workspace, AscendC::tiling::TCubeTiling tiling)
{
    // TPipe用于管理片上队列资源，通过TPipe完成内部资源初始化。
    AscendC::TPipe pipe;
    // GlobalTensor用于描述GM上的矩阵首地址。
    AscendC::GlobalTensor<T> aGlobal;
    AscendC::GlobalTensor<T> bGlobal;
    AscendC::GlobalTensor<T> cGlobal;
    AscendC::GlobalTensor<T> biasGlobal;
    // mmOutQueue用于管理Matmul输出到VECIN位置的中间结果缓存，后续LeakyRelu从该缓存读取输入。
    AscendC::TQue<AscendC::TPosition::VECIN, 1> mmOutQueue;
    // reluOutQueue用于管理Vector侧LeakyRelu输出使用的VECOUT缓存。队列深度为1，表示同一时刻该队列管理1块LocalTensor缓存。
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> reluOutQueue;

    // Matmul模板参数依次描述A、B、C、Bias的位置、格式和数据类型。
    // C使用VECIN，表示Matmul结果输出到Vector侧可读取的位置，便于后续执行LeakyRelu。
    matmul::Matmul<
        matmul::MatmulType<AscendC::TPosition::GM, CubeFormat::ND, T>,
        matmul::MatmulType<AscendC::TPosition::GM, CubeFormat::ND, T>,
        matmul::MatmulType<AscendC::TPosition::VECIN, CubeFormat::ND, T>,
        matmul::MatmulType<AscendC::TPosition::GM, CubeFormat::ND, T>>
        matmulObj;
    // 注册Matmul对象。系统workspace用于Matmul高阶API内部的临时资源管理。
    REGIST_MATMUL_OBJ(&pipe, GetSysWorkSpacePtr(), matmulObj, &tiling);

    // 将GM输入输出指针绑定到GlobalTensor。第二个参数表示该Tensor可访问的元素个数。
    aGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(a), tiling.M * tiling.Ka);
    bGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(b), tiling.Kb * tiling.N);
    cGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(c), tiling.M * tiling.N);
    biasGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(bias), tiling.N);

    // 当前样例只按M轴分核，N轴和K轴不分核。A矩阵和C矩阵需要按照AIV逻辑核号在M方向偏移，B矩阵和Bias在各个核上复用起始地址。
    // Kernel直调场景下通过GetBlockIdx()区分当前AIV侧逻辑任务编号，并映射到M轴分片。
    aGlobal = aGlobal[AscendC::GetBlockIdx() * tiling.singleCoreM * tiling.Ka];
    cGlobal = cGlobal[AscendC::GetBlockIdx() * tiling.singleCoreM * tiling.N];

    // 绑定当前核负责的A、B、Bias输入。Matmul内部会根据tiling完成分块搬运和Cube计算调度。
    matmulObj.SetTensorA(aGlobal);
    matmulObj.SetTensorB(bGlobal);
    matmulObj.SetBias(biasGlobal);

    // 初始化Vector侧队列缓存。mmOutQueue保存Matmul写入VECIN的中间结果，reluOutQueue保存LeakyRelu写入VECOUT的输出结果。
    // 每块缓存大小均为baseM * baseN个元素，对应当前逻辑核单次Iterate产生的输出分块。
    pipe.InitBuffer(mmOutQueue, 1, tiling.baseM * tiling.baseN * sizeof(T));
    pipe.InitBuffer(reluOutQueue, 1, tiling.baseM * tiling.baseN * sizeof(T));

    // 当前baseShape保持为128 * 16 * 128，每个AIV逻辑核负责256 * 16输出区域，需要通过2次Iterate完成。
    uint32_t computeRound = 0;
    while (matmulObj.template Iterate<true>()) {
        // 从VECIN队列申请LocalTensor缓存，用于承接Matmul输出分块。
        AscendC::LocalTensor<T> mmOutLocal = mmOutQueue.AllocTensor<T>();
        // 将Matmul结果获取到Vector侧LocalTensor中。第二个参数false表示不使能原子累加，
        // 第三个参数true表示按连续地址顺序写入，便于后续Vector计算直接读取。
        matmulObj.template GetTensorC<true>(mmOutLocal, false, true);
        // 将Matmul中间结果入队，建立Matmul结果写入与后续LeakyRelu读取之间的数据依赖。
        mmOutQueue.EnQue(mmOutLocal);
        // 从VECIN队列取出已经写入完成的Matmul中间结果，作为LeakyRelu的输入。
        mmOutLocal = mmOutQueue.DeQue<T>();
        // 从VECOUT队列申请LocalTensor缓存，用于保存LeakyRelu激活后的结果。
        AscendC::LocalTensor<T> reluOutLocal = reluOutQueue.AllocTensor<T>();
        // 对baseM * baseN个元素执行LeakyRelu逐元素激活。本样例采用非原地计算方式，
        // 输入为Matmul中间结果mmOutLocal，输出为独立的reluOutLocal。
        AscendC::LeakyRelu(reluOutLocal, mmOutLocal, static_cast<T>(0.001), tiling.baseM * tiling.baseN);
        // 将完成激活计算的LocalTensor入队，建立后续搬出阶段的数据依赖。
        reluOutQueue.EnQue(reluOutLocal);
        // 从队列取出已就绪的LocalTensor，准备搬运到GM输出矩阵。
        reluOutLocal = reluOutQueue.DeQue<T>();
        // LeakyRelu已完成对mmOutLocal的读取，释放VECIN队列中的Matmul中间结果缓存。
        mmOutQueue.FreeTensor(mmOutLocal);
        // 当前逻辑核每次Iterate生成1个baseM * baseN输出分块，按轮次写回当前C矩阵分片中的对应M轴位置。
        // UB->GM调用DataCopy接口 + DataCopyParams结构体参数:{count, len, srcStrideIn, dstStrideIn}
        // count对应搬运行数baseM；len对应每行baseN个T类型元素折算后的32B块数；
        // srcStrideIn为0表示UB中相邻行连续存放；本样例N等于baseN，因此dstStrideIn也为0。
        AscendC::DataCopy(cGlobal[computeRound * tiling.baseM * tiling.N], reluOutLocal,
            AscendC::DataCopyParams{static_cast<uint16_t>(tiling.baseM),
                static_cast<uint16_t>(tiling.baseN * sizeof(T) / 32), 0,
                static_cast<uint16_t>((tiling.N - tiling.baseN) * sizeof(T) / 32)});
        computeRound++;
        // 释放LocalTensor缓存，使该队列缓存可被下一轮Iterate复用。
        reluOutQueue.FreeTensor(reluOutLocal);
    }
    // 通知Matmul对象当前核计算结束，释放Matmul高阶API内部状态。
    matmulObj.End();
}

template <uint32_t M, uint32_t N, uint32_t K, uint32_t baseM, uint32_t baseN, uint32_t baseK, uint32_t usedCoreNum>
AscendC::tiling::TCubeTiling GenerateTiling(platform_ascendc::PlatformAscendC* ascendcPlatform)
{
    using TPosition = matmul_tiling::TPosition;
    using CubeFormat = matmul_tiling::CubeFormat;
    using DataType = matmul_tiling::DataType;

    matmul_tiling::MultiCoreMatmulTiling tilingApi(*ascendcPlatform);
    tilingApi.SetDim(usedCoreNum);
    tilingApi.SetAType(TPosition::GM, CubeFormat::ND, DataType::DT_FLOAT, false);
    tilingApi.SetBType(TPosition::GM, CubeFormat::ND, DataType::DT_FLOAT, false);
    tilingApi.SetCType(TPosition::VECIN, CubeFormat::ND, DataType::DT_FLOAT);
    tilingApi.SetBiasType(TPosition::GM, CubeFormat::ND, DataType::DT_FLOAT);
    tilingApi.SetOrgShape(M, N, K);
    tilingApi.SetShape(M, N, K);
    tilingApi.EnableBias(true);
    tilingApi.SetFixSplit(baseM, baseN, baseK);

    uint64_t ubSize = 0;
    ascendcPlatform->GetCoreMemSize(platform_ascendc::CoreMemType::UB, ubSize);
    uint64_t usedUb = static_cast<uint64_t>(baseM) * baseN * sizeof(float);
    tilingApi.SetBufferSpace(-1, -1, ubSize - usedUb);

    AscendC::tiling::TCubeTiling tilingData;
    int64_t res = tilingApi.GetTiling(tilingData);
    if (res == -1) {
        std::cout << "gen tiling failed" << std::endl;
    }
    return tilingData;
}

int32_t main(int32_t argc, char* argv[])
{
    constexpr uint32_t M = 512;
    constexpr uint32_t N = 16;
    constexpr uint32_t K = 128;
    constexpr uint32_t baseM = 128;
    constexpr uint32_t baseN = 16;
    constexpr uint32_t baseK = 128;
    constexpr uint32_t usedCoreNum = 2;
    constexpr uint32_t numBlocks = 1;

    auto ascendcPlatform = platform_ascendc::PlatformAscendCManager::GetInstance();
    size_t aByteSize = M * K * sizeof(float);
    size_t bByteSize = K * N * sizeof(float);
    size_t cByteSize = M * N * sizeof(float);
    size_t biasByteSize = N * sizeof(float);
    size_t workspaceSize = static_cast<size_t>(ascendcPlatform->GetLibApiWorkSpaceSize());
    auto tiling = GenerateTiling<M, N, K, baseM, baseN, baseK, usedCoreNum>(ascendcPlatform);

    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t* inputAHost = nullptr;
    uint8_t* inputADevice = nullptr;
    uint8_t* inputBHost = nullptr;
    uint8_t* inputBDevice = nullptr;
    uint8_t* inputBiasHost = nullptr;
    uint8_t* inputBiasDevice = nullptr;
    uint8_t* outputCHost = nullptr;
    uint8_t* outputCDevice = nullptr;
    uint8_t* workspaceDevice = nullptr;

    aclrtMallocHost((void**)(&inputAHost), aByteSize);
    aclrtMalloc((void**)&inputADevice, aByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/x1_gm.bin", aByteSize, inputAHost, aByteSize);
    aclrtMemcpy(inputADevice, aByteSize, inputAHost, aByteSize, ACL_MEMCPY_HOST_TO_DEVICE);

    aclrtMallocHost((void**)(&inputBHost), bByteSize);
    aclrtMalloc((void**)&inputBDevice, bByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/x2_gm.bin", bByteSize, inputBHost, bByteSize);
    aclrtMemcpy(inputBDevice, bByteSize, inputBHost, bByteSize, ACL_MEMCPY_HOST_TO_DEVICE);

    aclrtMallocHost((void**)(&inputBiasHost), biasByteSize);
    aclrtMalloc((void**)&inputBiasDevice, biasByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/bias.bin", biasByteSize, inputBiasHost, biasByteSize);
    aclrtMemcpy(inputBiasDevice, biasByteSize, inputBiasHost, biasByteSize, ACL_MEMCPY_HOST_TO_DEVICE);

    aclrtMallocHost((void**)(&outputCHost), cByteSize);
    aclrtMalloc((void**)&outputCDevice, cByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&workspaceDevice, workspaceSize, ACL_MEM_MALLOC_HUGE_FIRST);

    matmul_leakyrelu_custom<float><<<numBlocks, nullptr, stream>>>(
        inputADevice, inputBDevice, inputBiasDevice, outputCDevice, workspaceDevice, tiling);
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(outputCHost, cByteSize, outputCDevice, cByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", outputCHost, cByteSize);

    aclrtFree(inputADevice);
    aclrtFreeHost(inputAHost);
    aclrtFree(inputBDevice);
    aclrtFreeHost(inputBHost);
    aclrtFree(inputBiasDevice);
    aclrtFreeHost(inputBiasHost);
    aclrtFree(outputCDevice);
    aclrtFreeHost(outputCHost);
    aclrtFree(workspaceDevice);
    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();

    return 0;
}
