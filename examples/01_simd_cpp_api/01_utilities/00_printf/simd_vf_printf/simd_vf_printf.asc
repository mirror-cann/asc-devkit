/*!
 * \file simd_vf_printf.asc
 * \brief 使用vector编程模式，展示simd_vf printf接口的基本使用方法
 */

#include "acl/acl.h"
#include "utils/debug/asc_printf.h"
#include "kernel_operator.h"

constexpr uint32_t PRINT_COUNT = 1;
constexpr uint32_t ADD_DATA_LEN = 16;

// simd_vf printf演示: int, uint, float, string格式打印
__simd_vf__ inline void SimdVfPrintFormat()
{
    __ubuf__ const char* fmt = "[simd_vf] int=%d, uint=%u, float=%f, string=%s\n";
    printf(fmt, 10, 20U, 3.14f, "hello");
}

// simd_vf printf演示: 十六进制和指针格式打印
__simd_vf__ inline void SimdVfPrintHexPtr()
{
    __ubuf__ const char* fmt = "[simd_vf] hex=%x, ptr=%p\n";
    printf(fmt, 255, (void*)(uintptr_t)0x12ff);
}

// simd_vf printf演示: 纯字符串打印
__simd_vf__ inline void SimdVfPrintStr()
{
    __ubuf__ const char* fmt = "[simd_vf] This is a simd_vf printf demo string.\n";
    printf(fmt);
}

// simd_vf printf演示: 打印AICore侧AscendC::Add计算后的UB tensor结果
__simd_vf__ inline void SimdVfPrintAdd(__ubuf__ float* x, __ubuf__ float* y, __ubuf__ float* z, uint32_t count)
{
    __ubuf__ const char* fmt = "[simd_vf] add[%u]: %f + %f = %f\n";
    for (uint32_t i = 0; i < count; i++) {
        printf(fmt, i, x[i], y[i], z[i]);
    }
}

// AICore侧演示: 固定输入写入LocalTensor，调用AscendC::Add，再交给simd_vf打印
__aicore__ inline void SimdVfAddTensorDemo()
{
    AscendC::LocalMemAllocator<AscendC::Hardware::UB> ubAllocator;
    AscendC::LocalTensor<float> xLocal = ubAllocator.Alloc<float, ADD_DATA_LEN>();
    AscendC::LocalTensor<float> yLocal = ubAllocator.Alloc<float, ADD_DATA_LEN>();
    AscendC::LocalTensor<float> zLocal = ubAllocator.Alloc<float, ADD_DATA_LEN>();

    AscendC::Duplicate<float>(xLocal, 1.25f, ADD_DATA_LEN);
    AscendC::Duplicate<float>(yLocal, 10.00f, ADD_DATA_LEN);

    AscendC::Add(zLocal, xLocal, yLocal, ADD_DATA_LEN);
    AscendC::PipeBarrier<PIPE_V>();

    asc_vf_call<SimdVfPrintAdd>(
        (__ubuf__ float*)xLocal.GetPhyAddr(), (__ubuf__ float*)yLocal.GetPhyAddr(),
        (__ubuf__ float*)zLocal.GetPhyAddr(), PRINT_COUNT);
}

extern "C" __global__ __vector__ void simd_vf_printf_kernel()
{
    AscendC::InitSocState();

    AscendC::printf("[aicore] simd_vf printf demo start ...\n");
    AscendC::printf("[aicore] blockIdx=%u\n", AscendC::GetBlockIdx());

    asc_vf_call<SimdVfPrintFormat>();
    asc_vf_call<SimdVfPrintHexPtr>();
    asc_vf_call<SimdVfPrintStr>();
    SimdVfAddTensorDemo();

    AscendC::printf("[aicore] simd_vf printf demo end ...\n");
}

int32_t main(int32_t argc, char* argv[])
{
    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    simd_vf_printf_kernel<<<1, nullptr, stream>>>();

    aclrtSynchronizeStream(stream);
    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();
    return 0;
}
