#include <torch/extension.h>
#include "acl/acl_prof.h"
#include "acl/acl_base.h"
#include "kernel_operator.h"
#include "torch_npu/csrc/core/npu/NPUStream.h"

// 仅用于profiling上报format字段：根据Tensor维度数量推断常见ACL format，
// 未列出的维度统一按ND上报。
constexpr int64_t NCL_DIM_NUM = 3;
constexpr int64_t NCHW_DIM_NUM = 4;
constexpr int64_t NCDHW_DIM_NUM = 5;

#ifndef ACL_PROF_TENSOR_INFO_DEFINED
#define ACL_PROF_TENSOR_INFO_DEFINED
// 描述单个输入或输出Tensor，供msprof展示Shape、数据类型和Format信息。
struct aclprofTensor {
    uint32_t type;         // Tensor类型：0表示输入，1表示输出。
    uint32_t format;       // Format类型，对应aclFormat。
    uint32_t dataType;     // 数据类型，对应aclDataType。
    uint32_t shapeDim;     // Shape维度数量，最大支持8维。
    uint32_t shape[8];     // Shape信息。
};

// 描述一次算子调用的Profiling信息，包含算子标识、Stream以及输入输出Tensor列表。
struct aclprofTensorInfo{
    uint64_t opNameId;     // 通过uint64_t aclprofStr2Id(const char *message)转化
    uint64_t opTypeId;     // 通过uint64_t aclprofStr2Id(const char *message)转化
    uint32_t resv;
    uint32_t tensorNum;
    uint32_t kernelType;
    uint32_t blockNums;
    void *stream;          // Stream信息。
    aclprofTensor *tensors;
};

// aclprofRangePushEx使用的外层消息结构，用于携带aclprofTensorInfo。
struct aclprofEventAttributes {
    uint16_t version;
    uint16_t size;         // message字段大小。
    uint32_t messageType;  // 消息类型，0表示Tensor信息。
    union message {
        aclprofTensorInfo *tensorInfo;
    } message;
};

#endif // ACL_PROF_TENSOR_INFO_DEFINED

// 构造输入Tensor的profiling描述。msprof会从这里读取输入的format、dtype和shape，
// 并写入op_summary_*.csv中的Input Formats/Input Data Types/Input Shapes字段。
#define INPUT(x) aclprofTensor {                                                                            \
    (uint32_t)0,                                                                                            \
    static_cast<uint32_t>(ascendc_ops::GetFormat(static_cast<int64_t>(x.sizes().size()))),                  \
    static_cast<uint32_t>(ascendc_ops::GetAclDataType(x.scalar_type())),                                    \
    static_cast<uint32_t>(x.sizes().size()),                                                                \
    {                                                                                                       \
        static_cast<uint32_t>(x.sizes().size() > 0 ? x.sizes().data()[0] : 0),                              \
        static_cast<uint32_t>(x.sizes().size() > 1 ? x.sizes().data()[1] : 0),                              \
        static_cast<uint32_t>(x.sizes().size() > 2 ? x.sizes().data()[2] : 0),                              \
        static_cast<uint32_t>(x.sizes().size() > 3 ? x.sizes().data()[3] : 0),                              \
        static_cast<uint32_t>(x.sizes().size() > 4 ? x.sizes().data()[4] : 0),                              \
        static_cast<uint32_t>(x.sizes().size() > 5 ? x.sizes().data()[5] : 0),                              \
        static_cast<uint32_t>(x.sizes().size() > 6 ? x.sizes().data()[6] : 0),                              \
        static_cast<uint32_t>(x.sizes().size() > 7 ? x.sizes().data()[7] : 0)                               \
    }                                                                                                       \
}

// 构造输出Tensor的profiling描述。与INPUT类似，只是type字段填1，表示输出Tensor。
#define OUTPUT(z) aclprofTensor {                                                                           \
    (uint32_t)1,                                                                                            \
    static_cast<uint32_t>(ascendc_ops::GetFormat(static_cast<int64_t>(z.sizes().size()))),                  \
    static_cast<uint32_t>(ascendc_ops::GetAclDataType(z.scalar_type())),                                    \
    static_cast<uint32_t>(z.sizes().size()),                                                                \
    {                                                                                                       \
        static_cast<uint32_t>(z.sizes().size() > 0 ? z.sizes().data()[0] : 0),                              \
        static_cast<uint32_t>(z.sizes().size() > 1 ? z.sizes().data()[1] : 0),                              \
        static_cast<uint32_t>(z.sizes().size() > 2 ? z.sizes().data()[2] : 0),                              \
        static_cast<uint32_t>(z.sizes().size() > 3 ? z.sizes().data()[3] : 0),                              \
        static_cast<uint32_t>(z.sizes().size() > 4 ? z.sizes().data()[4] : 0),                              \
        static_cast<uint32_t>(z.sizes().size() > 5 ? z.sizes().data()[5] : 0),                              \
        static_cast<uint32_t>(z.sizes().size() > 6 ? z.sizes().data()[6] : 0),                              \
        static_cast<uint32_t>(z.sizes().size() > 7 ? z.sizes().data()[7] : 0)                               \
    }                                                                                                       \
}

// 组装profiling上报信息。该宏把算子名、算子类型、block数量、stream、
// 以及INPUT/OUTPUT生成的Tensor描述合成aclprofTensorInfo，供aclprofRangePushEx上报。
#define INIT_ACL_PROF_TENSOR_INFO(opName, opType, blockdim, kernelType, tensorInfo, stream, ...)            \
    uint64_t opNameId = aclprofStr2Id(opName);                                                              \
    uint64_t opTypeId = aclprofStr2Id(opType);                                                              \
    struct aclprofTensor tensors[] = {__VA_ARGS__};                                                         \
    tensorInfo = {opNameId, opTypeId, 0, sizeof(tensors)/sizeof(aclprofTensor), kernelType, blockdim, stream, tensors}


template <typename T, uint32_t dim0, uint32_t dim1>
__global__ __vector__ void add_custom(__gm__ T* x, __gm__ T* y, __gm__ T* z)
{
    AscendC::InitSocState();

    const uint32_t blockLength = dim0 * dim1 / AscendC::GetBlockNum();
    AscendC::GlobalTensor<T> xGm;
    AscendC::GlobalTensor<T> yGm;
    AscendC::GlobalTensor<T> zGm;
    xGm.SetGlobalBuffer(x + blockLength * AscendC::GetBlockIdx(), blockLength);
    yGm.SetGlobalBuffer(y + blockLength * AscendC::GetBlockIdx(), blockLength);
    zGm.SetGlobalBuffer(z + blockLength * AscendC::GetBlockIdx(), blockLength);

    AscendC::LocalMemAllocator<AscendC::Hardware::UB> ubAllocator;
    AscendC::LocalTensor<T> xLocal = ubAllocator.Alloc<T>(blockLength);
    AscendC::LocalTensor<T> yLocal = ubAllocator.Alloc<T>(blockLength);
    AscendC::LocalTensor<T> zLocal = ubAllocator.Alloc<T>(blockLength);

    AscendC::DataCopy(xLocal, xGm, blockLength);
    AscendC::DataCopy(yLocal, yGm, blockLength);
    AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
    AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);

    AscendC::Add(zLocal, xLocal, yLocal, blockLength);
    AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
    AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
    AscendC::DataCopy(zGm, zLocal, blockLength);

    AscendC::PipeBarrier<PIPE_ALL>();
}

namespace ascendc_ops {
aclDataType GetAclDataType(at::ScalarType scalarType)
{
    switch (scalarType) {
        case at::ScalarType::Float:
            return ACL_FLOAT;
        case at::ScalarType::Half:
            return ACL_FLOAT16;
        case at::ScalarType::Int:
            return ACL_INT32;
        case at::ScalarType::Long:
            return ACL_INT64;
        default:
            TORCH_CHECK(false, "Unsupported tensor dtype for profiling report: ", scalarType);
    }
}

aclFormat GetFormat(int64_t dimNum) 
{
    // Format只用于和Shape一起上报给msprof，不影响本样例Add Kernel的计算。
    aclFormat format = ACL_FORMAT_ND;
    switch (dimNum) {
        case NCL_DIM_NUM:
            format = ACL_FORMAT_NCL;
            break;
        case NCHW_DIM_NUM:
            format = ACL_FORMAT_NCHW;
            break;
        case NCDHW_DIM_NUM:
            format = ACL_FORMAT_NCDHW;
            break;
        default:
            format = ACL_FORMAT_ND;
    }
    return format;
}

at::Tensor ascendc_add(const at::Tensor& x, const at::Tensor& y)
{
    using DataType = half;
    constexpr uint32_t addCustomShapeDim0 = 8;
    constexpr uint32_t addCustomShapeDim1 = 2048;
    constexpr uint32_t blockNum = 8;

    auto aclStream = c10_npu::getCurrentNPUStream().stream(false);
    at::Tensor z = at::empty(x.sizes(), x.options());
    TORCH_CHECK(x.sizes().size() == 2 && x.sizes()[0] == addCustomShapeDim0 &&
        x.sizes()[1] == addCustomShapeDim1, "ascendc_add only supports shape [8, 2048].");
    TORCH_CHECK(y.sizes() == x.sizes(), "x and y must have the same shape.");
    TORCH_CHECK(x.scalar_type() == at::ScalarType::Half && y.scalar_type() == at::ScalarType::Half,
        "ascendc_add only supports float16 tensors.");

    aclprofTensorInfo tensorInfo;
    INIT_ACL_PROF_TENSOR_INFO("add_custom", "AddCustom", blockNum, 0, tensorInfo, aclStream, INPUT(x), INPUT(y), OUTPUT(z));
    aclprofEventAttributes attrs = {1, sizeof(aclprofEventAttributes::message), 0, &tensorInfo};

    // 在Kernel下发前后包一层profiling range，使msprof能把上面的Shape/DType/Format信息关联到该Kernel。
    aclprofRangePushEx(&attrs);
    add_custom<DataType, addCustomShapeDim0, addCustomShapeDim1><<<blockNum, nullptr, aclStream>>>(
        static_cast<DataType *>(x.mutable_data_ptr()),
        static_cast<DataType *>(y.mutable_data_ptr()),
        static_cast<DataType *>(z.mutable_data_ptr()));
    aclprofRangePop();
    return z;
}
} // namespace ascendc_ops

// 注册torch.library算子接口，使Python侧可以通过torch.ops.ascendc_ops.ascendc_add调用。
TORCH_LIBRARY(ascendc_ops, m)
{
    m.def("ascendc_add(Tensor x, Tensor y) -> Tensor");
}

// 为NPU后端绑定算子实现。PrivateUse1是torch-npu使用的设备后端DispatchKey。
TORCH_LIBRARY_IMPL(ascendc_ops, PrivateUse1, m)
{
    m.impl("ascendc_add", TORCH_FN(ascendc_ops::ascendc_add));
}
