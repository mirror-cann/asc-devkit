/*!
* \file scatter_custom.asc
* \brief 本样例演示数据离散功能，可根据输入张量和目的地址偏移张量，将输入张量分散到结果张量中
*/

#include "kernel_operator.h"
#include "data_utils.h"
#include "acl/acl.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

template <typename T, int32_t COUNT>
class KernelScatter {
public:
    __aicore__ inline KernelScatter() {}
    __aicore__ inline void Init(__gm__ uint8_t* srcGm, __gm__ uint8_t* dstOffsetGm, __gm__ uint8_t* dstGm)
    {
        xAddr = 0;
        yAddr = xAddr + static_cast<uint64_t>(COUNT) * sizeof(T);
        zAddr = yAddr + static_cast<uint64_t>(COUNT) * sizeof(uint32_t);
        srcGlobal.SetGlobalBuffer((__gm__ T*)srcGm, COUNT);
        dstOffsetGlobal.SetGlobalBuffer((__gm__ uint32_t*)dstOffsetGm, COUNT);
        dstGlobal.SetGlobalBuffer((__gm__ T*)dstGm, COUNT);
    }
    __aicore__ inline void Process()
    {
        AscendC::LocalTensor<T> srcLocal(AscendC::TPosition::VECCALC, xAddr, COUNT);
        AscendC::LocalTensor<uint32_t> dstOffsetLocal(AscendC::TPosition::VECCALC, yAddr, COUNT);
        AscendC::LocalTensor<T> dstLocal(AscendC::TPosition::VECCALC, zAddr, COUNT);

        // 数据搬入
        AscendC::DataCopy(srcLocal, srcGlobal, COUNT);
        AscendC::DataCopy(dstOffsetLocal, dstOffsetGlobal, COUNT);
        AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);

        // scatter
#if defined(__NPU_ARCH__) && (__NPU_ARCH__ == 2201)
        // Atlas A2/A3不支持Scatter指令，使用标量GetValue/SetValue循环逐元素搬出
        for (int32_t i = 0; i < COUNT; ++i) {
            auto offset = dstOffsetLocal.GetValue(i) / sizeof(T);
            auto srcValue = srcLocal.GetValue(i);
            dstLocal.SetValue(offset, srcValue);
        }
#elif defined(__NPU_ARCH__) && (__NPU_ARCH__ == 3510)
        // Ascend 950PR/950DT支持Scatter指令，直接调用intrinsic实现
        dstLocal.SetSize(COUNT);
        AscendC::Scatter(dstLocal, srcLocal, dstOffsetLocal, (uint32_t)0, COUNT);
#endif

        AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);

        // 数据搬出
        AscendC::DataCopy(dstGlobal, dstLocal, COUNT);
    }

private:
    uint64_t xAddr = 0;
    uint64_t yAddr = 0;
    uint64_t zAddr = 0;
    AscendC::GlobalTensor<T> srcGlobal;
    AscendC::GlobalTensor<uint32_t> dstOffsetGlobal;
    AscendC::GlobalTensor<T> dstGlobal;
};

template<int32_t COUNT>
__vector__ __global__ void scatter_custom(__gm__ uint8_t* srcGm, __gm__ uint8_t* dstOffsetGm, __gm__ uint8_t* dstGm)
{
    AscendC::InitSocState();
    KernelScatter<half, COUNT> op;
    op.Init(srcGm, dstOffsetGm, dstGm);
    op.Process();
    AscendC::PipeBarrier<PIPE_ALL>();
}

int32_t main(int32_t argc, char* argv[])
{
    constexpr uint32_t NUM_BLOCKS = 1;
    constexpr int32_t COUNT = 128;
    size_t inputByteSize = COUNT * sizeof(uint16_t);
    size_t inputByteSize1 = COUNT * sizeof(uint32_t);
    size_t outputByteSize = COUNT * sizeof(uint16_t);

    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t *xHost, *yHost, *zHost;
    uint8_t *xDevice, *yDevice, *zDevice;

    aclrtMallocHost((void**)(&xHost), inputByteSize);
    aclrtMallocHost((void**)(&yHost), inputByteSize1);
    aclrtMallocHost((void**)(&zHost), outputByteSize);
    aclrtMalloc((void**)&xDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&yDevice, inputByteSize1, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&zDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);

    ReadFile("./input/input_x.bin", inputByteSize, xHost, inputByteSize);
    ReadFile("./input/input_y.bin", inputByteSize1, yHost, inputByteSize1);

    aclrtMemcpy(xDevice, inputByteSize, xHost, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(yDevice, inputByteSize1, yHost, inputByteSize1, ACL_MEMCPY_HOST_TO_DEVICE);

    scatter_custom<COUNT><<<NUM_BLOCKS, nullptr, stream>>>(xDevice, yDevice, zDevice);
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(zHost, outputByteSize, zDevice, outputByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", zHost, outputByteSize);

    aclrtFree(xDevice);
    aclrtFree(yDevice);
    aclrtFree(zDevice);
    aclrtFreeHost(xHost);
    aclrtFreeHost(yHost);
    aclrtFreeHost(zHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();

    return 0;
}
