/* !
 * \file data_copy_l0c2gm.asc
 * \brief Demonstrates L0C-to-GM matrix movement with inline quantization using the Ascend C C API.
 */

#include <cstddef>
#include <cstdint>

#include "acl/acl.h"
#include "c_api/asc_simd.h"
#include "data_utils.h"

constexpr uint32_t CUBE_BLOCK = 16;
constexpr uint32_t C0_BYTES = 32;
constexpr uint32_t K_ROUND = 2;
constexpr uint32_t FIXPIPE_QUANT_ADDR_GRANULARITY = 128;
constexpr uint32_t FIXPIPE_L1_TO_FB_BURST_BYTES = 64;

constexpr uint32_t M = 128;
constexpr uint32_t K = 128;
constexpr uint32_t N = 256;
constexpr uint32_t K_CHUNK = K / K_ROUND;

__aicore__ constexpr uint32_t ceil_division(uint32_t numerator, uint32_t denominator)
{
    return (numerator + denominator - 1) / denominator;
}

__aicore__ constexpr uint32_t ceil_align(uint32_t numerator, uint32_t denominator)
{
    return ceil_division(numerator, denominator) * denominator;
}

constexpr bool IS_INT8_INPUT = SCENARIO_NUM == 1 || SCENARIO_NUM == 2 || SCENARIO_NUM == 5 || SCENARIO_NUM == 6;
constexpr bool IS_VECTOR_QUANT = SCENARIO_NUM == 2 || SCENARIO_NUM == 4 || SCENARIO_NUM == 6;
constexpr bool IS_NZ2ND_OUTPUT = SCENARIO_NUM == 1 || SCENARIO_NUM == 4 || SCENARIO_NUM == 5;
constexpr bool IS_RELU_ENABLED = SCENARIO_NUM == 1 || SCENARIO_NUM == 4 || SCENARIO_NUM == 6;

constexpr uint32_t INT8_C0_ELEMENTS = C0_BYTES / sizeof(int8_t);
constexpr uint32_t HALF_C0_ELEMENTS = C0_BYTES / sizeof(half);
constexpr uint32_t A_SINGLE_SIZE = M * K_CHUNK;
constexpr uint32_t B_SINGLE_SIZE = K_CHUNK * N;
constexpr uint32_t A_L1_MAX_BYTES = ceil_align(M, CUBE_BLOCK) * ceil_align(K_CHUNK, HALF_C0_ELEMENTS) * sizeof(half);
constexpr uint32_t B_L1_MAX_BYTES =
    ceil_align(K_CHUNK, HALF_C0_ELEMENTS) * ceil_align(N, HALF_C0_ELEMENTS) * sizeof(half);
constexpr uint32_t C_L0_MAX_BYTES = ceil_align(M, CUBE_BLOCK) * ceil_align(N, CUBE_BLOCK) * sizeof(float);
constexpr uint32_t QUANT_TRANSFER_BYTES = ceil_align(N * sizeof(uint64_t), FIXPIPE_QUANT_ADDR_GRANULARITY);

// Keep A1, B1, and C1 in separate regions of the C API local-memory workspace.
constexpr uint32_t A1_OFFSET_BYTES = 0;
constexpr uint32_t B1_OFFSET_BYTES = 64 * 1024;
constexpr uint32_t C1_OFFSET_BYTES = 128 * 1024;
constexpr uint32_t CBUF_WORKSPACE_BYTES = C1_OFFSET_BYTES + QUANT_TRANSFER_BYTES;

constexpr uint8_t L2_CACHE_NORMAL = 0;
constexpr uint8_t UNIT_FLAG_DISABLE = 0;
constexpr uint16_t MTE2_NZ_MATRIX_NUM = 1;
constexpr uint16_t MTE2_NZ_N_STRIDE = 1;
constexpr uint16_t MTE2_NZ_LOOP4_DST_STRIDE = 0;
constexpr uint16_t A_MTE2_NZ_C0_STRIDE =
    static_cast<uint16_t>(IS_INT8_INPUT ? ceil_align(M, INT8_C0_ELEMENTS) : ceil_align(M, HALF_C0_ELEMENTS));
constexpr uint16_t B_MTE2_NZ_C0_STRIDE = static_cast<uint16_t>(
    IS_INT8_INPUT ? ceil_align(K_CHUNK, INT8_C0_ELEMENTS) : ceil_align(K_CHUNK, HALF_C0_ELEMENTS));
constexpr uint64_t A_MTE2_NZ_PARA = (static_cast<uint64_t>(MTE2_NZ_LOOP4_DST_STRIDE) << 48) |
                                    (static_cast<uint64_t>(A_MTE2_NZ_C0_STRIDE) << 32) |
                                    (static_cast<uint64_t>(MTE2_NZ_N_STRIDE) << 16) | MTE2_NZ_MATRIX_NUM;
constexpr uint64_t B_MTE2_NZ_PARA = (static_cast<uint64_t>(MTE2_NZ_LOOP4_DST_STRIDE) << 48) |
                                    (static_cast<uint64_t>(B_MTE2_NZ_C0_STRIDE) << 32) |
                                    (static_cast<uint64_t>(MTE2_NZ_N_STRIDE) << 16) | MTE2_NZ_MATRIX_NUM;

// The low 32 bits are the IEEE-754 representation of 2.0f. Bit 46 selects signed int8 output.
constexpr uint64_t SCALAR_QUANT_HALF = 0x40000000ULL;
constexpr uint64_t SCALAR_QUANT_INT8 = SCALAR_QUANT_HALF | (1ULL << 46);
// For Nz output, loop_dst_stride is measured in output elements. The API
// converts its 32B-block dstStride to this unit before issuing Fixpipe.
constexpr uint32_t FIXPIPE_NZ_DST_STRIDE_HALF = M * C0_BYTES / sizeof(half);
constexpr uint32_t FIXPIPE_NZ_DST_STRIDE_INT8 = M * C0_BYTES / sizeof(int8_t);

__global__ __cube__ void data_copy_l0c2gm(
    __gm__ uint8_t* a, __gm__ uint8_t* b, __gm__ void* c, __gm__ uint64_t* quant_pre)
{
    asc_init();

    __cbuf__ uint8_t cbuf_workspace[CBUF_WORKSPACE_BYTES];
    __ca__ uint8_t a_l0_workspace[A_L1_MAX_BYTES];
    __cb__ uint8_t b_l0_workspace[B_L1_MAX_BYTES];
    __cc__ uint8_t c_l0_workspace[C_L0_MAX_BYTES];

    if constexpr (IS_INT8_INPUT) {
        __cbuf__ int8_t* a_l1 = reinterpret_cast<__cbuf__ int8_t*>(cbuf_workspace + A1_OFFSET_BYTES);
        __cbuf__ int8_t* b_l1 = reinterpret_cast<__cbuf__ int8_t*>(cbuf_workspace + B1_OFFSET_BYTES);
        __ca__ int8_t* a_l0 = reinterpret_cast<__ca__ int8_t*>(a_l0_workspace);
        __cb__ int8_t* b_l0 = reinterpret_cast<__cb__ int8_t*>(b_l0_workspace);
        __cc__ int32_t* c_l0 = reinterpret_cast<__cc__ int32_t*>(c_l0_workspace);

        for (uint32_t k_index = 0; k_index < K_ROUND; ++k_index) {
            asc_set_gm2l1_nz_para(A_MTE2_NZ_PARA);
            asc_copy_gm2l1_nd2nz(
                a_l1, reinterpret_cast<__gm__ int8_t*>(a) + k_index * A_SINGLE_SIZE, K_CHUNK * sizeof(int8_t),
                L2_CACHE_NORMAL, M, K_CHUNK, 0, false);
            asc_set_gm2l1_nz_para(B_MTE2_NZ_PARA);
            asc_copy_gm2l1_nd2nz(
                b_l1, reinterpret_cast<__gm__ int8_t*>(b) + k_index * B_SINGLE_SIZE, N * sizeof(int8_t),
                L2_CACHE_NORMAL, K_CHUNK, N, 0, false);

            asc_sync_notify(PIPE_MTE2, PIPE_MTE1, EVENT_ID0);
            asc_sync_wait(PIPE_MTE2, PIPE_MTE1, EVENT_ID0);
            asc_copy_l12l0a(
                a_l0, a_l1, 0, 0, ceil_division(M, CUBE_BLOCK), ceil_division(K_CHUNK, INT8_C0_ELEMENTS),
                ceil_division(M, CUBE_BLOCK), ceil_division(M, CUBE_BLOCK));
            // Nz -> Zn. asc_copy_l12l0b_trans uses the 3510 instruction stride directly.
            const uint32_t dst_offset = ceil_division(N, INT8_C0_ELEMENTS) * 512 * 2;
            const uint32_t src_offset = 512 * 2;
            for (uint32_t i = 0; i < ceil_division(K_CHUNK, INT8_C0_ELEMENTS); ++i) {
                asc_copy_l12l0b_trans(
                    b_l0 + i * dst_offset, b_l1 + i * src_offset, static_cast<uint16_t>(0),
                    static_cast<uint8_t>(ceil_division(N, INT8_C0_ELEMENTS)),
                    static_cast<uint16_t>(ceil_division(K_CHUNK, INT8_C0_ELEMENTS) * 2), static_cast<uint16_t>(1),
                    static_cast<uint16_t>(0), static_cast<uint16_t>(0));
            }
            asc_sync_notify(PIPE_MTE1, PIPE_M, EVENT_ID0);
            asc_sync_wait(PIPE_MTE1, PIPE_M, EVENT_ID0);
            asc_sync_notify(PIPE_MTE1, PIPE_MTE2, EVENT_ID0);
            asc_sync_wait(PIPE_MTE1, PIPE_MTE2, EVENT_ID0);
            asc_mmad(
                c_l0, a_l0, b_l0, M, K_CHUNK, ceil_align(N, C0_BYTES), UNIT_FLAG_DISABLE, false, false, k_index == 0);
            asc_sync_notify(PIPE_M, PIPE_MTE1, EVENT_ID0);
            asc_sync_wait(PIPE_M, PIPE_MTE1, EVENT_ID0);
        }

        if constexpr (IS_VECTOR_QUANT) {
            __cbuf__ uint64_t* quant_l1 = reinterpret_cast<__cbuf__ uint64_t*>(cbuf_workspace + C1_OFFSET_BYTES);
            __fbuf__ uint64_t quant_fb[QUANT_TRANSFER_BYTES / sizeof(uint64_t)];
            asc_copy_gm2l1(
                reinterpret_cast<__cbuf__ void*>(quant_l1), reinterpret_cast<__gm__ void*>(quant_pre), 1,
                QUANT_TRANSFER_BYTES / C0_BYTES, 0, 0, 0);
            asc_sync_notify(PIPE_MTE2, PIPE_FIX, EVENT_ID0);
            asc_sync_wait(PIPE_MTE2, PIPE_FIX, EVENT_ID0);
            asc_copy_l12fb(
                reinterpret_cast<__fbuf__ void*>(quant_fb), reinterpret_cast<__cbuf__ void*>(quant_l1), 1,
                QUANT_TRANSFER_BYTES / FIXPIPE_L1_TO_FB_BURST_BYTES, 0, 0);
            const uint64_t quant_fb_addr =
                static_cast<uint64_t>(reinterpret_cast<uintptr_t>(quant_fb)) / FIXPIPE_QUANT_ADDR_GRANULARITY;
            asc_set_l0c2gm_config(0, quant_fb_addr, false);
            asc_sync_pipe(PIPE_FIX);
        }

        asc_sync_notify(PIPE_M, PIPE_FIX, EVENT_ID0);
        asc_sync_wait(PIPE_M, PIPE_FIX, EVENT_ID0);
        if constexpr (IS_NZ2ND_OUTPUT) {
            asc_set_l0c2gm_nz2nd(1, 0, 0);
        }

        if constexpr (SCENARIO_NUM == 1) {
            asc_set_l0c_copy_prequant(SCALAR_QUANT_HALF);
            asc_copy_l0c2gm(
                reinterpret_cast<__gm__ half*>(c), c_l0, N, M, N, ceil_align(M, CUBE_BLOCK), L2_CACHE_NORMAL, 0,
                UNIT_FLAG_DISABLE, static_cast<uint64_t>(QuantMode_t::DEQF16), IS_RELU_ENABLED, false, true,
                static_cast<uint64_t>(QuantMode_post::NoConv), 0, false, 0, false, false, false, false);
        } else if constexpr (SCENARIO_NUM == 2) {
            asc_copy_l0c2gm(
                reinterpret_cast<__gm__ half*>(c), c_l0, ceil_align(N, CUBE_BLOCK), M, FIXPIPE_NZ_DST_STRIDE_HALF,
                ceil_align(M, CUBE_BLOCK), L2_CACHE_NORMAL, 0, UNIT_FLAG_DISABLE,
                static_cast<uint64_t>(QuantMode_t::VDEQF16), IS_RELU_ENABLED, false, false,
                static_cast<uint64_t>(QuantMode_post::NoConv), 0, false, 0, false, false, false, false);
        } else if constexpr (SCENARIO_NUM == 5) {
            asc_set_l0c_copy_prequant(SCALAR_QUANT_INT8);
            asc_copy_l0c2gm(
                reinterpret_cast<__gm__ int8_t*>(c), c_l0, N, M, N, ceil_align(M, CUBE_BLOCK), L2_CACHE_NORMAL, 0,
                UNIT_FLAG_DISABLE, static_cast<uint64_t>(QuantMode_t::REQ8), IS_RELU_ENABLED, false, true,
                static_cast<uint64_t>(QuantMode_post::NoConv), 0, false, 0, false, false, false, false);
        } else {
            asc_copy_l0c2gm(
                reinterpret_cast<__gm__ int8_t*>(c), c_l0, ceil_align(N, CUBE_BLOCK), M, FIXPIPE_NZ_DST_STRIDE_INT8,
                ceil_align(M, CUBE_BLOCK), L2_CACHE_NORMAL, 0, UNIT_FLAG_DISABLE,
                static_cast<uint64_t>(QuantMode_t::VREQ8), IS_RELU_ENABLED, false, false,
                static_cast<uint64_t>(QuantMode_post::NoConv), 0, false, 0, false, false, false, false);
        }
    } else {
        __cbuf__ half* a_l1 = reinterpret_cast<__cbuf__ half*>(cbuf_workspace + A1_OFFSET_BYTES);
        __cbuf__ half* b_l1 = reinterpret_cast<__cbuf__ half*>(cbuf_workspace + B1_OFFSET_BYTES);
        __ca__ half* a_l0 = reinterpret_cast<__ca__ half*>(a_l0_workspace);
        __cb__ half* b_l0 = reinterpret_cast<__cb__ half*>(b_l0_workspace);
        __cc__ float* c_l0 = reinterpret_cast<__cc__ float*>(c_l0_workspace);

        for (uint32_t k_index = 0; k_index < K_ROUND; ++k_index) {
            asc_set_gm2l1_nz_para(A_MTE2_NZ_PARA);
            asc_copy_gm2l1_nd2nz(
                a_l1, reinterpret_cast<__gm__ half*>(a) + k_index * A_SINGLE_SIZE, K_CHUNK * sizeof(half),
                L2_CACHE_NORMAL, M, K_CHUNK, 0, false);
            asc_set_gm2l1_nz_para(B_MTE2_NZ_PARA);
            asc_copy_gm2l1_nd2nz(
                b_l1, reinterpret_cast<__gm__ half*>(b) + k_index * B_SINGLE_SIZE, N * sizeof(half), L2_CACHE_NORMAL,
                K_CHUNK, N, 0, false);

            asc_sync_notify(PIPE_MTE2, PIPE_MTE1, EVENT_ID0);
            asc_sync_wait(PIPE_MTE2, PIPE_MTE1, EVENT_ID0);
            asc_copy_l12l0a(
                a_l0, a_l1, 0, 0, ceil_division(M, CUBE_BLOCK), ceil_division(K_CHUNK, HALF_C0_ELEMENTS),
                ceil_division(M, CUBE_BLOCK), ceil_division(M, CUBE_BLOCK));
            // Nz -> Zn. half uses one 256-element cube block per transpose iteration.
            const uint32_t dst_offset = ceil_division(N, HALF_C0_ELEMENTS) * 256;
            const uint32_t src_offset = 256;
            for (uint32_t i = 0; i < ceil_division(K_CHUNK, HALF_C0_ELEMENTS); ++i) {
                asc_copy_l12l0b_trans(
                    b_l0 + i * dst_offset, b_l1 + i * src_offset, static_cast<uint16_t>(0),
                    static_cast<uint8_t>(ceil_division(N, HALF_C0_ELEMENTS)),
                    static_cast<uint16_t>(ceil_division(K_CHUNK, HALF_C0_ELEMENTS)), static_cast<uint16_t>(0),
                    static_cast<uint16_t>(0), static_cast<uint16_t>(0));
            }
            asc_sync_notify(PIPE_MTE1, PIPE_M, EVENT_ID0);
            asc_sync_wait(PIPE_MTE1, PIPE_M, EVENT_ID0);
            asc_sync_notify(PIPE_MTE1, PIPE_MTE2, EVENT_ID0);
            asc_sync_wait(PIPE_MTE1, PIPE_MTE2, EVENT_ID0);
            asc_mmad(
                c_l0, a_l0, b_l0, M, K_CHUNK, ceil_align(N, C0_BYTES), UNIT_FLAG_DISABLE, false, false, k_index == 0);
            asc_sync_notify(PIPE_M, PIPE_MTE1, EVENT_ID0);
            asc_sync_wait(PIPE_M, PIPE_MTE1, EVENT_ID0);
        }

        if constexpr (IS_VECTOR_QUANT) {
            __cbuf__ uint64_t* quant_l1 = reinterpret_cast<__cbuf__ uint64_t*>(cbuf_workspace + C1_OFFSET_BYTES);
            __fbuf__ uint64_t quant_fb[QUANT_TRANSFER_BYTES / sizeof(uint64_t)];
            asc_copy_gm2l1(
                reinterpret_cast<__cbuf__ void*>(quant_l1), reinterpret_cast<__gm__ void*>(quant_pre), 1,
                QUANT_TRANSFER_BYTES / C0_BYTES, 0, 0, 0);
            asc_sync_notify(PIPE_MTE2, PIPE_FIX, EVENT_ID0);
            asc_sync_wait(PIPE_MTE2, PIPE_FIX, EVENT_ID0);
            asc_copy_l12fb(
                reinterpret_cast<__fbuf__ void*>(quant_fb), reinterpret_cast<__cbuf__ void*>(quant_l1), 1,
                QUANT_TRANSFER_BYTES / FIXPIPE_L1_TO_FB_BURST_BYTES, 0, 0);
            const uint64_t quant_fb_addr =
                static_cast<uint64_t>(reinterpret_cast<uintptr_t>(quant_fb)) / FIXPIPE_QUANT_ADDR_GRANULARITY;
            asc_set_l0c2gm_config(0, quant_fb_addr, false);
            asc_sync_pipe(PIPE_FIX);
        }

        asc_sync_notify(PIPE_M, PIPE_FIX, EVENT_ID0);
        asc_sync_wait(PIPE_M, PIPE_FIX, EVENT_ID0);
        if constexpr (IS_NZ2ND_OUTPUT) {
            asc_set_l0c2gm_nz2nd(1, 0, 0);
        }

        if constexpr (SCENARIO_NUM == 3) {
            asc_set_l0c_copy_prequant(SCALAR_QUANT_INT8);
            asc_copy_l0c2gm(
                reinterpret_cast<__gm__ int8_t*>(c), c_l0, ceil_align(N, CUBE_BLOCK), M, FIXPIPE_NZ_DST_STRIDE_INT8,
                ceil_align(M, CUBE_BLOCK), L2_CACHE_NORMAL, 0, UNIT_FLAG_DISABLE,
                static_cast<uint64_t>(QuantMode_t::QF322B8_PRE), IS_RELU_ENABLED, false, false,
                static_cast<uint64_t>(QuantMode_post::NoConv), 0, false, 0, false, false, false, false);
        } else {
            asc_copy_l0c2gm(
                reinterpret_cast<__gm__ int8_t*>(c), c_l0, N, M, N, ceil_align(M, CUBE_BLOCK), L2_CACHE_NORMAL, 0,
                UNIT_FLAG_DISABLE, static_cast<uint64_t>(QuantMode_t::VQF322B8_PRE), IS_RELU_ENABLED, false, true,
                static_cast<uint64_t>(QuantMode_post::NoConv), 0, false, 0, false, false, false, false);
        }
    }
}

bool check_acl_status(aclError status, const char* operation)
{
    if (status != ACL_SUCCESS) {
        ERROR_LOG("%s failed. error code = %d", operation, static_cast<int32_t>(status));
        return false;
    }
    return true;
}

int32_t main(int32_t argc, char* argv[])
{
    (void)argc;
    (void)argv;

    constexpr size_t input_element_size = IS_INT8_INPUT ? sizeof(int8_t) : sizeof(half);
    constexpr size_t output_element_size = (SCENARIO_NUM == 1 || SCENARIO_NUM == 2) ? sizeof(half) : sizeof(int8_t);
    constexpr size_t a_file_size = M * K * input_element_size;
    constexpr size_t b_file_size = K * N * input_element_size;
    constexpr size_t c_file_size = M * N * output_element_size;
    constexpr int32_t device_id = 0;

    uint8_t* a_host = nullptr;
    uint8_t* b_host = nullptr;
    uint8_t* c_host = nullptr;
    uint8_t* a_device = nullptr;
    uint8_t* b_device = nullptr;
    void* c_device = nullptr;
    uint8_t* quant_host = nullptr;
    uint64_t* quant_device = nullptr;
    aclrtStream stream = nullptr;
    bool acl_initialized = false;
    bool device_set = false;
    bool stream_created = false;
    int32_t result = 1;

    if (!check_acl_status(aclInit(nullptr), "aclInit")) {
        goto cleanup;
    }
    acl_initialized = true;
    if (!check_acl_status(aclrtSetDevice(device_id), "aclrtSetDevice")) {
        goto cleanup;
    }
    device_set = true;
    if (!check_acl_status(aclrtCreateStream(&stream), "aclrtCreateStream")) {
        goto cleanup;
    }
    stream_created = true;

    if (!check_acl_status(aclrtMallocHost(reinterpret_cast<void**>(&a_host), a_file_size), "aclrtMallocHost(a_host)") ||
        !check_acl_status(
            aclrtMalloc(reinterpret_cast<void**>(&a_device), a_file_size, ACL_MEM_MALLOC_HUGE_FIRST),
            "aclrtMalloc(a_device)") ||
        !ReadFile("./input/x1_gm.bin", a_host, a_file_size) ||
        !check_acl_status(
            aclrtMemcpy(a_device, a_file_size, a_host, a_file_size, ACL_MEMCPY_HOST_TO_DEVICE),
            "aclrtMemcpy(a_device)")) {
        goto cleanup;
    }

    if (!check_acl_status(aclrtMallocHost(reinterpret_cast<void**>(&b_host), b_file_size), "aclrtMallocHost(b_host)") ||
        !check_acl_status(
            aclrtMalloc(reinterpret_cast<void**>(&b_device), b_file_size, ACL_MEM_MALLOC_HUGE_FIRST),
            "aclrtMalloc(b_device)") ||
        !ReadFile("./input/x2_gm.bin", b_host, b_file_size) ||
        !check_acl_status(
            aclrtMemcpy(b_device, b_file_size, b_host, b_file_size, ACL_MEMCPY_HOST_TO_DEVICE),
            "aclrtMemcpy(b_device)")) {
        goto cleanup;
    }

    if (!check_acl_status(aclrtMallocHost(reinterpret_cast<void**>(&c_host), c_file_size), "aclrtMallocHost(c_host)") ||
        !check_acl_status(aclrtMalloc(&c_device, c_file_size, ACL_MEM_MALLOC_HUGE_FIRST), "aclrtMalloc(c_device)")) {
        goto cleanup;
    }

    if constexpr (IS_VECTOR_QUANT) {
        if (!check_acl_status(
                aclrtMallocHost(reinterpret_cast<void**>(&quant_host), QUANT_TRANSFER_BYTES),
                "aclrtMallocHost(quant_host)") ||
            !check_acl_status(
                aclrtMalloc(reinterpret_cast<void**>(&quant_device), QUANT_TRANSFER_BYTES, ACL_MEM_MALLOC_HUGE_FIRST),
                "aclrtMalloc(quant_device)") ||
            !ReadFile("./input/quant_pre.bin", quant_host, QUANT_TRANSFER_BYTES) ||
            !check_acl_status(
                aclrtMemcpy(
                    quant_device, QUANT_TRANSFER_BYTES, quant_host, QUANT_TRANSFER_BYTES, ACL_MEMCPY_HOST_TO_DEVICE),
                "aclrtMemcpy(quant_device)")) {
            goto cleanup;
        }
    }

    data_copy_l0c2gm<<<1, 0, stream>>>(a_device, b_device, c_device, quant_device);
    if (!check_acl_status(aclrtSynchronizeStream(stream), "aclrtSynchronizeStream") ||
        !check_acl_status(
            aclrtMemcpy(c_host, c_file_size, c_device, c_file_size, ACL_MEMCPY_DEVICE_TO_HOST),
            "aclrtMemcpy(c_host)") ||
        !WriteFile("./output/output.bin", c_host, c_file_size)) {
        goto cleanup;
    }

    result = 0;

cleanup:
    if (quant_device != nullptr && !check_acl_status(aclrtFree(quant_device), "aclrtFree(quant_device)")) {
        result = 1;
    }
    if (quant_host != nullptr && !check_acl_status(aclrtFreeHost(quant_host), "aclrtFreeHost(quant_host)")) {
        result = 1;
    }
    if (c_device != nullptr && !check_acl_status(aclrtFree(c_device), "aclrtFree(c_device)")) {
        result = 1;
    }
    if (c_host != nullptr && !check_acl_status(aclrtFreeHost(c_host), "aclrtFreeHost(c_host)")) {
        result = 1;
    }
    if (b_device != nullptr && !check_acl_status(aclrtFree(b_device), "aclrtFree(b_device)")) {
        result = 1;
    }
    if (b_host != nullptr && !check_acl_status(aclrtFreeHost(b_host), "aclrtFreeHost(b_host)")) {
        result = 1;
    }
    if (a_device != nullptr && !check_acl_status(aclrtFree(a_device), "aclrtFree(a_device)")) {
        result = 1;
    }
    if (a_host != nullptr && !check_acl_status(aclrtFreeHost(a_host), "aclrtFreeHost(a_host)")) {
        result = 1;
    }
    if (stream_created && !check_acl_status(aclrtDestroyStream(stream), "aclrtDestroyStream")) {
        result = 1;
    }
    if (device_set && !check_acl_status(aclrtResetDevice(device_id), "aclrtResetDevice")) {
        result = 1;
    }
    if (acl_initialized && !check_acl_status(aclFinalize(), "aclFinalize")) {
        result = 1;
    }
    return result;
}
