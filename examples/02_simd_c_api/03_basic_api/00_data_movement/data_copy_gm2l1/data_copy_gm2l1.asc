/* !
 * \file data_copy_gm2l1.asc
 * \brief Demonstrates GM-to-L1 matrix data movement with the Ascend C C API.
 */

#include <cstddef>
#include <cstdint>

#include "acl/acl.h"
#include "c_api/asc_simd.h"
#include "data_utils.h"

// half type, cube block: [16, 16]
constexpr uint32_t CUBE_BLOCK = 16;
constexpr uint32_t C0_BYTES = 32;
constexpr uint32_t FIXPIPE_QUANT_ADDR_GRANULARITY = 128;
constexpr uint32_t FIXPIPE_L1_TO_FB_BURST_BYTES = 64;

constexpr uint32_t M = 128;
constexpr uint32_t K = 128;
constexpr uint32_t N = 256;

__aicore__ constexpr uint32_t ceil_division(uint32_t numerator, uint32_t denominator)
{
    return (numerator + denominator - 1) / denominator;
}

__aicore__ constexpr uint32_t ceil_align(uint32_t numerator, uint32_t denominator)
{
    return ceil_division(numerator, denominator) * denominator;
}

// Fixpipe parameters: srcStride = ceil_align(baseM, CUBE_BLOCK)
// and dstStride = baseN.
constexpr uint16_t FIXPIPE_SRC_STRIDE = static_cast<uint16_t>(ceil_align(M, CUBE_BLOCK));
constexpr uint32_t FIXPIPE_DST_STRIDE = N;

constexpr uint32_t C0_ELEMENTS = C0_BYTES / sizeof(half);
constexpr uint32_t A_SINGLE_ELEMENTS = M * K;
constexpr uint32_t B_SINGLE_ELEMENTS = K * N;
constexpr uint32_t A_L1_ELEMENTS = ceil_align(M, CUBE_BLOCK) * ceil_align(K, C0_BYTES);
constexpr uint32_t B_L1_ELEMENTS = ceil_align(K, C0_BYTES) * ceil_align(N, C0_BYTES);
constexpr uint32_t C_L0_ELEMENTS = ceil_align(M, CUBE_BLOCK) * ceil_align(N, CUBE_BLOCK);
constexpr uint32_t QUANT_ELEMENTS = N;
// Fixpipe consumes vector-quantization parameters in 128B units. Keep the
// transfer buffer and GM-to-L1 transfer length aligned to that unit.
constexpr uint32_t QUANT_TRANSFER_BYTES = ceil_align(QUANT_ELEMENTS * sizeof(uint64_t), FIXPIPE_QUANT_ADDR_GRANULARITY);

// A1 starts at 0, B1 starts at 64 KiB, and C1 starts at 128 KiB.
constexpr uint32_t A1_OFFSET_BYTES = 0;
constexpr uint32_t B1_OFFSET_BYTES = 64 * 1024;
constexpr uint32_t C1_OFFSET_BYTES = 128 * 1024;
constexpr uint32_t CBUF_WORKSPACE_BYTES = C1_OFFSET_BYTES + QUANT_TRANSFER_BYTES;

constexpr uint8_t L2_CACHE_NORMAL = 0;
constexpr uint8_t UNIT_FLAG_DISABLE = 0;
// [15:0]  matrix_num (ndNum/dnNum) = 1;
// [31:16] dst_nz_n_stride = 1;
// [47:32] dst_nz_c0_stride = ceil_align(M/K, CUBE_BLOCK);
// [63:48] loop4_dst_stride = dst_nz_matrix_stride * sizeof(half) / C0_BYTES = 0.
// Only one input matrix is moved, so no inter-matrix destination stride is needed.
constexpr uint16_t MTE2_NZ_MATRIX_NUM = 1;
constexpr uint16_t MTE2_NZ_N_STRIDE = 1;
constexpr uint16_t MTE2_NZ_LOOP4_DST_STRIDE = 0;
constexpr uint16_t A_MTE2_NZ_C0_STRIDE = static_cast<uint16_t>(ceil_align(M, CUBE_BLOCK));
constexpr uint16_t B_MTE2_NZ_C0_STRIDE = static_cast<uint16_t>(ceil_align(K, CUBE_BLOCK));
constexpr uint64_t A_MTE2_NZ_PARA = (static_cast<uint64_t>(MTE2_NZ_LOOP4_DST_STRIDE) << 48) |
                                    (static_cast<uint64_t>(A_MTE2_NZ_C0_STRIDE) << 32) |
                                    (static_cast<uint64_t>(MTE2_NZ_N_STRIDE) << 16) | MTE2_NZ_MATRIX_NUM;
constexpr uint64_t B_MTE2_NZ_PARA = (static_cast<uint64_t>(MTE2_NZ_LOOP4_DST_STRIDE) << 48) |
                                    (static_cast<uint64_t>(B_MTE2_NZ_C0_STRIDE) << 32) |
                                    (static_cast<uint64_t>(MTE2_NZ_N_STRIDE) << 16) | MTE2_NZ_MATRIX_NUM;

__global__ __cube__ void data_copy_gm2l1(__gm__ half* a, __gm__ half* b, __gm__ void* c, __gm__ uint64_t* quant_pre)
{
    asc_init();

    // The C API does not attach an A1/B1/C1 position to a local array. Use
    // explicit offsets so the L1 layout matches data_copy_gm2l1.asc exactly.
    __cbuf__ uint8_t cbuf_workspace[CBUF_WORKSPACE_BYTES];
    __cbuf__ half* a_l1 = reinterpret_cast<__cbuf__ half*>(cbuf_workspace + A1_OFFSET_BYTES);
    __cbuf__ half* b_l1 = reinterpret_cast<__cbuf__ half*>(cbuf_workspace + B1_OFFSET_BYTES);
    __ca__ half a_l0[A_L1_ELEMENTS];
    __cb__ half b_l0[B_L1_ELEMENTS];
    __cc__ float c_l0[C_L0_ELEMENTS];

    if constexpr (SCENARIO_NUM == 1) {
        // The input is already stored in Nz layout.
        asc_copy_gm2l1((__cbuf__ void*)a_l1, (__gm__ void*)a, 1, A_SINGLE_ELEMENTS * sizeof(half) / C0_BYTES, 0, 0, 0);
        asc_copy_gm2l1((__cbuf__ void*)b_l1, (__gm__ void*)b, 1, B_SINGLE_ELEMENTS * sizeof(half) / C0_BYTES, 0, 0, 0);
    } else if constexpr (SCENARIO_NUM == 3) {
        // Convert DN input to Nz while moving GM data to L1.
        asc_set_gm2l1_nz_para(A_MTE2_NZ_PARA);
        asc_copy_gm2l1_dn2nz(a_l1, a, M * sizeof(half), L2_CACHE_NORMAL, M, K, 0, false);
        asc_set_gm2l1_nz_para(B_MTE2_NZ_PARA);
        asc_copy_gm2l1_dn2nz(b_l1, b, K * sizeof(half), L2_CACHE_NORMAL, K, N, 0, false);
    } else {
        // Convert ND input to Nz while moving GM data to L1.
        asc_set_gm2l1_nz_para(A_MTE2_NZ_PARA);
        asc_copy_gm2l1_nd2nz(a_l1, a, K * sizeof(half), L2_CACHE_NORMAL, M, K, 0, false);
        asc_set_gm2l1_nz_para(B_MTE2_NZ_PARA);
        asc_copy_gm2l1_nd2nz(b_l1, b, N * sizeof(half), L2_CACHE_NORMAL, K, N, 0, false);
    }

    // L0A/L0B transfers read L1 only after the MTE2 input copies complete.
    asc_sync_notify(PIPE_MTE2, PIPE_MTE1, EVENT_ID0);
    asc_sync_wait(PIPE_MTE2, PIPE_MTE1, EVENT_ID0);

    // Move the Nz data from L1 to L0A/L0B for matrix multiplication.
    asc_copy_l12l0a(
        a_l0, a_l1, 0, 0, ceil_division(M, CUBE_BLOCK), ceil_division(K, C0_ELEMENTS), ceil_division(M, CUBE_BLOCK),
        ceil_division(M, CUBE_BLOCK));
    // The transpose transfer converts Nz data in L1 to the Zn layout required by L0B.
    asc_copy_l12l0b_transpose(
        b_l0, b_l1, 0, 0, ceil_division(K, CUBE_BLOCK), ceil_division(N, C0_ELEMENTS), ceil_division(K, CUBE_BLOCK),
        ceil_division(N, CUBE_BLOCK));
    // Mmad consumes L0A and L0B after MTE1 fills them.
    asc_sync_notify(PIPE_MTE1, PIPE_M, EVENT_ID0);
    asc_sync_wait(PIPE_MTE1, PIPE_M, EVENT_ID0);

    asc_mmad(c_l0, a_l0, b_l0, M, K, ceil_align(N, C0_BYTES), UNIT_FLAG_DISABLE, false, false, true);

    if constexpr (SCENARIO_NUM == 4) {
        __cbuf__ uint64_t* quant_l1 = reinterpret_cast<__cbuf__ uint64_t*>(cbuf_workspace + C1_OFFSET_BYTES);
        __fbuf__ uint64_t quant_fb[QUANT_TRANSFER_BYTES / sizeof(uint64_t)];

        // Quantization parameters are consumed by Fixpipe, so let MTE2 fill
        // L1 while Mmad runs, then make only Fixpipe wait for them.
        asc_copy_gm2l1((__cbuf__ void*)quant_l1, (__gm__ void*)quant_pre, 1, QUANT_TRANSFER_BYTES / C0_BYTES, 0, 0, 0);
        // Fixpipe must not read quant_l1 until the MTE2 transfer completes.
        asc_sync_notify(PIPE_MTE2, PIPE_FIX, EVENT_ID0);
        asc_sync_wait(PIPE_MTE2, PIPE_FIX, EVENT_ID0);
        // Move the 2048B quantization-parameter buffer in 64B data blocks, so len_burst is 32.
        // Use the explicit form to move exactly the 128B-aligned parameter buffer.
        asc_copy_l12fb(
            (__fbuf__ void*)quant_fb, (__cbuf__ void*)quant_l1, 1, QUANT_TRANSFER_BYTES / FIXPIPE_L1_TO_FB_BURST_BYTES,
            0, 0);
        const uint64_t quant_fb_addr =
            static_cast<uint64_t>(reinterpret_cast<uintptr_t>(quant_fb)) / FIXPIPE_QUANT_ADDR_GRANULARITY;
        asc_set_l0c2gm_config(0, quant_fb_addr, false);
        // Complete L1-to-FB before the final L0C-to-GM Fixpipe operation consumes the FPC configuration.
        asc_sync_pipe(PIPE_FIX);
    }

    // Fixpipe needs the Mmad result, but does not need to wait for unrelated pipelines.
    asc_sync_notify(PIPE_M, PIPE_FIX, EVENT_ID0);
    asc_sync_wait(PIPE_M, PIPE_FIX, EVENT_ID0);

    // Configure loop3_para for every L0C-to-GM operation, including the vector-quantization path.
    // This sample outputs one contiguous ND matrix, so only nd_num is used.
    asc_set_l0c2gm_nz2nd(1, 0, 0);
    if constexpr (SCENARIO_NUM == 4) {
        // Convert the Nz result in L0C to row-major int8 data in GM with vector quantization.
        asc_copy_l0c2gm(
            (__gm__ int8_t*)c, c_l0, N, M, FIXPIPE_DST_STRIDE, FIXPIPE_SRC_STRIDE, L2_CACHE_NORMAL, 0, 0,
            static_cast<uint64_t>(QuantMode_t::VQF322B8_PRE), 0, false, true,
            static_cast<uint64_t>(QuantMode_post::NoConv), 0, false, 0, false, false, false, false);
    } else {
        // Convert the Nz result in L0C to row-major float data in GM.
        asc_copy_l0c2gm(
            (__gm__ float*)c, c_l0, N, M, FIXPIPE_DST_STRIDE, FIXPIPE_SRC_STRIDE, L2_CACHE_NORMAL, 0, 0,
            static_cast<uint64_t>(QuantMode_t::NoQuant), 0, false, true, static_cast<uint64_t>(QuantMode_post::NoConv),
            0, false, 0, false, false, false, false);
    }
}

bool check_acl_status(aclError status, const char* operation)
{
    if (status != ACL_SUCCESS) {
        ERROR_LOG("%s failed. error code = %d", operation, static_cast<int32_t>(status));
        return false;
    }
    return true;
}

int32_t main(int32_t argc, char* argv[])
{
    (void)argc;
    (void)argv;

    constexpr size_t a_file_size = M * K * sizeof(half);
    constexpr size_t b_file_size = K * N * sizeof(half);
    constexpr size_t quant_file_size = QUANT_TRANSFER_BYTES;
    constexpr int32_t device_id = 0;

    size_t c_file_size;
    if constexpr (SCENARIO_NUM == 4) {
        c_file_size = M * N * sizeof(int8_t);
    } else {
        c_file_size = M * N * sizeof(float);
    }

    uint8_t* a_host = nullptr;
    uint8_t* b_host = nullptr;
    uint8_t* c_host = nullptr;
    half* a_device = nullptr;
    half* b_device = nullptr;
    void* c_device = nullptr;
    uint8_t* quant_host = nullptr;
    uint64_t* quant_device = nullptr;
    aclrtStream stream = nullptr;
    bool acl_initialized = false;
    bool device_set = false;
    bool stream_created = false;
    int32_t result = 1;

    if (!check_acl_status(aclInit(nullptr), "aclInit")) {
        goto cleanup;
    }
    acl_initialized = true;
    if (!check_acl_status(aclrtSetDevice(device_id), "aclrtSetDevice")) {
        goto cleanup;
    }
    device_set = true;
    if (!check_acl_status(aclrtCreateStream(&stream), "aclrtCreateStream")) {
        goto cleanup;
    }
    stream_created = true;

    if (!check_acl_status(aclrtMallocHost(reinterpret_cast<void**>(&a_host), a_file_size), "aclrtMallocHost(a_host)") ||
        !check_acl_status(
            aclrtMalloc(reinterpret_cast<void**>(&a_device), a_file_size, ACL_MEM_MALLOC_HUGE_FIRST),
            "aclrtMalloc(a_device)") ||
        !ReadFile("./input/x1_gm.bin", a_host, a_file_size) ||
        !check_acl_status(
            aclrtMemcpy(a_device, a_file_size, a_host, a_file_size, ACL_MEMCPY_HOST_TO_DEVICE),
            "aclrtMemcpy(a_device)")) {
        goto cleanup;
    }

    if (!check_acl_status(aclrtMallocHost(reinterpret_cast<void**>(&b_host), b_file_size), "aclrtMallocHost(b_host)") ||
        !check_acl_status(
            aclrtMalloc(reinterpret_cast<void**>(&b_device), b_file_size, ACL_MEM_MALLOC_HUGE_FIRST),
            "aclrtMalloc(b_device)") ||
        !ReadFile("./input/x2_gm.bin", b_host, b_file_size) ||
        !check_acl_status(
            aclrtMemcpy(b_device, b_file_size, b_host, b_file_size, ACL_MEMCPY_HOST_TO_DEVICE),
            "aclrtMemcpy(b_device)")) {
        goto cleanup;
    }

    if (!check_acl_status(aclrtMallocHost(reinterpret_cast<void**>(&c_host), c_file_size), "aclrtMallocHost(c_host)") ||
        !check_acl_status(aclrtMalloc(&c_device, c_file_size, ACL_MEM_MALLOC_HUGE_FIRST), "aclrtMalloc(c_device)")) {
        goto cleanup;
    }

    if constexpr (SCENARIO_NUM == 4) {
        if (!check_acl_status(
                aclrtMallocHost(reinterpret_cast<void**>(&quant_host), quant_file_size),
                "aclrtMallocHost(quant_host)") ||
            !check_acl_status(
                aclrtMalloc(reinterpret_cast<void**>(&quant_device), quant_file_size, ACL_MEM_MALLOC_HUGE_FIRST),
                "aclrtMalloc(quant_device)") ||
            !ReadFile("./input/quant_pre.bin", quant_host, quant_file_size) ||
            !check_acl_status(
                aclrtMemcpy(quant_device, quant_file_size, quant_host, quant_file_size, ACL_MEMCPY_HOST_TO_DEVICE),
                "aclrtMemcpy(quant_device)")) {
            goto cleanup;
        }
    }

    data_copy_gm2l1<<<1, 0, stream>>>(a_device, b_device, c_device, quant_device);
    if (!check_acl_status(aclrtSynchronizeStream(stream), "aclrtSynchronizeStream") ||
        !check_acl_status(
            aclrtMemcpy(c_host, c_file_size, c_device, c_file_size, ACL_MEMCPY_DEVICE_TO_HOST),
            "aclrtMemcpy(c_host)") ||
        !WriteFile("./output/output.bin", c_host, c_file_size)) {
        goto cleanup;
    }

    result = 0;

cleanup:
    if constexpr (SCENARIO_NUM == 4) {
        if (quant_device != nullptr) {
            if (!check_acl_status(aclrtFree(quant_device), "aclrtFree(quant_device)")) {
                result = 1;
            }
        }
        if (quant_host != nullptr) {
            if (!check_acl_status(aclrtFreeHost(quant_host), "aclrtFreeHost(quant_host)")) {
                result = 1;
            }
        }
    }
    if (c_device != nullptr) {
        if (!check_acl_status(aclrtFree(c_device), "aclrtFree(c_device)")) {
            result = 1;
        }
    }
    if (c_host != nullptr) {
        if (!check_acl_status(aclrtFreeHost(c_host), "aclrtFreeHost(c_host)")) {
            result = 1;
        }
    }
    if (b_device != nullptr) {
        if (!check_acl_status(aclrtFree(b_device), "aclrtFree(b_device)")) {
            result = 1;
        }
    }
    if (b_host != nullptr) {
        if (!check_acl_status(aclrtFreeHost(b_host), "aclrtFreeHost(b_host)")) {
            result = 1;
        }
    }
    if (a_device != nullptr) {
        if (!check_acl_status(aclrtFree(a_device), "aclrtFree(a_device)")) {
            result = 1;
        }
    }
    if (a_host != nullptr) {
        if (!check_acl_status(aclrtFreeHost(a_host), "aclrtFreeHost(a_host)")) {
            result = 1;
        }
    }
    if (stream_created) {
        if (!check_acl_status(aclrtDestroyStream(stream), "aclrtDestroyStream")) {
            result = 1;
        }
    }
    if (device_set) {
        if (!check_acl_status(aclrtResetDevice(device_id), "aclrtResetDevice")) {
            result = 1;
        }
    }
    if (acl_initialized) {
        if (!check_acl_status(aclFinalize(), "aclFinalize")) {
            result = 1;
        }
    }
    return result;
}
