/* !
 * \file mmad.asc
 * \brief C API 矩阵乘法样例（场景 1 / 场景 2）
 *        场景1：int8_t  输入、int32_t 输出、A/B 均不转置、带 Bias
 *        场景2：bfloat16 输入、float   输出、A 不转置 B 转置、无 Bias（两次 Mmad 累加）
 */

#include "acl/acl.h"
#include "c_api/asc_simd.h"
#include "data_utils.h"

// ========== 编译期场景配置 ==========
constexpr uint32_t scenario_num = SCENARIO_NUM;
constexpr bool HAS_BIAS_TENSOR = (SCENARIO_NUM == 1);

// ========== 共享架构常量 ==========
constexpr uint32_t BLOCK_CUBE = 16;

// ========== 矩阵维度 ==========
constexpr uint32_t M = 30;
constexpr uint32_t N = 40;
constexpr uint32_t K = 70;

// ========== 各场景的常量与流水线函数 ==========
#include "mmad_s1.h"
#include "mmad_s2.h"

// ==================================================================
// 核函数入口：按场景分发四阶段流水线
// ==================================================================
__global__ __cube__ void mmad_custom(__gm__ uint8_t* a, __gm__ uint8_t* b, __gm__ uint8_t* bias, __gm__ uint8_t* c)
{
    asc_init();

    if constexpr (scenario_num == 1) {
        // === 场景 1：int8_t，带 Bias ===
        __cbuf__ int8_t a_l1[S1_A_L1_SIZE];
        __cbuf__ int8_t b_l1[S1_B_L1_SIZE];
        __cbuf__ int32_t bias_l1[S1_BIAS_ELEMS];

        s1_copy_matrix_a_to_l1(a_l1, (__gm__ int8_t*)a);
        s1_copy_matrix_b_to_l1(b_l1, (__gm__ int8_t*)b);
        s1_copy_bias_to_l1(bias_l1, (__gm__ int32_t*)bias);

        __ca__ int8_t a_l0[S1_A_L0_SIZE];
        __cb__ int8_t b_l0[S1_B_L0_SIZE];

        s1_split_matrix_a_to_l0a(a_l0, a_l1);
        s1_split_matrix_b_to_l0b_trans(b_l0, b_l1);
        s1_split_bias_to_bt(bias_l1);

        __cc__ int32_t c_l0[S1_C_L0_SIZE];

        s1_compute_mmad(c_l0, a_l0, b_l0);
        s1_copy_result_to_gm((__gm__ int32_t*)c, c_l0);

    } else if constexpr (scenario_num == 2) {
        // === 场景 2：bfloat16，无 Bias，两次 Mmad 累加 ===
        __cbuf__ bfloat16_t a_l1[S2_A_L1_SIZE];
        __cbuf__ bfloat16_t b_l1[S2_B_L1_SIZE];

        s2_copy_matrix_a_to_l1(a_l1, (__gm__ bfloat16_t*)a);
        s2_copy_matrix_b_to_l1(b_l1, (__gm__ bfloat16_t*)b);

        __ca__ bfloat16_t a_l0[S2_A_L0_SIZE];
        __cb__ bfloat16_t b_l0[S2_B_L0_SIZE];

        s2_split_matrix_a_to_l0a(a_l0, a_l1);
        s2_split_matrix_b_to_l0b(b_l0, b_l1);

        __cc__ float c_l0[S2_C_L0_SIZE];

        s2_compute_mmad(c_l0, a_l0, b_l0);
        s2_copy_result_to_gm((__gm__ float*)c, c_l0);
    }

    asc_sync_pipe(PIPE_ALL);
}

// ==================================================================
// Host 端主函数
// ==================================================================
int32_t main(int32_t argc, char* argv[])
{
    size_t a_file_size = 0;
    size_t b_file_size = 0;
    size_t bias_file_size = 0;
    size_t c_file_size = 0;

    if constexpr (scenario_num == 1) {
        a_file_size = M * K * sizeof(int8_t);
        b_file_size = K * N * sizeof(int8_t);
        bias_file_size = N * sizeof(int32_t);
        c_file_size = M * N * sizeof(int32_t);
    } else if constexpr (scenario_num == 2) {
        a_file_size = M * K * sizeof(bfloat16_t);
        b_file_size = K * N * sizeof(bfloat16_t);
        bias_file_size = N * sizeof(float);
        c_file_size = M * N * sizeof(float);
    }

    uint32_t num_blocks = 1;

    aclInit(nullptr);
    int32_t device_id = 0;
    aclrtSetDevice(device_id);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t* a_host;
    uint8_t* a_device;
    aclrtMallocHost((void**)(&a_host), a_file_size);
    aclrtMalloc((void**)&a_device, a_file_size, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/x1_gm.bin", a_file_size, a_host, a_file_size);
    aclrtMemcpy(a_device, a_file_size, a_host, a_file_size, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t* b_host;
    uint8_t* b_device;
    aclrtMallocHost((void**)(&b_host), b_file_size);
    aclrtMalloc((void**)&b_device, b_file_size, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/x2_gm.bin", b_file_size, b_host, b_file_size);
    aclrtMemcpy(b_device, b_file_size, b_host, b_file_size, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t* bias_host = nullptr;
    uint8_t* bias_device = nullptr;
    if constexpr (HAS_BIAS_TENSOR) {
        aclrtMallocHost((void**)(&bias_host), bias_file_size);
        aclrtMalloc((void**)&bias_device, bias_file_size, ACL_MEM_MALLOC_HUGE_FIRST);
        ReadFile("./input/bias_gm.bin", bias_file_size, bias_host, bias_file_size);
        aclrtMemcpy(bias_device, bias_file_size, bias_host, bias_file_size, ACL_MEMCPY_HOST_TO_DEVICE);
    }

    uint8_t* c_host;
    uint8_t* c_device;
    aclrtMallocHost((void**)(&c_host), c_file_size);
    aclrtMalloc((void**)&c_device, c_file_size, ACL_MEM_MALLOC_HUGE_FIRST);

    mmad_custom<<<num_blocks, 0, stream>>>(a_device, b_device, bias_device, c_device);
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(c_host, c_file_size, c_device, c_file_size, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", c_host, c_file_size);

    aclrtFree(a_device);
    aclrtFreeHost(a_host);
    aclrtFree(b_device);
    aclrtFreeHost(b_host);
    if constexpr (HAS_BIAS_TENSOR) {
        aclrtFree(bias_device);
        aclrtFreeHost(bias_host);
    }
    aclrtFree(c_device);
    aclrtFreeHost(c_host);

    aclrtDestroyStream(stream);
    aclrtResetDevice(device_id);
    aclFinalize();
    return 0;
}
