/* !
 * \file data_copy_ub2l1.asc
 * \brief Demonstrates UB-to-L1 matrix data movement with the Ascend C C API.
 */

#include <cstddef>
#include <cstdint>

#include "acl/acl.h"
#include "c_api/asc_simd.h"
#include "data_utils.h"

constexpr uint32_t CUBE_BLOCK = 16;
constexpr uint32_t C0_BYTES = 32;
constexpr uint32_t C0_ELEMENTS = C0_BYTES / sizeof(half);

__aicore__ constexpr uint32_t ceil_division(uint32_t numerator, uint32_t denominator)
{
    return (numerator + denominator - 1) / denominator;
}

__aicore__ constexpr uint32_t ceil_align(uint32_t numerator, uint32_t denominator)
{
    return ceil_division(numerator, denominator) * denominator;
}

constexpr uint16_t M = 128;
constexpr uint16_t K = 128;
constexpr uint16_t N = 128;

constexpr uint32_t A_ELEMENTS = M * K;
constexpr uint32_t B_ELEMENTS = K * N;
constexpr uint32_t C_ELEMENTS = M * N;
constexpr uint32_t A_BYTES = A_ELEMENTS * sizeof(half);
constexpr uint32_t B_BYTES = B_ELEMENTS * sizeof(half);

constexpr uint32_t A_L1_ELEMENTS = ceil_align(M, CUBE_BLOCK) * ceil_align(K, C0_ELEMENTS);
constexpr uint32_t B_L1_ELEMENTS = ceil_align(K, C0_ELEMENTS) * ceil_align(N, C0_ELEMENTS);
constexpr uint32_t C_L0_ELEMENTS = ceil_align(M, CUBE_BLOCK) * ceil_align(N, CUBE_BLOCK);

constexpr uint8_t L2_CACHE_NORMAL = 0;
constexpr uint8_t UNIT_FLAG_DISABLE = 0;
constexpr int64_t CROSS_CORE_FLAG_ID = 0x8;

__aicore__ void copy_ub_nd_to_nz(__ubuf__ half* dst, __ubuf__ half* src, uint16_t height, uint16_t width)
{
    const uint16_t column_blocks = width * sizeof(half) / C0_BYTES;
    const uint16_t src_gap = column_blocks - 1;

    for (uint16_t column_block = 0; column_block < column_blocks; ++column_block) {
        asc_copy_ub2ub(
            dst + column_block * height * C0_ELEMENTS, src + column_block * C0_ELEMENTS, height, 1, src_gap, 0);
    }
}

__global__ __mix__(1, 2) void data_copy_ub2l1(__gm__ half* a, __gm__ half* b, __gm__ void* c)
{
    asc_init();

    // A1 and B1 use separate L1 buffers shared by the AIV and AIC subcores.
    __cbuf__ half a_l1[A_L1_ELEMENTS];
    __cbuf__ half b_l1[B_L1_ELEMENTS];
    __ubuf__ half a_ub[A_ELEMENTS];
    __ubuf__ half b_ub[B_ELEMENTS];
    __ubuf__ half a_nz_ub[A_ELEMENTS];
    __ubuf__ half b_nz_ub[B_ELEMENTS];
    __ca__ half a_l0[A_L1_ELEMENTS];
    __cb__ half b_l0[B_L1_ELEMENTS];
    __cc__ float c_l0[C_L0_ELEMENTS];

    if ASC_IS_AIV {
        asc_copy_gm2ub(a_ub, a, A_BYTES);
        asc_copy_gm2ub(b_ub, b, B_BYTES);

        if constexpr (SCENARIO_NUM == 1) {
            // The inputs are already stored in Nz layout.
            asc_sync_notify(PIPE_MTE2, PIPE_MTE3, EVENT_ID0);
            asc_sync_wait(PIPE_MTE2, PIPE_MTE3, EVENT_ID0);
            asc_copy_ub2l1(a_l1, a_ub, A_BYTES);
            asc_copy_ub2l1(b_l1, b_ub, B_BYTES);
        } else {
            // Reorder ND data to Nz in independent UB temporary buffers.
            asc_sync_notify(PIPE_MTE2, PIPE_V, EVENT_ID0);
            asc_sync_wait(PIPE_MTE2, PIPE_V, EVENT_ID0);
            copy_ub_nd_to_nz(a_nz_ub, a_ub, M, K);
            copy_ub_nd_to_nz(b_nz_ub, b_ub, K, N);
            asc_sync_notify(PIPE_V, PIPE_MTE3, EVENT_ID0);
            asc_sync_wait(PIPE_V, PIPE_MTE3, EVENT_ID0);
            asc_copy_ub2l1(a_l1, a_nz_ub, A_BYTES);
            asc_copy_ub2l1(b_l1, b_nz_ub, B_BYTES);
        }

        // The AIC core reads L1 only after both MTE3 transfers are complete.
        asc_sync_block_arrive(PIPE_MTE3, CROSS_CORE_FLAG_ID);
    }

    if ASC_IS_AIC {
        asc_sync_block_wait(PIPE_S, CROSS_CORE_FLAG_ID);
        asc_copy_l12l0a(
            a_l0, a_l1, 0, 0, ceil_division(M, CUBE_BLOCK), ceil_division(K, C0_ELEMENTS), ceil_division(M, CUBE_BLOCK),
            ceil_division(M, CUBE_BLOCK));
        asc_copy_l12l0b_transpose(
            b_l0, b_l1, 0, 0, ceil_division(K, CUBE_BLOCK), ceil_division(N, C0_ELEMENTS), ceil_division(K, CUBE_BLOCK),
            ceil_division(N, C0_ELEMENTS));
        asc_sync_notify(PIPE_MTE1, PIPE_M, EVENT_ID0);
        asc_sync_wait(PIPE_MTE1, PIPE_M, EVENT_ID0);

        asc_mmad(c_l0, a_l0, b_l0, M, K, ceil_align(N, C0_ELEMENTS), UNIT_FLAG_DISABLE, false, false, true);
        asc_sync_notify(PIPE_M, PIPE_FIX, EVENT_ID0);
        asc_sync_wait(PIPE_M, PIPE_FIX, EVENT_ID0);

        // Configure one Nz matrix to be written back as a contiguous ND matrix.
        asc_set_l0c2gm_nz2nd(1, 2, M * N);
        asc_copy_l0c2gm(
            (__gm__ float*)c, c_l0, N, M, N, ceil_align(M, CUBE_BLOCK), L2_CACHE_NORMAL, 0, 0,
            static_cast<uint64_t>(QuantMode_t::NoQuant), 0, false, true, static_cast<uint64_t>(QuantMode_post::NoConv),
            0, false, 0, false, false, false, false);
    }
    asc_sync_pipe(PIPE_ALL);
}

bool check_acl_status(aclError status, const char* operation)
{
    if (status != ACL_SUCCESS) {
        ERROR_LOG("%s failed. error code = %d", operation, static_cast<int32_t>(status));
        return false;
    }
    return true;
}

int32_t main(int32_t argc, char* argv[])
{
    (void)argc;
    (void)argv;

    constexpr size_t a_file_size = A_BYTES;
    constexpr size_t b_file_size = B_BYTES;
    constexpr size_t c_file_size = C_ELEMENTS * sizeof(float);
    constexpr int32_t device_id = 0;

    uint8_t* a_host = nullptr;
    uint8_t* b_host = nullptr;
    uint8_t* c_host = nullptr;
    half* a_device = nullptr;
    half* b_device = nullptr;
    void* c_device = nullptr;
    aclrtStream stream = nullptr;
    bool acl_initialized = false;
    bool device_set = false;
    bool stream_created = false;
    int32_t result = 1;

    if (!check_acl_status(aclInit(nullptr), "aclInit")) {
        goto cleanup;
    }
    acl_initialized = true;
    if (!check_acl_status(aclrtSetDevice(device_id), "aclrtSetDevice")) {
        goto cleanup;
    }
    device_set = true;
    if (!check_acl_status(aclrtCreateStream(&stream), "aclrtCreateStream")) {
        goto cleanup;
    }
    stream_created = true;
    if (!check_acl_status(aclrtMallocHost(reinterpret_cast<void**>(&a_host), a_file_size), "aclrtMallocHost(a_host)") ||
        !check_acl_status(
            aclrtMalloc(reinterpret_cast<void**>(&a_device), a_file_size, ACL_MEM_MALLOC_HUGE_FIRST),
            "aclrtMalloc(a_device)") ||
        !ReadFile("./input/x1_gm.bin", a_host, a_file_size) ||
        !check_acl_status(
            aclrtMemcpy(a_device, a_file_size, a_host, a_file_size, ACL_MEMCPY_HOST_TO_DEVICE),
            "aclrtMemcpy(a_device)")) {
        goto cleanup;
    }

    if (!check_acl_status(aclrtMallocHost(reinterpret_cast<void**>(&b_host), b_file_size), "aclrtMallocHost(b_host)") ||
        !check_acl_status(
            aclrtMalloc(reinterpret_cast<void**>(&b_device), b_file_size, ACL_MEM_MALLOC_HUGE_FIRST),
            "aclrtMalloc(b_device)") ||
        !ReadFile("./input/x2_gm.bin", b_host, b_file_size) ||
        !check_acl_status(
            aclrtMemcpy(b_device, b_file_size, b_host, b_file_size, ACL_MEMCPY_HOST_TO_DEVICE),
            "aclrtMemcpy(b_device)")) {
        goto cleanup;
    }

    if (!check_acl_status(aclrtMallocHost(reinterpret_cast<void**>(&c_host), c_file_size), "aclrtMallocHost(c_host)") ||
        !check_acl_status(aclrtMalloc(&c_device, c_file_size, ACL_MEM_MALLOC_HUGE_FIRST), "aclrtMalloc(c_device)")) {
        goto cleanup;
    }

    data_copy_ub2l1<<<1, 0, stream>>>(a_device, b_device, c_device);
    if (!check_acl_status(aclrtSynchronizeStream(stream), "aclrtSynchronizeStream") ||
        !check_acl_status(
            aclrtMemcpy(c_host, c_file_size, c_device, c_file_size, ACL_MEMCPY_DEVICE_TO_HOST),
            "aclrtMemcpy(c_host)") ||
        !WriteFile("./output/output.bin", c_host, c_file_size)) {
        goto cleanup;
    }

    result = 0;

cleanup:
    if (c_device != nullptr && !check_acl_status(aclrtFree(c_device), "aclrtFree(c_device)")) {
        result = 1;
    }
    if (c_host != nullptr && !check_acl_status(aclrtFreeHost(c_host), "aclrtFreeHost(c_host)")) {
        result = 1;
    }
    if (b_device != nullptr && !check_acl_status(aclrtFree(b_device), "aclrtFree(b_device)")) {
        result = 1;
    }
    if (b_host != nullptr && !check_acl_status(aclrtFreeHost(b_host), "aclrtFreeHost(b_host)")) {
        result = 1;
    }
    if (a_device != nullptr && !check_acl_status(aclrtFree(a_device), "aclrtFree(a_device)")) {
        result = 1;
    }
    if (a_host != nullptr && !check_acl_status(aclrtFreeHost(a_host), "aclrtFreeHost(a_host)")) {
        result = 1;
    }
    if (stream_created && !check_acl_status(aclrtDestroyStream(stream), "aclrtDestroyStream")) {
        result = 1;
    }
    if (device_set && !check_acl_status(aclrtResetDevice(device_id), "aclrtResetDevice")) {
        result = 1;
    }
    if (acl_initialized && !check_acl_status(aclFinalize(), "aclFinalize")) {
        result = 1;
    }
    return result;
}
