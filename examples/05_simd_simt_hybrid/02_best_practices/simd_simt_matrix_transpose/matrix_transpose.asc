/* !
 * \file matrix_transpose.asc
 * \brief Matrix transpose with multiple implementation modes selected by SCENARIO_NUM:
 *        SCENARIO_NUM=0: SIMT direct GM access
 *        SCENARIO_NUM=1: SIMD GM-to-UB copy with SIMT transposed UB access
 */

#include <cmath>
#include <cstdint>
#include <cstdio>
#include <vector>
#include "acl/acl.h"
#include "simt_api/asc_simt.h"
#include "c_api/asc_simd.h"

#ifndef SCENARIO_NUM
#define SCENARIO_NUM 1
#endif

#if SCENARIO_NUM < 0 || SCENARIO_NUM > 1
#error "SCENARIO_NUM must be one of 0, 1."
#endif

namespace {
constexpr int TILE_DIM = 32;
constexpr int THREAD_COUNT = TILE_DIM * TILE_DIM;
constexpr uint32_t TILE_ROW_BYTES = TILE_DIM * sizeof(float);
uint32_t verify_result(const std::vector<float>& output, const std::vector<float>& golden, float abs_tolerance = 1e-3f)
{
    if (output.size() != golden.size()) {
        printf("[Failed] Case accuracy is verification failed!\n");
        return 1;
    }
    for (size_t i = 0; i < output.size(); ++i) {
        if (std::fabs(output[i] - golden[i]) > abs_tolerance) {
            printf("[Failed] Case accuracy is verification failed!\n");
            return 1;
        }
    }
    printf("[Success] Case accuracy is verification passed.\n");
    return 0;
}

std::vector<float> compute_golden(const std::vector<float>& input, const std::vector<uint32_t>& input_shape)
{
    if (input_shape.size() != 2) {
        fprintf(stderr, "Input shape must be 2-D.\n");
        return {};
    }

    const uint32_t height = input_shape[0];
    const uint32_t width = input_shape[1];
    if (input.size() != height * width) {
        fprintf(stderr, "Input data size does not match input shape.\n");
        return {};
    }

    // Host reference transpose:
    // output(col, row) = input(row, col)
    std::vector<float> output(input.size());
    for (uint32_t row = 0; row < height; ++row) {
        for (uint32_t col = 0; col < width; ++col) {
            output[col * height + row] = input[row * width + col];
        }
    }
    return output;
}
} // namespace

__simt_vf__ __launch_bounds__(THREAD_COUNT) inline void simt_transpose_naive(
    __gm__ float* output, __gm__ float* input, uint32_t width, uint32_t height, uint32_t grid_width)
{
    // Original coordinates in input.
    uint32_t block_row = blockIdx.x / grid_width;
    uint32_t block_col = blockIdx.x % grid_width;
    uint32_t tile_row = threadIdx.x / TILE_DIM;
    uint32_t tile_col = threadIdx.x % TILE_DIM;
    uint32_t input_row = block_row * TILE_DIM + tile_row;
    uint32_t input_col = block_col * TILE_DIM + tile_col;

    uint32_t index_in = input_col + width * input_row;
    // Transposed coordinates in output.
    uint32_t index_out = input_row + height * input_col;

    output[index_out] = input[index_in];
}

__simt_vf__ __launch_bounds__(THREAD_COUNT) inline void simt_transpose_coalesced(
    __gm__ float* output_tile, __ubuf__ float* input_tile, uint32_t height)
{
    uint32_t tile_row = threadIdx.x / TILE_DIM;
    uint32_t tile_col = threadIdx.x % TILE_DIM;

    output_tile[tile_col + tile_row * height] = input_tile[tile_col * TILE_DIM + tile_row];
}

template <int scenario>
__global__ __vector__ void transpose_kernel(
    __gm__ float* output, __gm__ float* input, uint32_t width, uint32_t height, uint32_t grid_width)
{
    if constexpr (scenario == 0) {
        // Case 0: SIMT threads read from GM and write directly to transposed GM addresses.
        asc_vf_call<simt_transpose_naive>(dim3(THREAD_COUNT), output, input, width, height, grid_width);
    } else if constexpr (scenario == 1) {
        // Case 1: copy one GM tile to UB first, then let SIMT threads read UB in transposed order.
        __ubuf__ float input_tile[THREAD_COUNT];
        const uint32_t tile_block_idx = get_block_idx();
        const uint32_t block_row = tile_block_idx / grid_width;
        const uint32_t block_col = tile_block_idx % grid_width;
        const uint32_t tile_offset = block_row * TILE_DIM * width + block_col * TILE_DIM;
        const uint32_t output_tile_offset = block_col * TILE_DIM * height + block_row * TILE_DIM;

        asc_set_gm2ub_loop_size(TILE_DIM, 1);
        asc_set_gm2ub_loop1_stride(width * sizeof(float), TILE_ROW_BYTES);
        asc_copy_gm2ub_align(input_tile, input + tile_offset, 1, TILE_ROW_BYTES, 0, 0, false, 0, 0, 0);
        asc_set_gm2ub_loop_size(1, 1);
        if ASC_IS_AIV {
            asc_sync_notify(PIPE_MTE2, PIPE_V, EVENT_ID0);
            asc_sync_wait(PIPE_MTE2, PIPE_V, EVENT_ID0);
        }

        // Write to the transposed output tile.
        asc_vf_call<simt_transpose_coalesced>(dim3(THREAD_COUNT), output + output_tile_offset, input_tile, height);
    }
}

std::vector<float> transpose(const std::vector<float>& input_host, const std::vector<uint32_t>& input_shape)
{
    const size_t tensor_elem_count = input_host.size();
    const size_t tensor_byte_size = tensor_elem_count * sizeof(float);
    std::vector<float> output_host(tensor_elem_count, 0.0f);

    if (input_shape.size() != 2) {
        fprintf(stderr, "Input shape must be 2-D.\n");
        return {};
    }

    const uint32_t matrix_height = input_shape[0];
    const uint32_t matrix_width = input_shape[1];
    if (input_host.size() != matrix_height * matrix_width) {
        fprintf(stderr, "Input data size does not match input shape.\n");
        return {};
    }

    // Runtime setup.
    aclInit(nullptr);
    aclrtSetDevice(0);

    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    float* input_device = nullptr;
    float* output_device = nullptr;
    // Allocate one input matrix and one output matrix in device memory.
    aclrtMalloc(reinterpret_cast<void**>(&input_device), tensor_byte_size, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc(reinterpret_cast<void**>(&output_device), tensor_byte_size, ACL_MEM_MALLOC_HUGE_FIRST);

    // Copy the input matrix to device.
    aclrtMemcpy(input_device, tensor_byte_size, input_host.data(), tensor_byte_size, ACL_MEMCPY_HOST_TO_DEVICE);

    // One block handles one 32x32 tile.
    const uint32_t grid_x = matrix_width / TILE_DIM;
    const uint32_t grid_y = matrix_height / TILE_DIM;
    const uint32_t bn = grid_x * grid_y;

    transpose_kernel<SCENARIO_NUM><<<bn, 0, stream>>>(output_device, input_device, matrix_width, matrix_height, grid_x);

    aclrtSynchronizeStream(stream);
    aclrtMemcpy(output_host.data(), tensor_byte_size, output_device, tensor_byte_size, ACL_MEMCPY_DEVICE_TO_HOST);

    const char* err = aclGetRecentErrMsg();
    if (err != nullptr) {
        fprintf(stderr, "%s\n", err);
    }
    aclrtFree(input_device);
    aclrtFree(output_device);
    aclrtDestroyStream(stream);
    aclrtResetDevice(0);
    aclFinalize();
    return output_host;
}

int main(int, char**)
{
    const std::vector<uint32_t> input_shape = {1024, 1024};
    const uint32_t matrix_height = input_shape[0];
    const uint32_t matrix_width = input_shape[1];

    if (matrix_width != matrix_height) {
        std::fprintf(stderr, "Only square matrices are supported in this sample.\n");
        return 1;
    }

    if (matrix_width % TILE_DIM != 0 || matrix_height % TILE_DIM != 0) {
        std::fprintf(stderr, "Matrix shape must be multiple of TILE_DIM=%d.\n", TILE_DIM);
        return 1;
    }

    const size_t tensor_elem_count = matrix_width * matrix_height;
    std::vector<float> input(tensor_elem_count);

    // Initialize deterministic input data.
    for (size_t i = 0; i < tensor_elem_count; ++i) {
        input[i] = i * 1.25f;
    }

    auto golden = compute_golden(input, input_shape);
    auto output = transpose(input, input_shape);

    return verify_result(output, golden);
}
