/*!
 * \file matrix_transpose.asc
 * \brief SIMD and SIMT hybrid programming sample demonstrating matrix transpose memory access optimization.
 */

#include <cmath>
#include <cstdint>
#include <cstdio>
#include <cstdlib>
#include <vector>
#include "acl/acl.h"
#include "kernel_operator.h"
#include "simt_api/asc_simt.h"
#include "c_api/asc_simd.h"

#ifndef SCENARIO_NUM
#define SCENARIO_NUM 4
#endif

#if SCENARIO_NUM < 0 || SCENARIO_NUM > 4
#error "SCENARIO_NUM must be one of 0, 1, 2, 3, 4."
#endif

namespace {
constexpr int TILE_DIM = 32;
constexpr int TILE_PAD = 8; // MTE搬运要求32B对齐，使用32×40的UB布局
constexpr int TILE_PAD_STRIDE = TILE_DIM + TILE_PAD;
constexpr uint32_t THREADS_2048 = 2048;
constexpr uint32_t THREADS_PER_BLOCK = THREADS_2048;
constexpr int TILES_PER_BLOCK = 2; // 2048线程对应2个32×32 tile
constexpr uint32_t TILE_ELEMENTS = TILE_DIM * TILE_DIM;
constexpr uint32_t TILE_ROW_BYTES = TILE_DIM * sizeof(float);
constexpr uint32_t TILE_PAD_ELEMENTS = TILE_DIM * TILE_PAD_STRIDE;
constexpr uint8_t SINGLE_BUFFER_MUTEX = 0;
constexpr uint8_t DB_INPUT_MUTEX_BASE = 1;
constexpr uint8_t DB_OUTPUT_MUTEX_BASE = 3;

struct LaunchConfig {
    uint32_t width;
    uint32_t height;
    uint32_t core_num;
    aclrtStream stream;
};

uint32_t verify_result(const std::vector<float>& output, const std::vector<float>& golden, float abs_tolerance = 1e-3f)
{
    if (output.size() != golden.size()) {
        printf("[Failed] Case accuracy verification failed!\n");
        return 1;
    }
    for (size_t i = 0; i < output.size(); ++i) {
        if (std::fabs(output[i] - golden[i]) > abs_tolerance) {
            printf("[Failed] Case accuracy verification failed!\n");
            return 1;
        }
    }
    printf("[Success] Case accuracy verification passed.\n");
    return 0;
}

const char* get_kernel_name(int32_t kernel_kind)
{
    switch (kernel_kind) {
        case 0:
            return "transpose_simt_naive";
        case 1:
            return "transpose_mte_ub_2tile_static";
        case 2:
            return "transpose_mte_ub_2tile";
        case 3:
            return "transpose_mte_ub_2tile_pad";
        case 4:
            return "transpose_mte_ub_2tile_pad_db";
        default:
            return "unknown";
    }
}

// 返回转置结果output(col,row)=input(row,col)。
std::vector<float> compute_golden(const std::vector<float>& input, const std::vector<uint32_t>& input_shape, int32_t)
{
    if (input_shape.size() != 2) {
        fprintf(stderr, "Input shape must be 2-D.\n");
        return {};
    }

    const uint32_t height = input_shape[0];
    const uint32_t width = input_shape[1];
    if (input.size() != static_cast<size_t>(height) * width) {
        fprintf(stderr, "Input data size does not match input shape.\n");
        return {};
    }

    std::vector<float> output(input.size());
    for (uint32_t row = 0; row < height; ++row) {
        for (uint32_t col = 0; col < width; ++col) {
            output[static_cast<size_t>(col) * height + row] = input[static_cast<size_t>(row) * width + col];
        }
    }
    return output;
}

uint32_t get_vector_core_num(uint32_t device_id)
{
    int64_t core_num = 0;
    aclError ret = aclrtGetDeviceInfo(device_id, ACL_DEV_ATTR_VECTOR_CORE_NUM, &core_num);
    if (ret != ACL_SUCCESS) {
        return 0;
    }
    return static_cast<uint32_t>(core_num);
}
} // namespace

#if SCENARIO_NUM == 0
__simt_vf__ __launch_bounds__(THREADS_2048) inline void simt_transpose_naive(
    __gm__ float* output, __gm__ float* input, uint32_t width, uint32_t height, uint32_t total)
{
    uint32_t tid = blockIdx.x * blockDim.x + threadIdx.x;
    uint32_t stride = gridDim.x * blockDim.x;
    for (uint32_t i = tid; i < total; i += stride) {
        uint32_t row = i / width;
        uint32_t col = i - row * width;
        // 直接写转置后的GM地址，写入方向跨行不连续。
        output[col * height + row] = input[i];
    }
}

__global__ __vector__ void transpose_naive_kernel(
    __gm__ float* output, __gm__ float* input, uint32_t width, uint32_t height)
{
    uint32_t total = width * height;
    asc_vf_call<simt_transpose_naive>(dim3(THREADS_PER_BLOCK), output, input, width, height, total);
}

void launch_case_kernel(float* output, float* input, const LaunchConfig& config)
{
    transpose_naive_kernel<<<config.core_num, 0, config.stream>>>(output, input, config.width, config.height);
}
#endif

#if SCENARIO_NUM > 0
__aicore__ inline void copy_gm_tile_to_ub(
    __ubuf__ float* in_tile, __gm__ float* input, uint32_t width, uint32_t tiles_x, uint32_t tile_id,
    uint32_t ub_row_bytes)
{
    uint32_t tile_y = tile_id / tiles_x;
    uint32_t tile_x = tile_id - tile_y * tiles_x;
    uint32_t input_offset = tile_y * TILE_DIM * width + tile_x * TILE_DIM;
    // MTE2按二维搬运把一个32×32 tile从GM连续搬入UB。
    asc_copy_gm2ub_align(
        in_tile, input + input_offset, TILE_DIM, TILE_ROW_BYTES, 0, 0, false, 0, width * sizeof(float), ub_row_bytes);
}

__aicore__ inline void copy_gm_2tile_to_ub(
    __ubuf__ float* in_tile, __gm__ float* input, uint32_t width, uint32_t tiles_x, uint32_t tile_base,
    uint32_t total_tiles)
{
    for (uint32_t local_tile = 0; local_tile < TILES_PER_BLOCK; ++local_tile) {
        uint32_t tile_id = tile_base + local_tile;
        if (tile_id < total_tiles) {
            // 非padding场景下，UB中每个输入tile为连续32×32布局。
            copy_gm_tile_to_ub(in_tile + local_tile * TILE_ELEMENTS, input, width, tiles_x, tile_id, TILE_ROW_BYTES);
        }
    }
}

__aicore__ inline void copy_gm_2tile_to_padded_ub(
    __ubuf__ float* in_tile, __gm__ float* input, uint32_t width, uint32_t tiles_x, uint32_t tile_base,
    uint32_t total_tiles)
{
    for (uint32_t local_tile = 0; local_tile < TILES_PER_BLOCK; ++local_tile) {
        uint32_t tile_id = tile_base + local_tile;
        if (tile_id < total_tiles) {
            // padding场景下，输入tile使用32×40布局以降低转置读UB时的bank冲突。
            copy_gm_tile_to_ub(
                in_tile + local_tile * TILE_PAD_ELEMENTS, input, width, tiles_x, tile_id,
                TILE_PAD_STRIDE * sizeof(float));
        }
    }
}

__aicore__ inline void copy_ub_tile_to_gm(
    __gm__ float* output, __ubuf__ float* out_tile, uint32_t height, uint32_t tiles_x, uint32_t tile_id)
{
    uint32_t tile_y = tile_id / tiles_x;
    uint32_t tile_x = tile_id - tile_y * tiles_x;
    uint32_t output_offset = tile_x * TILE_DIM * height + tile_y * TILE_DIM;
    // out_tile已经按输出矩阵行方向连续排布，MTE3可连续搬回GM。
    asc_copy_ub2gm_align(
        output + output_offset, out_tile, TILE_DIM, TILE_ROW_BYTES, 0, height * sizeof(float), TILE_ROW_BYTES);
}

__aicore__ inline void copy_ub_2tile_to_gm(
    __gm__ float* output, __ubuf__ float* out_tile, uint32_t height, uint32_t tiles_x, uint32_t tile_base,
    uint32_t total_tiles)
{
    for (uint32_t local_tile = 0; local_tile < TILES_PER_BLOCK; ++local_tile) {
        uint32_t tile_id = tile_base + local_tile;
        if (tile_id < total_tiles) {
            copy_ub_tile_to_gm(output, out_tile + local_tile * TILE_ELEMENTS, height, tiles_x, tile_id);
        }
    }
}
#endif

#if SCENARIO_NUM == 1 || SCENARIO_NUM == 2
__simt_vf__ __launch_bounds__(THREADS_2048) inline void simt_transpose_2tile(
    __ubuf__ float* out_tile, __ubuf__ float* in_tile, uint32_t tile_base, uint32_t total_tiles)
{
    uint32_t local_tile = threadIdx.y >> 5;
    uint32_t ty = threadIdx.y & (TILE_DIM - 1);
    uint32_t tx = threadIdx.x;
    uint32_t tile_id = tile_base + local_tile;
    if (tile_id >= total_tiles) {
        return;
    }

    // SIMT VF在UB内按转置方向读取in_tile，并连续写入out_tile。
    out_tile[local_tile * TILE_ELEMENTS + ty * TILE_DIM + tx] =
        in_tile[local_tile * TILE_ELEMENTS + tx * TILE_DIM + ty];
}
#endif

#if SCENARIO_NUM == 1
__global__ __vector__ void transpose_ub_2tile_static_kernel(
    __gm__ float* output, __gm__ float* input, uint32_t width, uint32_t height, uint32_t total_tiles)
{
    __ubuf__ float in_tile[TILES_PER_BLOCK][TILE_DIM][TILE_DIM];
    __ubuf__ float out_tile[TILES_PER_BLOCK][TILE_DIM][TILE_DIM];
    uint32_t tiles_x = width / TILE_DIM;
    uint32_t loop_start = block_idx * TILES_PER_BLOCK;
    uint32_t loop_step = block_num * TILES_PER_BLOCK;
    uint32_t loop_end = loop_start + TILES_PER_BLOCK;

    // Case 1按tile分组启动Thread Block，每个Thread Block只处理当前分配到的两个tile。
    for (uint32_t tile_base = loop_start; tile_base < loop_end && tile_base < total_tiles; tile_base += loop_step) {
        asc_lock(PIPE_MTE2, SINGLE_BUFFER_MUTEX);
        copy_gm_2tile_to_ub(&in_tile[0][0][0], input, width, tiles_x, tile_base, total_tiles);
        asc_unlock(PIPE_MTE2, SINGLE_BUFFER_MUTEX);

        // MTE2搬入完成后，SIMT VF读取UB输入buffer。
        asc_lock(PIPE_V, SINGLE_BUFFER_MUTEX);
        asc_vf_call<simt_transpose_2tile>(
            dim3(TILE_DIM, TILE_DIM * TILES_PER_BLOCK, 1), &out_tile[0][0][0], &in_tile[0][0][0], tile_base,
            total_tiles);
        asc_unlock(PIPE_V, SINGLE_BUFFER_MUTEX);

        // SIMT VF写完输出buffer后，MTE3将结果搬回GM。
        asc_lock(PIPE_MTE3, SINGLE_BUFFER_MUTEX);
        copy_ub_2tile_to_gm(output, &out_tile[0][0][0], height, tiles_x, tile_base, total_tiles);
        asc_unlock(PIPE_MTE3, SINGLE_BUFFER_MUTEX);
    }
}

void launch_case_kernel(float* output, float* input, const LaunchConfig& config)
{
    uint32_t total_tiles = (config.width / TILE_DIM) * (config.height / TILE_DIM);
    uint32_t bn = (total_tiles + TILES_PER_BLOCK - 1) / TILES_PER_BLOCK;
    transpose_ub_2tile_static_kernel<<<bn, 0, config.stream>>>(output, input, config.width, config.height, total_tiles);
}
#endif

#if SCENARIO_NUM == 2
__global__ __vector__ void transpose_ub_2tile_loop_kernel(
    __gm__ float* output, __gm__ float* input, uint32_t width, uint32_t height, uint32_t total_tiles)
{
    __ubuf__ float in_tile[TILES_PER_BLOCK][TILE_DIM][TILE_DIM];
    __ubuf__ float out_tile[TILES_PER_BLOCK][TILE_DIM][TILE_DIM];
    uint32_t tiles_x = width / TILE_DIM;
    uint32_t loop_start = block_idx * TILES_PER_BLOCK;
    uint32_t loop_step = block_num * TILES_PER_BLOCK;
    uint32_t loop_end = total_tiles;

    // Case 2固定Thread Block数，每个Thread Block按gridDim.x步长循环处理多个tile组。
    for (uint32_t tile_base = loop_start; tile_base < loop_end; tile_base += loop_step) {
        asc_lock(PIPE_MTE2, SINGLE_BUFFER_MUTEX);
        copy_gm_2tile_to_ub(&in_tile[0][0][0], input, width, tiles_x, tile_base, total_tiles);
        asc_unlock(PIPE_MTE2, SINGLE_BUFFER_MUTEX);

        // MTE2搬入完成后，SIMT VF读取UB输入buffer。
        asc_lock(PIPE_V, SINGLE_BUFFER_MUTEX);
        asc_vf_call<simt_transpose_2tile>(
            dim3(TILE_DIM, TILE_DIM * TILES_PER_BLOCK, 1), &out_tile[0][0][0], &in_tile[0][0][0], tile_base,
            total_tiles);
        asc_unlock(PIPE_V, SINGLE_BUFFER_MUTEX);

        // SIMT VF写完输出buffer后，MTE3将结果搬回GM。
        asc_lock(PIPE_MTE3, SINGLE_BUFFER_MUTEX);
        copy_ub_2tile_to_gm(output, &out_tile[0][0][0], height, tiles_x, tile_base, total_tiles);
        asc_unlock(PIPE_MTE3, SINGLE_BUFFER_MUTEX);
    }
}

void launch_case_kernel(float* output, float* input, const LaunchConfig& config)
{
    uint32_t total_tiles = (config.width / TILE_DIM) * (config.height / TILE_DIM);
    transpose_ub_2tile_loop_kernel<<<config.core_num, 0, config.stream>>>(
        output, input, config.width, config.height, total_tiles);
}
#endif

#if SCENARIO_NUM == 3 || SCENARIO_NUM == 4
__simt_vf__ __launch_bounds__(THREADS_2048) inline void simt_transpose_2tile_pad(
    __ubuf__ float* out_tile, __ubuf__ float* in_tile, uint32_t tile_base, uint32_t total_tiles)
{
    uint32_t local_tile = threadIdx.y >> 5;
    uint32_t ty = threadIdx.y & (TILE_DIM - 1);
    uint32_t tx = threadIdx.x;
    uint32_t tile_id = tile_base + local_tile;
    if (tile_id >= total_tiles) {
        return;
    }

    // 输入tile带padding，按32×40物理布局读取；输出tile仍按32×32连续布局写入。
    out_tile[local_tile * TILE_ELEMENTS + ty * TILE_DIM + tx] =
        in_tile[local_tile * TILE_PAD_ELEMENTS + tx * TILE_PAD_STRIDE + ty];
}

#endif

#if SCENARIO_NUM == 3
__global__ __vector__ void transpose_ub_pad_loop_kernel(
    __gm__ float* output, __gm__ float* input, uint32_t width, uint32_t height, uint32_t total_tiles)
{
    __ubuf__ float in_tile[TILES_PER_BLOCK][TILE_DIM][TILE_PAD_STRIDE];
    __ubuf__ float out_tile[TILES_PER_BLOCK][TILE_DIM][TILE_DIM];
    uint32_t tiles_x = width / TILE_DIM;
    uint32_t loop_start = block_idx * TILES_PER_BLOCK;
    uint32_t loop_step = block_num * TILES_PER_BLOCK;

    // Case 3沿用固定Thread Block数和循环处理方式，仅将输入tile换成32×40 padded布局。
    for (uint32_t tile_base = loop_start; tile_base < total_tiles; tile_base += loop_step) {
        asc_lock(PIPE_MTE2, SINGLE_BUFFER_MUTEX);
        copy_gm_2tile_to_padded_ub(&in_tile[0][0][0], input, width, tiles_x, tile_base, total_tiles);
        asc_unlock(PIPE_MTE2, SINGLE_BUFFER_MUTEX);

        // MTE2搬入完成后，SIMT VF按32×40 padded布局读取UB输入buffer。
        asc_lock(PIPE_V, SINGLE_BUFFER_MUTEX);
        asc_vf_call<simt_transpose_2tile_pad>(
            dim3(TILE_DIM, TILE_DIM * TILES_PER_BLOCK, 1), &out_tile[0][0][0], &in_tile[0][0][0], tile_base,
            total_tiles);
        asc_unlock(PIPE_V, SINGLE_BUFFER_MUTEX);

        // 输出buffer为32×32连续布局，MTE3按输出矩阵行方向搬回GM。
        asc_lock(PIPE_MTE3, SINGLE_BUFFER_MUTEX);
        copy_ub_2tile_to_gm(output, &out_tile[0][0][0], height, tiles_x, tile_base, total_tiles);
        asc_unlock(PIPE_MTE3, SINGLE_BUFFER_MUTEX);
    }
}

void launch_case_kernel(float* output, float* input, const LaunchConfig& config)
{
    uint32_t total_tiles = (config.width / TILE_DIM) * (config.height / TILE_DIM);
    transpose_ub_pad_loop_kernel<<<config.core_num, 0, config.stream>>>(
        output, input, config.width, config.height, total_tiles);
}
#endif

#if SCENARIO_NUM == 4
__global__ __vector__ void transpose_ub_pad_db_kernel(
    __gm__ float* output, __gm__ float* input, uint32_t width, uint32_t height, uint32_t total_tiles)
{
    // 两组UB buffer轮换使用：当前buffer进入SIMT VF/MTE3流水，下一组buffer由MTE2搬入。
    __ubuf__ float in_tile[2][TILES_PER_BLOCK][TILE_DIM][TILE_PAD_STRIDE];
    __ubuf__ float out_tile[2][TILES_PER_BLOCK][TILE_DIM][TILE_DIM];
    uint32_t tiles_x = width / TILE_DIM;
    uint32_t loop_step = block_num * TILES_PER_BLOCK;
    uint32_t curr_tile_base = block_idx * TILES_PER_BLOCK;
    if (curr_tile_base >= total_tiles) {
        return;
    }

    uint32_t loop_count = 0;

    for (uint32_t tile_base = curr_tile_base; tile_base < total_tiles; tile_base += loop_step) {
        uint32_t curr_buffer = loop_count & 1;
        uint8_t input_mutex = DB_INPUT_MUTEX_BASE + static_cast<uint8_t>(curr_buffer);
        uint8_t output_mutex = DB_OUTPUT_MUTEX_BASE + static_cast<uint8_t>(curr_buffer);

        asc_lock(PIPE_MTE2, input_mutex);
        copy_gm_2tile_to_padded_ub(&in_tile[curr_buffer][0][0][0], input, width, tiles_x, tile_base, total_tiles);
        asc_unlock(PIPE_MTE2, input_mutex);

        // SIMT VF等待当前输入buffer搬入完成；复用输出buffer前等待其上一次MTE3搬出完成。
        asc_lock(PIPE_V, input_mutex);
        asc_lock(PIPE_V, output_mutex);
        asc_vf_call<simt_transpose_2tile_pad>(
            dim3(TILE_DIM, TILE_DIM * TILES_PER_BLOCK, 1), &out_tile[curr_buffer][0][0][0],
            &in_tile[curr_buffer][0][0][0], tile_base, total_tiles);
        asc_unlock(PIPE_V, input_mutex);
        asc_unlock(PIPE_V, output_mutex);

        asc_lock(PIPE_MTE3, output_mutex);
        copy_ub_2tile_to_gm(output, &out_tile[curr_buffer][0][0][0], height, tiles_x, tile_base, total_tiles);
        asc_unlock(PIPE_MTE3, output_mutex);
        ++loop_count;
    }
}

void launch_case_kernel(float* output, float* input, const LaunchConfig& config)
{
    uint32_t total_tiles = (config.width / TILE_DIM) * (config.height / TILE_DIM);
    transpose_ub_pad_db_kernel<<<config.core_num, 0, config.stream>>>(
        output, input, config.width, config.height, total_tiles);
}
#endif

std::vector<float> run_case(const std::vector<float>& input_host, const std::vector<uint32_t>& input_shape)
{
    const size_t tensor_elem_count = input_host.size();
    const size_t tensor_byte_size = tensor_elem_count * sizeof(float);
    std::vector<float> output_host(tensor_elem_count, 0.0f);

    const uint32_t matrix_height = input_shape[0];
    const uint32_t matrix_width = input_shape[1];

    aclInit(nullptr);
    aclrtSetDevice(0);

    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    float* input_device = nullptr;
    float* output_device = nullptr;
    aclrtMalloc(reinterpret_cast<void**>(&input_device), tensor_byte_size, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc(reinterpret_cast<void**>(&output_device), tensor_byte_size, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMemcpy(input_device, tensor_byte_size, input_host.data(), tensor_byte_size, ACL_MEMCPY_HOST_TO_DEVICE);

    LaunchConfig launch_config = {
        matrix_width,
        matrix_height,
        get_vector_core_num(0),
        stream,
    };
    launch_case_kernel(output_device, input_device, launch_config);

    aclrtSynchronizeStream(stream);
    aclrtMemcpy(output_host.data(), tensor_byte_size, output_device, tensor_byte_size, ACL_MEMCPY_DEVICE_TO_HOST);

    const char* err = aclGetRecentErrMsg();
    if (err != nullptr) {
        fprintf(stderr, "%s\n", err);
    }
    aclrtFree(input_device);
    aclrtFree(output_device);
    aclrtDestroyStream(stream);
    aclrtResetDevice(0);
    aclFinalize();
    return output_host;
}

int main(int argc, char** argv)
{
    const uint32_t kernel_kind = SCENARIO_NUM;
    uint32_t matrix_size = 1024;
    if (argc > 1) {
        char* end = nullptr;
        unsigned long value = std::strtoul(argv[1], &end, 10);
        if (end != argv[1] && *end == '\0' && value > 0) {
            matrix_size = static_cast<uint32_t>(value);
        }
    }

    printf("Usage: %s [matrix_size] (compile-time SCENARIO_NUM=%u)\n", argv[0], kernel_kind);
    printf("Running case %u: %s...\n", kernel_kind, get_kernel_name(static_cast<int32_t>(kernel_kind)));
    printf("Threads/Thread Block: %u\n", THREADS_PER_BLOCK);
    printf("Matrix shape: %u x %u\n", matrix_size, matrix_size);

    if (matrix_size - (matrix_size / TILE_DIM) * TILE_DIM != 0) {
        std::fprintf(stderr, "Matrix shape must be multiple of TILE_DIM=%d.\n", TILE_DIM);
        return EXIT_FAILURE;
    }

    const std::vector<uint32_t> input_shape = {matrix_size, matrix_size};
    const size_t tensor_elem_count = static_cast<size_t>(matrix_size) * matrix_size;
    std::vector<float> input(tensor_elem_count);
    for (size_t i = 0; i < tensor_elem_count; ++i) {
        input[i] = i * 1.25f;
    }

    auto golden = compute_golden(input, input_shape, kernel_kind);
    auto output = run_case(input, input_shape);

    return verify_result(output, golden);
}
