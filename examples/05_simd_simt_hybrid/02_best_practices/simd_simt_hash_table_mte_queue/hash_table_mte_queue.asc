/* !
 * \file hash_table_mte_queue.asc
 * \brief Fixed-capacity HashTable insert_or_assign benchmark.
 *        This sample is intentionally scoped to explain the optimization path and does not
 *        attempt to reproduce every production HashTable feature.
 *        SCENARIO_NUM=0: one SIMT warp probes the table and stores value elements directly.
 *        SCENARIO_NUM=1: SIMT probes the table, then an in-kernel MTE task queue writes value vectors.
 */

#include <cmath>
#include <cstdint>
#include <cstdlib>
#include <iostream>
#include <utility>
#include <vector>

#include "acl/acl.h"
#include "c_api/asc_simd.h"
#include "simt_api/asc_simt.h"

#ifndef PROFILE_REPEAT_TIMES
#define PROFILE_REPEAT_TIMES 30
#endif

static_assert(SCENARIO_NUM == 0 || SCENARIO_NUM == 1, "SCENARIO_NUM must be 0 or 1");

namespace {
constexpr uint32_t THREAD_COUNT = 512;
constexpr uint32_t WARP_SIZE = 32;
constexpr uint32_t KEY_NUM = 128 * 1024;
constexpr uint32_t HASH_TABLE_CAPACITY = 256 * 1024;
constexpr uint32_t BLOCK_DIM = 64;
constexpr uint32_t PROFILE_REPEAT_TIMES_VALUE = PROFILE_REPEAT_TIMES;
constexpr uint32_t MTE_BATCH_SIZE = 32;
constexpr uint32_t MTE_LOCAL_VALUE_COUNT = MTE_BATCH_SIZE * 256;
constexpr uint32_t MTE_TASK_RING_CAPACITY = 128;
constexpr uint32_t MTE_TASK_RING_MASK = MTE_TASK_RING_CAPACITY - 1;
constexpr uint32_t UB_ALIGN_SIZE = 32;
constexpr uint32_t INVALID_BUCKET = 0xffffffffU;
constexpr int64_t EMPTY_KEY = 0;
constexpr int64_t LOCKED_KEY = -1;
constexpr uint32_t TEST_DIMS[] = {16, 32, 64, 128, 256};
constexpr const char* SCENARIO_NAME =
    (SCENARIO_NUM == 0) ? "SIMT Warp insert_or_assign" : "MTE task queue insert_or_assign";
} // namespace

#define CHECK_ACL(expr)                                                                                   \
    do {                                                                                                  \
        aclError ret = (expr);                                                                            \
        if (ret != ACL_SUCCESS) {                                                                         \
            std::cerr << "ACL call failed: " #expr << ", ret=" << static_cast<int32_t>(ret) << std::endl; \
            std::exit(1);                                                                                 \
        }                                                                                                 \
    } while (0)

inline uint64_t hash_key_host(int64_t key) { return static_cast<uint64_t>(key) * 11400714819323198485ULL; }

__simt_callee__ inline uint64_t hash_key_device(int64_t key)
{
    return static_cast<uint64_t>(key) * 11400714819323198485ULL;
}

// Wait for a temporarily locked slot to be published before probing further.
// This prevents another writer for the same key from skipping the locked slot and creating a duplicate entry.
__simt_callee__ inline int64_t wait_until_unlocked(__gm__ const int64_t* key_addr)
{
    int64_t current_key = *key_addr;
    while (current_key == LOCKED_KEY) {
        current_key = *key_addr;
    }
    return current_key;
}

// Minimal device-side vector wrapper used by the host sample code.
template <typename T>
class device_vector {
public:
    using value_type = T;
    using size_type = size_t;

    explicit device_vector(size_type count) : count_(count)
    {
        if (count_ == 0) {
            return;
        }
        CHECK_ACL(aclrtMalloc(reinterpret_cast<void**>(&data_), bytes(), ACL_MEM_MALLOC_HUGE_FIRST));
    }

    ~device_vector()
    {
        if (data_ != nullptr) {
            aclError ret = aclrtFree(data_);
            if (ret != ACL_SUCCESS) {
                std::cerr << "ACL call failed: aclrtFree, ret=" << static_cast<int32_t>(ret) << std::endl;
            }
        }
    }

    device_vector(const device_vector&) = delete;
    device_vector& operator=(const device_vector&) = delete;

    T* data() { return data_; }

    const T* data() const { return data_; }

    size_type size() const { return count_; }

    size_type bytes() const { return count_ * sizeof(T); }

    void copy_to(std::vector<T>& host) const
    {
        CHECK_ACL(aclrtMemcpy(host.data(), bytes(), data_, bytes(), ACL_MEMCPY_DEVICE_TO_HOST));
    }

    void fill_zero() { CHECK_ACL(aclrtMemset(data_, bytes(), 0, bytes())); }

private:
    T* data_ = nullptr;
    size_type count_ = 0;
};

// Fixed-capacity hash table used by this benchmark.
// It exposes a small STL-like surface while keeping storage on device memory,
// but intentionally omits production features that are unrelated to the MTE optimization path.
class unordered_map {
public:
    using key_type = int64_t;
    using mapped_type = float;
    using value_type = std::pair<key_type, mapped_type*>;
    using size_type = uint32_t;
    using insert_return_type = std::pair<size_type, bool>;

    // The key field is also the slot marker:
    // EMPTY_KEY means unused, LOCKED_KEY means a writer owns the slot, and any other value is a published key.
    struct alignas(32) bucket_type {
        key_type key;
        key_type padding[3];
    };

    unordered_map(size_type bucket_count, size_type mapped_dim, aclrtStream stream);
    ~unordered_map() = default;

    unordered_map(const unordered_map&) = delete;
    unordered_map& operator=(const unordered_map&) = delete;

    // Reset all buckets and values to the empty-table contents.
    void clear();

    // Insert or update a contiguous key/value range. The benchmark uses a fixed KEY_NUM input size.
    // Kernels publish a real key only after the mapped value vector has been fully written.
    insert_return_type insert_or_assign(
        const key_type* first_key, const key_type* last_key, const mapped_type* first_mapped);

    // Copy device table storage back to host for full-result verification.
    void copy_to(std::vector<bucket_type>& buckets, std::vector<mapped_type>& values) const;

    size_type size() const { return size_; }

    size_type bucket_count() const { return bucket_count_; }

    size_type mapped_dim() const { return mapped_dim_; }

    double load_factor() const { return static_cast<double>(size_) / bucket_count_; }

private:
    size_type bucket_count_ = 0;
    size_type mapped_dim_ = 0;
    size_type size_ = 0;
    aclrtStream stream_ = nullptr;
    device_vector<bucket_type> buckets_;
    device_vector<mapped_type> values_;
    device_vector<uint32_t> find_mismatch_count_;
};

using Bucket = unordered_map::bucket_type;

// Baseline path: one warp owns one key. Lane 0 probes/locks the slot, and all lanes shard the value store.
__simt_vf__ inline void insert_or_assign_warp_store_vf(
    __gm__ Bucket* table, __gm__ float* table_values, __gm__ const int64_t* keys, __gm__ const float* values,
    uint32_t key_num, uint32_t capacity, uint32_t dim, uint32_t block_index, uint32_t num_blocks)
{
    const uint32_t tid = static_cast<uint32_t>(threadIdx.x);
    const uint32_t lane_id = tid % WARP_SIZE;
    const uint32_t warp_id_in_block = tid / WARP_SIZE;
    const uint32_t warps_per_block = static_cast<uint32_t>(blockDim.x) / WARP_SIZE;
    const uint32_t global_warp_id = block_index * warps_per_block + warp_id_in_block;
    const uint32_t total_warps = num_blocks * warps_per_block;

    for (uint32_t idx = global_warp_id; idx < key_num; idx += total_warps) {
        int64_t key = keys[idx];
        uint32_t bucket_idx = 0;
        int32_t success = 0;

        if (lane_id == 0) {
            bucket_idx = static_cast<uint32_t>(hash_key_device(key)) & (capacity - 1);
            for (uint32_t probe = 0; probe < capacity; ++probe) {
                __gm__ int64_t* key_addr = &table[bucket_idx].key;
                int64_t old_key = asc_atomic_cas(key_addr, EMPTY_KEY, LOCKED_KEY);
                if (old_key == LOCKED_KEY) {
                    old_key = wait_until_unlocked(key_addr);
                }
                if (old_key == EMPTY_KEY) {
                    success = 1;
                    break;
                }
                if (old_key == key) {
                    old_key = asc_atomic_cas(key_addr, key, LOCKED_KEY);
                    if (old_key == key) {
                        success = 1;
                        break;
                    }
                    continue;
                }
                bucket_idx = (bucket_idx + 1) & (capacity - 1);
            }
        }

        success = asc_shfl(success, 0, WARP_SIZE);
        bucket_idx = asc_shfl(bucket_idx, 0, WARP_SIZE);
        if (success == 1) {
            uint32_t dst_base = bucket_idx * dim;
            uint32_t src_base = idx * dim;
            for (uint32_t j = lane_id; j < dim; j += WARP_SIZE) {
                table_values[dst_base + j] = values[src_base + j];
            }
            // Publish the key only after the value vector is visible.
            asc_threadfence();
            if (lane_id == 0) {
                (void)asc_atomic_exch(&table[bucket_idx].key, key);
            }
        }
    }
}

__global__ __vector__ void insert_or_assign_warp_store_kernel(
    __gm__ Bucket* table, __gm__ float* table_values, __gm__ const int64_t* keys, __gm__ const float* values,
    uint32_t key_num, uint32_t capacity, uint32_t dim)
{
    asc_vf_call<insert_or_assign_warp_store_vf>(
        dim3(THREAD_COUNT), table, table_values, keys, values, key_num, capacity, dim, block_idx, BLOCK_DIM);
}

class mte_task_queue {
public:
    // Bind the GM value buffers and UB ring-control storage used by the SIMT producer and MTE consumer.
    __aicore__ inline void init(
        __gm__ const float* values, __ubuf__ float* value_local, __ubuf__ uint64_t* src_addrs,
        __ubuf__ uint64_t* dst_addrs, __ubuf__ int64_t* task_keys, __ubuf__ uint64_t* key_addrs,
        __ubuf__ uint32_t* global_id, __ubuf__ uint32_t* mte_finish_id, __ubuf__ uint32_t* simt_assign_id,
        __ubuf__ uint32_t* task_finish_flag, __ubuf__ uint32_t* key_assign_id, __ubuf__ uint32_t* key_finish_id,
        uint32_t dim)
    {
        value_local_ = value_local;
        src_addrs_ = src_addrs;
        dst_addrs_ = dst_addrs;
        task_keys_ = task_keys;
        key_addrs_ = key_addrs;
        global_id_ = global_id;
        mte_finish_id_ = mte_finish_id;
        simt_assign_id_ = simt_assign_id;
        task_finish_flag_ = task_finish_flag;
        key_assign_id_ = key_assign_id;
        key_finish_id_ = key_finish_id;
        dim_ = dim;
        *reinterpret_cast<__ubuf__ volatile uint32_t*>(global_id_) = 0;
        *reinterpret_cast<__ubuf__ volatile uint32_t*>(mte_finish_id_) = 0;
        *reinterpret_cast<__ubuf__ volatile uint32_t*>(simt_assign_id_) = 0;
        *reinterpret_cast<__ubuf__ volatile uint32_t*>(task_finish_flag_) = 0;
        *reinterpret_cast<__ubuf__ volatile uint32_t*>(key_assign_id_) = 0;
        *reinterpret_cast<__ubuf__ volatile uint32_t*>(key_finish_id_) = 0;
        values_cache_mode_ = static_cast<uint8_t>((reinterpret_cast<uint64_t>(values)) >> 60);
    }

    // Reserve a contiguous task-id range for one SIMT warp.
    __simt_callee__ inline uint32_t apply_id(uint32_t task_count) const
    {
        return asc_atomic_add(global_id_, task_count);
    }

    // Fill one ring slot. The task is visible to the MTE consumer only after assign_task advances simt_assign_id_.
    __simt_callee__ inline void fill_task_info(
        uint32_t task_id, uint64_t src_addr, uint64_t dst_addr, int64_t key, uint64_t key_addr) const
    {
        uint32_t slot = task_id & MTE_TASK_RING_MASK;
        reinterpret_cast<__ubuf__ volatile uint64_t*>(src_addrs_)[slot] = src_addr;
        reinterpret_cast<__ubuf__ volatile uint64_t*>(dst_addrs_)[slot] = dst_addr;
        reinterpret_cast<__ubuf__ volatile int64_t*>(task_keys_)[slot] = key;
        reinterpret_cast<__ubuf__ volatile uint64_t*>(key_addrs_)[slot] = key_addr;
    }

    // Publish a contiguous range to the MTE consumer after all ring slots in that range have been filled.
    __simt_callee__ inline void assign_task(uint32_t task_start_id, uint32_t task_end_id) const
    {
        while (true) {
            if (asc_atomic_cas(simt_assign_id_, task_start_id, task_end_id) == task_start_id) {
                return;
            }
        }
    }

    // Tell the MTE consumer that no more tasks will be produced.
    __simt_callee__ inline void assignment_finish() const
    {
        *reinterpret_cast<__ubuf__ volatile uint32_t*>(task_finish_flag_) = 1;
    }

    // Publish keys for tasks whose MTE value copy has already completed. This also frees ring slots.
    template <bool drain_all = false>
    __simt_callee__ inline void drain(uint32_t new_task_end_id) const
    {
        while (true) {
            uint32_t key_finish_id = *reinterpret_cast<__ubuf__ volatile uint32_t*>(key_finish_id_);
            if constexpr (drain_all) {
                if (new_task_end_id == key_finish_id) {
                    break;
                }
            } else {
                if (new_task_end_id - key_finish_id <= MTE_TASK_RING_CAPACITY) {
                    break;
                }
            }

            uint32_t mte_finish_id = *reinterpret_cast<__ubuf__ volatile uint32_t*>(mte_finish_id_);
            uint32_t key_assign_id = *reinterpret_cast<__ubuf__ volatile uint32_t*>(key_assign_id_);
            if (key_assign_id >= mte_finish_id) {
                continue;
            }

            uint32_t available = mte_finish_id - key_assign_id;
            uint32_t publish_count = (available < MTE_BATCH_SIZE) ? available : MTE_BATCH_SIZE;
            uint32_t lane_id = static_cast<uint32_t>(laneid());
            uint32_t publish_start_id = 0;
            if (lane_id == 0) {
                publish_start_id = asc_atomic_cas(key_assign_id_, key_assign_id, key_assign_id + publish_count);
            }
            publish_start_id = asc_shfl(publish_start_id, 0);
            if (publish_start_id != key_assign_id) {
                continue;
            }

            if (lane_id < publish_count) {
                uint32_t slot = (key_assign_id + lane_id) & MTE_TASK_RING_MASK;
                int64_t key = reinterpret_cast<__ubuf__ volatile int64_t*>(task_keys_)[slot];
                uint64_t key_addr = reinterpret_cast<__ubuf__ volatile uint64_t*>(key_addrs_)[slot];
                // The slot is still owned by this insert task, so a release store is enough to publish the key.
                *reinterpret_cast<__gm__ volatile int64_t*>(key_addr) = key;
            }
            asc_threadfence();
            if (lane_id == 0) {
                while (true) {
                    if (asc_atomic_cas(key_finish_id_, publish_start_id, key_assign_id + publish_count) ==
                        publish_start_id) {
                        break;
                    }
                }
            }
        }
    }

    __simt_callee__ inline void drain_all() const
    {
        uint32_t last_task_id = *reinterpret_cast<__ubuf__ volatile uint32_t*>(simt_assign_id_);
        drain<true>(last_task_id);
    }

    // Compact active lanes in a warp into task IDs, wait for ring space, and assign the filled task range.
    __simt_callee__ inline void assign_warp_task(
        uint64_t src_addr, uint64_t dst_addr, int64_t key, uint64_t key_addr, bool need_assign) const
    {
        uint32_t write_mask = asc_ballot(need_assign ? 1 : 0);
        uint32_t warp_write_count = static_cast<uint32_t>(__popc(write_mask));
        if (warp_write_count == 0) {
            return;
        }

        uint32_t lane_id = static_cast<uint32_t>(laneid());
        uint32_t task_start_id = 0;
        if (lane_id == 0) {
            task_start_id = apply_id(warp_write_count);
        }
        task_start_id = asc_shfl(task_start_id, 0);
        uint32_t task_end_id = task_start_id + warp_write_count;

        drain(task_end_id);

        if (need_assign) {
            uint32_t lane_offset = static_cast<uint32_t>(__popc(write_mask & static_cast<uint32_t>(lanemask_lt())));
            fill_task_info(task_start_id + lane_offset, src_addr, dst_addr, key, key_addr);
        }
        asc_threadfence();

        if (lane_id == 0) {
            assign_task(task_start_id, task_end_id);
        }
    }

    // Consume assigned tasks with MTE2 + MTE3. Key publication is intentionally left to the SIMT drain path.
    __aicore__ inline void run_task() const
    {
        uint32_t value_bytes = dim_ * sizeof(float);
        uint32_t value_bytes_aligned = ((value_bytes + UB_ALIGN_SIZE - 1) / UB_ALIGN_SIZE) * UB_ALIGN_SIZE;
        uint32_t value_elems_aligned = value_bytes_aligned / sizeof(float);
        uint32_t max_proc_batch = MTE_LOCAL_VALUE_COUNT / value_elems_aligned;
        if (max_proc_batch > MTE_BATCH_SIZE) {
            max_proc_batch = MTE_BATCH_SIZE;
        }
        if (max_proc_batch == 0) {
            max_proc_batch = 1;
        }

        uint32_t mte_finish_id = 0;
        while (true) {
            uint32_t simt_assign_id = *reinterpret_cast<__ubuf__ volatile uint32_t*>(simt_assign_id_);
            if (simt_assign_id == mte_finish_id) {
                if (*reinterpret_cast<__ubuf__ volatile uint32_t*>(task_finish_flag_) == 1) {
                    return;
                }
                continue;
            }

            uint32_t available = simt_assign_id - mte_finish_id;
            uint32_t proc_count = (available < max_proc_batch) ? available : max_proc_batch;
            for (uint32_t i = 0; i < proc_count; ++i) {
                uint32_t slot = (mte_finish_id + i) & MTE_TASK_RING_MASK;
                uint64_t src_addr = reinterpret_cast<__ubuf__ volatile uint64_t*>(src_addrs_)[slot];
                asc_copy_gm2ub_align(
                    value_local_ + i * value_elems_aligned, reinterpret_cast<__gm__ float*>(src_addr), 1, value_bytes,
                    0, 0, true, values_cache_mode_, 0, 0);
            }

            asc_sync_notify(PIPE_MTE2, PIPE_MTE3, EVENT_ID0);
            asc_sync_wait(PIPE_MTE2, PIPE_MTE3, EVENT_ID0);

            for (uint32_t i = 0; i < proc_count; ++i) {
                uint32_t slot = (mte_finish_id + i) & MTE_TASK_RING_MASK;
                uint64_t dst_addr = reinterpret_cast<__ubuf__ volatile uint64_t*>(dst_addrs_)[slot];
                uint8_t table_values_cache_mode = static_cast<uint8_t>(dst_addr >> 60);
                asc_copy_ub2gm_align(
                    reinterpret_cast<__gm__ float*>(dst_addr), value_local_ + i * value_elems_aligned, 1, value_bytes,
                    table_values_cache_mode, 0, 0);
            }

            asc_sync_notify(PIPE_MTE3, PIPE_S, EVENT_ID0);
            asc_sync_wait(PIPE_MTE3, PIPE_S, EVENT_ID0);

            mte_finish_id += proc_count;
            *reinterpret_cast<__ubuf__ volatile uint32_t*>(mte_finish_id_) = mte_finish_id;
        }
    }

    // Keep the SIMD side alive until the SIMT drain path has published every completed key.
    __aicore__ inline void wait_publish_done() const
    {
        while (true) {
            uint32_t finish_flag = *reinterpret_cast<__ubuf__ volatile uint32_t*>(task_finish_flag_);
            uint32_t simt_assign_id = *reinterpret_cast<__ubuf__ volatile uint32_t*>(simt_assign_id_);
            uint32_t key_finish_id = *reinterpret_cast<__ubuf__ volatile uint32_t*>(key_finish_id_);
            if (finish_flag == 1 && key_finish_id == simt_assign_id) {
                return;
            }
        }
    }

private:
    __ubuf__ float* value_local_ = nullptr;
    __ubuf__ uint64_t* src_addrs_ = nullptr;
    __ubuf__ uint64_t* dst_addrs_ = nullptr;
    __ubuf__ int64_t* task_keys_ = nullptr;
    __ubuf__ uint64_t* key_addrs_ = nullptr;
    __ubuf__ uint32_t* global_id_ = nullptr;
    __ubuf__ uint32_t* mte_finish_id_ = nullptr;
    __ubuf__ uint32_t* simt_assign_id_ = nullptr;
    __ubuf__ uint32_t* task_finish_flag_ = nullptr;
    __ubuf__ uint32_t* key_assign_id_ = nullptr;
    __ubuf__ uint32_t* key_finish_id_ = nullptr;
    uint32_t dim_ = 0;
    uint8_t values_cache_mode_ = 0;
};

// SIMT producer: probe and lock a slot, then enqueue the value move and delayed key publication task.
__simt_vf__ inline void insert_or_assign_task_queue_probe_vf(
    mte_task_queue task_queue, __gm__ Bucket* table, __gm__ float* table_values, __gm__ const int64_t* keys,
    __gm__ const float* values, uint32_t key_num, uint32_t capacity, uint32_t dim, uint32_t block_index,
    uint32_t num_blocks)
{
    const uint32_t thread_all = static_cast<uint32_t>(blockDim.x) * num_blocks;
    for (uint32_t idx = block_index * static_cast<uint32_t>(blockDim.x) + static_cast<uint32_t>(threadIdx.x);
         idx < key_num; idx += thread_all) {
        int64_t key = keys[idx];
        uint32_t bucket_idx = static_cast<uint32_t>(hash_key_device(key)) & (capacity - 1);
        uint32_t result = INVALID_BUCKET;

        for (uint32_t probe = 0; probe < capacity; ++probe) {
            __gm__ int64_t* key_addr = &table[bucket_idx].key;
            int64_t old_key = asc_atomic_cas(key_addr, EMPTY_KEY, LOCKED_KEY);
            if (old_key == LOCKED_KEY) {
                old_key = wait_until_unlocked(key_addr);
            }
            if (old_key == EMPTY_KEY) {
                result = bucket_idx;
                break;
            }
            if (old_key == key) {
                old_key = asc_atomic_cas(key_addr, key, LOCKED_KEY);
                if (old_key == key) {
                    result = bucket_idx;
                    break;
                }
                continue;
            }
            bucket_idx = (bucket_idx + 1) & (capacity - 1);
        }

        bool need_assign = (result != INVALID_BUCKET);
        uint64_t src_addr = 0;
        uint64_t dst_addr = 0;
        uint64_t key_addr = 0;
        if (need_assign) {
            src_addr = reinterpret_cast<uint64_t>(values + idx * dim);
            dst_addr = reinterpret_cast<uint64_t>(table_values + result * dim);
            key_addr = reinterpret_cast<uint64_t>(&table[result].key);
        }
        task_queue.assign_warp_task(src_addr, dst_addr, key, key_addr, need_assign);
    }

    asc_syncthreads();
    if (threadIdx.x == 0) {
        task_queue.assignment_finish();
    }
    task_queue.drain_all();
}

__global__ __vector__ void insert_or_assign_mte_task_queue_kernel(
    __gm__ Bucket* table, __gm__ float* table_values, __gm__ const int64_t* keys, __gm__ const float* values,
    uint32_t key_num, uint32_t capacity, uint32_t dim)
{
    asc_init();

    const uint32_t core_idx = static_cast<uint32_t>(block_idx);
    const uint32_t core_num = BLOCK_DIM;
    const uint32_t rows_per_core = (key_num + core_num - 1) / core_num;
    const uint32_t core_start = core_idx * rows_per_core;
    const uint32_t core_end = (core_start + rows_per_core < key_num) ? (core_start + rows_per_core) : key_num;

    __ubuf__ float value_local[MTE_LOCAL_VALUE_COUNT];
    __ubuf__ uint64_t task_src_addrs[MTE_TASK_RING_CAPACITY];
    __ubuf__ uint64_t task_dst_addrs[MTE_TASK_RING_CAPACITY];
    __ubuf__ int64_t task_keys[MTE_TASK_RING_CAPACITY];
    __ubuf__ uint64_t task_key_addrs[MTE_TASK_RING_CAPACITY];
    __ubuf__ uint32_t global_id[1];
    __ubuf__ uint32_t mte_finish_id[1];
    __ubuf__ uint32_t simt_assign_id[1];
    __ubuf__ uint32_t task_finish_flag[1];
    __ubuf__ uint32_t key_assign_id[1];
    __ubuf__ uint32_t key_finish_id[1];

    mte_task_queue task_queue;
    task_queue.init(
        values, value_local, task_src_addrs, task_dst_addrs, task_keys, task_key_addrs, global_id, mte_finish_id,
        simt_assign_id, task_finish_flag, key_assign_id, key_finish_id, dim);

    if (core_start >= core_end) {
        return;
    }

    asc_sync_pipe(pipe_t::PIPE_ALL);
    asc_vf_call<insert_or_assign_task_queue_probe_vf>(
        dim3(THREAD_COUNT), task_queue, table, table_values, keys, values, key_num, capacity, dim, block_idx,
        BLOCK_DIM);
    task_queue.run_task();
    task_queue.wait_publish_done();
}

// Device-side find pass used to verify that published keys always point to complete values.
__simt_vf__ inline void find_verify_vf(
    __gm__ const Bucket* table, __gm__ const float* table_values, __gm__ const int64_t* keys,
    __gm__ const float* expected_values, __gm__ uint32_t* mismatch_count, uint32_t key_num, uint32_t capacity,
    uint32_t dim, uint32_t block_index, uint32_t num_blocks)
{
    const uint32_t thread_all = static_cast<uint32_t>(blockDim.x) * num_blocks;
    for (uint32_t idx = block_index * static_cast<uint32_t>(blockDim.x) + static_cast<uint32_t>(threadIdx.x);
         idx < key_num; idx += thread_all) {
        int64_t key = keys[idx];
        uint32_t bucket_idx = static_cast<uint32_t>(hash_key_device(key)) & (capacity - 1);
        uint32_t matched = 0;

        for (uint32_t probe = 0; probe < capacity; ++probe) {
            int64_t current_key = table[bucket_idx].key;
            if (current_key == key) {
                uint32_t value_base = bucket_idx * dim;
                uint32_t src_base = idx * dim;
                matched = 1;
                for (uint32_t j = 0; j < dim; ++j) {
                    if (table_values[value_base + j] != expected_values[src_base + j]) {
                        matched = 0;
                        break;
                    }
                }
                break;
            }
            if (current_key == EMPTY_KEY) {
                break;
            }
            bucket_idx = (bucket_idx + 1) & (capacity - 1);
        }

        if (matched == 0) {
            (void)asc_atomic_add(mismatch_count, 1U);
        }
    }
}

__global__ __vector__ void find_verify_kernel(
    __gm__ const Bucket* table, __gm__ const float* table_values, __gm__ const int64_t* keys,
    __gm__ const float* expected_values, __gm__ uint32_t* mismatch_count, uint32_t key_num, uint32_t capacity,
    uint32_t dim)
{
    asc_vf_call<find_verify_vf>(
        dim3(THREAD_COUNT), table, table_values, keys, expected_values, mismatch_count, key_num, capacity, dim,
        block_idx, BLOCK_DIM);
}

void init_host_data(std::vector<int64_t>& keys, std::vector<float>& values, uint32_t dim)
{
    for (uint32_t i = 0; i < KEY_NUM; ++i) {
        uint64_t raw_key = (static_cast<uint64_t>(i) * 11400714819323198485ULL) & (HASH_TABLE_CAPACITY - 1);
        keys[i] = static_cast<int64_t>(raw_key + 1);
        for (uint32_t j = 0; j < dim; ++j) {
            values[i * dim + j] = static_cast<float>(((i * 17 + j) & 0x3ff) * 0.25f);
        }
    }
}

// Host-side linear-probe find used after copying the device table back.
bool find_value_in_table(
    const std::vector<Bucket>& table, const std::vector<float>& table_values, int64_t key, const float* expected,
    uint32_t dim)
{
    uint32_t bucket_idx = static_cast<uint32_t>(hash_key_host(key)) & (HASH_TABLE_CAPACITY - 1);
    for (uint32_t probe = 0; probe < HASH_TABLE_CAPACITY; ++probe) {
        const Bucket& bucket = table[bucket_idx];
        if (bucket.key == key) {
            uint32_t value_base = bucket_idx * dim;
            for (uint32_t j = 0; j < dim; ++j) {
                if (std::fabs(table_values[value_base + j] - expected[j]) > 1e-6f) {
                    std::cerr << "Mismatch key=" << key << ", elem=" << j << ", expected=" << expected[j]
                              << ", actual=" << table_values[value_base + j] << std::endl;
                    return false;
                }
            }
            return true;
        }
        if (bucket.key == EMPTY_KEY) {
            return false;
        }
        bucket_idx = (bucket_idx + 1) & (HASH_TABLE_CAPACITY - 1);
    }
    return false;
}

// Validate both publication markers and key/value contents for every inserted row.
bool verify_result(
    const std::vector<int64_t>& keys, const std::vector<float>& values, const std::vector<Bucket>& table,
    const std::vector<float>& table_values, uint32_t dim)
{
    for (uint32_t bucket_idx = 0; bucket_idx < HASH_TABLE_CAPACITY; ++bucket_idx) {
        const Bucket& bucket = table[bucket_idx];
        if (bucket.key == LOCKED_KEY) {
            std::cerr << "Bucket remains locked, bucket=" << bucket_idx << std::endl;
            return false;
        }
    }

    for (uint32_t row = 0; row < KEY_NUM; ++row) {
        if (!find_value_in_table(table, table_values, keys[row], values.data() + row * dim, dim)) {
            std::cerr << "Cannot find expected key/value, key=" << keys[row] << std::endl;
            return false;
        }
    }
    return true;
}

// Dispatch the selected benchmark scenario. Both paths are single-kernel insert_or_assign implementations.
void launch_insert_or_assign(
    Bucket* buckets, float* mapped_values, const int64_t* keys, const float* values, uint32_t dim, aclrtStream stream)
{
    if constexpr (SCENARIO_NUM == 0) {
        insert_or_assign_warp_store_kernel<<<BLOCK_DIM, 0, stream>>>(
            buckets, mapped_values, keys, values, KEY_NUM, HASH_TABLE_CAPACITY, dim);
    } else {
        insert_or_assign_mte_task_queue_kernel<<<BLOCK_DIM, 0, stream>>>(
            buckets, mapped_values, keys, values, KEY_NUM, HASH_TABLE_CAPACITY, dim);
    }
}

unordered_map::unordered_map(size_type bucket_count, size_type mapped_dim, aclrtStream stream)
    : bucket_count_(bucket_count),
      mapped_dim_(mapped_dim),
      stream_(stream),
      buckets_(bucket_count),
      values_(static_cast<size_t>(bucket_count) * mapped_dim),
      find_mismatch_count_(1)
{
    clear();
}

void unordered_map::clear()
{
    buckets_.fill_zero();
    values_.fill_zero();
    size_ = 0;
}

unordered_map::insert_return_type unordered_map::insert_or_assign(
    const key_type* first_key, const key_type* last_key, const mapped_type* first_mapped)
{
    size_type count = static_cast<size_type>(last_key - first_key);
    if (count != KEY_NUM) {
        std::cerr << "Unsupported insert count: " << count << ", expected " << KEY_NUM << std::endl;
        return insert_return_type{0, false};
    }

    device_vector<key_type> keys(count);
    device_vector<mapped_type> mapped_values(static_cast<size_t>(count) * mapped_dim_);

    CHECK_ACL(aclrtMemcpy(keys.data(), keys.bytes(), first_key, keys.bytes(), ACL_MEMCPY_HOST_TO_DEVICE));
    CHECK_ACL(aclrtMemcpy(
        mapped_values.data(), mapped_values.bytes(), first_mapped, mapped_values.bytes(), ACL_MEMCPY_HOST_TO_DEVICE));

    // Repeat count is configurable. run.sh uses one workload so msOpProf captures one complete insert path.
    for (uint32_t i = 0; i < PROFILE_REPEAT_TIMES_VALUE; ++i) {
        launch_insert_or_assign(
            buckets_.data(), values_.data(), keys.data(), mapped_values.data(), mapped_dim_, stream_);
    }
    CHECK_ACL(aclrtSynchronizeStream(stream_));

    // Device-side find verification catches publication-order bugs before host copies inspect the table.
    find_mismatch_count_.fill_zero();
    find_verify_kernel<<<BLOCK_DIM, 0, stream_>>>(
        buckets_.data(), values_.data(), keys.data(), mapped_values.data(), find_mismatch_count_.data(), count,
        bucket_count_, mapped_dim_);
    CHECK_ACL(aclrtSynchronizeStream(stream_));
    std::vector<uint32_t> mismatch_count(1);
    find_mismatch_count_.copy_to(mismatch_count);
    if (mismatch_count[0] != 0) {
        std::cerr << "Device find verification failed, mismatch_count=" << mismatch_count[0] << std::endl;
        return insert_return_type{0, false};
    }

    size_ = count;
    return insert_return_type{count, true};
}

void unordered_map::copy_to(std::vector<bucket_type>& buckets, std::vector<mapped_type>& values) const
{
    buckets.resize(bucket_count_);
    values.resize(static_cast<size_t>(bucket_count_) * mapped_dim_);
    buckets_.copy_to(buckets);
    values_.copy_to(values);
}

bool run_one_dim(uint32_t dim, aclrtStream stream)
{
    std::vector<int64_t> keys(KEY_NUM);
    std::vector<float> values(static_cast<size_t>(KEY_NUM) * dim);
    init_host_data(keys, values, dim);

    unordered_map table(HASH_TABLE_CAPACITY, dim, stream);
    auto insert_result = table.insert_or_assign(keys.data(), keys.data() + keys.size(), values.data());
    if (!insert_result.second) {
        return false;
    }

    std::vector<Bucket> buckets;
    std::vector<float> table_values;
    table.copy_to(buckets, table_values);
    bool ok = verify_result(keys, values, buckets, table_values, dim);

    return ok;
}

void print_header()
{
    std::cout << "\n### HashTable insert_or_assign benchmark\n";
    std::cout << "* scenario = " << SCENARIO_NUM << " (" << SCENARIO_NAME << ")\n";
    std::cout << "* capacity = " << HASH_TABLE_CAPACITY << ", key_num = " << KEY_NUM
              << ", load_factor = " << (static_cast<double>(KEY_NUM) / HASH_TABLE_CAPACITY) << "\n";
    std::cout << "* block_dim = " << BLOCK_DIM << ", thread_count = " << THREAD_COUNT << ", warp_size = " << WARP_SIZE
              << "\n";
    std::cout << "* profile_repeat = " << PROFILE_REPEAT_TIMES_VALUE << "\n";
    std::cout << "* timing method = msOpProf\n\n";
    std::cout << "| Scenario | Dim | Impl | Verify |\n";
    std::cout << "|---:|---:|:---|:---|\n";
}

void print_result(uint32_t dim, bool verify_ok)
{
    std::cout << "| " << SCENARIO_NUM << " | " << dim << " | " << SCENARIO_NAME << " | "
              << (verify_ok ? "PASS" : "FAIL") << " |\n";
}

bool is_supported_dim(uint32_t dim)
{
    for (uint32_t supported_dim : TEST_DIMS) {
        if (dim == supported_dim) {
            return true;
        }
    }
    return false;
}

std::vector<uint32_t> get_dims_to_run(int32_t argc, char** argv)
{
    std::vector<uint32_t> dims;
    if (argc == 1) {
        for (uint32_t dim : TEST_DIMS) {
            dims.push_back(dim);
        }
        return dims;
    }
    if (argc != 2) {
        std::cerr << "Usage: " << argv[0] << " [dim]" << std::endl;
        return dims;
    }

    char* end = nullptr;
    unsigned long parsed = std::strtoul(argv[1], &end, 10);
    if (end == argv[1] || *end != '\0' || parsed == 0 || parsed > UINT32_MAX) {
        std::cerr << "Invalid dim: " << argv[1] << std::endl;
        return dims;
    }

    uint32_t dim = static_cast<uint32_t>(parsed);
    if (!is_supported_dim(dim)) {
        std::cerr << "Unsupported dim: " << dim << ". Supported dims: ";
        for (uint32_t supported_dim : TEST_DIMS) {
            std::cerr << supported_dim << " ";
        }
        std::cerr << std::endl;
        return dims;
    }
    dims.push_back(dim);
    return dims;
}

int32_t main(int32_t argc, char** argv)
{
    std::vector<uint32_t> dims = get_dims_to_run(argc, argv);
    if (dims.empty()) {
        return 1;
    }

    CHECK_ACL(aclInit(nullptr));
    CHECK_ACL(aclrtSetDevice(0));

    aclrtStream stream = nullptr;
    CHECK_ACL(aclrtCreateStream(&stream));

    print_header();
    bool all_ok = true;
    for (uint32_t dim : dims) {
        bool ok = run_one_dim(dim, stream);
        print_result(dim, ok);
        all_ok = all_ok && ok;
    }
    std::cout << (all_ok ? "Verification PASSED" : "Verification FAILED") << std::endl;

    CHECK_ACL(aclrtDestroyStream(stream));
    CHECK_ACL(aclrtResetDevice(0));
    CHECK_ACL(aclFinalize());

    return all_ok ? 0 : 1;
}
