/* !
 * \file grid_config.asc
 * \brief SIMT vf programming sample demonstrating grid/block configuration and vf call optimization
 */

#include <iostream>
#include <iterator>
#include <vector>
#include <cstdlib>
#include <ctime>
#include "acl/acl.h"
#include "simt_api/asc_simt.h"

#ifndef SCENARIO_NUM
#define SCENARIO_NUM 1
#endif

#if SCENARIO_NUM < 1 || SCENARIO_NUM > 16
#error "SCENARIO_NUM must be between 1 and 16."
#endif

namespace {
constexpr uint32_t MAX_THREAD_NUM = 2048;
constexpr uint32_t AIV_CORE_NUM = 64;
constexpr uint32_t INPUT_TOTAL_LENGTH = 2200000;
// 大shape：[1024,2048] = 2097152个元素
constexpr uint32_t LARGE_SHAPE_TOTAL_LENGTH = 1024 * 2048;
// 小shape：[8,2048] = 16384个元素
constexpr uint32_t SMALL_SHAPE_TOTAL_LENGTH = 8 * 2048;

enum class KernelType {
    EMPTY,           // 空核函数，仅测调度基线
    GATHER_STRIDED,  // 每个block跨步处理一段元素(优化写法)
};

struct ScenarioConfig {
    uint32_t blocks_per_grid;
    uint32_t total_length;
    KernelType kernel;
    uint32_t vf_call_times;
    const char* name;
};

// 运行期查询物理 Vector Core(AIV)数量；查询失败时返回 AIV_CORE_NUM
uint32_t query_aiv_core_num(int32_t device_id)
{
    int64_t core_num = 0;
    aclError ret = aclrtGetDeviceInfo(
        static_cast<uint32_t>(device_id), ACL_DEV_ATTR_VECTOR_CORE_NUM, &core_num);
    return (ret == ACL_SUCCESS && core_num > 0) ? static_cast<uint32_t>(core_num) : AIV_CORE_NUM;
}

// 解析每block线程数：按每核实际元素数自适应，封顶到硬件上限MAX_THREAD_NUM
// (每核元素数<2048时降低线程数，消除空转线程)
uint32_t resolve_thread_num(uint32_t blocks_per_grid, uint32_t total_length)
{
    uint32_t per_core = (total_length + blocks_per_grid - 1) / blocks_per_grid;
    return per_core < MAX_THREAD_NUM ? per_core : MAX_THREAD_NUM;
}

ScenarioConfig get_scenario_config(uint32_t scenario)
{
    switch (scenario) {
        // 大shape [1024,2048] = 2097152
        case 1:  return {1,    LARGE_SHAPE_TOTAL_LENGTH, KernelType::EMPTY, 1, "large shape, 1 core, 1 vf (empty)"};
        case 2:  return {32,   LARGE_SHAPE_TOTAL_LENGTH, KernelType::EMPTY, 1, "large shape, 32 cores, 1 vf (empty)"};
        case 3:  return {0,    LARGE_SHAPE_TOTAL_LENGTH, KernelType::EMPTY, 1, "large shape, full physical cores, 1 vf (empty)"};
        case 4:  return {128,  LARGE_SHAPE_TOTAL_LENGTH, KernelType::EMPTY, 1, "large shape, 128 cores, 1 vf (empty)"};
        case 5:  return {1024, LARGE_SHAPE_TOTAL_LENGTH, KernelType::EMPTY, 1, "large shape, 1024 cores, 1 vf (empty)"};
        case 6:  return {32,   LARGE_SHAPE_TOTAL_LENGTH, KernelType::EMPTY, 2, "large shape, 32 cores, 2 vf (empty)"};
        case 7:  return {0,    LARGE_SHAPE_TOTAL_LENGTH, KernelType::EMPTY, 2, "large shape, full physical cores, 2 vf (empty)"};
        case 8:  return {1024, LARGE_SHAPE_TOTAL_LENGTH, KernelType::EMPTY, 2, "large shape, 1024 cores, 2 vf (empty)"};
        case 9:  return {1024, LARGE_SHAPE_TOTAL_LENGTH, KernelType::GATHER_STRIDED, 0, "large shape, 1024 cores, gather strided"};
        case 10: return {0,    LARGE_SHAPE_TOTAL_LENGTH, KernelType::GATHER_STRIDED, 0, "large shape, full physical cores, gather strided"};
        case 11: return {32,   LARGE_SHAPE_TOTAL_LENGTH, KernelType::GATHER_STRIDED, 0, "large shape, 32 cores, gather strided"};
        // 小shape [8,2048] = 16384
        case 12: return {4,    SMALL_SHAPE_TOTAL_LENGTH, KernelType::GATHER_STRIDED, 0, "small shape(16384), 4 cores, gather strided"};
        case 13: return {8,    SMALL_SHAPE_TOTAL_LENGTH, KernelType::GATHER_STRIDED, 0, "small shape(16384), 8 cores, gather strided"};
        case 14: return {16,   SMALL_SHAPE_TOTAL_LENGTH, KernelType::GATHER_STRIDED, 0, "small shape(16384), 16 cores, gather strided"};
        case 15: return {32,   SMALL_SHAPE_TOTAL_LENGTH, KernelType::GATHER_STRIDED, 0, "small shape(16384), 32 cores, gather strided"};
        case 16: return {0,    SMALL_SHAPE_TOTAL_LENGTH, KernelType::GATHER_STRIDED, 0, "small shape(16384), full physical cores, gather strided"};
        default: return {32,   LARGE_SHAPE_TOTAL_LENGTH, KernelType::EMPTY, 1, "unknown"};
    }
}
}

__simt_vf__ __launch_bounds__(MAX_THREAD_NUM) inline void simt_empty(__gm__ float* input, __gm__ uint32_t* index) {}

__global__ __vector__ void empty_kernel(
    __gm__ float* input, __gm__ uint32_t* index, __gm__ float* output, uint32_t input_total_length,
    uint32_t index_total_length, uint32_t vf_call_times)
{
    for (uint32_t vf_idx = 0; vf_idx < vf_call_times; vf_idx++) {
        asc_vf_call<simt_empty>(dim3(MAX_THREAD_NUM), input, index);
    }
}

__simt_vf__ __launch_bounds__(MAX_THREAD_NUM) inline void simt_gather(
    __gm__ float* output, __gm__ float* input, __gm__ uint32_t* index, uint32_t input_total_length,
    uint32_t index_total_length)
{
    uint32_t idx = blockIdx.x * blockDim.x + threadIdx.x;
    uint32_t stride = gridDim.x * blockDim.x;

    for (uint32_t i = idx; i < index_total_length; i += stride) {
        uint32_t gather_idx = index[i];
        if (gather_idx >= input_total_length) {
            gather_idx = 0;
        }
        output[i] = input[gather_idx];
    }
}

__global__ __vector__ void gather_kernel(
    __gm__ float* input, __gm__ uint32_t* index, __gm__ float* output, uint32_t input_total_length,
    uint32_t index_total_length, uint32_t thread_num)
{
    asc_vf_call<simt_gather>(
        dim3(thread_num), output, input, index, input_total_length, index_total_length);
}

std::vector<float> run_kernel(std::vector<float>& input, std::vector<uint32_t>& index,
                              uint32_t blocks_per_grid, KernelType kernel, uint32_t vf_call_times)
{
    uint32_t input_total_length = input.size();
    size_t input_total_byte_size = input_total_length * sizeof(float);

    uint32_t index_total_length = index.size();
    size_t index_total_byte_size = index_total_length * sizeof(uint32_t);

    uint32_t output_total_length = index.size();
    size_t output_total_byte_size = output_total_length * sizeof(float);

    int32_t device_id = 0;
    aclrtStream stream = nullptr;

    uint8_t* input_host = reinterpret_cast<uint8_t*>(input.data());
    uint8_t* index_host = reinterpret_cast<uint8_t*>(index.data());
    uint8_t* output_host = nullptr;
    float* input_device = nullptr;
    uint32_t* index_device = nullptr;
    float* output_device = nullptr;

    aclInit(nullptr);
    aclrtSetDevice(device_id);
    aclrtCreateStream(&stream);

    // blocks_per_grid == 0 表示"用满全部物理核"：运行期查询真实核数后替换
    if (blocks_per_grid == 0) {
        blocks_per_grid = query_aiv_core_num(device_id);
    }

    aclrtMallocHost((void**)(&output_host), output_total_byte_size);
    aclrtMalloc((void**)&input_device, input_total_byte_size, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&index_device, index_total_byte_size, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&output_device, output_total_byte_size, ACL_MEM_MALLOC_HUGE_FIRST);

    aclrtMemcpy(input_device, input_total_byte_size, input_host, input_total_byte_size, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(index_device, index_total_byte_size, index_host, index_total_byte_size, ACL_MEMCPY_HOST_TO_DEVICE);

    if (kernel == KernelType::GATHER_STRIDED) {
        uint32_t threads_per_block = resolve_thread_num(blocks_per_grid, index_total_length);
        gather_kernel<<<blocks_per_grid, 0, stream>>>(
            input_device, index_device, output_device, input_total_length, index_total_length, threads_per_block);
    } else {
        aclrtMemcpy(
            output_device, output_total_byte_size, input_device, output_total_byte_size, ACL_MEMCPY_DEVICE_TO_DEVICE);
        empty_kernel<<<blocks_per_grid, 0, stream>>>(
            input_device, index_device, output_device, input_total_length, index_total_length, vf_call_times);
    }

    aclrtSynchronizeStream(stream);

    aclrtMemcpy(output_host, output_total_byte_size, output_device, output_total_byte_size, ACL_MEMCPY_DEVICE_TO_HOST);
    std::vector<float> output((float*)output_host, (float*)(output_host + output_total_byte_size));

    aclrtFree(input_device);
    aclrtFree(index_device);
    aclrtFree(output_device);
    aclrtFreeHost(output_host);

    const char* err = aclGetRecentErrMsg();
    if (err != nullptr) {
        fprintf(stderr, "%s\n", err);
    }

    aclrtDestroyStream(stream);
    aclrtResetDevice(device_id);
    aclFinalize();
    return output;
}

uint32_t verify_result(std::vector<float>& output, std::vector<float>& golden)
{
    auto print_tensor = [](std::vector<float>& tensor, const char* name) {
        constexpr size_t max_print_size = 20;
        std::cout << name << ": ";
        std::copy(
            tensor.begin(), tensor.begin() + std::min(tensor.size(), max_print_size),
            std::ostream_iterator<float>(std::cout, " "));
        if (tensor.size() > max_print_size) {
            std::cout << "...";
        }
        std::cout << std::endl;
    };
    print_tensor(output, "Output");
    print_tensor(golden, "Golden");

    if (std::equal(golden.begin(), golden.end(), output.begin())) {
        std::cout << "[Success] Case accuracy is verification passed." << std::endl;
        return 0;
    } else {
        std::cout << "[Failed] Case accuracy is verification failed!" << std::endl;
        return 1;
    }
}

int32_t main(int32_t argc, char* argv[])
{
    srand(static_cast<uint32_t>(time(nullptr)));

    const uint32_t scenario = static_cast<uint32_t>(SCENARIO_NUM);
    ScenarioConfig config = get_scenario_config(scenario);

    printf("Scenario %u: %s\n", scenario, config.name);

    std::vector<float> input(INPUT_TOTAL_LENGTH);
    for (uint32_t i = 0; i < INPUT_TOTAL_LENGTH; i++) {
        input[i] = i * 1.2f;
    }

    const uint32_t total_length = config.total_length;
    std::vector<uint32_t> index(total_length);
    for (uint32_t i = 0; i < total_length; i++) {
        index[i] = rand() % INPUT_TOTAL_LENGTH;
    }

    std::vector<float> golden(total_length);
    if (config.kernel == KernelType::EMPTY) {
        for (uint32_t i = 0; i < total_length; i++) {
            golden[i] = input[i];
        }
    } else {
        for (uint32_t i = 0; i < total_length; i++) {
            golden[i] = input[index[i]];
        }
    }

    std::vector<float> output =
        run_kernel(input, index, config.blocks_per_grid, config.kernel, config.vf_call_times);
    if (output.empty()) {
        return 1;
    }
    return verify_result(output, golden);
}
