/* !
 * \file floor_mod.asc
 * \brief int32_t floor_mod with multiple implementation modes selected by SCENARIO_NUM:
 *        SCENARIO_NUM=0: pure SIMT direct GM access (no GM<->UB DataCopy)
 *        SCENARIO_NUM=1: SIMD
 *        SCENARIO_NUM=2: SIMT non-contiguous access
 *        SCENARIO_NUM=3: SIMT contiguous access
 */

#include "acl/acl.h"
#include "kernel_operator.h"
#include "simt_api/asc_simt.h"
#include "data_utils.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

constexpr uint32_t scenarioNum = SCENARIO_NUM;
namespace {
constexpr uint32_t THREAD_COUNT = 1024;
constexpr uint32_t BUFFER_NUM = 2;
constexpr uint32_t TENSOR_NUM_PER_BUFFER = 3;
constexpr uint32_t UB_SIZE_BYTES = 256 * 1024;
constexpr uint32_t RESERVED_UB_BYTES = 8 * 1024;
constexpr uint32_t MIN_SIMT_DCACHE_BYTES = 32 * 1024;
constexpr uint32_t MAX_DYNAMIC_UB_BYTES = UB_SIZE_BYTES - RESERVED_UB_BYTES - MIN_SIMT_DCACHE_BYTES;
constexpr uint32_t FMOD_B32_SIGN = 0x80000000;
} // namespace

// =====================================================================
// SCENARIO_NUM=0: Pure SIMT direct GM access
// =====================================================================
template <typename T>
__simt_vf__ inline void floor_mod_simt_gm_contiguous(__gm__ T* x, __gm__ T* y, __gm__ T* z, uint32_t inputTotalLength)
{
    for (uint32_t index = static_cast<uint32_t>(threadIdx.x); index < inputTotalLength;
         index += static_cast<uint32_t>(blockDim.x)) {
        T yValue = y[index];
        const auto rem = x[index] % yValue;
        bool signsDiffer = ((rem < 0) != (yValue < 0));
        if (signsDiffer && (rem != 0)) {
            z[index] = rem + yValue;
        } else {
            z[index] = rem;
        }
    }
}

// =====================================================================
// SCENARIO_NUM=1: SIMD implementation (standalone Div + zero protection)
// =====================================================================
template <typename T>
__simd_vf__ inline void floor_mod_simd(__ubuf__ T* zAddr, __ubuf__ T* xAddr, __ubuf__ T* yAddr, const uint32_t count)
{
    constexpr uint32_t oneRepeatSize = AscendC::GetVecLen() / sizeof(T);
    uint16_t loopTimes = AscendC::CeilDivision(count, oneRepeatSize);

    AscendC::Reg::RegTensor<T> xValue;
    AscendC::Reg::RegTensor<T> yValue;
    AscendC::Reg::RegTensor<T> modValue;
    AscendC::Reg::RegTensor<T> tempValue;
    AscendC::Reg::RegTensor<T> defaultValue;
    AscendC::Reg::RegTensor<T> signValue;

    AscendC::Reg::MaskReg mask;
    AscendC::Reg::MaskReg selectMask;
    AscendC::Reg::MaskReg adjustMask;
    uint32_t maskCount = count;

    AscendC::Reg::Duplicate(defaultValue, T(-1));
    AscendC::Reg::Duplicate(signValue, FMOD_B32_SIGN);

    for (uint16_t i = 0; i < loopTimes; i++) {
        mask = AscendC::Reg::UpdateMask<T>(maskCount);
        AscendC::Reg::LoadAlign(xValue, xAddr + i * oneRepeatSize);
        AscendC::Reg::LoadAlign(yValue, yAddr + i * oneRepeatSize);

        // int32_t SIMD computes trunc division inside VF, then builds rem = x - y * div.
        AscendC::Reg::Div(tempValue, xValue, yValue, mask);
        AscendC::Reg::Mul(tempValue, yValue, tempValue, mask);
        AscendC::Reg::Sub(modValue, xValue, tempValue, mask);

        // Divide-by-zero protection: when y == 0, result is -1.
        AscendC::Reg::Compares<T, AscendC::CMPMODE::NE>(selectMask, yValue, T(0), mask);
        AscendC::Reg::Select(tempValue, modValue, defaultValue, selectMask);

        // Adjust trunc remainder to floor_mod.
        AscendC::Reg::Add(modValue, tempValue, yValue, mask);
        AscendC::Reg::Compares<T, AscendC::CMPMODE::NE>(adjustMask, tempValue, T(0), mask);
        AscendC::Reg::And(xValue, tempValue, signValue, mask);
        AscendC::Reg::And(yValue, yValue, signValue, mask);
        AscendC::Reg::Compare<T, AscendC::CMPMODE::NE>(selectMask, xValue, yValue, mask);
        AscendC::Reg::MaskAnd(adjustMask, selectMask, adjustMask, mask);
        AscendC::Reg::Select(modValue, modValue, tempValue, adjustMask);
        AscendC::Reg::StoreAlign(zAddr + i * oneRepeatSize, modValue, mask);
    }
}

// =====================================================================
// SCENARIO_NUM=2: SIMT non-contiguous access
// =====================================================================
template <typename T, uint32_t TileLength>
__simt_vf__ inline void floor_mod_simt_non_contiguous(
    __ubuf__ T* x, __ubuf__ T* y, __ubuf__ T* z, uint32_t inputTotalLength)
{
    constexpr uint32_t elems_per_thread = TileLength / THREAD_COUNT;
    uint32_t tid = threadIdx.x;
    for (uint32_t i = 0; i < elems_per_thread; i++) {
        uint32_t index = tid * elems_per_thread + i;
        if (index >= inputTotalLength)
            break;
        T yValue = y[index];
        auto rem = x[index] % yValue;
        bool signsDiffer = ((rem < 0) != (yValue < 0));
        if (signsDiffer && (rem != 0)) {
            z[index] = rem + yValue;
        } else {
            z[index] = rem;
        }
    }
}

// =====================================================================
// SCENARIO_NUM=3: SIMT contiguous access
// =====================================================================
template <typename T>
__simt_vf__ inline void floor_mod_simt_contiguous(
    __ubuf__ T* x, __ubuf__ T* y, __ubuf__ T* z, uint32_t inputTotalLength)
{
    for (uint32_t index = static_cast<uint32_t>(threadIdx.x); index < inputTotalLength;
         index += static_cast<uint32_t>(blockDim.x)) {
        T yValue = y[index];
        const auto rem = x[index] % yValue;
        bool signsDiffer = ((rem < 0) != (yValue < 0));
        if (signsDiffer && (rem != 0)) {
            z[index] = rem + yValue;
        } else {
            z[index] = rem;
        }
    }
}

// =====================================================================
// Kernel class for SCENARIO_NUM=0
// =====================================================================
template <typename T, uint32_t DataLenPerCore>
class KernelGmSimt {
public:
    __aicore__ inline void Init(__gm__ uint8_t* x, __gm__ uint8_t* y, __gm__ uint8_t* z)
    {
        this->xGm.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(x) + AscendC::GetBlockIdx() * DataLenPerCore);
        this->yGm.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(y) + AscendC::GetBlockIdx() * DataLenPerCore);
        this->zGm.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(z) + AscendC::GetBlockIdx() * DataLenPerCore);
        this->xGm.SetL2CacheHint(AscendC::CacheMode::CACHE_MODE_DISABLE);
        this->yGm.SetL2CacheHint(AscendC::CacheMode::CACHE_MODE_DISABLE);
    }

    __aicore__ inline void ProcessGmSimt()
    {
        asc_vf_call<floor_mod_simt_gm_contiguous<T>>(
            dim3(THREAD_COUNT), const_cast<__gm__ T*>(xGm.GetPhyAddr()), const_cast<__gm__ T*>(yGm.GetPhyAddr()),
            const_cast<__gm__ T*>(zGm.GetPhyAddr()), DataLenPerCore);
    }

private:
    AscendC::GlobalTensor<T> xGm;
    AscendC::GlobalTensor<T> yGm;
    AscendC::GlobalTensor<T> zGm;
};

// =====================================================================
// Shared GM<->UB tiling pipeline for SCENARIO_NUM=1/2/3
// =====================================================================
template <typename T, typename Derived, uint32_t DataLenPerCore, uint32_t TileLength, uint32_t TileNumPerCore>
class KernelUbBase {
public:
    __aicore__ inline void Init(__gm__ uint8_t* x, __gm__ uint8_t* y, __gm__ uint8_t* z)
    {
        this->xGm.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(x) + AscendC::GetBlockIdx() * DataLenPerCore);
        this->yGm.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(y) + AscendC::GetBlockIdx() * DataLenPerCore);
        this->zGm.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(z) + AscendC::GetBlockIdx() * DataLenPerCore);
        this->xGm.SetL2CacheHint(AscendC::CacheMode::CACHE_MODE_DISABLE);
        this->yGm.SetL2CacheHint(AscendC::CacheMode::CACHE_MODE_DISABLE);

        xPing = AscendC::LocalTensor<T>(AscendC::TPosition::VECCALC, X_PING_OFFSET, TileLength);
        yPing = AscendC::LocalTensor<T>(AscendC::TPosition::VECCALC, Y_PING_OFFSET, TileLength);
        zPing = AscendC::LocalTensor<T>(AscendC::TPosition::VECCALC, Z_PING_OFFSET, TileLength);
        xPong = AscendC::LocalTensor<T>(AscendC::TPosition::VECCALC, X_PONG_OFFSET, TileLength);
        yPong = AscendC::LocalTensor<T>(AscendC::TPosition::VECCALC, Y_PONG_OFFSET, TileLength);
        zPong = AscendC::LocalTensor<T>(AscendC::TPosition::VECCALC, Z_PONG_OFFSET, TileLength);
    }

    __aicore__ inline void ProcessTiles()
    {
        AscendC::SetFlag<AscendC::HardEvent::V_MTE2>(EVENT_ID0);
        AscendC::SetFlag<AscendC::HardEvent::V_MTE2>(EVENT_ID1);
        AscendC::SetFlag<AscendC::HardEvent::MTE3_V>(EVENT_ID0);
        AscendC::SetFlag<AscendC::HardEvent::MTE3_V>(EVENT_ID1);

        for (uint32_t tileIdx = 0; tileIdx < TileNumPerCore; ++tileIdx) {
            int32_t eventId = ((tileIdx & 1) == 0 ? EVENT_ID0 : EVENT_ID1);
            AscendC::LocalTensor<T>& xLocal = ((tileIdx & 1) == 0 ? xPing : xPong);
            AscendC::LocalTensor<T>& yLocal = ((tileIdx & 1) == 0 ? yPing : yPong);
            AscendC::LocalTensor<T>& zLocal = ((tileIdx & 1) == 0 ? zPing : zPong);

            AscendC::WaitFlag<AscendC::HardEvent::V_MTE2>(eventId);
            CopyIn(tileIdx, TileLength, xLocal, yLocal);
            AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(eventId);

            AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(eventId);
            AscendC::WaitFlag<AscendC::HardEvent::MTE3_V>(eventId);
            static_cast<Derived*>(this)->Compute(TileLength, xLocal, yLocal, zLocal);
            AscendC::SetFlag<AscendC::HardEvent::V_MTE2>(eventId);

            AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(eventId);
            AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(eventId);
            CopyOut(tileIdx, TileLength, zLocal);
            AscendC::SetFlag<AscendC::HardEvent::MTE3_V>(eventId);
        }

        AscendC::WaitFlag<AscendC::HardEvent::V_MTE2>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::V_MTE2>(EVENT_ID1);
        AscendC::WaitFlag<AscendC::HardEvent::MTE3_V>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE3_V>(EVENT_ID1);
    }

protected:
    __aicore__ inline void CopyIn(
        uint32_t tileIdx, uint32_t count, AscendC::LocalTensor<T>& xLocal, AscendC::LocalTensor<T>& yLocal)
    {
        uint32_t tileOffset = tileIdx * TileLength;
        AscendC::DataCopy(xLocal, xGm[tileOffset], count);
        AscendC::DataCopy(yLocal, yGm[tileOffset], count);
    }

    __aicore__ inline void CopyOut(uint32_t tileIdx, uint32_t count, AscendC::LocalTensor<T>& zLocal)
    {
        uint32_t tileOffset = tileIdx * TileLength;
        AscendC::DataCopy(zGm[tileOffset], zLocal, count);
    }

private:
    static constexpr uint64_t X_PING_OFFSET = 0;
    static constexpr uint64_t Y_PING_OFFSET = TileLength * sizeof(T);
    static constexpr uint64_t Z_PING_OFFSET = 2 * TileLength * sizeof(T);
    static constexpr uint64_t X_PONG_OFFSET = 3 * TileLength * sizeof(T);
    static constexpr uint64_t Y_PONG_OFFSET = 4 * TileLength * sizeof(T);
    static constexpr uint64_t Z_PONG_OFFSET = 5 * TileLength * sizeof(T);
    AscendC::GlobalTensor<T> xGm;
    AscendC::GlobalTensor<T> yGm;
    AscendC::GlobalTensor<T> zGm;
    AscendC::LocalTensor<T> xPing;
    AscendC::LocalTensor<T> yPing;
    AscendC::LocalTensor<T> zPing;
    AscendC::LocalTensor<T> xPong;
    AscendC::LocalTensor<T> yPong;
    AscendC::LocalTensor<T> zPong;
};

template <typename T, uint32_t DataLenPerCore, uint32_t TileLength, uint32_t TileNumPerCore>
class KernelSimd
    : public KernelUbBase<
          T, KernelSimd<T, DataLenPerCore, TileLength, TileNumPerCore>, DataLenPerCore, TileLength, TileNumPerCore> {
public:
    __aicore__ inline void Compute(
        uint32_t count, AscendC::LocalTensor<T>& xLocal, AscendC::LocalTensor<T>& yLocal,
        AscendC::LocalTensor<T>& zLocal)
    {
        __ubuf__ T* xAddr = (__ubuf__ T*)xLocal.GetPhyAddr();
        __ubuf__ T* yAddr = (__ubuf__ T*)yLocal.GetPhyAddr();
        __ubuf__ T* zAddr = (__ubuf__ T*)zLocal.GetPhyAddr();

        asc_vf_call<floor_mod_simd<T>>(zAddr, xAddr, yAddr, count);
    }
};

template <typename T, uint32_t DataLenPerCore, uint32_t TileLength, uint32_t TileNumPerCore>
class KernelSimtNonContiguous : public KernelUbBase<
                                    T, KernelSimtNonContiguous<T, DataLenPerCore, TileLength, TileNumPerCore>,
                                    DataLenPerCore, TileLength, TileNumPerCore> {
public:
    __aicore__ inline void Compute(
        uint32_t count, AscendC::LocalTensor<T>& xLocal, AscendC::LocalTensor<T>& yLocal,
        AscendC::LocalTensor<T>& zLocal)
    {
        __ubuf__ T* xAddr = (__ubuf__ T*)xLocal.GetPhyAddr();
        __ubuf__ T* yAddr = (__ubuf__ T*)yLocal.GetPhyAddr();
        __ubuf__ T* zAddr = (__ubuf__ T*)zLocal.GetPhyAddr();

        asc_vf_call<floor_mod_simt_non_contiguous<T, TileLength>>(dim3(THREAD_COUNT), xAddr, yAddr, zAddr, count);
        // SIMT writes UB directly; wait for those UB accesses before MTE3 reads or buffers are reused.
        AscendC::DataSyncBarrier<AscendC::MemDsbT::UB>();
    }
};

template <typename T, uint32_t DataLenPerCore, uint32_t TileLength, uint32_t TileNumPerCore>
class KernelSimtContiguous : public KernelUbBase<
                                 T, KernelSimtContiguous<T, DataLenPerCore, TileLength, TileNumPerCore>, DataLenPerCore,
                                 TileLength, TileNumPerCore> {
public:
    __aicore__ inline void Compute(
        uint32_t count, AscendC::LocalTensor<T>& xLocal, AscendC::LocalTensor<T>& yLocal,
        AscendC::LocalTensor<T>& zLocal)
    {
        __ubuf__ T* xAddr = (__ubuf__ T*)xLocal.GetPhyAddr();
        __ubuf__ T* yAddr = (__ubuf__ T*)yLocal.GetPhyAddr();
        __ubuf__ T* zAddr = (__ubuf__ T*)zLocal.GetPhyAddr();

        asc_vf_call<floor_mod_simt_contiguous<T>>(dim3(THREAD_COUNT), xAddr, yAddr, zAddr, count);
        // SIMT writes UB directly; wait for those UB accesses before MTE3 reads or buffers are reused.
        AscendC::DataSyncBarrier<AscendC::MemDsbT::UB>();
    }
};

template <typename T, uint32_t DataLenPerCore>
__global__ __vector__ void floor_mod_gm_simt_custom(__gm__ uint8_t* x, __gm__ uint8_t* y, __gm__ uint8_t* z)
{
    AscendC::InitSocState();
    KernelGmSimt<T, DataLenPerCore> kernel;
    kernel.Init(x, y, z);
    kernel.ProcessGmSimt();
    AscendC::PipeBarrier<PIPE_ALL>();
}

template <typename T, uint32_t DataLenPerCore, uint32_t TileLength, uint32_t TileNumPerCore>
__global__ __vector__ void floor_mod_simd_custom(__gm__ uint8_t* x, __gm__ uint8_t* y, __gm__ uint8_t* z)
{
    AscendC::InitSocState();
    KernelSimd<T, DataLenPerCore, TileLength, TileNumPerCore> kernel;
    kernel.Init(x, y, z);
    kernel.ProcessTiles();
    AscendC::PipeBarrier<PIPE_ALL>();
}

template <typename T, uint32_t DataLenPerCore, uint32_t TileLength, uint32_t TileNumPerCore>
__global__ __vector__ void floor_mod_simt_non_contiguous_custom(
    __gm__ uint8_t* x, __gm__ uint8_t* y, __gm__ uint8_t* z)
{
    AscendC::InitSocState();
    KernelSimtNonContiguous<T, DataLenPerCore, TileLength, TileNumPerCore> kernel;
    kernel.Init(x, y, z);
    kernel.ProcessTiles();
    AscendC::PipeBarrier<PIPE_ALL>();
}

template <typename T, uint32_t DataLenPerCore, uint32_t TileLength, uint32_t TileNumPerCore>
__global__ __vector__ void floor_mod_simt_contiguous_custom(__gm__ uint8_t* x, __gm__ uint8_t* y, __gm__ uint8_t* z)
{
    AscendC::InitSocState();
    KernelSimtContiguous<T, DataLenPerCore, TileLength, TileNumPerCore> kernel;
    kernel.Init(x, y, z);
    kernel.ProcessTiles();
    AscendC::PipeBarrier<PIPE_ALL>();
}

int32_t main(int32_t argc, char* argv[])
{
    using T = int32_t;
    constexpr uint32_t inputShapeH = 8192;
    constexpr uint32_t inputShapeW = 8192;
    constexpr uint32_t inputTotalLength = inputShapeH * inputShapeW;
    constexpr uint32_t blockDim = 64;
    constexpr uint32_t tileLength = 8192;
    constexpr uint32_t dataLenPerCore = inputTotalLength / blockDim;
    constexpr uint32_t tileNumPerCore = dataLenPerCore / tileLength;
    constexpr uint32_t ubKernelDynUBufSize = tileLength * sizeof(T) * TENSOR_NUM_PER_BUFFER * BUFFER_NUM;
    constexpr uint32_t numBlocks = blockDim;
    size_t inputByteSize = inputTotalLength * sizeof(T);
    size_t zByteSize = inputTotalLength * sizeof(T);

    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t* xHost = nullptr;
    uint8_t* yHost = nullptr;
    uint8_t* zHost = nullptr;
    uint8_t* xDevice = nullptr;
    uint8_t* yDevice = nullptr;
    uint8_t* zDevice = nullptr;

    aclrtMallocHost((void**)(&xHost), inputByteSize);
    aclrtMalloc((void**)&xDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/input_self.bin", inputByteSize, xHost, inputByteSize);
    aclrtMemcpy(xDevice, inputByteSize, xHost, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);

    aclrtMallocHost((void**)(&yHost), inputByteSize);
    aclrtMalloc((void**)&yDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/input_other.bin", inputByteSize, yHost, inputByteSize);
    aclrtMemcpy(yDevice, inputByteSize, yHost, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);

    aclrtMallocHost((void**)(&zHost), zByteSize);
    aclrtMalloc((void**)&zDevice, zByteSize, ACL_MEM_MALLOC_HUGE_FIRST);

    if constexpr (scenarioNum == 0) {
        floor_mod_gm_simt_custom<T, dataLenPerCore><<<numBlocks, 0, stream>>>(xDevice, yDevice, zDevice);
    } else if constexpr (scenarioNum == 1) {
        floor_mod_simd_custom<T, dataLenPerCore, tileLength, tileNumPerCore>
            <<<numBlocks, ubKernelDynUBufSize, stream>>>(xDevice, yDevice, zDevice);
    } else if constexpr (scenarioNum == 2) {
        floor_mod_simt_non_contiguous_custom<T, dataLenPerCore, tileLength, tileNumPerCore>
            <<<numBlocks, ubKernelDynUBufSize, stream>>>(xDevice, yDevice, zDevice);
    } else {
        floor_mod_simt_contiguous_custom<T, dataLenPerCore, tileLength, tileNumPerCore>
            <<<numBlocks, ubKernelDynUBufSize, stream>>>(xDevice, yDevice, zDevice);
    }
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(zHost, zByteSize, zDevice, zByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", zHost, zByteSize);

    aclrtFree(xDevice);
    aclrtFreeHost(xHost);
    aclrtFree(yDevice);
    aclrtFreeHost(yHost);
    aclrtFree(zDevice);
    aclrtFreeHost(zHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();

    return 0;
}
