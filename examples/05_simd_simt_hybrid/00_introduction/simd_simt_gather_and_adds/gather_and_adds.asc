/* !
 * \file gather_and_adds.asc
 * \brief 实现Gather和Adds融合计算，演示SIMT与SIMD编程模式的混合使用
 */

#include "acl/acl.h"
#include "kernel_operator.h"
#include "data_utils.h"
#include "simt_api/asc_simt.h"
#include "c_api/asc_simd.h"

namespace {
// Adds阶段对Gather结果执行的标量加数，对应计算公式中的“+ 1”。
constexpr float ADDS_ADDEND = 1.0f;
// 本样例每个Vector Core处理1024个index元素，因此SIMT VF函数启动1024个线程，每个线程处理1个元素。
constexpr uint32_t THREAD_COUNT = 1024;
} // namespace

/*
 * simt_gather使用SIMT编程模式完成离散访存。
 *
 * 每个SIMT线程根据threadIdx.x处理当前Vector Core负责的一个index元素：
 * 1. 通过blockIdx.x、blockDim.x和threadIdx.x计算全局index位置；
 * 2. 从GM中的index读取待访问的input下标；
 * 3. 从GM中的input读取对应元素，并写入UB中的local_output。
 *
 * __launch_bounds__(THREAD_COUNT)用于在编译期声明本SIMT VF函数的最大线程数。
 */
__simt_vf__ __launch_bounds__(THREAD_COUNT) inline void simt_gather(
    __gm__ float* input, __gm__ uint32_t* index, __ubuf__ float* local_output, uint32_t input_total_length,
    uint32_t index_total_length, uint32_t output_total_length)
{
    // 保护单核输出范围，避免线程数大于单核实际处理元素数时越界写UB。
    if (threadIdx.x >= output_total_length) {
        return;
    }
    // 根据当前核号和线程号计算全局index数组中的元素位置。
    uint32_t idx = blockIdx.x * blockDim.x + threadIdx.x;
    // 保护全局index访问范围，避免读取超过index输入长度的数据。
    if (idx >= index_total_length) {
        return;
    }
    // index中保存的是需要从input中读取的元素下标。
    uint32_t gather_idx = index[idx];
    // 保护input访问范围，避免非法index导致GM读越界。
    if (gather_idx >= input_total_length) {
        return;
    }
    // 将离散读取到的GM数据按线程号连续写入UB，供后续SIMD阶段连续处理。
    local_output[threadIdx.x] = input[gather_idx];
}

/*
 * simd_adds使用SIMD编程模式完成UB上连续数据的逐元素加法。
 *
 * input为SIMT阶段写入UB的Gather结果，output为加1后的UB输出。
 * one_repeat_size表示一个Vector寄存器位宽VL中包含的float元素个数，repeat_times表示完成count个元素所需的循环次数。
 */
__simd_vf__ inline void simd_adds(
    __ubuf__ float* output, __ubuf__ float* input, uint32_t count, uint32_t one_repeat_size, uint16_t repeat_times)
{
    // src_reg0、dst_reg0为矢量数据寄存器，类型为vector_float；mask_reg为掩码寄存器，类型为vector_bool。
    vector_float src_reg0;
    vector_float dst_reg0;
    vector_bool mask_reg;

    for (uint16_t i = 0; i < repeat_times; i++) {
        // 根据待处理元素总数生成mask。本样例单核数据量可被repeat整除，各轮均处理完整repeat。
        mask_reg = asc_update_mask_b32(count);
        // 从UB加载一段连续数据到源寄存器。
        asc_loadalign(src_reg0, input + i * one_repeat_size);
        // 对寄存器中的有效元素执行加ADDS_ADDEND操作。
        asc_add_scalar(dst_reg0, src_reg0, ADDS_ADDEND, mask_reg);
        // 将寄存器中的计算结果写回UB输出区域。
        asc_storealign(output + i * one_repeat_size, dst_reg0, mask_reg);
    }
}

/*
 * gather_and_adds_kernel为Vector Core上的入口核函数，完成Gather和Adds融合计算。
 *
 * 整体流程：
 * 1. 使用SIMT VF函数simt_gather从GM按index离散读取input数据，并将结果写入UB；
 * 2. 使用SIMD VF函数simd_adds在UB中对Gather结果执行加1计算；
 * 3. 使用搬运接口将最终结果从UB搬运回GM。
 */
__global__ __vector__ void gather_and_adds_kernel(
    __gm__ float* input, __gm__ uint32_t* index, __gm__ float* output, uint32_t input_total_length,
    uint32_t index_total_length)
{
    // 按启动核数均分index元素。本样例index_total_length为8192、核数为8，每个核处理1024个元素。
    uint32_t index_total_length_per_block = index_total_length / block_num;
    // 申请UB空间作为Gather结果和Adds结果的本地输出缓存。
    extern __ubuf__ float local_output[];
    // 启动SIMT VF函数。dim3(THREAD_COUNT)表示本次VF调用启动THREAD_COUNT个SIMT线程。
    asc_vf_call<simt_gather>(
        dim3(THREAD_COUNT), input, index, local_output, input_total_length, index_total_length,
        index_total_length_per_block);
    // asc_get_vf_len返回当前Vector寄存器位宽VL的大小，除以float字节数得到每轮处理的float元素个数。
    uint32_t one_repeat_size = asc_get_vf_len() / sizeof(float);
    // 向上取整计算循环次数，保证单核负责的全部元素都被处理。
    uint16_t repeat_times = (index_total_length_per_block + one_repeat_size - 1) / one_repeat_size;
    // 启动SIMD VF函数，对Gather结果执行加1操作。
    asc_vf_call<simd_adds>(local_output, local_output, index_total_length_per_block, one_repeat_size, repeat_times);
    // 同步Vector计算流水和MTE3搬出流水，确保Adds结果写入UB后再搬运到GM。
    asc_sync_notify(PIPE_V, PIPE_MTE3, EVENT_ID0);
    asc_sync_wait(PIPE_V, PIPE_MTE3, EVENT_ID0);
    // 将UB中的Adds结果按核号偏移搬运到GM输出，每个核写回自身负责的连续输出分片。
    asc_copy_ub2gm_align(
        output + index_total_length_per_block * block_idx, local_output, 1,
        index_total_length_per_block * sizeof(float), 0, 0, 0);
}

int32_t main(int32_t argc, char* argv[])
{
    // 输入input长度为100000，index和output长度均为8192。
    constexpr uint32_t input_total_length = 100000;
    constexpr uint32_t index_total_length = 8 * 1024;
    // 启动8个Vector Core，每个核处理1024个输出元素。
    constexpr uint32_t num_blocks = 8;

    size_t input_byte_size = input_total_length * sizeof(float);
    size_t index_byte_size = index_total_length * sizeof(uint32_t);
    size_t output_byte_size = index_total_length * sizeof(float);

    aclInit(nullptr);
    int32_t device_id = 0;
    aclrtSetDevice(device_id);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t* input_host = nullptr;
    float* input_device = nullptr;
    aclrtMallocHost((void**)(&input_host), input_byte_size);
    aclrtMalloc((void**)&input_device, input_byte_size, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/input_x.bin", input_byte_size, input_host, input_byte_size);
    aclrtMemcpy(input_device, input_byte_size, input_host, input_byte_size, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t* index_host = nullptr;
    uint32_t* index_device = nullptr;
    aclrtMallocHost((void**)(&index_host), index_byte_size);
    aclrtMalloc((void**)&index_device, index_byte_size, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/index.bin", index_byte_size, index_host, index_byte_size);
    aclrtMemcpy(index_device, index_byte_size, index_host, index_byte_size, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t* output_host = nullptr;
    float* output_device = nullptr;
    aclrtMallocHost((void**)(&output_host), output_byte_size);
    aclrtMalloc((void**)&output_device, output_byte_size, ACL_MEM_MALLOC_HUGE_FIRST);

    // kernel启动时第二个参数表示动态UB大小，供SIMT/SIMD混合编程场景使用。
    constexpr uint32_t dyn_ub_size = THREAD_COUNT * sizeof(float);
    gather_and_adds_kernel<<<num_blocks, dyn_ub_size, stream>>>(
        input_device, index_device, output_device, input_total_length, index_total_length);

    aclrtSynchronizeStream(stream);
    aclrtMemcpy(output_host, output_byte_size, output_device, output_byte_size, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", output_host, output_byte_size);

    aclrtFree(input_device);
    aclrtFree(index_device);
    aclrtFree(output_device);
    aclrtFreeHost(input_host);
    aclrtFreeHost(index_host);
    aclrtFreeHost(output_host);
    aclrtDestroyStream(stream);
    aclrtResetDevice(device_id);
    aclFinalize();

    return 0;
}
