#include <algorithm>
#include <cerrno>
#include <cstdlib>
#include <cstdint>
#include <iostream>
#include <iterator>
#include <limits>
#include <vector>
#include "acl/acl.h"
#include "tiling/platform/platform_ascendc.h"

namespace {
    constexpr uint32_t MAX_THREAD_COUNT = 2048;
    constexpr uint32_t MAX_BLOCK_COUNT = 65535;
    constexpr uint32_t DEFAULT_INPUT_LENGTH = 20;
    constexpr uint32_t DEFAULT_OUTPUT_LENGTH = 40;
    constexpr uint32_t THREAD_NUM_PER_BLOCK = 256;
    constexpr uint32_t GRID_DIM = 8;
}

template <typename type_data, typename type_idx>
__global__ __launch_bounds__(MAX_THREAD_COUNT) void scatter_custom(
    type_data* output,
    const type_data* input,
    const type_idx* index,
    uint32_t input_length,
    uint32_t output_length)
{
    uint32_t begin = blockIdx.x * blockDim.x + threadIdx.x;
    uint32_t stride = gridDim.x * blockDim.x;

    for (uint32_t i = begin; i < input_length; i += stride) {
        type_idx scatter_index = index[i];
        if (scatter_index >= 0 && static_cast<uint32_t>(scatter_index) < output_length) {
            output[static_cast<uint32_t>(scatter_index)] = input[i];
        }
    }
}

bool block_split(uint32_t input_length, uint32_t &numBlocks, uint32_t &thread_num_per_block)
{
    // const auto& platformInfoMgr = platform_ascendc::PlatformAscendCManager::GetInstance();
    // if (platformInfoMgr == nullptr) {
    //     std::cout << "[ERROR] Get platform info failed, please check device status." << std::endl;
    //     return false;
    // }

    // uint32_t real_core_num = platformInfoMgr->GetCoreNumAiv();
    // thread_num_per_block = std::min(input_length, MAX_THREAD_COUNT);
    // numBlocks = (input_length + thread_num_per_block - 1) / thread_num_per_block;
    // if (numBlocks > real_core_num) {
    //     numBlocks = real_core_num;
    //     thread_num_per_block = MAX_THREAD_COUNT;
    // }
    // if (numBlocks > MAX_BLOCK_COUNT) {
    //     std::cout << "[ERROR] input_length: " << input_length << " can not be bigger than "
    //               << MAX_THREAD_COUNT * MAX_BLOCK_COUNT << "." << std::endl;
    //     return false;
    // }
    numBlocks = GRID_DIM;
    thread_num_per_block = THREAD_NUM_PER_BLOCK;
    return true;
}

template <typename type_idx>
bool check_scatter_params(
    const std::vector<float>& input,
    const std::vector<type_idx>& index,
    uint32_t output_length)
{
    if (input.empty() || index.empty()) {
        std::cout << "[ERROR] Empty input tensors." << std::endl;
        return false;
    }
    if (input.size() != index.size()) {
        std::cout << "[ERROR] input and index must have the same length." << std::endl;
        return false;
    }
    if (output_length == 0) {
        std::cout << "[ERROR] output length must be greater than 0." << std::endl;
        return false;
    }
    for (type_idx value : index) {
        if (value < 0 || value >= static_cast<type_idx>(output_length)) {
            std::cout << "[ERROR] index value is out of range for output." << std::endl;
            return false;
        }
    }
    return true;
}

std::vector<float> scatter(
    std::vector<float>& input,
    std::vector<int32_t>& index,
    uint32_t output_length)
{
    if (!check_scatter_params(input, index, output_length)) {
        return {};
    }

    uint32_t input_length = input.size();
    std::vector<float> output(output_length, 0.0f);

    uint32_t numBlocks = 0;
    uint32_t thread_num_per_block = 0;
    if (!block_split(input_length, numBlocks, thread_num_per_block)) {
        return {};
    }
    std::cout << "[INFO] Block number is " << numBlocks << "." << std::endl;
    std::cout << "[INFO] Thread number in a block is " << thread_num_per_block << "." << std::endl;

    int32_t device_id = 0;
    aclrtStream stream = nullptr;

    uint8_t* input_host = reinterpret_cast<uint8_t *>(input.data());
    uint8_t* index_host = reinterpret_cast<uint8_t *>(index.data());
    uint8_t* output_init_host = reinterpret_cast<uint8_t *>(output.data());

    float* input_device = nullptr;
    float* output_device = nullptr;
    int32_t* index_device = nullptr;
    uint8_t* output_host = nullptr;

    size_t input_total_byte_size = input_length * sizeof(float);
    size_t index_total_byte_size = input_length * sizeof(int32_t);
    size_t output_total_byte_size = output_length * sizeof(float);

    aclInit(nullptr);
    aclrtSetDevice(device_id);
    aclrtCreateStream(&stream);

    aclrtMallocHost((void **)(&output_host), output_total_byte_size);
    aclrtMalloc((void **)&input_device, input_total_byte_size, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void **)&output_device, output_total_byte_size, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void **)&index_device, index_total_byte_size, ACL_MEM_MALLOC_HUGE_FIRST);

    aclrtMemcpy(input_device, input_total_byte_size, input_host, input_total_byte_size, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(output_device, output_total_byte_size, output_init_host, output_total_byte_size,
        ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(index_device, index_total_byte_size, index_host, index_total_byte_size, ACL_MEMCPY_HOST_TO_DEVICE);

    uint32_t dyn_ubuf_size = 0;
    scatter_custom<<<numBlocks, thread_num_per_block, dyn_ubuf_size, stream>>>(
        output_device, input_device, index_device, input_length, output_length);

    aclrtSynchronizeStream(stream);
    aclrtMemcpy(output_host, output_total_byte_size, output_device, output_total_byte_size, ACL_MEMCPY_DEVICE_TO_HOST);
    output.assign((float *)output_host, (float *)(output_host + output_total_byte_size));

    aclrtFree(input_device);
    aclrtFree(output_device);
    aclrtFree(index_device);
    aclrtFreeHost(output_host);

    aclrtDestroyStream(stream);
    aclrtResetDevice(device_id);
    aclFinalize();
    return output;
}

uint32_t verify_result(std::vector<float>& output, std::vector<float>& golden, std::vector<float>& input, std::vector<int32_t>& index)
{
    auto print_tensor_float = [](std::vector<float>& tensor, const char* name) {
        constexpr size_t max_print_size = 50;
        std::cout << name << ": ";
        std::copy(tensor.begin(), tensor.begin() + std::min(tensor.size(), max_print_size),
            std::ostream_iterator<float>(std::cout, " "));
        if (tensor.size() > max_print_size) {
            std::cout << "...";
        }
        std::cout << std::endl;
    };

    auto print_tensor_int = [](std::vector<int32_t>& tensor, const char* name) {
        constexpr size_t max_print_size = 50;
        std::cout << name << ": ";
        std::copy(tensor.begin(), tensor.begin() + std::min(tensor.size(), max_print_size),
            std::ostream_iterator<int32_t>(std::cout, " "));
        if (tensor.size() > max_print_size) {
            std::cout << "...";
        }
        std::cout << std::endl;
    };

    print_tensor_float(input, "Input");
    print_tensor_int(index, "Index");
    print_tensor_float(output, "Output");
    print_tensor_float(golden, "Golden");
    if (output.size() == golden.size() && std::equal(output.begin(), output.end(), golden.begin())) {
        std::cout << "[Success] Case accuracy is verification passed." << std::endl;
        return 0;
    }
    std::cout << "[Failed] Case accuracy is verification failed!" << std::endl;
    return 1;
}

std::vector<float> scatter_golden(
    const std::vector<float>& input,
    const std::vector<int32_t>& index,
    uint32_t output_length)
{
    std::vector<float> golden(output_length, 0.0f);
    for (uint32_t i = 0; i < input.size(); i++) {
        golden[static_cast<uint32_t>(index[i])] = input[i];
    }
    return golden;
}

struct ScatterCase {
    std::vector<float> input;
    std::vector<int32_t> index;
    uint32_t output_length;
};

bool parse_length_arg(const char* arg, const char* arg_name, uint32_t& value)
{
    if (arg == nullptr || arg[0] == '\0') {
        std::cout << "[ERROR] " << arg_name << " must be a positive integer." << std::endl;
        return false;
    }

    errno = 0;
    char* end = nullptr;
    unsigned long parsed_value = std::strtoul(arg, &end, 10);
    if (errno != 0 || end == arg || *end != '\0' || parsed_value == 0 ||
        parsed_value > std::numeric_limits<uint32_t>::max()) {
        std::cout << "[ERROR] " << arg_name << " must be a positive uint32 value." << std::endl;
        return false;
    }

    value = static_cast<uint32_t>(parsed_value);
    return true;
}

ScatterCase make_sparse_scatter_case(uint32_t input_length, uint32_t output_length)
{
    ScatterCase scatter_case;
    scatter_case.output_length = output_length;
    scatter_case.input.resize(input_length);
    scatter_case.index.resize(input_length);

    std::vector<uint8_t> used(output_length, 0);
    uint32_t step = std::max(1U, output_length / input_length);
    uint32_t offset = output_length > 1 ? 1 : 0;
    for (uint32_t i = 0; i < input_length; i++) {
        scatter_case.input[i] = static_cast<float>((i + 1) * 10);

        uint32_t sparse_index = (offset + i * step) % output_length;
        while (used[sparse_index] != 0) {
            sparse_index = (sparse_index + 1) % output_length;
        }
        used[sparse_index] = 1;
        scatter_case.index[i] = static_cast<int32_t>(sparse_index);
    }

    return scatter_case;
}

int32_t main(int32_t argc, char* argv[])
{
    uint32_t input_length = DEFAULT_INPUT_LENGTH;
    uint32_t output_length = DEFAULT_OUTPUT_LENGTH;
    // if (argc > 3) {
    //     std::cout << "Usage: " << argv[0] << " [input_length] [output_length]" << std::endl;
    //     return 1;
    // }
    // if (argc >= 2 && !parse_length_arg(argv[1], "input_length", input_length)) {
    //     return 1;
    // }
    // if (argc >= 3 && !parse_length_arg(argv[2], "output_length", output_length)) {
    //     return 1;
    // }
    // if (input_length > output_length) {
    //     std::cout << "[ERROR] input_length must be less than or equal to output_length "
    //               << "to keep this sample free of scatter write conflicts." << std::endl;
    //     return 1;
    // }

    ScatterCase scatter_case = make_sparse_scatter_case(input_length, output_length);
    std::cout << "[INFO] input_length=" << scatter_case.input.size()
              << ", output_length=" << scatter_case.output_length << std::endl;

    std::vector<float> golden = scatter_golden(scatter_case.input, scatter_case.index, scatter_case.output_length);
    std::vector<float> output = scatter(scatter_case.input, scatter_case.index, scatter_case.output_length);
    if (output.empty() || verify_result(output, golden, scatter_case.input, scatter_case.index) != 0) {
        return 1;
    }

    return 0;
}
