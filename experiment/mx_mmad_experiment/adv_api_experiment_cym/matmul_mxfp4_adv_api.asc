/* !
 * \file matmul_mxfp4_adv_api.asc
 * \brief 基于 Ascend C 高阶 API，实现低比特浮点数的 MxFP4 矩阵乘法
 */

#include "data_utils.h"
#include "kernel_tiling/kernel_tiling.h"
#include "tiling/platform/platform_ascendc.h"
#include "tiling/tiling_api.h"
#include "acl/acl.h"
#include "kernel_operator.h"
#define ASCENDC_CUBE_ONLY
#include "lib/matmul_intf.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

#ifndef SCENARIO_NUM
#define SCENARIO_NUM 1
#endif

constexpr uint32_t scenario = SCENARIO_NUM;
// MxMatmul 中 scale 沿 K 轴按 32 元素共享 1 个 scale。
// 样例使用 ceil(K / 64) * 2 的写法，等价于先算 ceil(K / 32)，再做 2 Byte 对齐。
constexpr uint32_t SCALE_CEIL_NUMBER = 64;
constexpr uint32_t SCALE_NUMBER = 2;

constexpr uint32_t AlignScaleK(uint32_t k)
{
    // scaleK 是 scale 矩阵在 K 方向上的逻辑长度，供 Host 侧文件大小和 Kernel 侧切片共同使用。
    return (k + SCALE_CEIL_NUMBER - 1) / SCALE_CEIL_NUMBER * SCALE_NUMBER;
}

template <
    uint32_t Mv, uint32_t Kv, uint32_t Nv, uint32_t UsedCoreNumV, uint32_t SingleMV,
    uint32_t SingleKV, uint32_t SingleNV, uint32_t BaseMV, uint32_t BaseKV, uint32_t BaseNV>
struct ScenarioStaticCfg {
    static constexpr uint32_t M = Mv;
    static constexpr uint32_t K = Kv;
    static constexpr uint32_t N = Nv;
    static constexpr uint32_t usedCoreNum = UsedCoreNumV;

    // 本样例固定转置场景
    static constexpr bool IS_TRANS_A = false;
    static constexpr bool IS_TRANS_B = true;

    // SINGLE_* 描述一个核要处理的数据块大小；BASE_* 描述 L0/L1 中更细粒度的基本计算块大小。
    // 这些参数共同决定常量化 tiling 结果。
    static constexpr uint32_t singleCoreM = SingleMV;
    static constexpr uint32_t singleCoreN = SingleNV;
    static constexpr uint32_t singleCoreK = SingleKV;
    static constexpr uint32_t baseM = BaseMV;
    static constexpr uint32_t baseN = BaseNV;
    static constexpr uint32_t baseK = BaseKV;

    static constexpr uint32_t SCALE_K = AlignScaleK(K);
    // 本样例固定多核切分仅沿 M/N 展开，因此总核数必须等于 M 方向块数 * N 方向块数。
    static constexpr uint32_t CORE_BLOCKS_M = (M + singleCoreM - 1) / singleCoreM;
    static constexpr uint32_t CORE_BLOCKS_N = (N + singleCoreN - 1) / singleCoreN;

    // SHAPE_PARAMS 直接提供给 GetMMConfig，用来生成 MatmulApiStaticTiling。
    static constexpr MatmulShapeParams SHAPE_PARAMS = {singleCoreM, singleCoreN, singleCoreK, baseM, baseN, baseK};

    static_assert(K == singleCoreK, "This samples only support the scenario where the K-axis is not cut.");
    static_assert(K % 2 == 0, "MxFP4 input requires K to be even.");
    static_assert(baseM <= singleCoreM, "baseM must not exceed singleCoreM.");
    static_assert(baseN <= singleCoreN, "baseN must not exceed singleCoreN.");
    static_assert(baseK <= singleCoreK, "baseK must not exceed singleCoreK.");
    static_assert(
        usedCoreNum == CORE_BLOCKS_M * CORE_BLOCKS_N, "usedCoreNum must match the compile-time M/N core split.");

    static_assert(usedCoreNum <= 28, "This samples support max usedCoreNum is 28!");
    static_assert(singleCoreM <= M, "singleCoreM must <= M");
    static_assert(singleCoreN <= N, "singleCoreN must <= N");
    static_assert(baseK % 64 == 0, "baseK must be a multiple of 64.");
    static_assert(baseM % 16 == 0, "baseM must be a multiple of 16.");
    static_assert(baseN % 16 == 0, "baseN must be a multiple of 16.");
    static_assert(static_cast<uint64_t>(baseM) * static_cast<uint64_t>(baseK) <= 131072,
        "baseM * baseK must be <= 131072 elements for fp4 input (L0A/L0B is 64K).");
    static_assert(static_cast<uint64_t>(baseM) * static_cast<uint64_t>(baseN) <= 131072,
        "baseM * baseN must be <= 131072 elements for bf16 output (L0C is 256KB).");
};

template <typename Config, typename AType, typename BType, typename CType>
__aicore__ inline constexpr MatmulApiStaticTiling GetMxConstantCFG()
{
    // shape/base 信息都来自编译期常量，编译过程中直接实例化出固定配置的 Matmul 对象，
    // kernel 启动时不再需要额外读取 GM 中的 tiling 数据。
    MatmulConfig mmCFG = GetMMConfig<MatmulConfigMode::CONFIG_MDL>(Config::SHAPE_PARAMS);
    auto constantCFG = AscendC::GetMatmulApiTiling<AType, BType, CType, CType>(mmCFG);
    return constantCFG;
}

template <typename Config, typename AType, typename BType, typename CType>
class MatmulMxfp4Kernel {
public:
    __aicore__ inline MatmulMxfp4Kernel(){};

    // MatmulTypeWithScale 表示输入不仅有 A/B 主矩阵，还有配套的 scaleA/scaleB。
    // 这里的转置参数会影响 Matmul 对 GM 中 A/B/scale 的解释方式。
    using aType = AscendC::MatmulTypeWithScale<
        AscendC::TPosition::GM, AscendC::TPosition::GM, CubeFormat::ND, AType, Config::IS_TRANS_A>;
    using bType = AscendC::MatmulTypeWithScale<
        AscendC::TPosition::GM, AscendC::TPosition::GM, CubeFormat::ND, BType, Config::IS_TRANS_B>;
    using cType = AscendC::MatmulType<AscendC::TPosition::GM, CubeFormat::ND, CType>;

    // 获取常量化tiling配置
    constexpr static auto CONSTANT_CFG = GetMxConstantCFG<Config, aType, bType, cType>();

    AscendC::Matmul<
        aType, bType, cType, cType, CONSTANT_CFG, AscendC::MatmulCallBackFunc<nullptr, nullptr, nullptr>,
        AscendC::Impl::Detail::MatmulWithScalePolicy>
        matmulObj;

    __aicore__ inline void Init(GM_ADDR a, GM_ADDR b, GM_ADDR as, GM_ADDR bs, GM_ADDR c)
    {
        // 先设置整个矩阵的起始地址，随后再根据 blockIdx 计算偏移地址，从而索引到当前核负责的计算块。
        aGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ AType*>(a), Config::M * Config::K);
        bGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ BType*>(b), Config::K * Config::N);
        cGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ CType*>(c), Config::M * Config::N);
        asGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ AscendC::fp8_e8m0_t*>(as), Config::M * Config::SCALE_K);
        bsGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ AscendC::fp8_e8m0_t*>(bs), Config::SCALE_K * Config::N);

        // 这几个 offset 都是“元素偏移”，不是字节偏移。
        // GlobalTensor 的 operator[] 会自动按元素类型完成地址偏移。
        int32_t offsetA = 0;
        int32_t offsetB = 0;
        int32_t offsetAscale = 0;
        int32_t offsetBscale = 0;
        int32_t offsetC = 0;
        CalcOffset(AscendC::GetBlockIdx(), offsetA, offsetB, offsetAscale, offsetBscale, offsetC);

        // 不同的核处理不同的数据块，根据offset地址去偏移。
        aGlobal = aGlobal[offsetA];
        bGlobal = bGlobal[offsetB];
        cGlobal = cGlobal[offsetC];
        asGlobal = asGlobal[offsetAscale];
        bsGlobal = bsGlobal[offsetBscale];
    }

    __aicore__ inline void Process(AscendC::TPipe* pipe)
    {
        // Matmul对象中使用了常量化Tiling模板，注册时，最后一个参数可以传 nullptr。
        REGIST_MATMUL_OBJ(pipe, GetSysWorkSpacePtr(), matmulObj, (TCubeTiling*)nullptr);
        // SetOrgShape 设置 Matmul 原始shape信息。
        matmulObj.SetOrgShape(Config::M, Config::N, Config::K);

        // 对齐分块后，最后一个 M/N 分块可能是尾块。
        const uint32_t tailM = GetTailSize(Config::M, mCoreIndex, Config::singleCoreM);
        const uint32_t tailN = GetTailSize(Config::N, nCoreIndex, Config::singleCoreN);
        constexpr uint32_t tailK = Config::K < Config::singleCoreK ? Config::K : Config::singleCoreK;
        if (tailM < Config::singleCoreM || tailN < Config::singleCoreN || tailK < Config::singleCoreK) {
            matmulObj.SetTail(tailM, tailN, tailK);
        }

        matmulObj.SetTensorA(aGlobal, Config::IS_TRANS_A);
        matmulObj.SetTensorB(bGlobal, Config::IS_TRANS_B);
        matmulObj.SetTensorScaleA(asGlobal, Config::IS_TRANS_A);
        matmulObj.SetTensorScaleB(bsGlobal, Config::IS_TRANS_B);

        // IterateAll 会在当前核负责的 M/N/K 范围内完成所有数据的计算。
        matmulObj.IterateAll(cGlobal);
        matmulObj.End();
    }

private:
    __aicore__ inline static uint32_t GetTailSize(uint32_t total, uint32_t coreIndex, uint32_t single)
    {
        // total 不是 single 的整数倍时，最后一个块只处理剩余部分。
        const uint32_t remain = total - coreIndex * single;
        return remain < single ? remain : single;
    }

    __aicore__ inline void CalcOffset(
        int32_t blockIdx, int32_t& offsetA, int32_t& offsetB, int32_t& offsetAscale, int32_t& offsetBscale,
        int32_t& offsetC)
    {
        // blockIdx 采用 M 优先展开：
        // mCoreIndex 在 [0, CORE_BLOCKS_M) 内变化，nCoreIndex 再跨步推进。
        mCoreIndex = blockIdx % Config::CORE_BLOCKS_M;
        nCoreIndex = blockIdx / Config::CORE_BLOCKS_M;

        if constexpr (Config::IS_TRANS_A) {
            // A 转置时，GM 按 [K, M] 理解，沿 M 切块只需平移列起点。
            offsetA = mCoreIndex * Config::singleCoreM;
            offsetAscale = mCoreIndex * Config::singleCoreM;
        } else {
            // A 非转置时，GM 按 [M, K] 连续存放，沿 M 切块需要跨过完整 K 行宽。
            offsetA = mCoreIndex * Config::K * Config::singleCoreM;
            offsetAscale = mCoreIndex * Config::SCALE_K * Config::singleCoreM;
        }

        if constexpr (Config::IS_TRANS_B) {
            // B 转置时，输入文件逻辑按 [N, K] 提供，每个 N 分块在 GM 中跨过一整块 K*N 宽度。
            offsetB = nCoreIndex * Config::K * Config::singleCoreN;
            offsetBscale = nCoreIndex * Config::SCALE_K * Config::singleCoreN;
        } else {
            // B 非转置时，GM 按 [K, N] 理解，沿 N 切块只需要移动列起点。
            offsetB = nCoreIndex * Config::singleCoreN;
            offsetBscale = nCoreIndex * Config::singleCoreN;
        }

        // C 始终按 [M, N] 输出，因此 offset 只由 M/N 两个维度的分块位置决定。
        offsetC = mCoreIndex * Config::N * Config::singleCoreM + nCoreIndex * Config::singleCoreN;
    }

    AscendC::GlobalTensor<AType> aGlobal;
    AscendC::GlobalTensor<BType> bGlobal;
    AscendC::GlobalTensor<CType> cGlobal;
    AscendC::GlobalTensor<AscendC::fp8_e8m0_t> asGlobal;
    AscendC::GlobalTensor<AscendC::fp8_e8m0_t> bsGlobal;
    uint32_t mCoreIndex{0};
    uint32_t nCoreIndex{0};
};

template <typename Config>
__global__ __cube__ void matmul_mxfp4_static(GM_ADDR a, GM_ADDR b, GM_ADDR as, GM_ADDR bs, GM_ADDR c)
{
    // kernel 入口不再接收 tilingGM，tiling 已常量化到模板实例里。
    AscendC::TPipe pipe;
    MatmulMxfp4Kernel<Config, fp4x2_e1m2_t, fp4x2_e1m2_t, bfloat16_t> matmulKernel;
    matmulKernel.Init(a, b, as, bs, c);
    matmulKernel.Process(&pipe);
}

template <typename Config>
int32_t RunScenario()
{
    std::cout << "Running scenario " << scenario << ": M=" << Config::M << ", K=" << Config::K << ", N=" << Config::N
              << ", usedCoreNum=" << Config::usedCoreNum << std::endl;
    std::cout << "Static tiling: singleCoreM=" << Config::singleCoreM << ", singleCoreN=" << Config::singleCoreN
              << ", singleCoreK=" << Config::singleCoreK << ", baseM=" << Config::baseM << ", baseN=" << Config::baseN
              << ", baseK=" << Config::baseK << std::endl;

    // fp4x2 每字节包含 2 个元素，因此 A/B 的文件大小需要除以 2。
    size_t aFileSize = static_cast<size_t>(Config::M * Config::K) * sizeof(uint8_t) / 2;
    size_t bFileSize = static_cast<size_t>(Config::K * Config::N) * sizeof(uint8_t) / 2;

    size_t asFileSize = static_cast<size_t>(Config::M * Config::SCALE_K) * sizeof(uint8_t);
    size_t bsFileSize = static_cast<size_t>(Config::SCALE_K * Config::N) * sizeof(uint8_t);
    size_t cFileSize = static_cast<size_t>(Config::M * Config::N) * sizeof(uint16_t);

    int32_t deviceId = 0;
    aclrtStream stream = nullptr;
    aclrtContext context = nullptr;

    aclInit(nullptr);
    aclrtSetDevice(deviceId);
    aclrtCreateContext(&context, deviceId);
    aclrtCreateStream(&stream);

    uint8_t* aHost = nullptr;
    uint8_t* aDevice = nullptr;
    aclrtMallocHost((void**)(&aHost), aFileSize);
    aclrtMalloc((void**)&aDevice, aFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/x1_gm.bin", aFileSize, aHost, aFileSize);
    aclrtMemcpy(aDevice, aFileSize, aHost, aFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t* bHost = nullptr;
    uint8_t* bDevice = nullptr;
    aclrtMallocHost((void**)(&bHost), bFileSize);
    aclrtMalloc((void**)&bDevice, bFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/x2_gm.bin", bFileSize, bHost, bFileSize);
    aclrtMemcpy(bDevice, bFileSize, bHost, bFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t* asHost = nullptr;
    uint8_t* asDevice = nullptr;
    aclrtMallocHost((void**)(&asHost), asFileSize);
    aclrtMalloc((void**)&asDevice, asFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/x1_scale_gm.bin", asFileSize, asHost, asFileSize);
    aclrtMemcpy(asDevice, asFileSize, asHost, asFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t* bsHost = nullptr;
    uint8_t* bsDevice = nullptr;
    aclrtMallocHost((void**)(&bsHost), bsFileSize);
    aclrtMalloc((void**)&bsDevice, bsFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/x2_scale_gm.bin", bsFileSize, bsHost, bsFileSize);
    aclrtMemcpy(bsDevice, bsFileSize, bsHost, bsFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t* cHost = nullptr;
    uint8_t* cDevice = nullptr;
    aclrtMallocHost((void**)(&cHost), cFileSize);
    aclrtMalloc((void**)&cDevice, cFileSize, ACL_MEM_MALLOC_HUGE_FIRST);

    matmul_mxfp4_static<Config>
        <<<Config::usedCoreNum, nullptr, stream>>>(aDevice, bDevice, asDevice, bsDevice, cDevice);
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(cHost, cFileSize, cDevice, cFileSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", cHost, cFileSize);

    aclrtFree(aDevice);
    aclrtFreeHost(aHost);
    aclrtFree(bDevice);
    aclrtFreeHost(bHost);
    aclrtFree(asDevice);
    aclrtFreeHost(asHost);
    aclrtFree(bsDevice);
    aclrtFreeHost(bsHost);
    aclrtFree(cDevice);
    aclrtFreeHost(cHost);

    aclrtDestroyStream(stream);
    aclrtDestroyContext(context);
    aclrtResetDevice(deviceId);
    aclFinalize();
    return 0;
}

template <uint32_t ScenarioId>
struct ScenarioCfg;

// 命名规则: SCENARIO_MULTI_CORE_#UsedCoreNum_#SingleCoreM_#SingleCoreK_#SingleCoreN_#baseM_#baseK_#baseN
constexpr uint32_t SCENARIO_MULTI_CORE_16_1792_7168_1792_128_128_128 = 1;
constexpr uint32_t SCENARIO_MULTI_CORE_16_1792_7168_1792_256_256_256 = 2;


// Cfg定义顺序 : M, K, N, UsedCoreNum, IsTransA, IsTransB, SingleCoreM, SingleCoreK, SingleCoreN, BaseM, BaseK, BaseN

// 场景1：M=K=N=7168  16核切分为 4 x 4，每核处理 1792 x 7168 x 1792
// baseM/K/N 取 128 用作常量化 tiling 的基础 tile 块
template <>
struct ScenarioCfg<SCENARIO_MULTI_CORE_16_1792_7168_1792_128_128_128>
    : ScenarioStaticCfg<7168, 7168, 7168, 16, 1792, 7168, 1792, 128, 128, 128> {};

// 场景2：M=K=N=7168 16 核切分为 4 x 4，每核处理 1792 x 7168 x 1792
// baseM/K/N 取 256，用作常量化 tiling 的基础 tile 块
template <>
struct ScenarioCfg<SCENARIO_MULTI_CORE_16_1792_7168_1792_256_256_256>
    : ScenarioStaticCfg<7168, 7168, 7168, 16, 1792, 7168, 1792, 256, 256, 256> {};

// Todo : 请新增场景3所需ScenarioCfg配置
// 功能要求： 使能28核切分，输出结果精度比对通过
// 性能要求： Cube计算单元的时间占比aic_mac_ratio达到80%以上 并且Cube计算单元的执行时间aic_mac_time达到理论计算性能的95%以上
template <>
struct ScenarioCfg<3>
    : ScenarioStaticCfg<7168, 7168, 7168, 28, 1024, 7168, 1792, 256, 256, 256> {};

int32_t main(int32_t argc, char* argv[])
{
    (void)argc;
    (void)argv;

    if constexpr (scenario == SCENARIO_MULTI_CORE_16_1792_7168_1792_128_128_128) {
        return RunScenario<ScenarioCfg<SCENARIO_MULTI_CORE_16_1792_7168_1792_128_128_128>>();
    } else if constexpr (scenario == SCENARIO_MULTI_CORE_16_1792_7168_1792_256_256_256) {
        return RunScenario<ScenarioCfg<SCENARIO_MULTI_CORE_16_1792_7168_1792_256_256_256>>();
    } else if constexpr (scenario == 3){
        return RunScenario<ScenarioCfg<3>>();
    } else {
        std::cout << "Invalid SCENARIO_NUM: " << scenario << std::endl;
        return -1;
    }
}
