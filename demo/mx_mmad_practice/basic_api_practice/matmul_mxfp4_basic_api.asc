/* !
 * \file matmul_mxfp4_basic_api.asc
 * \brief 基于 Ascend C 基础 API 和静态 Tensor 编程方式，实现低比特浮点数的 MxFP4 矩阵乘法。
 *
 * 本样例展示Cube计算中的关键过程：
 * - GM 到 L1 的大包搬运
 * - L1 与 L0 的双缓冲流水
 * - fp4 数据与 scale 张量的配对搬运/装载
 * - 尾块场景下的 Mmad 与 Fixpipe 输出
 */

#include "acl/acl.h"
#include "kernel_operator.h"
#include "data_utils.h"
#include <iostream>

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

#ifndef SCENARIO_NUM
#define SCENARIO_NUM 1
#endif

constexpr uint32_t scenario = SCENARIO_NUM;
constexpr uint32_t CUBE_BLOCK = 16;
constexpr uint32_t L0_PINGPONG_BYTES = 32 * 1024;
constexpr uint32_t L1_PINGPONG_BYTES = 256 * 1024;
constexpr bool IS_B_TRANSPOSE = true;
constexpr bool IS_BS_TRANSPOSE = true;
constexpr uint32_t SCALE_CEIL_NUMBER = 32;
constexpr uint32_t SCALE_ALIGN_NUMBER = 2;

template <
    typename AType, typename BType, typename CType, uint32_t M, uint32_t K, uint32_t N, uint32_t baseM, uint32_t baseK,
    uint32_t baseN, uint32_t singleCoreM, uint32_t singleCoreK, uint32_t singleCoreN, uint32_t stepKa, uint32_t stepKb,
    uint32_t scaleFactorKa, uint32_t scaleFactorKb>
class KernelMmadmx {
    // 编译期常量：统一封装 packed K 与 scale K，避免后续地址/步长计算重复写公式。
    static constexpr uint32_t PACKED_K = AscendC::DivCeil(K, 2);
    static constexpr uint32_t SCALE_K = AscendC::AlignUp(AscendC::DivCeil(K, SCALE_CEIL_NUMBER), SCALE_ALIGN_NUMBER);
    using ScaleAType = fp8_e8m0_t;
    using ScaleBType = fp8_e8m0_t;
    using ScalePackType = half;
    using AccType = float;

public:
    __aicore__ inline KernelMmadmx() {}
    __aicore__ inline void Init(GM_ADDR a, GM_ADDR b, GM_ADDR as, GM_ADDR bs, GM_ADDR c)
    {
        aGMOri.SetGlobalBuffer((__gm__ AType*)a);
        bGMOri.SetGlobalBuffer((__gm__ BType*)b);
        asGMOri.SetGlobalBuffer((__gm__ ScaleAType*)as);
        bsGMOri.SetGlobalBuffer((__gm__ ScaleBType*)bs);
        cGMOri.SetGlobalBuffer((__gm__ CType*)c);
    }

    __aicore__ inline void Process()
    {
        InitComputeParams();

        // ============================================================
        // 1. Buffer 分配：L1 / L0 双缓冲 Ping-Pong 布局
        // ============================================================
        // L1:
        //   A1 + AS1 Ping/Pong 占用 [0, 256KB)
        //   B1 + BS1 Ping/Pong 占用 [256KB, 512KB)
        // L0:
        //   A2/B2 使用 32KB Ping-Pong
        // CO1:
        //   保存 Mmad 的 float 累积结果
        // A/B 为 fp4x2 打包数据，scaleA/scaleB 为按 K/32 压缩后的 fp8 scale 数据。
        constexpr uint32_t a1BufSize = baseM * AscendC::DivCeil(baseK * stepKa, 2);
        constexpr uint32_t b1BufSize = baseN * AscendC::DivCeil(baseK * stepKb, 2);
        constexpr uint32_t as1BufSize = baseM * AscendC::DivCeil(baseK * stepKa, SCALE_CEIL_NUMBER) * scaleFactorKa;
        constexpr uint32_t bs1BufSize = baseN * AscendC::DivCeil(baseK * stepKb, SCALE_CEIL_NUMBER) * scaleFactorKb;
        static_assert(2 * a1BufSize + 2 * as1BufSize <= L1_PINGPONG_BYTES, "A/As ping-pong L1 footprint exceeds 256KB");
        static_assert(2 * b1BufSize + 2 * bs1BufSize <= L1_PINGPONG_BYTES, "B/Bs ping-pong L1 footprint exceeds 256KB");
        uint32_t a2PingpongSize = baseM * baseK;
        uint32_t b2PingpongSize = baseK * baseN;

        // A1: L1 Ping/Pong
        AscendC::LocalTensor<AType> a1LocalPing(AscendC::TPosition::A1, 0, a1BufSize);
        AscendC::LocalTensor<AType> a1LocalPong(AscendC::TPosition::A1, a1BufSize, a1BufSize);
        AscendC::LocalTensor<ScaleAType> as1LocalPing(AscendC::TPosition::A1, 2 * a1BufSize, as1BufSize);
        AscendC::LocalTensor<ScaleAType> as1LocalPong(AscendC::TPosition::A1, 2 * a1BufSize + as1BufSize, as1BufSize);

        // B1: L1 Ping/Pong
        AscendC::LocalTensor<BType> b1LocalPing(AscendC::TPosition::B1, L1_PINGPONG_BYTES, b1BufSize);
        AscendC::LocalTensor<BType> b1LocalPong(AscendC::TPosition::B1, L1_PINGPONG_BYTES + b1BufSize, b1BufSize);
        AscendC::LocalTensor<ScaleBType> bs1LocalPing(
            AscendC::TPosition::B1, L1_PINGPONG_BYTES + 2 * b1BufSize, bs1BufSize);
        AscendC::LocalTensor<ScaleBType> bs1LocalPong(
            AscendC::TPosition::B1, L1_PINGPONG_BYTES + 2 * b1BufSize + bs1BufSize, bs1BufSize);

        // A2/B2: L0 Ping/Pong
        AscendC::LocalTensor<AType> a2LocalPing(AscendC::TPosition::A2, 0, a2PingpongSize);
        AscendC::LocalTensor<AType> a2LocalPong(AscendC::TPosition::A2, L0_PINGPONG_BYTES, a2PingpongSize);
        AscendC::LocalTensor<BType> b2LocalPing(AscendC::TPosition::B2, 0, b2PingpongSize);
        AscendC::LocalTensor<BType> b2LocalPong(AscendC::TPosition::B2, L0_PINGPONG_BYTES, b2PingpongSize);

        // CO1: L0C
        AscendC::LocalTensor<AccType> cLocal(AscendC::TPosition::CO1, 0, baseM * baseN);

        ProcessLoop(
            a1LocalPing, a1LocalPong, as1LocalPing, as1LocalPong, a2LocalPing, a2LocalPong, b1LocalPing, b1LocalPong,
            bs1LocalPing, bs1LocalPong, b2LocalPing, b2LocalPong, cLocal);
    }

private:
    __aicore__ inline int32_t GetDataEventId(uint32_t pingPongIdx) const
    {
        return (pingPongIdx == 0) ? EVENT_ID0 : EVENT_ID1;
    }

    __aicore__ inline int32_t GetScaleEventId(uint32_t pingPongIdx) const
    {
        return (pingPongIdx == 0) ? EVENT_ID2 : EVENT_ID3;
    }

    __aicore__ inline int32_t GetL0EventId(uint32_t pingPongIdx) const
    {
        return (pingPongIdx == 0) ? EVENT_ID0 : EVENT_ID1;
    }

    __aicore__ inline void ProcessLoop(
        AscendC::LocalTensor<AType>& a1LocalPing, AscendC::LocalTensor<AType>& a1LocalPong,
        AscendC::LocalTensor<ScaleAType>& as1LocalPing, AscendC::LocalTensor<ScaleAType>& as1LocalPong,
        AscendC::LocalTensor<AType>& a2LocalPing, AscendC::LocalTensor<AType>& a2LocalPong,
        AscendC::LocalTensor<BType>& b1LocalPing, AscendC::LocalTensor<BType>& b1LocalPong,
        AscendC::LocalTensor<ScaleBType>& bs1LocalPing, AscendC::LocalTensor<ScaleBType>& bs1LocalPong,
        AscendC::LocalTensor<BType>& b2LocalPing, AscendC::LocalTensor<BType>& b2LocalPong,
        AscendC::LocalTensor<AccType>& cLocal)
    {
        // ============================================================
        // 1. DataCopyIn 进度跟踪变量
        // ============================================================
        constexpr uint32_t asChunkStep = stepKa * scaleFactorKa;
        constexpr uint32_t bsChunkStep = stepKb * scaleFactorKb;
        static_assert(stepKa == stepKb, "stepKa and stepKb must match when A/B share data events");
        static_assert(asChunkStep == bsChunkStep, "As/Bs scale chunk steps must match when scale events are shared");
        constexpr uint32_t dataChunkStep = stepKa;
        constexpr uint32_t scaleChunkStep = asChunkStep;
        uint32_t dataNextKChunkIdx = 0;  // A/B 下一次 DataCopyIn 要搬运的 K 方向大包索引
        uint32_t scaleNextKChunkIdx = 0; // As/Bs 下一次 DataCopyIn 要搬运的 K 方向大包索引
        uint8_t dataCopyInIdx = 0;       // A/B 下一次写入的 L1 buffer 索引：0=Ping, 1=Pong
        uint8_t scaleCopyInIdx = 0;      // As/Bs 下一次写入的 L1 buffer 索引：0=Ping, 1=Pong

        // ============================================================
        // 2. 同步标志初始化
        // ============================================================
        // 反向同步需要先置位，否则首轮 WaitFlag 会阻塞。
        // MTE1_MTE2:
        //   EVENT_ID0/1 对应 A/B Ping/Pong
        //   EVENT_ID2/3 对应 As/Bs Ping/Pong
        AscendC::SetFlag<AscendC::HardEvent::MTE1_MTE2>(EVENT_ID0);
        AscendC::SetFlag<AscendC::HardEvent::MTE1_MTE2>(EVENT_ID1);
        AscendC::SetFlag<AscendC::HardEvent::MTE1_MTE2>(EVENT_ID2);
        AscendC::SetFlag<AscendC::HardEvent::MTE1_MTE2>(EVENT_ID3);
        // M_MTE1:
        //   EVENT_ID0/1 对应 A2/B2 Ping/Pong
        AscendC::SetFlag<AscendC::HardEvent::M_MTE1>(EVENT_ID0);
        AscendC::SetFlag<AscendC::HardEvent::M_MTE1>(EVENT_ID1);

        // ============================================================
        // 3. N/M 外层循环 + K 主循环
        // ============================================================
        for (uint32_t nBlockIdx = 0; nBlockIdx < nLoopCount; nBlockIdx++) {
            for (uint32_t mBlockIdx = 0; mBlockIdx < mLoopCount; mBlockIdx++) {
                // 每个 (mBlockIdx, nBlockIdx) 子块重新初始化 DataCopyIn 进度。
                dataNextKChunkIdx = 0;
                scaleNextKChunkIdx = 0;
                dataCopyInIdx = 0;
                scaleCopyInIdx = 0;

                int32_t dataWriteEvent = GetDataEventId(dataCopyInIdx);
                // ---- 搬入 A/B 的首个大包 ----
                AscendC::WaitFlag<AscendC::HardEvent::MTE1_MTE2>(dataWriteEvent);
                DataCopyInA(a1LocalPing, dataNextKChunkIdx, mBlockIdx);
                DataCopyInB(b1LocalPing, dataNextKChunkIdx, nBlockIdx);
                AscendC::SetFlag<AscendC::HardEvent::MTE2_MTE1>(dataWriteEvent);
                dataNextKChunkIdx += dataChunkStep;
                dataCopyInIdx ^= 1;

                int32_t scaleWriteEvent = GetScaleEventId(scaleCopyInIdx);
                // ---- 搬入 As/Bs 的首个大包 ----
                AscendC::WaitFlag<AscendC::HardEvent::MTE1_MTE2>(scaleWriteEvent);
                DataCopyInAScale(as1LocalPing, scaleNextKChunkIdx, mBlockIdx);
                DataCopyInBScale(bs1LocalPing, scaleNextKChunkIdx, nBlockIdx);
                AscendC::SetFlag<AscendC::HardEvent::MTE2_MTE1>(scaleWriteEvent);
                scaleNextKChunkIdx += scaleChunkStep;
                scaleCopyInIdx ^= 1;

                for (uint32_t kBlockIdx = 0; kBlockIdx < kLoopCount; kBlockIdx++) {
                    // 依据当前 kBlockIdx 定位本次消费的 L1 Ping/Pong 以及大包内偏移。
                    uint32_t dataReadIdx = (kBlockIdx / dataChunkStep) % 2;
                    uint32_t scaleReadIdx = (kBlockIdx / scaleChunkStep) % 2;
                    uint32_t kOffsetInDataChunk = kBlockIdx % dataChunkStep;
                    uint32_t kOffsetInScaleChunk = kBlockIdx % scaleChunkStep;

                    AscendC::LocalTensor<AType> a1ReadBuf = (dataReadIdx == 0) ? a1LocalPing : a1LocalPong;
                    AscendC::LocalTensor<BType> b1ReadBuf = (dataReadIdx == 0) ? b1LocalPing : b1LocalPong;
                    AscendC::LocalTensor<ScaleAType> as1ReadBuf = (scaleReadIdx == 0) ? as1LocalPing : as1LocalPong;
                    AscendC::LocalTensor<ScaleBType> bs1ReadBuf = (scaleReadIdx == 0) ? bs1LocalPing : bs1LocalPong;
                    AscendC::LocalTensor<AType> a2Local = (mte1DBFlag == 0) ? a2LocalPing : a2LocalPong;
                    AscendC::LocalTensor<BType> b2Local = (mte1DBFlag == 0) ? b2LocalPing : b2LocalPong;

                    // ---- 反向同步：等待上一轮 Compute 释放对应 L0 缓冲区 ----
                    AscendC::WaitFlag<AscendC::HardEvent::M_MTE1>(GetL0EventId(mte1DBFlag));

                    // ---- 正向同步：仅在大包首个 baseK 分块处等待 L1 数据就绪 ----
                    if (kOffsetInDataChunk == 0) {
                        AscendC::WaitFlag<AscendC::HardEvent::MTE2_MTE1>(GetDataEventId(dataReadIdx));
                    }
                    if (kOffsetInScaleChunk == 0) {
                        AscendC::WaitFlag<AscendC::HardEvent::MTE2_MTE1>(GetScaleEventId(scaleReadIdx));
                    }

                    // ---- DataLoad: L1 -> L0 ----
                    DataLoadA(a1ReadBuf, as1ReadBuf, a2Local, mBlockIdx, kOffsetInDataChunk, kOffsetInScaleChunk);
                    DataLoadB(b1ReadBuf, bs1ReadBuf, b2Local, nBlockIdx, kOffsetInDataChunk, kOffsetInScaleChunk);

                    // ---- 反向同步：当前 L1 大包全部消费完后，通知 DataCopyIn 可覆盖 ----
                    if (((kOffsetInDataChunk + 1) == dataChunkStep) || (kBlockIdx + 1 == kLoopCount)) {
                        AscendC::SetFlag<AscendC::HardEvent::MTE1_MTE2>(GetDataEventId(dataReadIdx));
                    }
                    if (((kOffsetInScaleChunk + 1) == scaleChunkStep) || (kBlockIdx + 1 == kLoopCount)) {
                        AscendC::SetFlag<AscendC::HardEvent::MTE1_MTE2>(GetScaleEventId(scaleReadIdx));
                    }

                    // ---- Compute: Mmad 矩阵乘累加 ----
                    Compute(cLocal, a2Local, b2Local, kBlockIdx, mBlockIdx, nBlockIdx);

                    // ---- 预取下一个 L1 大包，与当前 Compute 重叠 ----
                    // 触发条件：
                    //   1) 首个 kBlock 已经启动，另一半 Ping/Pong 仍空闲
                    //   2) 当前大包最后一个 baseK 被消费完，对应缓冲区可覆盖
                    if (((kBlockIdx == 0) || ((kOffsetInDataChunk + 1) == dataChunkStep)) &&
                        dataNextKChunkIdx < kLoopCount) {
                        AscendC::LocalTensor<AType> a1WriteBuf = (dataCopyInIdx == 0) ? a1LocalPing : a1LocalPong;
                        AscendC::LocalTensor<BType> b1WriteBuf = (dataCopyInIdx == 0) ? b1LocalPing : b1LocalPong;
                        int32_t nextDataWriteEvent = GetDataEventId(dataCopyInIdx);
                        AscendC::WaitFlag<AscendC::HardEvent::MTE1_MTE2>(nextDataWriteEvent);
                        DataCopyInA(a1WriteBuf, dataNextKChunkIdx, mBlockIdx);
                        DataCopyInB(b1WriteBuf, dataNextKChunkIdx, nBlockIdx);
                        AscendC::SetFlag<AscendC::HardEvent::MTE2_MTE1>(nextDataWriteEvent);
                        dataNextKChunkIdx += dataChunkStep;
                        dataCopyInIdx ^= 1;
                    }
                    if (((kBlockIdx == 0) || ((kOffsetInScaleChunk + 1) == scaleChunkStep)) &&
                        scaleNextKChunkIdx < kLoopCount) {
                        AscendC::LocalTensor<ScaleAType> as1WriteBuf =
                            (scaleCopyInIdx == 0) ? as1LocalPing : as1LocalPong;
                        AscendC::LocalTensor<ScaleBType> bs1WriteBuf =
                            (scaleCopyInIdx == 0) ? bs1LocalPing : bs1LocalPong;
                        int32_t nextScaleWriteEvent = GetScaleEventId(scaleCopyInIdx);
                        AscendC::WaitFlag<AscendC::HardEvent::MTE1_MTE2>(nextScaleWriteEvent);
                        DataCopyInAScale(as1WriteBuf, scaleNextKChunkIdx, mBlockIdx);
                        DataCopyInBScale(bs1WriteBuf, scaleNextKChunkIdx, nBlockIdx);
                        AscendC::SetFlag<AscendC::HardEvent::MTE2_MTE1>(nextScaleWriteEvent);
                        scaleNextKChunkIdx += scaleChunkStep;
                        scaleCopyInIdx ^= 1;
                    }
                }

                // ---- CopyOut: CO1 -> GM ----
                CopyOut(cLocal, mBlockIdx, nBlockIdx);
            }
        }

        // ============================================================
        // 4. 等待所有同步完成
        // ============================================================
        AscendC::WaitFlag<AscendC::HardEvent::M_MTE1>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::M_MTE1>(EVENT_ID1);
        AscendC::WaitFlag<AscendC::HardEvent::MTE1_MTE2>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE1_MTE2>(EVENT_ID1);
        AscendC::WaitFlag<AscendC::HardEvent::MTE1_MTE2>(EVENT_ID2);
        AscendC::WaitFlag<AscendC::HardEvent::MTE1_MTE2>(EVENT_ID3);
    }

    __aicore__ inline void InitComputeParams()
    {
        // ---- 1. 计算当前核在 M/N 方向的迭代索引，确定 GM 起始偏移 ----
        constexpr uint32_t mIter = AscendC::DivCeil(M, singleCoreM);
        uint32_t mIterIdx = AscendC::GetBlockIdx() % mIter;
        uint32_t nIterIdx = AscendC::GetBlockIdx() / mIter;

        uint64_t gmOffsetA = mIterIdx * singleCoreM * K;
        uint64_t gmOffsetB = IS_B_TRANSPOSE ? nIterIdx * K * singleCoreN : nIterIdx * singleCoreN;
        uint64_t gmOffsetC = mIterIdx * singleCoreM * N + nIterIdx * singleCoreN;
        uint64_t gmOffsetAs = mIterIdx * singleCoreM * SCALE_K;
        uint64_t gmOffsetBs = IS_BS_TRANSPOSE ? nIterIdx * SCALE_K * singleCoreN : nIterIdx * singleCoreN;
        aGM = aGMOri[gmOffsetA];
        bGM = bGMOri[gmOffsetB];
        asGM = asGMOri[gmOffsetAs];
        bsGM = bsGMOri[gmOffsetBs];
        cGM = cGMOri[gmOffsetC];

        // ---- 2. 计算当前核实际负责的 M/N 尺寸，最后一块可能小于 singleCore ----
        actualSingleCoreM = M - mIterIdx * singleCoreM;
        actualSingleCoreM = actualSingleCoreM < singleCoreM ? actualSingleCoreM : singleCoreM;
        actualSingleCoreN = N - nIterIdx * singleCoreN;
        actualSingleCoreN = actualSingleCoreN < singleCoreN ? actualSingleCoreN : singleCoreN;

        // ---- 3. 计算 K/M/N 三个维度的循环次数 ----
        kLoopCount = AscendC::DivCeil(singleCoreK, baseK);
        mLoopCount = AscendC::DivCeil(actualSingleCoreM, baseM);
        nLoopCount = AscendC::DivCeil(actualSingleCoreN, baseN);

        // ---- 4. 计算 N 方向分块参数：完整 baseN 块数、尾块大小及对齐结果 ----
        baseNCount = actualSingleCoreN / baseN;
        tailN = actualSingleCoreN % baseN;
        tailNAlign = AscendC::DivCeil(tailN, CUBE_BLOCK) * CUBE_BLOCK;

        // ---- 5. 计算 M 方向分块参数：完整 baseM 块数、尾块大小及对齐结果 ----
        baseMCount = actualSingleCoreM / baseM;
        tailM = actualSingleCoreM % baseM;
        tailMAlign = AscendC::DivCeil(tailM, CUBE_BLOCK) * CUBE_BLOCK;
    }

    // GM -> A1: 将 A 的一个 K 方向大包搬入 L1。
    // kChunkIdx 表示第几个大包，mBlockIdx 表示当前 M 方向分块。
    __aicore__ inline void DataCopyInA(AscendC::LocalTensor<AType> a1Local, uint32_t kChunkIdx, uint32_t mBlockIdx)
    {
        // NOTE:
        // A/A1 的元素类型是 fp4x2，即 1 个元素打包 2 个 fp4。
        // 因此 DataCopy 的宽度、步长和偏移都按 packedK = ceil(K / 2) 计算，
        // 不能直接按逻辑 fp4 元素个数 K 计算。
        uint32_t curM = (mBlockIdx != baseMCount) ? baseM : tailM;
        constexpr uint32_t packedStepK = AscendC::DivCeil(baseK * stepKa, 2);
        AscendC::Nd2NzParams nd2nzA1Params;
        nd2nzA1Params.ndNum = 1;
        nd2nzA1Params.nValue = curM;
        nd2nzA1Params.dValue = packedStepK;
        nd2nzA1Params.srcNdMatrixStride = 0; // 源操作数相邻 ND 矩阵间的地址偏移
        nd2nzA1Params.srcDValue = PACKED_K;  // 源操作数同一 ND 矩阵内相邻行起始地址偏移
        nd2nzA1Params.dstNzC0Stride = baseM; // 转成 NZ 后，同一行分段后的地址间隔
        nd2nzA1Params.dstNzNStride = 1;      // 相邻行在目标 NZ 中的偏移
        nd2nzA1Params.dstNzMatrixStride = 0;
        AscendC::DataCopy(a1Local, aGM[kChunkIdx * baseK + mBlockIdx * K * baseM], nd2nzA1Params);
    }

    // GM -> AS1: 将 A 的 scale 大包搬入 L1。
    __aicore__ inline void DataCopyInAScale(
        AscendC::LocalTensor<ScaleAType> as1Local, uint32_t kChunkIdx, uint32_t mBlockIdx)
    {
        uint32_t curM = (mBlockIdx != baseMCount) ? baseM : tailM;
        constexpr uint32_t stepScaleK = AscendC::DivCeil(baseK * stepKa * scaleFactorKa, SCALE_CEIL_NUMBER);
        static_assert(stepScaleK % 2 == 0, "stepScaleK需2B对齐以使用Dn2Nz.b16");
        static_assert(baseK % 64 == 0, "baseK需64对齐以计算b16 scale搬运偏移");
        uint32_t scaleOffset = (kChunkIdx * baseK) / SCALE_CEIL_NUMBER;
        // scale 为 fp8(1B)，但 MX 路径要求按 2B 连续搬运。
        // 因此这里把 2 个 fp8 视作 1 个 b16，使用 Dn2Nz 完成 scale 搬运和布局变换。
        AscendC::Dn2NzParams dn2nzParams;
        dn2nzParams.dnNum = 1;
        dn2nzParams.dValue = curM;
        dn2nzParams.nValue = stepScaleK / 2;
        dn2nzParams.srcDnMatrixStride = 0;
        dn2nzParams.srcDValue = SCALE_K / 2;
        dn2nzParams.dstNzC0Stride = stepScaleK / 2;
        dn2nzParams.dstNzNStride = 1;
        dn2nzParams.dstNzMatrixStride = 0;

        // scale 在 GM 中以 fp8 存储，但这里复用 b16 视图完成 Dn2Nz 搬运。
        AscendC::GlobalTensor<ScalePackType> asGMB16;
        asGMB16.SetGlobalBuffer(
            ((__gm__ ScalePackType*)(asGM.GetPhyAddr())) + (mBlockIdx * baseM * SCALE_K + scaleOffset) / 2,
            curM * (SCALE_K / 2));
        auto asLocalB16 = as1Local.ReinterpretCast<ScalePackType>();
        AscendC::DataCopy(asLocalB16, asGMB16, dn2nzParams);
    }

    // GM -> B1: 将 B 的一个 K 方向大包搬入 L1。
    // kChunkIdx 表示第几个大包，nBlockIdx 表示当前 N 方向分块。
    __aicore__ inline void DataCopyInB(AscendC::LocalTensor<BType> b1Local, uint32_t kChunkIdx, uint32_t nBlockIdx)
    {
        // NOTE:
        // B/B1 同样是 fp4x2 打包数据，因此地址与 stride 也按 packedK 计算。
        // 只有 MmadParams.k 才表示逻辑上的 fp4 元素个数 baseK。
        uint32_t curN = (nBlockIdx != baseNCount) ? baseN : tailN;
        constexpr uint32_t packedStepK = AscendC::DivCeil(baseK * stepKb, 2);
        AscendC::Nd2NzParams nd2nzB1Params;
        if constexpr (!IS_B_TRANSPOSE) {
            nd2nzB1Params.ndNum = 1;
            nd2nzB1Params.nValue = packedStepK;
            nd2nzB1Params.dValue = curN;
            nd2nzB1Params.srcNdMatrixStride = 0;
            nd2nzB1Params.srcDValue = N;
            nd2nzB1Params.dstNzC0Stride = packedStepK;
            nd2nzB1Params.dstNzNStride = 1;
            nd2nzB1Params.dstNzMatrixStride = 0;
            AscendC::DataCopy(b1Local, bGM[kChunkIdx * baseK * N + nBlockIdx * baseN], nd2nzB1Params);
        } else {
            nd2nzB1Params.ndNum = 1;
            nd2nzB1Params.nValue = curN;
            nd2nzB1Params.dValue = packedStepK;
            nd2nzB1Params.srcNdMatrixStride = 0;
            nd2nzB1Params.srcDValue = PACKED_K;
            nd2nzB1Params.dstNzC0Stride = baseN;
            nd2nzB1Params.dstNzNStride = 1;
            nd2nzB1Params.dstNzMatrixStride = 0;
            AscendC::DataCopy(b1Local, bGM[kChunkIdx * baseK + nBlockIdx * baseN * K], nd2nzB1Params);
        }
    }

    // GM -> BS1: 将 B 的 scale 大包搬入 L1。
    __aicore__ inline void DataCopyInBScale(
        AscendC::LocalTensor<ScaleBType> bs1Local, uint32_t kChunkIdx, uint32_t nBlockIdx)
    {
        uint32_t curN = (nBlockIdx != baseNCount) ? baseN : tailN;
        constexpr uint32_t stepScaleK = AscendC::DivCeil(baseK * stepKb * scaleFactorKb, SCALE_CEIL_NUMBER);
        static_assert(stepScaleK % 2 == 0, "stepScaleK需2B对齐以使用Dn2Nz.b16");
        static_assert(baseK % 64 == 0, "baseK需64对齐以计算b16 scale搬运偏移");
        uint32_t scaleOffset = (kChunkIdx * baseK) / SCALE_CEIL_NUMBER;
        // 与 A scale 同理：按 b16 视图进行 Dn2Nz，确保后续 LOAD_MX_2D 读取到正确排布。
        AscendC::Dn2NzParams dn2nzParams;
        dn2nzParams.dnNum = 1;
        dn2nzParams.dValue = curN;
        dn2nzParams.nValue = stepScaleK / 2;
        dn2nzParams.srcDnMatrixStride = 0;
        dn2nzParams.srcDValue = SCALE_K / 2;
        dn2nzParams.dstNzC0Stride = stepScaleK / 2;
        dn2nzParams.dstNzNStride = 1;
        dn2nzParams.dstNzMatrixStride = 0;

        AscendC::GlobalTensor<ScalePackType> bsGMB16;
        bsGMB16.SetGlobalBuffer(
            ((__gm__ ScalePackType*)(bsGM.GetPhyAddr())) + (nBlockIdx * baseN * SCALE_K + scaleOffset) / 2,
            curN * (SCALE_K / 2));
        auto bsLocalB16 = bs1Local.ReinterpretCast<ScalePackType>();
        AscendC::DataCopy(bsLocalB16, bsGMB16, dn2nzParams);
    }

    __aicore__ inline void DataLoadA(
        AscendC::LocalTensor<AType> a1Local, AscendC::LocalTensor<ScaleAType> as1Local,
        AscendC::LocalTensor<AType> a2Local, uint32_t mBlockIdx, uint32_t kOffsetInChunkA,
        uint32_t kOffsetInScaleChunkA)
    {
        // A1 中按逻辑 baseK * baseM 步进；scale 则按 K/32 对应的分形偏移步进。
        uint32_t srcAddr = kOffsetInChunkA * baseK * baseM;
        uint32_t scaleSrcAddr = (kOffsetInScaleChunkA * baseK / SCALE_CEIL_NUMBER) * CUBE_BLOCK;
        uint32_t curMAlign = (mBlockIdx != baseMCount) ? baseM : tailMAlign;

        // LoadData 会把 fp4 数据和对应 scale 一起装载到 L0，供后续 Mmad 直接消费。
        // 尾块场景下使用对齐后的 tailMAlign，保证地址和分形长度满足硬件要求。
        AscendC::LoadData2DParamsV2 loadDataParams;
        loadDataParams.mStartPosition = 0;
        loadDataParams.kStartPosition = 0;
        loadDataParams.mStep = AscendC::DivCeil(curMAlign, CUBE_BLOCK);     // M 方向搬运长度，单位 16 元素
        loadDataParams.kStep = AscendC::DivCeil(baseK, 64);                 // K 方向搬运长度，单位 32B
        loadDataParams.srcStride = AscendC::DivCeil(baseM, CUBE_BLOCK);     // 源 K 方向相邻分形间隔
        loadDataParams.dstStride = AscendC::DivCeil(curMAlign, CUBE_BLOCK); // 目标 K 方向相邻分形间隔
        loadDataParams.sid = 0;
        loadDataParams.ifTranspose = false;
        AscendC::LoadData2DMxParams loadMxDataParams;
        loadMxDataParams.xStartPosition = 0;
        loadMxDataParams.yStartPosition = 0;
        loadMxDataParams.xStep = AscendC::DivCeil(curMAlign, CUBE_BLOCK); // M 方向搬运长度，单位 1 个分形
        loadMxDataParams.yStep = AscendC::DivCeil(baseK, 64);             // K 方向搬运长度，单位 32B
        loadMxDataParams.srcStride =
            AscendC::DivCeil(baseK * stepKa * scaleFactorKa, 64); // 源 scale K 方向相邻分形间隔
        loadMxDataParams.dstStride = AscendC::DivCeil(baseK, 64);
        AscendC::LoadData(a2Local, a1Local[srcAddr], as1Local[scaleSrcAddr], loadDataParams, loadMxDataParams);
    }

    // B1 -> B2: 将 L1 中一个 baseK * baseN 分块装载到 L0。
    __aicore__ inline void DataLoadB(
        AscendC::LocalTensor<BType> b1Local, AscendC::LocalTensor<ScaleBType> bs1Local,
        AscendC::LocalTensor<BType> b2Local, uint32_t nBlockIdx, uint32_t kOffsetInChunkB,
        uint32_t kOffsetInScaleChunkB)
    {
        uint32_t srcAddr = kOffsetInChunkB * baseK * (IS_B_TRANSPOSE ? baseN : CUBE_BLOCK);
        uint32_t scaleSrcAddr = (kOffsetInScaleChunkB * baseK / SCALE_CEIL_NUMBER) * CUBE_BLOCK;
        uint32_t curNAlign = (nBlockIdx != baseNCount) ? baseN : tailNAlign;

        // B 的装载路径与 A 对称，尾块场景下使用 tailNAlign 保证分形对齐。
        AscendC::LoadData2DParamsV2 loadDataParamsB;
        loadDataParamsB.mStartPosition = 0;
        loadDataParamsB.kStartPosition = 0;
        loadDataParamsB.mStep = AscendC::DivCeil(curNAlign, CUBE_BLOCK);     // N 方向搬运长度，单位 16 元素
        loadDataParamsB.kStep = AscendC::DivCeil(baseK, 64);                 // K 方向搬运长度，单位 32B
        loadDataParamsB.srcStride = AscendC::DivCeil(baseN, CUBE_BLOCK);     // 源 K 方向相邻分形间隔
        loadDataParamsB.dstStride = AscendC::DivCeil(curNAlign, CUBE_BLOCK); // 目标 K 方向相邻分形间隔
        loadDataParamsB.ifTranspose = false;
        AscendC::LoadData2DMxParams loadMxDataParams;
        loadMxDataParams.xStartPosition = 0;
        loadMxDataParams.yStartPosition = 0;
        loadMxDataParams.xStep = AscendC::DivCeil(curNAlign, CUBE_BLOCK); // N 方向搬运长度，单位 1 个分形
        loadMxDataParams.yStep = AscendC::DivCeil(baseK, 64);             // K 方向搬运长度，单位 32B
        loadMxDataParams.srcStride =
            AscendC::DivCeil(baseK * stepKb * scaleFactorKb, 64); // 源 scale K 方向相邻分形间隔
        loadMxDataParams.dstStride = AscendC::DivCeil(baseK, 64);
        AscendC::LoadData(b2Local, b1Local[srcAddr], bs1Local[scaleSrcAddr], loadDataParamsB, loadMxDataParams);
    }

    // A2 * B2 -> CO1: 执行一次 Mmad 累加。
    __aicore__ inline void Compute(
        AscendC::LocalTensor<AccType> cLocal, AscendC::LocalTensor<AType> a2Local, AscendC::LocalTensor<BType> b2Local,
        uint32_t kBlockIdx, uint32_t mBlockIdx, uint32_t nBlockIdx)
    {
        // MTE1_M 正向同步：等待 L1 -> L0 装载完成。
        int32_t l0Event = GetL0EventId(mte1DBFlag);
        AscendC::SetFlag<AscendC::HardEvent::MTE1_M>(l0Event);
        AscendC::WaitFlag<AscendC::HardEvent::MTE1_M>(l0Event);
        uint32_t curM = (mBlockIdx != baseMCount) ? baseM : tailM;
        uint32_t curN = (nBlockIdx != baseNCount) ? baseN : tailN;
        // Mmad 累积结果保存在 float 累加缓冲中，最后再经 Fixpipe 量化到输出类型。
        AscendC::MmadParams mmadParams;
        mmadParams.m = curM;
        mmadParams.n = curN;
        mmadParams.k = baseK;
        mmadParams.cmatrixInitVal = (kBlockIdx == 0);
        AscendC::Mmad(cLocal, a2Local, b2Local, mmadParams);
        // M_MTE1 反向同步：通知下一轮 DataLoad 可以覆盖当前 L0 buffer。
        AscendC::SetFlag<AscendC::HardEvent::M_MTE1>(l0Event);
        mte1DBFlag ^= 1;
    }

    // CO1 -> GM: 将一个 baseM * baseN 子块写回输出矩阵。
    __aicore__ inline void CopyOut(AscendC::LocalTensor<AccType> cLocal, uint32_t mBlockIdx, uint32_t nBlockIdx)
    {
        AscendC::SetFlag<AscendC::HardEvent::M_FIX>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::M_FIX>(EVENT_ID0);
        uint32_t curMAlign = (mBlockIdx != baseMCount) ? baseM : tailMAlign;
        uint32_t curM = (mBlockIdx != baseMCount) ? baseM : tailM;
        uint32_t curN = (nBlockIdx != baseNCount) ? baseN : tailN;
        // Fixpipe 负责：
        // 1) 按实际 curM/curN 处理尾块
        // 2) 将 float 累积结果量化/转换后写回 CType
        AscendC::FixpipeParamsArch3510<AscendC::CO2Layout::ROW_MAJOR> fixpipeParams;
        fixpipeParams.nSize = curN;
        fixpipeParams.mSize = curM;
        fixpipeParams.srcStride = curMAlign;
        fixpipeParams.dstStride = N;
        fixpipeParams.quantPre = QuantMode_t::F322BF16;
        AscendC::Fixpipe(cGM[mBlockIdx * baseM * N + nBlockIdx * baseN], cLocal, fixpipeParams);
        AscendC::SetFlag<AscendC::HardEvent::FIX_M>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::FIX_M>(EVENT_ID0);
    }

private:
    AscendC::GlobalTensor<AType> aGM;
    AscendC::GlobalTensor<BType> bGM;
    AscendC::GlobalTensor<ScaleAType> asGM;
    AscendC::GlobalTensor<ScaleBType> bsGM;
    AscendC::GlobalTensor<CType> cGM;
    AscendC::GlobalTensor<AType> aGMOri;
    AscendC::GlobalTensor<BType> bGMOri;
    AscendC::GlobalTensor<ScaleAType> asGMOri;
    AscendC::GlobalTensor<ScaleBType> bsGMOri;
    AscendC::GlobalTensor<CType> cGMOri;
    uint32_t actualSingleCoreM, actualSingleCoreN;
    uint32_t mLoopCount, nLoopCount, kLoopCount;
    uint32_t baseMCount, baseNCount;
    uint32_t tailM, tailN;
    uint32_t tailMAlign, tailNAlign;
    uint8_t mte1DBFlag = 0;
};

template <
    uint32_t M, uint32_t K, uint32_t N, uint32_t baseM, uint32_t baseK, uint32_t baseN, uint32_t singleCoreM,
    uint32_t singleCoreK, uint32_t singleCoreN, uint32_t stepKa, uint32_t stepKb, uint32_t scaleFactorKa,
    uint32_t scaleFactorKb>
__global__ __cube__ void mmadmx_custom(GM_ADDR a, GM_ADDR b, GM_ADDR as, GM_ADDR bs, GM_ADDR c)
{
    AscendC::InitSocState();
    KernelMmadmx<
        fp4x2_e1m2_t, fp4x2_e1m2_t, bfloat16_t, M, K, N, baseM, baseK, baseN, singleCoreM, singleCoreK, singleCoreN,
        stepKa, stepKb, scaleFactorKa, scaleFactorKb>
        op;
    op.Init(a, b, as, bs, c);
    op.Process();
    AscendC::PipeBarrier<PIPE_ALL>();
}

template <
    uint32_t M, uint32_t K, uint32_t N, uint32_t baseM, uint32_t baseK, uint32_t baseN, uint32_t singleCoreM,
    uint32_t singleCoreK, uint32_t singleCoreN, uint32_t stepKa, uint32_t stepKb, uint32_t scaleFactorKa,
    uint32_t scaleFactorKb, uint32_t usedCoreNum>
int32_t RunScenario()
{
    static_assert(K % 2 == 0, "MxFP4 input requires K to be even.");
    static_assert(K == singleCoreK, "This samples only support the scenario where the K-axis is not cut.");
    static_assert(singleCoreM <= M, "singleCoreM must <= M");
    static_assert(singleCoreN <= N, "singleCoreN must <= N");
    static_assert(baseK % 64 == 0, "baseK must be a multiple of 64.");
    static_assert(static_cast<uint64_t>(baseM) * static_cast<uint64_t>(baseK) <= 65536,
        "baseM * baseK must be <= 65536 elements for fp4 input (32KB packed size && L0A/L0B DB is enable).");
    static_assert(static_cast<uint64_t>(baseM) * static_cast<uint64_t>(baseN) <= 131072,
        "baseM * baseN must be <= 131072 elements for bf16 output (L0C is 256KB).");
    static_assert(usedCoreNum <= 28, "This samples support max usedCoreNum is 28!");
    static_assert(stepKa == stepKb, "stepKa and stepKb must be same");
    static_assert(scaleFactorKa == scaleFactorKb, "scaleFactorKa and scaleFactorKb must be same");
    static_assert(baseK * stepKa * scaleFactorKa <= singleCoreK, "baseK * stepKa * scaleFactorKa should <= singleCoreK");
    static_assert(baseK * stepKb * scaleFactorKb <= singleCoreK, "baseK * stepKb * scaleFactorKb should <= singleCoreK");

    // 本样例模板固定多核切分仅沿 M/N 展开，因此总核数必须等于 M 方向块数 * N 方向块数。
    static_assert(K == singleCoreK, "This samples only support the scenario where the K-axis is not cut.");
    static constexpr uint32_t CORE_BLOCKS_M = (M + singleCoreM - 1) / singleCoreM;
    static constexpr uint32_t CORE_BLOCKS_N = (N + singleCoreN - 1) / singleCoreN;
    static_assert(
        usedCoreNum == CORE_BLOCKS_M * CORE_BLOCKS_N, "usedCoreNum must match the compile-time M/N core split.");


    constexpr uint32_t scaleKUnaligned = (K + SCALE_CEIL_NUMBER - 1) / SCALE_CEIL_NUMBER;
    constexpr uint32_t sK = ((scaleKUnaligned + SCALE_ALIGN_NUMBER - 1) / SCALE_ALIGN_NUMBER) * SCALE_ALIGN_NUMBER;

    std::cout << "Running scenario " << scenario << ": M=" << M << ", K=" << K << ", N=" << N << ", baseM=" << baseM
              << ", baseN=" << baseN << ", baseK=" << baseK << ", singleCoreM=" << singleCoreM
              << ", singleCoreN=" << singleCoreN << ", singleCoreK=" << singleCoreK << ", stepKa=" << stepKa
              << ", stepKb=" << stepKb << ", scaleFactorKa=" << scaleFactorKa << ", scaleFactorKb=" << scaleFactorKb
              << ", usedCoreNum=" << usedCoreNum << std::endl;

    size_t aFileSize = static_cast<size_t>(M * K) * sizeof(uint8_t) / 2; // 单位Byte
    size_t bFileSize = static_cast<size_t>(N * K) * sizeof(uint8_t) / 2; // 单位Byte
    size_t asFileSize = static_cast<size_t>(M * sK) * sizeof(uint8_t);
    size_t bsFileSize = static_cast<size_t>(N * sK) * sizeof(uint8_t);
    size_t cFileSize = static_cast<size_t>(M * N) * sizeof(uint16_t);

    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t* aHost;
    uint8_t* aDevice;
    aclrtMallocHost((void**)(&aHost), aFileSize);
    aclrtMalloc((void**)&aDevice, aFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/x1_gm.bin", aFileSize, aHost, aFileSize);
    aclrtMemcpy(aDevice, aFileSize, aHost, aFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t* bHost;
    uint8_t* bDevice;
    aclrtMallocHost((void**)(&bHost), bFileSize);
    aclrtMalloc((void**)&bDevice, bFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/x2_gm.bin", bFileSize, bHost, bFileSize);
    aclrtMemcpy(bDevice, bFileSize, bHost, bFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t* asHost;
    uint8_t* asDevice;
    aclrtMallocHost((void**)(&asHost), asFileSize);
    aclrtMalloc((void**)&asDevice, asFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/x1_scale_gm.bin", asFileSize, asHost, asFileSize);
    aclrtMemcpy(asDevice, asFileSize, asHost, asFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t* bsHost;
    uint8_t* bsDevice;
    aclrtMallocHost((void**)(&bsHost), bsFileSize);
    aclrtMalloc((void**)&bsDevice, bsFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/x2_scale_gm.bin", bsFileSize, bsHost, bsFileSize);
    aclrtMemcpy(bsDevice, bsFileSize, bsHost, bsFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t* cHost;
    uint8_t* cDevice;
    aclrtMallocHost((void**)(&cHost), cFileSize);
    aclrtMalloc((void**)&cDevice, cFileSize, ACL_MEM_MALLOC_HUGE_FIRST);

    mmadmx_custom<
        M, K, N, baseM, baseK, baseN, singleCoreM, singleCoreK, singleCoreN, stepKa, stepKb, scaleFactorKa,
        scaleFactorKb><<<usedCoreNum, nullptr, stream>>>(aDevice, bDevice, asDevice, bsDevice, cDevice);
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(cHost, cFileSize, cDevice, cFileSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", cHost, cFileSize);

    aclrtFree(aDevice);
    aclrtFreeHost(aHost);
    aclrtFree(bDevice);
    aclrtFreeHost(bHost);
    aclrtFree(asDevice);
    aclrtFreeHost(asHost);
    aclrtFree(bsDevice);
    aclrtFreeHost(bsHost);
    aclrtFree(cDevice);
    aclrtFreeHost(cHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();
    return 0;
}

// 命名规则: SCENARIO_MULTI_CORE_#UsedCoreNum_#SingleCoreM_#SingleCoreK_#SingleCoreN_#baseM_#baseK_#baseN_stepK_scaleFactorK
constexpr uint32_t SCENARIO_MULTI_CORE_16_1792_7168_1792_128_128_128_1_1 = 1;
constexpr uint32_t SCENARIO_MULTI_CORE_16_1792_7168_1792_256_256_256_1_1 = 2;
// Todo : 请新增场景3：
// 功能要求： 使能28核切分，输出结果精度比对通过
// 性能要求： Cube计算单元的时间占比aic_mac_ratio达到80%以上 并且Cube计算单元的执行时间aic_mac_time达到理论计算性能的95%以上

int32_t main(int32_t argc, char* argv[])
{
    (void)argc;
    (void)argv;

    constexpr uint32_t M = 7168;
    constexpr uint32_t K = 7168;
    constexpr uint32_t N = 7168;

    if constexpr (scenario == SCENARIO_MULTI_CORE_16_1792_7168_1792_128_128_128_1_1) {
        // singleCoreM/singleCoreK/singleCoreN 描述单个核完成的矩阵乘计算shape大小。
        // 按 4 x 4 切分 M/N，因此每个核处理 1792 x 7168 x 1792，K 方向不切分，保持 7168
        constexpr uint32_t singleCoreM = 1792;
        constexpr uint32_t singleCoreK = 7168;
        constexpr uint32_t singleCoreN = 1792;

        // baseM/baseK/baseN 是基础计算块大小，对应 L1->L0 搬运和单次Cube计算指令的最小 tile 粒度。
        constexpr uint32_t baseM = 128;
        constexpr uint32_t baseK = 128;
        constexpr uint32_t baseN = 128;

        // stepKa/stepKb 表示一次从 GM->L1 搬运多少个 baseK 块。
        constexpr uint32_t stepKa = 1;
        constexpr uint32_t stepKb = 1;
        // scaleFactorKa/scaleFactorKb 控制 scale 相对 A/B 在 K 方向的预取倍数。
        constexpr uint32_t scaleFactorKa = 1;
        constexpr uint32_t scaleFactorKb = 1;
        // usedCoreNum 是 kernel launch 启动的核数；此处 16 核对应 M/N 方向 4 x 4 切分。
        constexpr uint32_t usedCoreNum = 16;
        return RunScenario<
            M, K, N, baseM, baseK, baseN, singleCoreM, singleCoreK, singleCoreN, stepKa, stepKb, scaleFactorKa,
            scaleFactorKb, usedCoreNum>();
    } else if constexpr (scenario == SCENARIO_MULTI_CORE_16_1792_7168_1792_256_256_256_1_1) {
        // singleCoreM/singleCoreK/singleCoreN 描述单个核完成的矩阵乘计算shape大小。
        // 按 4 x 4 切分 M/N，因此每个核处理 1792 x 7168 x 1792，K 方向不切分，保持 7168
        constexpr uint32_t singleCoreM = 1792;
        constexpr uint32_t singleCoreK = 7168;
        constexpr uint32_t singleCoreN = 1792;

        // baseM/baseK/baseN 是基础计算块大小，对应 L1->L0 搬运和单次Cube计算指令的最小 tile 粒度。
        constexpr uint32_t baseM = 256;
        constexpr uint32_t baseK = 256;
        constexpr uint32_t baseN = 256;

        // stepKa/stepKb 表示一次从 GM->L1 搬运多少个 baseK 块。
        constexpr uint32_t stepKa = 1;
        constexpr uint32_t stepKb = 1;
        // scaleFactorKa/scaleFactorKb 控制 scale 相对 A/B 在 K 方向的预取倍数。
        constexpr uint32_t scaleFactorKa = 1;
        constexpr uint32_t scaleFactorKb = 1;
        // usedCoreNum 是 kernel launch 启动的核数；此处 16 核对应 M/N 方向 4 x 4 切分。
        constexpr uint32_t usedCoreNum = 16;
        return RunScenario<
            M, K, N, baseM, baseK, baseN, singleCoreM, singleCoreK, singleCoreN, stepKa, stepKb, scaleFactorKa,
            scaleFactorKb, usedCoreNum>();
    } else {
        std::cout << "Invalid SCENARIO_NUM: " << scenario << std::endl;
        return -1;
    }
}
